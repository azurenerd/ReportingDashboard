@page "/"
@namespace ReportingDashboard.Web.Pages
@implements IDisposable
@inject IDashboardDataService DataService

@{
    var state = DataService.Current;
}

@if (state.Error is not null)
{
    <ParseErrorBanner Error="state.Error" />
}

<DashboardHeader Model="state.Model" />
<TimelineSvg Timeline="state.Model.Timeline" Today="state.Model.CurrentDate" />
<Heatmap HeatmapData="state.Model.Heatmap" />

@code {
    protected override void OnInitialized()
    {
        DataService.OnChanged += HandleChanged;
    }

    private void HandleChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnChanged -= HandleChanged;
    }
}