<div class="hdr">
    <div>
        <h1>
            @Project.Title
            @if (!string.IsNullOrEmpty(Project.BacklogUrl))
            {
                <a href="@Project.BacklogUrl">@Project.BacklogLinkText</a>
            }
        </h1>
        <div class="sub">@Project.Subtitle</div>
    </div>
    <div class="legend">
        <span class="legend-item">
            <span class="diamond amber"></span> PoC Milestone
        </span>
        <span class="legend-item">
            <span class="diamond green"></span> Production Release
        </span>
        <span class="legend-item">
            <span class="circle grey"></span> Checkpoint
        </span>
        <span class="legend-item">
            <span class="now-bar"></span> @NowLabel
        </span>
    </div>
</div>

@code {
    [Parameter] public required Project Project { get; set; }
    [Parameter] public required string NowLabel { get; set; }
}