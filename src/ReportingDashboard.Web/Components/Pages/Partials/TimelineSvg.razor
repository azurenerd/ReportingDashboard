@namespace ReportingDashboard.Web.Components.Pages.Partials
@using ReportingDashboard.Web.Layout
@using ReportingDashboard.Web.Models
@using Microsoft.AspNetCore.Components

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var lane in Model.Lanes)
        {
            <div class="tl-lane-label">
                <strong style="color:@lane.Color;font-size:12px;font-weight:600;line-height:1.4;">@lane.Id</strong><br />
                <span style="font-size:12px;font-weight:400;color:#444;">@lane.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" xmlns="http://www.w3.org/2000/svg" style="overflow:visible;display:block">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @foreach (var g in Model.Gridlines)
            {
                <line x1="@Fmt(g.X)" y1="0" x2="@Fmt(g.X)" y2="185"
                      stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                @(GridlineLabel(g))
            }

            @foreach (var lane in Model.Lanes)
            {
                <line x1="0" y1="@Fmt(lane.Y)" x2="1560" y2="@Fmt(lane.Y)"
                      stroke="@lane.Color" stroke-width="3" />

                @foreach (var m in lane.Milestones)
                {
                    var capY = IsAbove(m.CaptionPosition) ? m.Y - 12 : m.Y + 20;

                    @switch (m.Type)
                    {
                        case MilestoneGeometryType.Poc:
                            <polygon points="@DiamondPoints(m.X, m.Y)"
                                     fill="#F4B400" filter="url(#sh)" />
                            break;
                        case MilestoneGeometryType.Prod:
                            <polygon points="@DiamondPoints(m.X, m.Y)"
                                     fill="#34A853" filter="url(#sh)" />
                            break;
                        case MilestoneGeometryType.Checkpoint:
                            <circle cx="@Fmt(m.X)" cy="@Fmt(m.Y)" r="5"
                                    fill="white" stroke="@lane.Color" stroke-width="2.5" />
                            break;
                    }

                    @(CaptionLabel(m.X, capY, m.Caption))
                }
            }

            @if (Model.Now.InRange)
            {
                <line x1="@Fmt(Model.Now.X)" y1="0" x2="@Fmt(Model.Now.X)" y2="185"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @(NowLabel(Model.Now.X + 4, 175))
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public required TimelineViewModel Model { get; set; }

    private static string Fmt(double v) =>
        v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string DiamondPoints(double x, double y)
    {
        string F(double v) => Fmt(v);
        return $"{F(x)},{F(y - 6)} {F(x + 6)},{F(y)} {F(x)},{F(y + 6)} {F(x - 6)},{F(y)}";
    }

    private static bool IsAbove(CaptionPlacement p) =>
        string.Equals(p.ToString(), "Above", System.StringComparison.OrdinalIgnoreCase);

    private static string Escape(string? s) =>
        System.Net.WebUtility.HtmlEncode(s ?? string.Empty);

    private static MarkupString GridlineLabel(MonthGridline g) =>
        new MarkupString(
            $"<text x=\"{Fmt(g.X + 3)}\" y=\"12\" fill=\"#666\" font-size=\"11\" font-weight=\"600\">{Escape(g.Label)}</text>");

    private static MarkupString CaptionLabel(double x, double y, string? caption) =>
        new MarkupString(
            $"<text x=\"{Fmt(x)}\" y=\"{Fmt(y)}\" fill=\"#666\" font-size=\"10\" text-anchor=\"middle\">{Escape(caption)}</text>");

    private static MarkupString NowLabel(double x, double y) =>
        new MarkupString(
            $"<text x=\"{Fmt(x)}\" y=\"{Fmt(y)}\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\">NOW</text>");
}