@namespace ReportingDashboard.Web.Components.Pages.Partials
@using ReportingDashboard.Web.Services

<div class="error-banner" role="alert">
    <strong>@Heading</strong>
    @if (!string.IsNullOrWhiteSpace(Error.FilePath))
    {
        <span class="error-path">@Error.FilePath</span>
    }
    @if (Error.Line is int line)
    {
        <span class="error-location">line @line@(Error.Column is int col ? $", col {col}" : string.Empty)</span>
    }
    @if (!string.IsNullOrWhiteSpace(Error.Message))
    {
        <span class="error-message">@Error.Message</span>
    }
</div>

@code {
    [Parameter] public required DashboardLoadError Error { get; set; }

    private string Heading => Error.Kind switch
    {
        "NotFound" => "data.json not found",
        "ParseError" => "Failed to parse data.json",
        "ValidationError" => "data.json validation failed",
        _ => "Failed to load data.json"
    };
}
