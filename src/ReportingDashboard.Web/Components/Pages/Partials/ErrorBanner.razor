@* Stub shell - T8 will flesh out the red banner markup per architecture. *@

<div class="error-banner" role="alert">
    <strong>Failed to load data.json</strong>
    <span class="error-kind">@Error.Kind</span>
    <span class="error-path">@Error.FilePath</span>
    @if (Error.Line is { } l)
    {
        <span class="error-location">line @l, col @Error.Column</span>
    }
    <span class="error-message">@Error.Message</span>
</div>

@code {
    [Parameter] public required DashboardLoadError Error { get; set; }
}