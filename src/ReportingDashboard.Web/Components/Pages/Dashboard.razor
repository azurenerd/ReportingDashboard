@page "/"
@using ReportingDashboard.Web.Models
@using ReportingDashboard.Web.Services
@using ReportingDashboard.Web.ViewModels
@using ReportingDashboard.Web.Components.Pages.Partials
@inject IDashboardDataService DataService

@if (result is not null)
{
    @if (result.Error is not null)
    {
        <ErrorBanner Error="result.Error" />
    }
    <DashboardHeader Project="(result.Data?.Project ?? Project.Placeholder)" NowLabel="nowLabel" />
    <TimelineSvg Model="TimelineViewModel.Empty" />
    <Heatmap Model="HeatmapViewModel.Empty" />
}

@code {
    private DashboardLoadResult? result;
    private string nowLabel = "";

    protected override void OnInitialized()
    {
        result = DataService.GetCurrent();
        nowLabel = $"Now ({DateTime.Today:MMM yyyy})";
    }
}