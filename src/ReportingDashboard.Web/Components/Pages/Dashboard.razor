@page "/"
@inject IDataService DataService

<PageTitle>Reporting Dashboard</PageTitle>

@if (_loading)
{
    <div class="loading-state">Loading dashboard data…</div>
}
else
{
    <div class="dashboard-fixed-layout">
        <DashboardHeader Title="@_data.Title"
                         Subtitle="@_data.Subtitle"
                         BacklogLink="@_data.BacklogLink" />

        <TimelineSection Timeline="@_data.Timeline" />

        <HeatmapGrid Heatmap="@_data.Heatmap"
                     Months="@_data.Months"
                     CurrentMonth="@_data.CurrentMonth" />
    </div>
}

@code {
    private DashboardData _data = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _data = await DataService.LoadDashboardDataAsync();
        _loading = false;
    }
}