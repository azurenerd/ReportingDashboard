@page "/"
@namespace ReportingDashboard.Web.Components.Pages
@using System.Globalization
@using ReportingDashboard.Web.Components.Pages.Partials
@using ReportingDashboard.Web.Layout
@using ReportingDashboard.Web.Models
@using ReportingDashboard.Web.Services
@inject IDashboardDataService DataService

<PageTitle>Reporting Dashboard</PageTitle>

@if (_error is not null)
{
    <ErrorBanner Error="_error" />
}

@if (_data is not null)
{
    <DashboardHeader Project="_data.Project" NowLabel="@_nowLabel" />
    <TimelineSvg Model="_timelineVm" />
    <Heatmap Model="_heatmapVm" />
}
else
{
    <DashboardHeader Project="Project.Placeholder" NowLabel="@_nowLabel" />
    <TimelineSvg Model="TimelineViewModel.Empty" />
    <Heatmap Model="HeatmapViewModel.Empty" />
}

@code {
    private DashboardData? _data;
    private DashboardLoadError? _error;
    private TimelineViewModel _timelineVm = TimelineViewModel.Empty;
    private HeatmapViewModel _heatmapVm = HeatmapViewModel.Empty;
    private string _nowLabel = string.Empty;

    protected override void OnInitialized()
    {
        var today = DateTime.Today;
        _nowLabel = $"Now ({today.ToString("MMM yyyy", CultureInfo.InvariantCulture)})";

        try
        {
            var result = DataService.GetCurrent();
            _data = result.Data;
            _error = result.Error;

            if (_data is not null)
            {
                var dateOnly = DateOnly.FromDateTime(today);
                try
                {
                    _timelineVm = TimelineLayoutEngine.Build(_data.Timeline, dateOnly);
                }
                catch
                {
                    _timelineVm = TimelineViewModel.Empty;
                }

                try
                {
                    _heatmapVm = HeatmapLayoutEngine.Build(_data.Heatmap, dateOnly);
                }
                catch
                {
                    _heatmapVm = HeatmapViewModel.Empty;
                }
            }
        }
        catch (Exception ex)
        {
            _data = null;
            _error = new DashboardLoadError(
                FilePath: string.Empty,
                Message: ex.Message,
                Line: null,
                Column: null,
                Kind: "ParseError");
        }
    }
}
