@page "/"
@inject IDataService DataService

@if (_error is not null)
{
    <div style="display:flex;align-items:center;justify-content:center;width:1920px;height:1080px;padding:40px;">
        <div style="max-width:800px;text-align:center;font-size:18px;color:#991B1B;background:#FEF2F2;border:1px solid #EA4335;border-radius:8px;padding:40px;">
            <h2 style="margin-bottom:16px;">⚠ Dashboard Error</h2>
            <p>@_error</p>
        </div>
    </div>
}
else if (_data is not null)
{
    <DashboardHeader Title="@_data.Title" Subtitle="@_data.Subtitle" BacklogUrl="@_data.BacklogUrl" CurrentDate="@_data.CurrentDate" />
    <TimelineSection Timeline="@_data.Timeline" CurrentDate="@_data.CurrentDate" />
    <HeatmapGrid Heatmap="@_data.Heatmap" />
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        _data = DataService.GetData();
        _error = DataService.GetError();
    }
}
