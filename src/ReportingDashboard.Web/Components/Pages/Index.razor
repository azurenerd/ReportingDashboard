@page "/timeline-preview"
@using ReportingDashboard.Web.Layout
@using ReportingDashboard.Web.Models
@using ReportingDashboard.Web.Components.Pages.Partials

<PageTitle>Reporting Dashboard</PageTitle>

<style>
    html, body { margin: 0; padding: 0; background: #FFFFFF; color: #111;
                 font-family: 'Segoe UI', -apple-system, 'Helvetica Neue', Arial, sans-serif; }
    .rd-root { width: 1920px; }
    .rd-hdr { padding: 12px 44px 10px; border-bottom: 1px solid #E0E0E0; }
    .rd-hdr h1 { font-size: 24px; font-weight: 700; color: #111; margin: 0; }
    .rd-hdr .sub { font-size: 12px; color: #888; margin-top: 2px; }
</style>

<div class="rd-root">
    <div class="rd-hdr">
        <h1>Reporting Dashboard</h1>
        <div class="sub">Milestone Timeline (T5 preview)</div>
    </div>
    <TimelineSvg Model="_timelineVm" />
</div>

@code {
    private TimelineViewModel _timelineVm = TimelineViewModel.Empty;

    protected override void OnInitialized()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        try
        {
            _timelineVm = TimelineLayoutEngine.Build(BuildDemoTimeline(today), today);
        }
        catch
        {
            _timelineVm = BuildVmDirectly(today);
        }

        if (_timelineVm.Lanes.Count == 0)
        {
            _timelineVm = BuildVmDirectly(today);
        }
    }

    private static Timeline BuildDemoTimeline(DateOnly today)
    {
        var start = new DateOnly(today.Year, 1, 1);
        var end = new DateOnly(today.Year, 6, 30);

        return new Timeline
        {
            Start = start,
            End = end,
            Lanes = new List<TimelineLane>
            {
                new TimelineLane
                {
                    Id = "M1",
                    Label = "Chatbot & MS Role",
                    Color = "#0078D4",
                    Milestones = new List<Milestone>
                    {
                        new() { Date = new DateOnly(today.Year, 1, 12), Type = MilestoneType.Checkpoint, Label = "Jan 12" },
                        new() { Date = new DateOnly(today.Year, 3, 26), Type = MilestoneType.Poc, Label = "Mar PoC" },
                        new() { Date = new DateOnly(today.Year, 4, 30), Type = MilestoneType.Prod, Label = "Apr Prod" }
                    }
                },
                new TimelineLane
                {
                    Id = "M2",
                    Label = "PDS & Data Inventory",
                    Color = "#00897B",
                    Milestones = new List<Milestone>
                    {
                        new() { Date = new DateOnly(today.Year, 2, 15), Type = MilestoneType.Checkpoint, Label = "Feb 15" },
                        new() { Date = new DateOnly(today.Year, 5, 10), Type = MilestoneType.Prod, Label = "May Prod" }
                    }
                },
                new TimelineLane
                {
                    Id = "M3",
                    Label = "Auto Review DFD",
                    Color = "#546E7A",
                    Milestones = new List<Milestone>
                    {
                        new() { Date = new DateOnly(today.Year, 3, 1), Type = MilestoneType.Checkpoint, Label = "Mar 1" },
                        new() { Date = new DateOnly(today.Year, 6, 1), Type = MilestoneType.Poc, Label = "Jun PoC" }
                    }
                }
            }
        };
    }

    private static TimelineViewModel BuildVmDirectly(DateOnly today)
    {
        const double w = 1560;
        const double h = 185;
        const double top = 20, bot = 20;
        var inner = h - top - bot;

        double y(int i, int n) => top + (i + 0.5) * inner / n;

        var lanes = new List<LaneGeometry>
        {
            new LaneGeometry("M1", "Chatbot & MS Role", "#0078D4", y(0, 3),
                new List<MilestoneGeometry>
                {
                    new(w * 0.05, y(0, 3), MilestoneGeometryType.Checkpoint, "Jan 12", CaptionPlacement.Above),
                    new(w * 0.45, y(0, 3), MilestoneGeometryType.Poc, "Mar PoC", CaptionPlacement.Above),
                    new(w * 0.75, y(0, 3), MilestoneGeometryType.Prod, "Apr Prod", CaptionPlacement.Above)
                }),
            new LaneGeometry("M2", "PDS & Data Inventory", "#00897B", y(1, 3),
                new List<MilestoneGeometry>
                {
                    new(w * 0.20, y(1, 3), MilestoneGeometryType.Checkpoint, "Feb 15", CaptionPlacement.Above),
                    new(w * 0.85, y(1, 3), MilestoneGeometryType.Prod, "May Prod", CaptionPlacement.Above)
                }),
            new LaneGeometry("M3", "Auto Review DFD", "#546E7A", y(2, 3),
                new List<MilestoneGeometry>
                {
                    new(w * 0.30, y(2, 3), MilestoneGeometryType.Checkpoint, "Mar 1", CaptionPlacement.Above),
                    new(w * 0.95, y(2, 3), MilestoneGeometryType.Poc, "Jun PoC", CaptionPlacement.Above)
                })
        };

        var grids = new List<MonthGridline>
        {
            new(w * 0.00, "Jan"), new(w * 0.17, "Feb"), new(w * 0.34, "Mar"),
            new(w * 0.51, "Apr"), new(w * 0.68, "May"), new(w * 0.85, "Jun")
        };

        return new TimelineViewModel(grids, lanes, new NowMarker(w * 0.5, true), 1560, 185);
    }
}