<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap &mdash; Shipped &middot; In Progress &middot; Carryover &middot; Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@Heatmap.Months.Count, 1fr); grid-template-rows: 36px repeat(@Heatmap.Categories.Count, 1fr);">
        @* Header row *@
        <div class="hm-corner">Status</div>
        @for (int m = 0; m < Heatmap.Months.Count; m++)
        {
            var month = Heatmap.Months[m];
            var isCurrent = month == Heatmap.CurrentMonth;
            var isLast = m == Heatmap.Months.Count - 1;
            <div class="hm-col-hdr @(isCurrent ? "apr-hdr" : "")" style="@(isLast ? "border-right:none;" : "")">
                @month @(isCurrent ? "▸ Now" : "")
            </div>
        }

        @* Data rows *@
        @foreach (var category in Heatmap.Categories)
        {
            var totalCount = category.Items.Values.Sum(v => v.Count);
            var icon = GetCategoryIcon(category.ColorClass);
            <div class="hm-row-hdr @(category.ColorClass)-hdr">@icon @category.Name.ToUpper() (@totalCount)</div>

            @for (int m = 0; m < Heatmap.Months.Count; m++)
            {
                var month = Heatmap.Months[m];
                var isCurrent = month == Heatmap.CurrentMonth;
                var isLast = m == Heatmap.Months.Count - 1;
                var items = category.Items.TryGetValue(month, out var list) ? list : new List<string>();
                <HeatmapCell Items="@items"
                             ColorClass="@category.ColorClass"
                             IsCurrentMonth="@isCurrent"
                             IsLastColumn="@isLast" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData Heatmap { get; set; } = new();

    private static string GetCategoryIcon(string colorClass) => colorClass switch
    {
        "ship" => "✓",
        "prog" => "●",
        "carry" => "↻",
        "block" => "⚠",
        _ => ""
    };
}
