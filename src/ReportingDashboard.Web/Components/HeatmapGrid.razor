@{
    var categories = BuildCategories();
    var monthCount = Months.Count;
    var gridCols = $"160px repeat({monthCount}, 1fr)";
}

<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap</div>
    <div class="hm-grid" style="grid-template-columns: @gridCols;">
        <div class="hm-corner">Status / Month</div>
        @foreach (var month in Months)
        {
            var isCurrent = month == CurrentMonth;
            <div class="hm-col-hdr @(isCurrent ? "current-month-hdr" : "")">
                @if (isCurrent)
                {
                    @month<span class="now-badge"> ● Now</span>
                }
                else
                {
                    @month
                }
            </div>
        }

        @foreach (var category in categories)
        {
            var totalCount = category.Items.Values.Sum(v => v.Count);
            <div class="hm-row-hdr @(category.ColorClass)-hdr">
                @category.Name.ToUpper() (@totalCount)
            </div>
            @foreach (var month in Months)
            {
                var items = category.Items.ContainsKey(month) ? category.Items[month] : new List<string>();
                var isCurrent = month == CurrentMonth;
                <HeatmapCell Items="@items"
                             ColorClass="@category.ColorClass"
                             IsCurrentMonth="@isCurrent" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData Heatmap { get; set; } = new();
    [Parameter] public List<string> Months { get; set; } = new();
    [Parameter] public string CurrentMonth { get; set; } = "";

    private List<HeatmapCategory> BuildCategories()
    {
        return new List<HeatmapCategory>
        {
            new() { Name = "Shipped", ColorClass = "shipped", Items = Heatmap.Shipped },
            new() { Name = "In Progress", ColorClass = "in-progress", Items = Heatmap.InProgress },
            new() { Name = "Carryover", ColorClass = "carryover", Items = Heatmap.Carryover },
            new() { Name = "Blockers", ColorClass = "blockers", Items = Heatmap.Blockers }
        };
    }
}