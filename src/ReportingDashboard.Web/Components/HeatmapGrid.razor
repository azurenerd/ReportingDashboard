<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap - Shipped · In Progress · Carryover · Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@Heatmap.Months.Count, 1fr);">
        @* Header row *@
        <div class="hm-corner">Status</div>
        @for (int i = 0; i < Heatmap.Months.Count; i++)
        {
            var month = Heatmap.Months[i];
            var isCurrentMonth = month == Heatmap.CurrentMonth;
            var isLast = i == Heatmap.Months.Count - 1;
            var headerClass = "hm-col-hdr" + (isCurrentMonth ? " apr-hdr" : "");
            var headerStyle = isLast ? "border-right:none;" : "";
            <div class="@headerClass" style="@headerStyle">
                @month@(isCurrentMonth ? " ▼ Now" : "")
            </div>
        }

        @* Data rows *@
        @foreach (var category in Heatmap.Categories)
        {
            var totalCount = category.Items.Values.Sum(v => v.Count);
            var emoji = category.ColorClass switch
            {
                "ship" => "✅",
                "prog" => "🔵",
                "carry" => "🟡",
                "block" => "🔴",
                _ => ""
            };

            <div class="hm-row-hdr @(category.ColorClass)-hdr">@emoji @category.Name.ToUpper() (@totalCount)</div>

            @for (int i = 0; i < Heatmap.Months.Count; i++)
            {
                var month = Heatmap.Months[i];
                var isCurrentMonth = month == Heatmap.CurrentMonth;
                var isLast = i == Heatmap.Months.Count - 1;
                var items = category.Items.TryGetValue(month, out var list) ? list : new List<string>();

                <HeatmapCell Items="@items" ColorClass="@category.ColorClass" IsCurrentMonth="@isCurrentMonth" IsLastColumn="@isLast" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData Heatmap { get; set; } = new();
}
