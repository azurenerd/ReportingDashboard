<div class="hdr">
    <div class="hdr-left">
        <h1>@Title
            @if (!string.IsNullOrWhiteSpace(BacklogUrl))
            {
                <a href="@BacklogUrl" target="_blank" rel="noopener noreferrer">↗ ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Subtitle</div>
    </div>
    <div class="legend">
        <span class="legend-item">
            <span class="legend-diamond poc-diamond"></span>
            PoC Milestone
        </span>
        <span class="legend-item">
            <span class="legend-diamond prod-diamond"></span>
            Production Release
        </span>
        <span class="legend-item">
            <span class="legend-circle"></span>
            Checkpoint
        </span>
        <span class="legend-item">
            <span class="legend-now"></span>
            Now
        </span>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string BacklogUrl { get; set; } = "";
    [Parameter] public string CurrentDate { get; set; } = "";
}