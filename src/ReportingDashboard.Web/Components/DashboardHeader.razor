<div class="hdr">
    <div>
        <h1>@Title <a href="@BacklogUrl">↗ ADO Backlog</a></h1>
        <div class="sub">@Subtitle</div>
    </div>
    <div class="legend">
        <span class="legend-item">
            <span class="icon-poc"></span>PoC Milestone
        </span>
        <span class="legend-item">
            <span class="icon-prod"></span>Production Release
        </span>
        <span class="legend-item">
            <span class="icon-checkpoint"></span>Checkpoint
        </span>
        <span class="legend-item">
            <span class="icon-now"></span>Now (@NowLabel)
        </span>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string BacklogUrl { get; set; } = "";
    [Parameter] public string CurrentDate { get; set; } = "";

    private string NowLabel
    {
        get
        {
            if (DateTime.TryParse(CurrentDate, out var dt))
                return dt.ToString("MMM yyyy");
            return CurrentDate;
        }
    }
}
