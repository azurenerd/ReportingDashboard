<div class="hdr">
    <div>
        <h1>@Title <a href="@BacklogUrl">&#x1F4CB; ADO Backlog</a></h1>
        <div class="sub">@Subtitle</div>
    </div>

    <div class="legend">
        <span class="legend-item">
            <span class="legend-icon poc-icon"></span>PoC Milestone
        </span>
        <span class="legend-item">
            <span class="legend-icon prod-icon"></span>Production Release
        </span>
        <span class="legend-item">
            <span class="legend-icon checkpoint-icon"></span>Checkpoint
        </span>
        <span class="legend-item">
            <span class="legend-icon now-icon"></span>Now (@NowLabel)
        </span>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string BacklogUrl { get; set; } = "";
    [Parameter] public string CurrentDate { get; set; } = "";

    private string NowLabel
    {
        get
        {
            if (DateTime.TryParse(CurrentDate, out var dt))
                return dt.ToString("MMM yyyy");
            return "";
        }
    }
}
