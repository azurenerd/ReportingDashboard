<header class="dash-header">
    <div class="dash-header-left">
        <h1 class="dash-title">@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="dash-subtitle">@Subtitle</p>
        }
    </div>
    <div class="dash-header-right">
        @if (!string.IsNullOrWhiteSpace(BacklogLink))
        {
            <a class="backlog-link" href="@BacklogLink" target="_blank" rel="noopener noreferrer">
                📋 View Backlog
            </a>
        }
        <div class="legend">
            <span class="legend-item"><span class="legend-dot shipped-dot"></span> Shipped</span>
            <span class="legend-item"><span class="legend-dot in-progress-dot"></span> In Progress</span>
            <span class="legend-item"><span class="legend-dot carryover-dot"></span> Carryover</span>
            <span class="legend-item"><span class="legend-dot blockers-dot"></span> Blockers</span>
        </div>
    </div>
</header>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string BacklogLink { get; set; } = "";
}