@if (Timeline.Tracks.Count > 0)
{
    <div class="timeline-wrap">
        <h2 class="timeline-heading">Project Timeline</h2>
        <svg class="timeline-svg" width="@SvgWidth" height="@SvgHeight" viewBox="0 0 @SvgWidth @SvgHeight"
             xmlns="http://www.w3.org/2000/svg">

            @* Month grid lines and labels *@
            @foreach (var monthTick in _monthTicks)
            {
                <line x1="@monthTick.X" y1="@HeaderHeight" x2="@monthTick.X" y2="@SvgHeight"
                      stroke="#e0e0e0" stroke-width="1" />
                @((MarkupString)$"<text x=\"{monthTick.X + 4}\" y=\"{HeaderHeight - 6}\" font-size=\"11\" fill=\"#888\">{monthTick.Label}</text>")
            }

            @* Tracks *@
            @{ var trackIndex = 0; }
            @foreach (var track in Timeline.Tracks)
            {
                var y = HeaderHeight + (trackIndex * TrackHeight) + (TrackHeight / 2);
                var labelY = HeaderHeight + (trackIndex * TrackHeight) + 4;

                @* Track label *@
                @((MarkupString)$"<text x=\"4\" y=\"{labelY + 14}\" font-size=\"12\" font-weight=\"600\" fill=\"#333\">{System.Web.HttpUtility.HtmlEncode(track.Label)}</text>")

                @* Track line *@
                <line x1="@LabelWidth" y1="@y" x2="@SvgWidth" y2="@y"
                      stroke="@track.Color" stroke-width="3" opacity="0.3" />

                @* Milestones *@
                @foreach (var ms in track.Milestones)
                {
                    var mx = LabelWidth + TimelineHelper.DateToX(ms.Date, Timeline.StartDate, Timeline.EndDate, ChartWidth);
                    var isDeadline = ms.Type == "deadline";

                    @if (isDeadline)
                    {
                        <polygon points="@($"{mx - 6},{y - 6} {mx + 6},{y - 6} {mx},{y + 6}")"
                                 fill="@track.Color" />
                    }
                    else
                    {
                        <circle cx="@mx" cy="@y" r="5" fill="@track.Color" />
                    }
                    @((MarkupString)$"<text x=\"{mx}\" y=\"{y - 10}\" text-anchor=\"middle\" font-size=\"10\" fill=\"#555\">{System.Web.HttpUtility.HtmlEncode(ms.Label)}</text>")
                }

                trackIndex++;
            }

            @* Now indicator *@
            @if (!string.IsNullOrEmpty(Timeline.NowDate))
            {
                var nowX = LabelWidth + TimelineHelper.DateToX(Timeline.NowDate, Timeline.StartDate, Timeline.EndDate, ChartWidth);
                <line x1="@nowX" y1="@(HeaderHeight - 2)" x2="@nowX" y2="@SvgHeight"
                      stroke="#D13438" stroke-width="2" stroke-dasharray="4,3" />
                @((MarkupString)$"<text x=\"{nowX}\" y=\"{HeaderHeight - 8}\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" fill=\"#D13438\">NOW</text>")
            }
        </svg>
    </div>
}

@code {
    [Parameter] public TimelineData Timeline { get; set; } = new();

    private const double SvgWidth = 1216;
    private const double LabelWidth = 120;
    private const double HeaderHeight = 32;
    private const double TrackHeight = 48;
    private double ChartWidth => SvgWidth - LabelWidth;
    private double SvgHeight => HeaderHeight + (Timeline.Tracks.Count * TrackHeight) + 8;

    private List<MonthTick> _monthTicks = new();

    protected override void OnParametersSet()
    {
        _monthTicks = BuildMonthTicks();
    }

    private List<MonthTick> BuildMonthTicks()
    {
        var ticks = new List<MonthTick>();
        if (!DateTime.TryParse(Timeline.StartDate, out var start) ||
            !DateTime.TryParse(Timeline.EndDate, out var end))
            return ticks;

        var current = new DateTime(start.Year, start.Month, 1);
        while (current <= end)
        {
            var x = LabelWidth + TimelineHelper.DateToX(
                current.ToString("yyyy-MM-dd"), Timeline.StartDate, Timeline.EndDate, ChartWidth);
            ticks.Add(new MonthTick { X = x, Label = current.ToString("MMM") });
            current = current.AddMonths(1);
        }
        return ticks;
    }

    private class MonthTick
    {
        public double X { get; set; }
        public string Label { get; set; } = "";
    }
}