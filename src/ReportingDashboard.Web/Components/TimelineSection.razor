<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in Timeline.Tracks)
        {
            <div class="tl-label">
                <span style="color:@track.Color;font-weight:600;">@track.Id</span><br />
                <span style="font-weight:400;color:#444;">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        @((MarkupString)BuildSvg())
    </div>
</div>

@using System.Text
@using System.Net

@code {
    [Parameter] public TimelineData Timeline { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = "";

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private double _nowX = -1;
    private List<MonthGridline> _monthGridlines = new();

    private record MonthGridline(double X, string Label);

    protected override void OnParametersSet()
    {
        if (DateTime.TryParse(CurrentDate, out _) &&
            DateTime.TryParse(Timeline.StartDate, out _) &&
            DateTime.TryParse(Timeline.EndDate, out _))
        {
            _nowX = DateToX(CurrentDate);
        }

        ComputeMonthGridlines();
    }

    private string BuildSvg()
    {
        var sb = new StringBuilder();
        sb.Append("<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"1560\" height=\"185\" style=\"overflow:visible;display:block\">");
        sb.Append("<defs><filter id=\"sh\"><feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\"/></filter></defs>");

        // Month gridlines
        foreach (var mg in _monthGridlines)
        {
            sb.Append($"<line x1=\"{F(mg.X)}\" y1=\"0\" x2=\"{F(mg.X)}\" y2=\"185\" stroke=\"#bbb\" stroke-opacity=\"0.4\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{F(mg.X + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\" font-family=\"Segoe UI,Arial\">{E(mg.Label)}</text>");
        }

        // NOW line
        if (_nowX >= 0)
        {
            sb.Append($"<line x1=\"{F(_nowX)}\" y1=\"0\" x2=\"{F(_nowX)}\" y2=\"185\" stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/>");
            sb.Append($"<text x=\"{F(_nowX + 4)}\" y=\"14\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" font-family=\"Segoe UI,Arial\">NOW</text>");
        }

        // Tracks
        for (int i = 0; i < Timeline.Tracks.Count; i++)
        {
            var track = Timeline.Tracks[i];
            var ty = TrackY(i);

            sb.Append($"<line x1=\"0\" y1=\"{F(ty)}\" x2=\"1560\" y2=\"{F(ty)}\" stroke=\"{track.Color}\" stroke-width=\"3\"/>");

            foreach (var ms in track.Milestones)
            {
                var mx = DateToX(ms.Date);
                var labelAbove = ShouldLabelAbove(track, ms);
                var labelY = labelAbove ? ty - 16 : ty + 24;

                if (ms.Type == "poc")
                {
                    sb.Append($"<g><polygon points=\"{DiamondPoints(mx, ty)}\" fill=\"#F4B400\" filter=\"url(#sh)\"/>");
                    if (!string.IsNullOrEmpty(ms.Label))
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(labelY)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{E(ms.Label)}</text>");
                    sb.Append($"<title>{E(ms.Label)} - {E(ms.Date)} - PoC Milestone</title></g>");
                }
                else if (ms.Type == "production")
                {
                    sb.Append($"<g><polygon points=\"{DiamondPoints(mx, ty)}\" fill=\"#34A853\" filter=\"url(#sh)\"/>");
                    if (!string.IsNullOrEmpty(ms.Label))
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(labelY)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{E(ms.Label)}</text>");
                    sb.Append($"<title>{E(ms.Label)} - {E(ms.Date)} - Production Release</title></g>");
                }
                else if (ms.Type == "checkpoint-small")
                {
                    sb.Append($"<g><circle cx=\"{F(mx)}\" cy=\"{F(ty)}\" r=\"4\" fill=\"#999\"/>");
                    sb.Append($"<title>{E(ms.Label)} - {E(ms.Date)} - Checkpoint</title></g>");
                }
                else
                {
                    var anchor = mx < 30 ? "start" : "middle";
                    sb.Append($"<g><circle cx=\"{F(mx)}\" cy=\"{F(ty)}\" r=\"7\" fill=\"white\" stroke=\"{track.Color}\" stroke-width=\"2.5\"/>");
                    if (!string.IsNullOrEmpty(ms.Label))
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(labelY)}\" text-anchor=\"{anchor}\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{E(ms.Label)}</text>");
                    sb.Append($"<title>{E(ms.Label)} - {E(ms.Date)} - Checkpoint</title></g>");
                }
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }

    private void ComputeMonthGridlines()
    {
        _monthGridlines.Clear();
        if (!DateTime.TryParse(Timeline.StartDate, out var start) ||
            !DateTime.TryParse(Timeline.EndDate, out var end))
            return;

        var current = new DateTime(start.Year, start.Month, 1);
        while (current <= end)
        {
            var x = DateToX(current);
            _monthGridlines.Add(new MonthGridline(x, current.ToString("MMM")));
            current = current.AddMonths(1);
        }
    }

    public static double DateToX(DateTime date, DateTime startDate, DateTime endDate)
    {
        var totalDays = (endDate - startDate).TotalDays;
        if (totalDays <= 0) return 0;
        var dayOffset = (date - startDate).TotalDays;
        return dayOffset / totalDays * SvgWidth;
    }

    private double DateToX(string dateStr)
    {
        if (!DateTime.TryParse(dateStr, out var date) ||
            !DateTime.TryParse(Timeline.StartDate, out var start) ||
            !DateTime.TryParse(Timeline.EndDate, out var end))
            return 0;
        return DateToX(date, start, end);
    }

    private double DateToX(DateTime date)
    {
        if (!DateTime.TryParse(Timeline.StartDate, out var start) ||
            !DateTime.TryParse(Timeline.EndDate, out var end))
            return 0;
        return DateToX(date, start, end);
    }

    private double TrackY(int index)
    {
        var trackCount = Timeline.Tracks.Count;
        return SvgHeight / (trackCount + 1) * (index + 1);
    }

    private bool ShouldLabelAbove(TimelineTrack track, Milestone ms)
    {
        var idx = track.Milestones.IndexOf(ms);
        if (idx % 2 == 0) return true;
        return false;
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{F(cx)},{F(cy - radius)} {F(cx + radius)},{F(cy)} {F(cx)},{F(cy + radius)} {F(cx - radius)},{F(cy)}";
    }

    private static string F(double v) => Math.Round(v, 1).ToString(System.Globalization.CultureInfo.InvariantCulture);
    private static string E(string v) => WebUtility.HtmlEncode(v ?? "");
}
