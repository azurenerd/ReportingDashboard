<div class="tl-area">
    <div class="tl-sidebar">
        @foreach (var track in Timeline.Tracks)
        {
            <div class="tl-track-label">
                <span style="color: @track.Color; font-weight: 600;">@track.Id</span>
                <span style="color: #444; font-weight: 400;"> - @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" overflow="visible" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines *@
            @foreach (var mt in _monthTicks)
            {
                <line x1="@F(mt.X)" y1="0" x2="@F(mt.X)" y2="185"
                      stroke="#bbb" stroke-width="1" stroke-opacity="0.4" />
                @SvgText(F(mt.X + 4), "12", mt.Label, fill: "#666", fontSize: "11", fontWeight: "600")
            }

            @* Track lines and milestones *@
            @{
                var trackCount = Timeline.Tracks.Count;
            }
            @for (var i = 0; i < trackCount; i++)
            {
                var track = Timeline.Tracks[i];
                var y = 185.0 / (trackCount + 1) * (i + 1);

                <line x1="0" y1="@F(y)" x2="1560" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    var mx = DateToX(ms.Date);
                    var tooltipText = $"{ms.Label} - {ms.Date} ({ms.Type})";

                    @if (ms.Type == "poc")
                    {
                        <g>
                            <polygon points="@DiamondPoints(mx, y)"
                                     fill="#F4B400" filter="url(#sh)" />
                            <title>@tooltipText</title>
                        </g>
                    }
                    else if (ms.Type == "production")
                    {
                        <g>
                            <polygon points="@DiamondPoints(mx, y)"
                                     fill="#34A853" filter="url(#sh)" />
                            <title>@tooltipText</title>
                        </g>
                    }
                    else
                    {
                        <g>
                            <circle cx="@F(mx)" cy="@F(y)" r="7"
                                    fill="white" stroke="@track.Color" stroke-width="2.5" />
                            <title>@tooltipText</title>
                        </g>
                    }

                    @SvgText(F(mx), F(y - 14), ms.Label, fill: "#666", fontSize: "10", textAnchor: "middle")
                }
            }

            @* NOW indicator *@
            @if (!string.IsNullOrEmpty(CurrentDate))
            {
                var nowX = DateToX(CurrentDate);
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="185"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @SvgText(F(nowX), "-4", "NOW", fill: "#EA4335", fontSize: "10", fontWeight: "700", textAnchor: "middle")
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData Timeline { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = "";

    private const double SvgWidth = 1560.0;
    private List<MonthTick> _monthTicks = new();

    protected override void OnParametersSet()
    {
        _monthTicks = BuildMonthTicks();
    }

    private double DateToX(string dateStr)
    {
        return TimelineHelper.DateToX(dateStr, Timeline.StartDate, Timeline.EndDate, SvgWidth);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{F(cx)},{F(cy - radius)} {F(cx + radius)},{F(cy)} {F(cx)},{F(cy + radius)} {F(cx - radius)},{F(cy)}";
    }

    private static string F(double v) => Math.Round(v, 1).ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static MarkupString SvgText(string x, string y, string content,
        string fill = "#666", string fontSize = "11",
        string? fontWeight = null, string? textAnchor = null)
    {
        var attrs = $"x=\"{x}\" y=\"{y}\" fill=\"{fill}\" font-size=\"{fontSize}\"";
        if (fontWeight is not null) attrs += $" font-weight=\"{fontWeight}\"";
        if (textAnchor is not null) attrs += $" text-anchor=\"{textAnchor}\"";
        return new MarkupString($"<text {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");
    }

    private List<MonthTick> BuildMonthTicks()
    {
        var ticks = new List<MonthTick>();
        if (!DateTime.TryParse(Timeline.StartDate, out var start) ||
            !DateTime.TryParse(Timeline.EndDate, out var end))
            return ticks;

        var current = new DateTime(start.Year, start.Month, 1);
        while (current <= end)
        {
            var x = TimelineHelper.DateToX(
                current.ToString("yyyy-MM-dd"), Timeline.StartDate, Timeline.EndDate, SvgWidth);
            ticks.Add(new MonthTick { X = x, Label = current.ToString("MMM") });
            current = current.AddMonths(1);
        }
        return ticks;
    }

    private class MonthTick
    {
        public double X { get; set; }
        public string Label { get; set; } = "";
    }
}