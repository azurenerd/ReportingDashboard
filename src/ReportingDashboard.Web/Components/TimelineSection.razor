@code {
    [Parameter] public TimelineData Timeline { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = "";

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private DateTime _startDate;
    private DateTime _endDate;
    private double _totalDays;

    protected override void OnParametersSet()
    {
        if (DateTime.TryParse(Timeline.StartDate, out var s))
            _startDate = s;
        if (DateTime.TryParse(Timeline.EndDate, out var e))
            _endDate = e;
        _totalDays = (_endDate - _startDate).TotalDays;
    }

    public static double DateToX(DateTime date, DateTime startDate, DateTime endDate, double svgWidth = SvgWidth)
    {
        var totalDays = (endDate - startDate).TotalDays;
        if (totalDays <= 0) return 0;
        var dayOffset = (date - startDate).TotalDays;
        return dayOffset / totalDays * svgWidth;
    }

    private double DateToX(string dateStr)
    {
        if (!DateTime.TryParse(dateStr, out var dt)) return 0;
        return DateToX(dt, _startDate, _endDate);
    }

    private double TrackY(int index)
    {
        return SvgHeight / (Timeline.Tracks.Count + 1) * (index + 1);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{cx},{cy - radius} {cx + radius},{cy} {cx},{cy + radius} {cx - radius},{cy}";
    }

    private List<(string label, double x)> GetMonthGridlines()
    {
        var result = new List<(string, double)>();
        var current = new DateTime(_startDate.Year, _startDate.Month, 1);
        while (current <= _endDate)
        {
            var x = DateToX(current, _startDate, _endDate);
            result.Add((current.ToString("MMM"), x));
            current = current.AddMonths(1);
        }
        return result;
    }

    private string FormatTooltip(Milestone m)
    {
        if (DateTime.TryParse(m.Date, out var dt))
        {
            var typeLabel = m.Type switch
            {
                "poc" => "PoC Milestone",
                "production" => "Production Release",
                "checkpoint" => "Checkpoint",
                _ => m.Type
            };
            return $"{dt:MMM d} \u2014 {typeLabel}";
        }
        return m.Label;
    }
}

<div class="tl-area">
    <div class="tl-sidebar">
        @foreach (var track in Timeline.Tracks)
        {
            <div class="tl-label" style="color:@track.Color;">
                @track.Id<br /><span class="tl-label-desc">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg xmlns="http://www.w3.org/2000/svg" width="1560" height="185" style="overflow:visible;display:block">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines *@
            @foreach (var (label, x) in GetMonthGridlines())
            {
                <g>
                    <line x1="@F(x)" y1="0" x2="@F(x)" y2="@F(SvgHeight)" stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                    <text x="@F(x + 5)" y="14" fill="#666" font-size="11" font-weight="600" font-family="Segoe UI,Arial">@label</text>
                </g>
            }

            @* NOW line *@
            @if (!string.IsNullOrEmpty(CurrentDate))
            {
                var nowX = DateToX(CurrentDate);
                <g>
                    <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@F(SvgHeight)" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                    <text x="@F(nowX + 4)" y="14" fill="#EA4335" font-size="10" font-weight="700" font-family="Segoe UI,Arial">NOW</text>
                </g>
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < Timeline.Tracks.Count; i++)
            {
                var track = Timeline.Tracks[i];
                var y = TrackY(i);

                <line x1="0" y1="@F(y)" x2="@F(SvgWidth)" y2="@F(y)" stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    var mx = DateToX(ms.Date);
                    var tooltip = FormatTooltip(ms);

                    @if (ms.Type == "checkpoint")
                    {
                        <g class="milestone-group">
                            <circle cx="@F(mx)" cy="@F(y)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5" />
                            <text x="@F(mx)" y="@F(y - 16)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                            <title>@tooltip</title>
                        </g>
                    }
                    else if (ms.Type == "checkpoint-small")
                    {
                        <g class="milestone-group">
                            <circle cx="@F(mx)" cy="@F(y)" r="4" fill="#999" />
                            <title>@tooltip</title>
                        </g>
                    }
                    else if (ms.Type == "checkpoint-medium")
                    {
                        <g class="milestone-group">
                            <circle cx="@F(mx)" cy="@F(y)" r="5" fill="white" stroke="#888" stroke-width="2.5" />
                            <text x="@F(mx)" y="@F(y - 16)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                            <title>@tooltip</title>
                        </g>
                    }
                    else if (ms.Type == "poc")
                    {
                        <g class="milestone-group">
                            <polygon points="@DiamondPoints(mx, y)" fill="#F4B400" filter="url(#sh)" />
                            <text x="@F(mx)" y="@F(y + 24)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                            <title>@tooltip</title>
                        </g>
                    }
                    else if (ms.Type == "production")
                    {
                        <g class="milestone-group">
                            <polygon points="@DiamondPoints(mx, y)" fill="#34A853" filter="url(#sh)" />
                            <text x="@F(mx)" y="@F(y - 24)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                            <title>@tooltip</title>
                        </g>
                    }
                }
            }
        </svg>
    </div>
</div>

@functions {
    private static string F(double v) => Math.Round(v, 1).ToString(System.Globalization.CultureInfo.InvariantCulture);
}
