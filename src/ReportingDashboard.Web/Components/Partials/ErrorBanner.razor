@using ReportingDashboard.Web.Models

<div class="error-banner" role="alert">
    <span class="error-glyph" aria-hidden="true">&#9888;</span>
    <span class="error-text">@BannerText</span>
</div>

@code {
    [Parameter, EditorRequired] public required DashboardLoadError Error { get; set; }

    private string BannerText => BuildText(Error);

    private static string BuildText(DashboardLoadError err)
    {
        return err.Kind switch
        {
            "NotFound" => $"data.json not found at {err.FilePath}. See README for schema.",
            "ValidationError" => $"data.json validation failed: {err.Message}",
            _ => $"Failed to load data.json: {FormatParse(err)}"
        };
    }

    private static string FormatParse(DashboardLoadError err)
    {
        if (err.Line is int l && err.Column is int c)
        {
            return $"{err.Message} at line {l}, column {c}.";
        }
        return err.Message;
    }
}