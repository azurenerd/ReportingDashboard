<div class="hm-cell @(IsCurrentMonth ? "current-month-cell" : "")">
    @if (Items.Count > 0)
    {
        <div class="cell-count @ColorClass-count">@Items.Count</div>
        <ul class="cell-items">
            @foreach (var item in Items)
            {
                <li class="cell-item">@item</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public List<string> Items { get; set; } = new();
    [Parameter] public string ColorClass { get; set; } = "";
    [Parameter] public bool IsCurrentMonth { get; set; }
}