@{
    var cellClass = $"hm-cell {ColorClass}-cell" + (IsCurrentMonth ? " apr" : "");
    var cellStyle = IsLastColumn ? "border-right:none;" : "";
}

<div class="@cellClass" style="@cellStyle">
    @if (Items == null || Items.Count == 0)
    {
        <div class="it" style="color:#AAA;">-</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
</div>

@code {
    [Parameter] public List<string> Items { get; set; } = new();
    [Parameter] public string ColorClass { get; set; } = "";
    [Parameter] public bool IsCurrentMonth { get; set; }
    [Parameter] public bool IsLastColumn { get; set; }
}
