<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(ReportingDashboard.Web.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(ReportingDashboard.Web.Shared.MainLayout)">
            <p role="alert">Not found.</p>
        </LayoutView>
    </NotFound>
</Router>