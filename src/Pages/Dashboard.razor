@page "/"
@using AgentSquad.Models
@using AgentSquad.Services
@inject ProjectDataService ProjectDataService

<div class="container-fluid">
    <h1 class="section-spacing">Project Dashboard</h1>

    @if (projectData == null && !hasError)
    {
        <p class="text-muted">Loading project data...</p>
    }
    else if (hasError)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else if (projectData?.Project != null)
    {
        <MilestoneTimeline Milestones="projectData.Milestones" 
                          ProjectStartDate="projectData.Project.StartDate"
                          ProjectEndDate="projectData.Project.EndDate" />

        <div class="row section-spacing">
            <div class="col-12 col-md-6 col-lg-4">
                <StatusCard StatusCategory="Shipped" 
                           TaskCount="projectData.Metrics.ShippedCount"
                           Tasks="projectData.Tasks.Where(t => t.Status == TaskStatus.Shipped).ToList()"
                           CardColor="status-card-green" />
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <StatusCard StatusCategory="In-Progress"
                           TaskCount="projectData.Metrics.InProgressCount"
                           Tasks="projectData.Tasks.Where(t => t.Status == TaskStatus.InProgress).ToList()"
                           CardColor="status-card-blue" />
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <StatusCard StatusCategory="Carried-Over"
                           TaskCount="projectData.Metrics.CarriedOverCount"
                           Tasks="projectData.Tasks.Where(t => t.Status == TaskStatus.CarriedOver).ToList()"
                           CardColor="status-card-orange" />
            </div>
        </div>

        <ProgressMetrics CompletionPercentage="projectData.Metrics.CompletionPercentage"
                        TotalTasks="projectData.Tasks.Count"
                        CompletedTasks="projectData.Tasks.Count(t => t.Status == TaskStatus.Shipped)"
                        BurndownRate="projectData.Metrics.BurndownRate" />
    }
</div>

@code {
    private ProjectData projectData;
    private string errorMessage;
    private bool hasError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projectData = await ProjectDataService.LoadProjectDataAsync();
            if (projectData == null)
            {
                hasError = true;
                errorMessage = "Failed to load project data. Ensure data.json exists and is valid.";
            }
        }
        catch (FileNotFoundException)
        {
            hasError = true;
            errorMessage = "data.json file not found. Please create wwwroot/data.json with project data.";
        }
        catch (System.Text.Json.JsonException ex)
        {
            hasError = true;
            errorMessage = $"Invalid JSON format in data.json: {ex.Message}";
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = $"Error loading project data: {ex.Message}";
        }
    }
}