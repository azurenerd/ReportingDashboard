@using AgentSquad.Runner.Models
@if (Milestones != null && Milestones.Count > 0)
{
    <div class="section-spacing timeline-section">
        <h2>Project Milestones</h2>
        <div class="timeline-container">
            <div class="row">
                @foreach (var milestone in Milestones)
                {
                    <div class="col-12 col-md-6 col-lg-4 mb-3">
                        <div class="card status-card">
                            <div class="card-body card-spacing">
                                <h5>@milestone.Name</h5>
                                <p class="text-muted mb-2">Target: @milestone.TargetDate.ToShortDateString()</p>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @milestone.CompletionPercentage%">
                                        @milestone.CompletionPercentage%
                                    </div>
                                </div>
                                <p class="mt-2 mb-0">
                                    <small>
                                        @if (milestone.Status == MilestoneStatus.Completed)
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else if (milestone.Status == MilestoneStatus.InProgress)
                                        {
                                            <span class="badge bg-primary">In Progress</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pending</span>
                                        }
                                    </small>
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();
}