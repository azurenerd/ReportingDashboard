@using AgentSquad.Runner.Models

<div class="col-12 col-md-6 col-lg-4 mb-4">
    <div class="card status-card metric-card h-100">
        <div class="card-body card-spacing">
            <h5 class="card-title">@StatusLabel</h5>
            <p class="display-6 mb-3 text-primary">@TaskCount</p>
            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#tasks-@(StatusLabel.Replace(" ", ""))">
                View Tasks
            </button>
            <div class="collapse mt-3" id="tasks-@(StatusLabel.Replace(" ", ""))">
                <div>
                    @if (Tasks != null && Tasks.Count > 0)
                    {
                        <ul class="list-unstyled">
                            @foreach (var task in Tasks)
                            {
                                <li class="mb-2 small">
                                    ✓ @task.Name (@task.AssignedTo)
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small">No tasks</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string StatusLabel { get; set; } = "";

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task> Tasks { get; set; } = new();
}