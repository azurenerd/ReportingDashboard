@using AgentSquad.Models

<div class="card status-card @CardColor">
    <div class="card-header">
        <h4 class="mb-2">@StatusCategory</h4>
        <p class="fs-2 mb-0">@TaskCount</p>
    </div>
    <div class="card-body">
        @if ((Tasks?.Count ?? 0) > 0)
        {
            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#tasks-@StatusCategory.Replace(" ", "-")">
                View Tasks
            </button>
            <div class="collapse mt-3" id="tasks-@StatusCategory.Replace(" ", "-")">
                <ul class="list-unstyled">
                    @foreach (var task in Tasks)
                    {
                        <li class="mb-2">
                            <input type="checkbox" class="form-check-input" disabled /> 
                            <span>@task.Name</span>
                            @if (!string.IsNullOrEmpty(task.AssignedTo))
                            {
                                <br />
                                <small class="text-muted">Assigned to: @task.AssignedTo</small>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No tasks</p>
        }
    </div>
</div>

@code {
    [Parameter] public string StatusCategory { get; set; }
    [Parameter] public int TaskCount { get; set; }
    [Parameter] public List<TaskItem> Tasks { get; set; }
    [Parameter] public string CardColor { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(StatusCategory))
        {
            throw new ArgumentException("StatusCategory parameter is required.", nameof(StatusCategory));
        }
    }
}