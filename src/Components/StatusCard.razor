@using AgentSquad.Models

<div class="card status-card @CardColor">
    <div class="card-header">
        <h4>@StatusCategory</h4>
        <p class="fs-2">@TaskCount</p>
    </div>
    <div class="card-body">
        <button class="btn btn-sm btn-link" data-bs-toggle="collapse" data-bs-target="#tasks-@StatusCategory">
            View Tasks
        </button>
        <div class="collapse" id="tasks-@StatusCategory">
            <ul class="list-unstyled mt-2">
                @foreach (var task in Tasks ?? new())
                {
                    <li class="mb-2">
                        <input type="checkbox" disabled /> @task.Name
                        @if (!string.IsNullOrEmpty(task.AssignedOwner))
                        {
                            <small class="text-muted">(@task.AssignedOwner)</small>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter] public string StatusCategory { get; set; }
    [Parameter] public int TaskCount { get; set; }
    [Parameter] public List<TaskItem> Tasks { get; set; }
    [Parameter] public string CardColor { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(StatusCategory))
        {
            throw new ArgumentException("StatusCategory parameter is required.", nameof(StatusCategory));
        }
    }
}