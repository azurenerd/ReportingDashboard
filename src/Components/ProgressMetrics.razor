@using AgentSquad.Models

<section class="section-spacing">
  <h2>Progress Metrics</h2>
  <div class="row">
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card card-spacing">
        <h4>Completion</h4>
        <p class="fs-2">@ProjectData?.CompletionPercentage%</p>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card card-spacing">
        <h4>On Track</h4>
        <p class="fs-2">@ProjectData?.OnTrackPercentage%</p>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card card-spacing">
        <h4>At Risk</h4>
        <p class="fs-2">@ProjectData?.AtRiskPercentage%</p>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card card-spacing">
        <h4>Blocked</h4>
        <p class="fs-2">@ProjectData?.BlockedPercentage%</p>
      </div>
    </div>
  </div>
</section>

@code {
  [Parameter] public ProjectData ProjectData { get; set; }
}