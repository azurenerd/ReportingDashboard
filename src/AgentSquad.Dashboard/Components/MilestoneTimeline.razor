@using AgentSquad.Dashboard.Models

<div class="milestone-section">
    <h2>Project Milestones</h2>
    <MudTimeline TimelinePosition="TimelinePosition.Default">
        @foreach (var milestone in Data?.Milestones ?? new List<Milestone>())
        {
            <MudTimelineItem Color="GetMilestoneColor(milestone.Status)">
                <ItemOpposite>
                    <MudText Typo="Typo.body2">@milestone.TargetDate:d</MudText>
                </ItemOpposite>
                <ItemContent>
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@milestone.Name</MudText>
                            <div style="margin-top: 10px;">
                                <MudChip Label="true" Color="GetStatusChipColor(milestone.Status)">
                                    @milestone.Status
                                </MudChip>
                                <MudProgressLinear Value="@milestone.PercentComplete" Class="mt-2" />
                                <MudText Typo="Typo.caption">@milestone.PercentComplete% Complete</MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>
</div>

@code {
    [CascadingParameter]
    public ProjectData? Data { get; set; }

    private Color GetMilestoneColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "In Progress" => Color.Warning,
        "Not Started" => Color.Default,
        _ => Color.Default
    };

    private Color GetStatusChipColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "In Progress" => Color.Warning,
        "Not Started" => Color.Error,
        _ => Color.Default
    };
}