@using System.Text.RegularExpressions

<div class="status-card card border-@CardColor" style="border-width: 4px;">
    <div class="card-header bg-@CardColor text-white">
        <h3 class="card-title mb-0">@StatusCategory</h3>
        <div class="task-count">@TaskCount</div>
    </div>
    <div class="card-body">
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#tasks-@StatusCategory.Replace(' ', '-')" aria-expanded="false">
            View Tasks
        </button>
        <div class="collapse mt-3" id="tasks-@StatusCategory.Replace(' ', '-')">
            @if (Tasks != null && Tasks.Any())
            {
                <ul class="task-list">
                    @foreach (var task in Tasks)
                    {
                        <li class="task-item">
                            <span class="task-checkbox">✓</span>
                            <span class="task-name">@task.Name</span>
                            <span class="task-owner">@task.AssignedTo</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No tasks in this category.</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task>? Tasks { get; set; }

    [Parameter]
    public string? CardColor { get; set; }
}