@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="container mt-5">
                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Page Not Found</h4>
                    <p>Sorry, the page you are looking for does not exist.</p>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    [Inject]
    private IProjectDataService DataService { get; set; } = null!;

    private ProjectDashboard? Dashboard { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; } = true;

    protected override void OnInitialized()
    {
        try
        {
            if (DataService.IsInitialized)
            {
                Dashboard = DataService.GetDashboard();
                ErrorMessage = null;
            }
            else if (DataService.LastError != null)
            {
                ErrorMessage = DataService.LastError;
                Dashboard = null;
            }
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = "Dashboard data not initialized. " + ex.Message;
            Dashboard = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
            Dashboard = null;
        }
        finally
        {
            IsLoading = false;
        }
    }
}