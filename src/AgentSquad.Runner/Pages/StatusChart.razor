@using AgentSquad.Runner.Models
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div style="background: white; border-radius: 4px; padding: 24px; border: 1px solid #ddd;">
    <div style="position: relative; height: 300px;">
        <canvas id="statusChart" style="width: 100%; height: 100%;"></canvas>
    </div>
</div>

@code {
    [Parameter]
    public (int Shipped, int InProgress, int CarriedOver) StatusCounts { get; set; }

    private int _previousShipped = -1;
    private int _previousInProgress = -1;
    private int _previousCarriedOver = -1;

    protected override async Task OnParametersSetAsync()
    {
        // Check if status counts have changed
        if (StatusCounts.Shipped != _previousShipped ||
            StatusCounts.InProgress != _previousInProgress ||
            StatusCounts.CarriedOver != _previousCarriedOver)
        {
            _previousShipped = StatusCounts.Shipped;
            _previousInProgress = StatusCounts.InProgress;
            _previousCarriedOver = StatusCounts.CarriedOver;

            // Update chart with new data
            await InitializeChart();
        }

        await base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChart();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task InitializeChart()
    {
        try
        {
            // Prepare chart data
            var labels = new[] { "Shipped", "In Progress", "Carried Over" };
            var data = new[] { StatusCounts.Shipped, StatusCounts.InProgress, StatusCounts.CarriedOver };
            var backgroundColor = new[] { "#4caf50", "#2196f3", "#ff9800" };
            var borderColor = new[] { "#388e3c", "#1565c0", "#e65100" };

            // Create simple bar chart using canvas and Chart.js
            var chartConfig = new
            {
                type = "bar",
                data = new
                {
                    labels = labels,
                    datasets = new[]
                    {
                        new
                        {
                            label = "Count",
                            data = data,
                            backgroundColor = backgroundColor,
                            borderColor = borderColor,
                            borderWidth = 1
                        }
                    }
                },
                options = new
                {
                    responsive = true,
                    maintainAspectRatio = false,
                    indexAxis = "x",
                    scales = new
                    {
                        y = new { beginAtZero = true, ticks = new { stepSize = 1 } }
                    },
                    plugins = new
                    {
                        legend = new { display = false }
                    }
                }
            };

            await JSRuntime.InvokeVoidAsync("initStatusChart", "statusChart", chartConfig);
        }
        catch (Exception ex)
        {
            // Silently fail - chart is non-critical
            Console.WriteLine($"Chart initialization failed: {ex.Message}");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await ValueTask.CompletedTask;
    }
}