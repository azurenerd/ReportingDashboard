@using AgentSquad.Runner.Models

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 24px;">
    <!-- Shipped Section -->
    <div style="background: white; border-radius: 4px; border: 1px solid #ddd; overflow: hidden;">
        <div style="background: #4caf50; color: white; padding: 16px; font-weight: 600;">
            Shipped (@(Shipped?.Count ?? 0))
        </div>
        <div style="padding: 16px;">
            @if (Shipped == null || Shipped.Count == 0)
            {
                <div style="color: #999; text-align: center; padding: 24px 0;">
                    No items shipped
                </div>
            }
            else
            {
                <ul style="list-style: none; padding: 0; margin: 0;">
                    @foreach (var item in Shipped)
                    {
                        <li style="padding: 12px 0; border-bottom: 1px solid #eee; font-size: 14px;">
                            <div style="color: #1a1a1a; font-weight: 500;">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Assignee))
                            {
                                <div style="color: #999; font-size: 13px; margin-top: 4px;">@item.Assignee</div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <!-- In Progress Section -->
    <div style="background: white; border-radius: 4px; border: 1px solid #ddd; overflow: hidden;">
        <div style="background: #2196f3; color: white; padding: 16px; font-weight: 600;">
            In Progress (@(InProgress?.Count ?? 0))
        </div>
        <div style="padding: 16px;">
            @if (InProgress == null || InProgress.Count == 0)
            {
                <div style="color: #999; text-align: center; padding: 24px 0;">
                    No items in progress
                </div>
            }
            else
            {
                <ul style="list-style: none; padding: 0; margin: 0;">
                    @foreach (var item in InProgress)
                    {
                        <li style="padding: 12px 0; border-bottom: 1px solid #eee; font-size: 14px;">
                            <div style="color: #1a1a1a; font-weight: 500;">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Assignee))
                            {
                                <div style="color: #999; font-size: 13px; margin-top: 4px;">@item.Assignee</div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <!-- Carried Over Section -->
    <div style="background: white; border-radius: 4px; border: 1px solid #ddd; overflow: hidden;">
        <div style="background: #ff9800; color: white; padding: 16px; font-weight: 600;">
            Carried Over (@(CarriedOver?.Count ?? 0))
        </div>
        <div style="padding: 16px;">
            @if (CarriedOver == null || CarriedOver.Count == 0)
            {
                <div style="color: #999; text-align: center; padding: 24px 0;">
                    No items carried over
                </div>
            }
            else
            {
                <ul style="list-style: none; padding: 0; margin: 0;">
                    @foreach (var item in CarriedOver)
                    {
                        <li style="padding: 12px 0; border-bottom: 1px solid #eee; font-size: 14px;">
                            <div style="color: #1a1a1a; font-weight: 500;">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Assignee))
                            {
                                <div style="color: #999; font-size: 13px; margin-top: 4px;">@item.Assignee</div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<WorkItem> Shipped { get; set; }

    [Parameter]
    public IReadOnlyList<WorkItem> InProgress { get; set; }

    [Parameter]
    public IReadOnlyList<WorkItem> CarriedOver { get; set; }
}