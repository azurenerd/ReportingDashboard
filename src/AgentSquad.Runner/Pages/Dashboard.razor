@page "/"
@page "/dashboard"

@inherits LayoutComponentBase
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Lg" Class="py-6">
    <style>
        .dashboard-wrapper {
            max-width: 1200px !important;
            margin: 0 auto;
        }
        .dashboard-section {
            margin-bottom: 2rem;
        }
        .dashboard-grid {
            display: grid;
            gap: 2rem;
        }
    </style>

    <div class="dashboard-wrapper dashboard-grid">
        <!-- Error Boundary Section -->
        @if (!DataService.HasData && !string.IsNullOrEmpty(DataService.GetLastError()))
        {
            <MudAlert Severity="Severity.Error" Class="dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" GutterBottom="false">
                        <strong>⚠️ Error Loading Dashboard</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        @DataService.GetLastError()
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mt-2">
                        Please check your data.json file format and try again.
                    </MudText>
                </MudStack>
            </MudAlert>
        }

        <!-- Loading State -->
        @if (!DataService.HasData && string.IsNullOrEmpty(DataService.GetLastError()))
        {
            <MudAlert Severity="Severity.Info" Class="dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" GutterBottom="false">
                        <strong>📊 Loading Dashboard</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        Reading data.json and initializing dashboard...
                    </MudText>
                </MudStack>
            </MudAlert>
        }

        <!-- Main Dashboard Content -->
        @if (DataService.HasData)
        {
            <!-- Project Summary Section -->
            @if (DataService.GetProject() != null)
            {
                var project = DataService.GetProject();
                <section class="dashboard-section">
                    <MudPaper Class="pa-6" Elevation="2">
                        <MudText Typo="Typo.h3" GutterBottom="true" Class="mb-3">
                            @project.Name
                        </MudText>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <MudText Typo="Typo.body1" Color="Color.TextSecondary">
                                @project.Description
                            </MudText>
                        }
                    </MudPaper>
                </section>
            }

            <!-- Milestone Timeline Section -->
            <section class="dashboard-section">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4">
                        📅 Key Milestones
                    </MudText>
                    <MilestoneTimeline Milestones="DataService.GetMilestones()" />
                </MudPaper>
            </section>

            <!-- Status Chart Section -->
            <section class="dashboard-section">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4">
                        📈 Work Item Status
                    </MudText>
                    <StatusChart StatusCounts="DataService.GetStatusCounts()" />
                </MudPaper>
            </section>

            <!-- Work Items List Section -->
            <section class="dashboard-section">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4">
                        ✓ Work Items
                    </MudText>
                    <WorkItemList 
                        Shipped="DataService.GetWorkItemsByStatus(WorkItemStatus.Shipped)"
                        InProgress="DataService.GetWorkItemsByStatus(WorkItemStatus.InProgress)"
                        CarriedOver="DataService.GetWorkItemsByStatus(WorkItemStatus.CarriedOver)" />
                </MudPaper>
            </section>
        }
    </div>
</MudContainer>

@inject DashboardDataService DataService