@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Components

<PageTitle>Executive Dashboard</PageTitle>

<div class="dashboard-container">
    <h1>Executive Dashboard</h1>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @_errorMessage
            <button type="button" class="btn-close" @onclick="@(() => _errorMessage = null)"></button>
        </div>
    }

    @if (_isLoading)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (DataService.HasData)
    {
        var project = DataService.GetProject();
        var milestones = DataService.GetMilestones();
        var statusCounts = DataService.GetStatusCounts();

        @if (project != null)
        {
            <div class="project-header">
                <h2>@project.Name</h2>
                @if (!string.IsNullOrEmpty(project.Description))
                {
                    <p class="description">@project.Description</p>
                }
            </div>
        }

        <div class="status-overview">
            <StatusChart StatusCounts="statusCounts"></StatusChart>
        </div>

        <div class="milestones-section">
            <h3>Milestones</h3>
            @if (milestones.Count == 0)
            {
                <p>No milestones defined</p>
            }
            else
            {
                <div class="milestones-list">
                    @foreach (var milestone in milestones)
                    {
                        <div class="milestone-card">
                            <h4>@milestone.Name</h4>
                            <p><strong>Date:</strong> @milestone.Date.ToString("yyyy-MM-dd")</p>
                            <p><strong>Status:</strong> @milestone.Status</p>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="work-items-section">
            <h3>Work Items by Status</h3>
            <div class="row">
                <div class="col-md-4">
                    <h4>Shipped (@statusCounts.Shipped)</h4>
                    <WorkItemList Items="DataService.GetWorkItemsByStatus(WorkItemStatus.Shipped)"></WorkItemList>
                </div>
                <div class="col-md-4">
                    <h4>In Progress (@statusCounts.InProgress)</h4>
                    <WorkItemList Items="DataService.GetWorkItemsByStatus(WorkItemStatus.InProgress)"></WorkItemList>
                </div>
                <div class="col-md-4">
                    <h4>Carried Over (@statusCounts.CarriedOver)</h4>
                    <WorkItemList Items="DataService.GetWorkItemsByStatus(WorkItemStatus.CarriedOver)"></WorkItemList>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">No dashboard data available. Please check the data.json file.</div>
    }
</div>