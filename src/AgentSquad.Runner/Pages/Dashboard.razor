@page "/"
@page "/dashboard"
@implements IAsyncDisposable
@inject DashboardDataService DataService
@using AgentSquad.Runner.Models
@using MudBlazor

<PageTitle>Project Dashboard</PageTitle>

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px 16px;
        background-color: #f5f5f5;
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .dashboard-header {
        margin-bottom: 32px;
    }

    .project-title {
        font-size: 32px;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0 0 8px 0;
    }

    .project-description {
        font-size: 16px;
        color: #666;
        margin: 0;
    }

    .dashboard-section {
        margin-bottom: 32px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0 0 16px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 14px;
    }

    .error-alert {
        margin-bottom: 32px;
    }

    .loading-indicator {
        text-align: center;
        padding: 48px 24px;
        color: #999;
        font-size: 16px;
    }

    .empty-state {
        text-align: center;
        padding: 48px 24px;
        color: #999;
        background: white;
        border-radius: 4px;
        border: 1px solid #ddd;
    }
</style>

<div class="dashboard-container">
    @if (!DataService.HasData && string.IsNullOrEmpty(DataService.GetLastError()))
    {
        <div class="loading-indicator">
            <p>Loading dashboard...</p>
        </div>
    }
    else if (!DataService.HasData && !string.IsNullOrEmpty(DataService.GetLastError()))
    {
        <div class="error-alert">
            <MudAlert Severity="Severity.Error" ContentAlignment="HorizontalAlignment.Left">
                <strong>Error Loading Dashboard</strong>
                <p style="margin: 8px 0 0 0; font-size: 14px;">@DataService.GetLastError()</p>
                <p style="margin: 4px 0 0 0; font-size: 12px; color: #666;">
                    Please check your data.json file and save it again to recover.
                </p>
            </MudAlert>
        </div>
    }
    else
    {
        <!-- Project Summary Header -->
        <div class="dashboard-header">
            <h1 class="project-title">@DataService.GetProject()?.Name</h1>
            @if (!string.IsNullOrWhiteSpace(DataService.GetProject()?.Description))
            {
                <p class="project-description">@DataService.GetProject().Description</p>
            }
        </div>

        <!-- Milestone Timeline Section -->
        @if (DataService.GetMilestones().Count > 0)
        {
            <div class="dashboard-section">
                <h2 class="section-title">Milestones</h2>
                <MilestoneTimeline Milestones="DataService.GetMilestones()" />
            </div>
        }

        <!-- Status Chart Section -->
        <div class="dashboard-section">
            <h2 class="section-title">Work Item Status</h2>
            <StatusChart StatusCounts="DataService.GetStatusCounts()" />
        </div>

        <!-- Work Items by Status Section -->
        <div class="dashboard-section">
            <h2 class="section-title">Work Items</h2>
            <WorkItemList 
                Shipped="DataService.GetWorkItemsByStatus(WorkItemStatus.Shipped)"
                InProgress="DataService.GetWorkItemsByStatus(WorkItemStatus.InProgress)"
                CarriedOver="DataService.GetWorkItemsByStatus(WorkItemStatus.CarriedOver)" />
        </div>
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Step 6: Subscribe to OnDataChanged event in OnInitializedAsync()
        DataService.OnDataChanged += OnDataChanged;
        
        await base.OnInitializedAsync();
    }

    /// <summary>
    /// Step 6: Handler called when data.json changes.
    /// Triggers Blazor re-render by calling StateHasChanged().
    /// </summary>
    private void OnDataChanged()
    {
        // StateHasChanged() triggers Blazor to re-render this component
        // This causes all child components to receive updated parameters
        // and re-render with fresh data from DashboardDataService
        StateHasChanged();
    }

    /// <summary>
    /// Step 6: Cleanup handler - unsubscribe from OnDataChanged event on dispose.
    /// Prevents memory leaks and multiple event subscriptions.
    /// </summary>
    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        // Unsubscribe from OnDataChanged event
        DataService.OnDataChanged -= OnDataChanged;
        
        await ValueTask.CompletedTask;
    }
}