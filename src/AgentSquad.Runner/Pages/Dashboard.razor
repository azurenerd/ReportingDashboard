@page "/"
@page "/dashboard"
@using AgentSquad.Runner.Components
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@implements IAsyncDisposable

@inject DashboardDataService DataService
@inject ILogger<Dashboard> Logger

<MudContainer MaxWidth="MaxWidth.Lg" Class="dashboard-container">
    @if (!DataService.HasData && !string.IsNullOrEmpty(DataService.GetLastError()))
    {
        <MudAlert Severity="Severity.Error" Class="dashboard-section">
            <strong>Error Loading Dashboard</strong>
            <p>@DataService.GetLastError()</p>
            <p style="font-size: 12px; color: #666;">Check data.json format and try again.</p>
        </MudAlert>
    }

    @if (DataService.HasData)
    {
        <MudCard Class="dashboard-section">
            <MudCardContent>
                <MudText Typo="Typo.h4" Class="mb-3">@(DataService.GetProject()?.Name ?? "Project Dashboard")</MudText>
                @if (!string.IsNullOrEmpty(DataService.GetProject()?.Description))
                {
                    <MudText Typo="Typo.body1" Color="Color.TextSecondary">
                        @DataService.GetProject().Description
                    </MudText>
                }
            </MudCardContent>
        </MudCard>

        <MilestoneTimeline Milestones="DataService.GetMilestones()" />

        <MudCard Class="dashboard-section">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">Work Item Status</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <StatusChart StatusCounts="DataService.GetStatusCounts()" />
            </MudCardContent>
        </MudCard>

        <WorkItemList 
            Shipped="DataService.GetWorkItemsByStatus(WorkItemStatus.Shipped)"
            InProgress="DataService.GetWorkItemsByStatus(WorkItemStatus.InProgress)"
            CarriedOver="DataService.GetWorkItemsByStatus(WorkItemStatus.CarriedOver)" />
    }
    else if (DataService.HasData == false)
    {
        <MudAlert Severity="Severity.Info" Class="dashboard-section">
            <strong>Loading Dashboard...</strong>
            <p>Please wait while the dashboard data is being loaded.</p>
        </MudAlert>
    }
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            DataService.OnDataChanged += OnDataChanged;
            await Task.Delay(100);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing Dashboard component");
        }
    }

    private void OnDataChanged()
    {
        try
        {
            InvokeAsync(() => StateHasChanged());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnDataChanged handler");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            DataService.OnDataChanged -= OnDataChanged;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error disposing Dashboard component");
        }
        
        await ValueTask.CompletedTask;
    }
}