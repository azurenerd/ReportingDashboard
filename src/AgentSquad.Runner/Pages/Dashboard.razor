@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IDashboardDataService DataService
@inject IDateCalculationService DateService
@inject IVisualizationService VisualizationService

<PageTitle>Dashboard</PageTitle>

@if (errorMessage != null)
{
    <div class="error-container">
        <h2>Error Loading Dashboard</h2>
        <p>@errorMessage</p>
    </div>
}
else if (config == null)
{
    <div class="loading-container">
        <p>Loading dashboard...</p>
    </div>
}
else
{
    <div class="dashboard-container">
        <Header Config="config" LastUpdated="lastUpdated" />
        <TimelineChart Milestones="config.Milestones" CurrentDate="DateTime.UtcNow" />
        <HeatmapGrid Quarters="config.Quarters" CurrentDate="DateTime.UtcNow" />
    </div>
}

@code {
    private DashboardConfig? config;
    private string? errorMessage;
    private DateTime lastUpdated;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            config = await DataService.GetDashboardConfigAsync();
            lastUpdated = DataService.GetLastModifiedTime();
            errorMessage = null;
        }
        catch (FileNotFoundException ex)
        {
            errorMessage = $"Unable to load project data. {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = $"Data validation error: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
    }
}