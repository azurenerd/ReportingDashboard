@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject ReportDataService ReportService

@if (ReportService.IsError)
{
    <div class="error-alert">
        <strong>Error loading project data:</strong>
        <span>@ReportService.ErrorMessage</span>
    </div>
}
else if (Report != null)
{
    <div class="dashboard-header">
        <div class="header-title-section">
            <h1 class="dashboard-title">@Report.ProjectName</h1>
            <div class="dashboard-subtitle">@Report.ProjectContext</div>
        </div>
        
        <div class="header-legend">
            <div class="legend-item">
                <div class="legend-symbol">
                    <div class="legend-poc"></div>
                </div>
                <span>PoC Milestone</span>
            </div>
            <div class="legend-item">
                <div class="legend-symbol">
                    <div class="legend-production"></div>
                </div>
                <span>Production Release</span>
            </div>
            <div class="legend-item">
                <div class="legend-symbol">
                    <div class="legend-checkpoint"></div>
                </div>
                <span>Checkpoint</span>
            </div>
            <div class="legend-item">
                <div class="legend-symbol">
                    <div class="legend-now"></div>
                </div>
                <span>Now (Apr 2026)</span>
            </div>
        </div>
    </div>

    <TimelineComponent Milestones="@Report.Milestones" 
                     TimePeriods="@Report.TimePeriods" 
                     CurrentMonthIndex="@Report.CurrentMonthIndex" />

    <HeatmapComponent StatusCategories="@Report.StatusCategories" 
                    TimePeriods="@Report.TimePeriods" 
                    CurrentMonthIndex="@Report.CurrentMonthIndex" />
}
else
{
    <div style="padding: 40px; text-align: center;">
        <p>Loading dashboard...</p>
    </div>
}

@code {
    private ProjectReport? Report;

    protected override void OnInitialized()
    {
        Report = ReportService.GetReport();
    }
}