@using AgentSquad.Runner.Models

<div style="background: white; border-radius: 4px; padding: 24px; border: 1px solid #ddd;">
    @if (Milestones == null || Milestones.Count == 0)
    {
        <div style="color: #999; text-align: center; padding: 24px;">
            No milestones scheduled
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 16px;">
            @foreach (var milestone in Milestones.OrderBy(m => m.Date))
            {
                <div style="display: flex; align-items: center; gap: 16px;">
                    <!-- Status Indicator Circle -->
                    <svg width="24" height="24" viewBox="0 0 24 24" style="flex-shrink: 0;">
                        <circle cx="12" cy="12" r="10" 
                            fill="@GetStatusColor(milestone.Status)" 
                            stroke="@GetStatusBorderColor(milestone.Status)" 
                            stroke-width="2" />
                    </svg>

                    <!-- Milestone Info -->
                    <div style="flex: 1;">
                        <div style="font-weight: 600; color: #1a1a1a; font-size: 14px;">
                            @milestone.Name
                        </div>
                        <div style="font-size: 13px; color: #666; margin-top: 4px;">
                            @milestone.Date.ToString("MMM dd, yyyy") 
                            <span style="color: #999;">• @milestone.Status</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<Milestone> Milestones { get; set; }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Completed" => "#4caf50",    // Green
            "On Track" => "#ffc107",     // Yellow/Amber
            "At Risk" => "#f44336",      // Red
            _ => "#999"                  // Gray fallback
        };
    }

    private string GetStatusBorderColor(string status)
    {
        return status switch
        {
            "Completed" => "#388e3c",    // Darker green
            "On Track" => "#ffa000",     // Darker amber
            "At Risk" => "#d32f2f",      // Darker red
            _ => "#666"                  // Gray fallback
        };
    }
}