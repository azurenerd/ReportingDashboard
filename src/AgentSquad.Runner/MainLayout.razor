@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@implements IAsyncDisposable
@inherits LayoutComponentBase
@inject IProjectDataService DataService

<div class="page">
    <main>
        @if (IsLoading)
        {
            <div class="container-fluid d-flex align-items-center justify-content-center" style="height: 100vh;">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading dashboard...</p>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="container-fluid p-4">
                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Error Loading Dashboard</h4>
                    <p>@ErrorMessage</p>
                    <hr>
                    <p class="mb-0">
                        <small>Please check that <code>data/data.json</code> exists and is properly formatted. 
                        Restart the application after fixing the file.</small>
                    </p>
                </div>
            </div>
        }
        else if (Dashboard != null)
        {
            <CascadingValue Value="Dashboard">
                @Body
            </CascadingValue>
        }
        else
        {
            <div class="container-fluid p-4">
                <div class="alert alert-warning" role="alert">
                    <h4 class="alert-heading">No Data Available</h4>
                    <p>Dashboard data is not available. Please restart the application.</p>
                </div>
            </div>
        }
    </main>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = null!;

    private ProjectDashboard? Dashboard { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; } = true;

    protected override void OnInitialized()
    {
        try
        {
            if (DataService.IsInitialized)
            {
                Dashboard = DataService.GetDashboard();
                ErrorMessage = null;
            }
            else if (DataService.LastError != null)
            {
                ErrorMessage = DataService.LastError;
                Dashboard = null;
            }
            else
            {
                ErrorMessage = "Dashboard data not initialized.";
                Dashboard = null;
            }
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Dashboard initialization error: {ex.Message}";
            Dashboard = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
            Dashboard = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        // Cleanup if needed
        await ValueTask.CompletedTask;
    }
}