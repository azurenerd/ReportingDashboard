@using AgentSquad.Runner.Models
@inject IDataProvider DataProvider

<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>@ProjectData?.Name</h1>
    </header>
    
    <main class="dashboard-main">
        @if (IsLoading)
        {
            <p>Loading dashboard...</p>
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">
                <p>@ErrorMessage</p>
            </div>
        }
        else if (ProjectData != null)
        {
            <section class="timeline-section">
                <h2>Milestones</h2>
                @if (ProjectData.Milestones != null && ProjectData.Milestones.Count > 0)
                {
                    <p>@ProjectData.Milestones.Count milestone(s)</p>
                }
                else
                {
                    <p>No milestones available.</p>
                }
            </section>

            <section class="metrics-section">
                <h2>Project Metrics</h2>
                <p>Completion: @ProjectData.CompletionPercentage%</p>
                <p>Status: @ProjectData.HealthStatus</p>
            </section>

            <section class="work-items-section">
                <h2>Work Items</h2>
                @if (ProjectData.WorkItems != null && ProjectData.WorkItems.Count > 0)
                {
                    <p>@ProjectData.WorkItems.Count work item(s)</p>
                }
                else
                {
                    <p>No work items available.</p>
                }
            </section>
        }
    </main>
</div>

@code {
    [Parameter]
    public Project ProjectData { get; set; }

    private bool IsLoading { get; set; } = false;
    private string ErrorMessage { get; set; }
}