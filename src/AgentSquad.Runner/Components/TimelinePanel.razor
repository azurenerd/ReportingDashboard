@using AgentSquad.Runner.Models

<div class="timeline-section mb-5">
    <h2 class="mb-4">Milestone Timeline</h2>
    <div class="timeline-container d-flex gap-2 overflow-auto pb-3">
        @if (Dashboard?.Milestones != null && Dashboard.Milestones.Count > 0)
        {
            @foreach (var milestone in Dashboard.Milestones.OrderBy(m => m.TargetDate))
            {
                <div class="timeline-item flex-shrink-0">
                    <div class="timeline-marker @GetStatusClass(milestone.Status)"></div>
                    <h6>@milestone.Name</h6>
                    <small class="text-muted d-block">@milestone.TargetDate.ToString("MMM dd")</small>
                    <span class="badge @GetBadgeClass(milestone.Status)">@milestone.Status</span>
                </div>
            }
        }
    </div>
</div>

@code {
    [CascadingParameter]
    public ProjectDashboard? Dashboard { get; set; }

    private string GetStatusClass(string status) => status switch
    {
        "Completed" => "status-completed",
        "OnTrack" => "status-ontrack",
        "AtRisk" => "status-atrisk",
        "Delayed" => "status-delayed",
        _ => "status-unknown"
    };

    private string GetBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "OnTrack" => "bg-primary",
        "AtRisk" => "bg-warning",
        "Delayed" => "bg-danger",
        _ => "bg-secondary"
    };
}