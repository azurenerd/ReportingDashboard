@using AgentSquad.Runner.Models

<div class="metrics-footer">
    <div class="container-fluid">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">--</div>
                    <h6 class="metric-label">Total Planned</h6>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">--</div>
                    <h6 class="metric-label">Completed</h6>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">--</div>
                    <h6 class="metric-label">Completion %</h6>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">--</div>
                    <h6 class="metric-label">Health Score</h6>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] 
    public ProjectDashboard? Dashboard { get; set; }
}