@using AgentSquad.Runner.Models
@implements IAsyncDisposable

@inject IJSRuntime JSRuntime
@inject ILogger<StatusChart> Logger

<MudCard Class="dashboard-section">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">Work Item Status Summary</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <div class="status-chart-section">
            <div class="status-chart-container">
                <canvas @ref="chartCanvas" id="statusChart"></canvas>
            </div>
        </div>
        
        <div class="status-chart-legend">
            <div class="status-chart-legend-item">
                <div class="status-chart-legend-color shipped"></div>
                <MudText Typo="Typo.caption">Shipped: @StatusCounts.Shipped</MudText>
            </div>
            <div class="status-chart-legend-item">
                <div class="status-chart-legend-color in-progress"></div>
                <MudText Typo="Typo.caption">In Progress: @StatusCounts.InProgress</MudText>
            </div>
            <div class="status-chart-legend-item">
                <div class="status-chart-legend-color carried-over"></div>
                <MudText Typo="Typo.caption">Carried Over: @StatusCounts.CarriedOver</MudText>
            </div>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public (int Shipped, int InProgress, int CarriedOver) StatusCounts { get; set; }

    private ElementReference chartCanvas;
    private IJSObjectReference? chartModule;
    private object? chartInstance;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (chartCanvas.Id != null)
            {
                await InitializeChartAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnParametersSetAsync");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                await InitializeChartAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnAfterRenderAsync");
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            chartModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/chart-helper.js");

            chartInstance = await chartModule.InvokeAsync<object>(
                "initializeChart",
                chartCanvas,
                new { 
                    shipped = StatusCounts.Shipped,
                    inProgress = StatusCounts.InProgress,
                    carriedOver = StatusCounts.CarriedOver
                });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing chart");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            if (chartModule is not null)
            {
                await chartModule.DisposeAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error disposing chart module");
        }
    }
}