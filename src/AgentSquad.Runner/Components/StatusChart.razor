@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@implements IAsyncDisposable

@if (StatusCounts.Shipped + StatusCounts.InProgress + StatusCounts.CarriedOver == 0)
{
    <div class="alert alert-info">No work items to display</div>
}
else
{
    <div class="chart-container">
        <h3>Work Item Status Overview</h3>
        <canvas id="statusChart"></canvas>
    </div>
}

@code {
    [Parameter]
    public (int Shipped, int InProgress, int CarriedOver) StatusCounts { get; set; }

    [Inject]
    public required IJSRuntime JSRuntime { get; set; }

    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && StatusCounts.Shipped + StatusCounts.InProgress + StatusCounts.CarriedOver > 0)
        {
            try
            {
                module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./Components/StatusChart.razor.js");

                await module.InvokeVoidAsync("initChart", 
                    StatusCounts.Shipped, 
                    StatusCounts.InProgress, 
                    StatusCounts.CarriedOver);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading chart: {ex.Message}");
            }
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}