@using AgentSquad.Runner.Models
@using Microsoft.AspNetCore.Components

<div class="status-chart">
    <canvas @ref="chartCanvas" id="statusChartCanvas"></canvas>
</div>

@code {
    [Parameter]
    public (int Shipped, int InProgress, int CarriedOver) StatusCounts { get; set; }

    [Inject]
    public IJSRuntime JSRuntime { get; set; }

    private ElementReference chartCanvas;

    protected override async Task OnParametersSetAsync()
    {
        // Chart initialization will be implemented in step 3
        await Task.CompletedTask;
    }

    private async Task InitializeChart()
    {
        // JavaScript interop for Chart.js will be implemented in step 3
        await Task.CompletedTask;
    }
}