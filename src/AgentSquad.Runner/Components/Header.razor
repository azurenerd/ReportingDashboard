@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IVisualizationService VisualizationService

<div class="hdr">
    <div class="hdr-left">
        <h1>@Config.ProjectName <a href="#">? ADO Backlog</a></h1>
        <div class="sub">@Config.Description</div>
    </div>
    <div class="hdr-right">
        <div class="legend-item">
            <div class="legend-shape">
                <div class="legend-diamond legend-diamond-poc"></div>
            </div>
            <span>PoC Milestone</span>
        </div>
        <div class="legend-item">
            <div class="legend-shape">
                <div class="legend-diamond legend-diamond-release"></div>
            </div>
            <span>Production Release</span>
        </div>
        <div class="legend-item">
            <div class="legend-shape">
                <div class="legend-circle"></div>
            </div>
            <span>Checkpoint</span>
        </div>
        <div class="legend-item">
            <div class="legend-shape">
                <div class="legend-now-line"></div>
            </div>
            <span>Now (April 2026)</span>
        </div>
        <div class="last-updated">
            Last Updated: @LastUpdated.ToString("MMM dd, yyyy 'at' h:mm tt 'UTC'")
        </div>
    </div>
</div>

@code {
    [Parameter]
    public DashboardConfig Config { get; set; } = null!;

    [Parameter]
    public DateTime LastUpdated { get; set; }
}