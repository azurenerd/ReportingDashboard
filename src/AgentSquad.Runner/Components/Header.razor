@using AgentSquad.Runner.Models

@if (ReportData != null)
{
    <div class="hdr">
        <div style="flex: 1;">
            <h1 style="margin: 0 0 4px 0; font-size: 24px; font-weight: 700; color: #111;">
                @ReportData.ReportTitle
            </h1>
            <div style="font-size: 12px; color: #888; margin-bottom: 8px;">
                @ReportData.Subtitle
            </div>
            @if (!string.IsNullOrEmpty(ReportData.AdoBacklogUrl))
            {
                <a href="@ReportData.AdoBacklogUrl" target="_blank" style="font-size: 12px; color: #0078D4; text-decoration: none;">
                    ADO Backlog →
                </a>
            }
        </div>

        <div style="display: flex; gap: 22px; flex-shrink: 0;">
            <div style="display: inline-flex; align-items: center; gap: 6px;">
                <div style="width: 12px; height: 12px; background-color: #F4B400; transform: rotate(45deg); flex-shrink: 0;"></div>
                <span style="font-size: 12px; color: #111;">PoC Milestone</span>
            </div>

            <div style="display: inline-flex; align-items: center; gap: 6px;">
                <div style="width: 12px; height: 12px; background-color: #34A853; transform: rotate(45deg); flex-shrink: 0;"></div>
                <span style="font-size: 12px; color: #111;">Production Release</span>
            </div>

            <div style="display: inline-flex; align-items: center; gap: 6px;">
                <div style="width: 8px; height: 8px; background-color: #999; border-radius: 50%; flex-shrink: 0;"></div>
                <span style="font-size: 12px; color: #111;">Checkpoint</span>
            </div>

            <div style="display: inline-flex; align-items: center; gap: 6px;">
                <div style="width: 2px; height: 14px; background-color: #EA4335; flex-shrink: 0;"></div>
                <span style="font-size: 12px; color: #111;">Now (Apr 2026)</span>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ReportData? ReportData { get; set; }
}