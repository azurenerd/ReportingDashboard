@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services

@if (Items == null || Items.Count == 0)
{
    <div class="alert alert-info">No work items in this category</div>
}
else
{
    <div class="work-items-container">
        @foreach (var item in Items)
        {
            <div class="work-item-card">
                <h4>@item.Title</h4>
                <p><strong>Status:</strong> @GetStatusLabel(item.Status)</p>
                @if (!string.IsNullOrEmpty(item.Assignee))
                {
                    <p><strong>Assignee:</strong> @item.Assignee</p>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public required IReadOnlyList<WorkItem> Items { get; set; }

    private string GetStatusLabel(WorkItemStatus status)
    {
        return status switch
        {
            WorkItemStatus.Shipped => "Shipped",
            WorkItemStatus.InProgress => "In Progress",
            WorkItemStatus.CarriedOver => "Carried Over",
            _ => "Unknown"
        };
    }
}