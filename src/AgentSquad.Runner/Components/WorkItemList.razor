@using AgentSquad.Runner.Models

<div class="work-item-sections">
    @RenderWorkItemSection("Shipped", Shipped, "shipped")
    @RenderWorkItemSection("In Progress", InProgress, "in-progress")
    @RenderWorkItemSection("Carried Over", CarriedOver, "carried-over")
</div>

@code {
    [Parameter]
    public IReadOnlyList<WorkItem> Shipped { get; set; } = new List<WorkItem>();

    [Parameter]
    public IReadOnlyList<WorkItem> InProgress { get; set; } = new List<WorkItem>();

    [Parameter]
    public IReadOnlyList<WorkItem> CarriedOver { get; set; } = new List<WorkItem>();

    private RenderFragment RenderWorkItemSection(string title, IReadOnlyList<WorkItem> items, string statusClass)
    {
        return @<MudCard Class="work-item-section">
            <MudCardHeader Class="@($"section-header {statusClass}")">
                <CardHeaderContent>
                    <div class="section-header-content">
                        <MudText Typo="Typo.h6" Class="section-header-title">@title</MudText>
                        <span class="section-header-count">@items.Count</span>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (items.Count > 0)
                {
                    <ul class="work-item-list">
                        @foreach (var item in items)
                        {
                            <li class="work-item">
                                <h6 class="work-item-title">@item.Title</h6>
                                @if (!string.IsNullOrEmpty(item.Assignee))
                                {
                                    <p class="assignee-text">@item.Assignee</p>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="work-item-list-empty">
                        <span class="work-item-list-empty-icon">✓</span>
                        <MudText Typo="Typo.body2" Color="Color.TextSecondary">
                            No items in this status
                        </MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>;
    }
}