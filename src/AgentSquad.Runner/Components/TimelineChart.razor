@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Config

@implements IAsyncDisposable

@if (TimelineSvgMarkup != null)
{
    <div class="timeline-container">
        <div class="timeline-labels">
            @foreach (var milestone in Milestones ?? new List<Milestone>())
            {
                <div class="timeline-label">@milestone.Label</div>
            }
        </div>
        <div class="timeline-svg-wrapper">
            @((MarkupString)TimelineSvgMarkup)
        </div>
    </div>
}
else
{
    <div class="timeline-loading">Loading timeline...</div>
}

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();

    [Parameter]
    public DateTime CurrentDate { get; set; } = DateTime.Now;

    [Inject]
    private IDateCalculationService DateService { get; set; } = null!;

    [Inject]
    private IVisualizationService VisualizationService { get; set; } = null!;

    [Inject]
    private ILogger<TimelineChart> Logger { get; set; } = null!;

    private string? TimelineSvgMarkup;

    protected override void OnParametersSet()
    {
        try
        {
            TimelineSvgMarkup = GenerateTimelineSvg();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating timeline SVG");
            TimelineSvgMarkup = "<div class=\"timeline-error\">Error loading timeline</div>";
        }
    }

    private string GenerateTimelineSvg()
    {
        var baselineDate = new DateTime(CurrentDate.Year, 1, 1);
        var svg = new System.Text.StringBuilder();

        // SVG opening tag with defs for drop shadow
        svg.AppendLine("<svg width=\"1560\" height=\"185\" xmlns=\"http://www.w3.org/2000/svg\" class=\"timeline-svg\">");
        svg.AppendLine("<defs>");
        svg.AppendLine("<filter id=\"drop-shadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">");
        svg.AppendLine("<feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"2\" flood-opacity=\"0.3\" />");
        svg.AppendLine("</filter>");
        svg.AppendLine("</defs>");

        // Draw month gridlines (Jan=0, Feb=260, Mar=520, Apr=780, May=1040, Jun=1300)
        for (int month = 0; month < 6; month++)
        {
            int xPosition = month * 260;
            svg.AppendLine(VisualizationService.GenerateSvgLine(
                xPosition, 0, xPosition, 185,
                VisualizationConstants.ColorBorderLight,
                VisualizationConstants.GridlineStrokeWidth
            ));
        }

        // Draw "Now" marker (red dashed line)
        try
        {
            var nowMarkerX = DateService.GetNowMarkerXPosition(CurrentDate, baselineDate);
            if (nowMarkerX >= 0 && nowMarkerX <= 1560)
            {
                svg.AppendLine(VisualizationService.GenerateSvgLine(
                    nowMarkerX, 0, nowMarkerX, 185,
                    VisualizationConstants.ColorNowMarker,
                    VisualizationConstants.NowMarkerLineStrokeWidth,
                    "5,5"
                ));
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error calculating Now marker position");
        }

        // Draw milestone shapes
        if (Milestones != null && Milestones.Count > 0)
        {
            var milestoneShapes = VisualizationService.GetMilestoneShapes(
                Milestones,
                baselineDate,
                VisualizationConstants.ColorNowMarker
            );

            foreach (var shape in milestoneShapes)
            {
                svg.AppendLine(shape);
            }
        }

        // Draw timeline baseline
        svg.AppendLine(VisualizationService.GenerateSvgLine(
            0, 90, 1560, 90,
            VisualizationConstants.ColorBorderHeavy,
            VisualizationConstants.TimelineLineStrokeWidth
        ));

        svg.AppendLine("</svg>");

        return svg.ToString();
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }
}