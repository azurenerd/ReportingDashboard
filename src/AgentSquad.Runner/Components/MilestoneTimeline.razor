@using AgentSquad.Runner.Models
@using System.Linq

<div class="milestone-timeline">
    @if (Milestones == null || Milestones.Count == 0)
    {
        <p class="no-data">No milestones scheduled</p>
    }
    else
    {
        <!-- Timeline rendering will be implemented in step 2 -->
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<Milestone> Milestones { get; set; } = new List<Milestone>().AsReadOnly();

    private IReadOnlyList<Milestone> SortedMilestones { get; set; }

    protected override void OnParametersSet()
    {
        if (Milestones != null)
        {
            SortedMilestones = Milestones
                .OrderBy(m => m.Date)
                .ToList()
                .AsReadOnly();
        }
    }
}