@using AgentSquad.Runner.Models
@using System.Linq

<div class="milestone-timeline-container">
    @if (SortedMilestones == null || SortedMilestones.Count == 0)
    {
        <p class="no-data-message">No milestones scheduled</p>
    }
    else
    {
        <div class="milestone-grid">
            @foreach (var milestone in SortedMilestones)
            {
                var statusColor = GetStatusColor(milestone.Status);
                <div class="milestone-item">
                    <div class="milestone-badge" style="background-color: @statusColor;">
                        <svg class="status-circle" viewBox="0 0 24 24" width="20" height="20">
                            <circle cx="12" cy="12" r="10" fill="@statusColor" />
                        </svg>
                    </div>
                    <div class="milestone-content">
                        <div class="milestone-name">@milestone.Name</div>
                        <div class="milestone-date">@milestone.Date.ToString("MM/dd/yyyy")</div>
                        <div class="milestone-status">@milestone.Status</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .milestone-timeline-container {
        width: 100%;
        padding: 0;
    }

    .no-data-message {
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
        font-size: 13px;
        color: #999;
        text-align: center;
        padding: 20px 0;
        margin: 0;
    }

    .milestone-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        width: 100%;
    }

    .milestone-item {
        display: flex;
        gap: 12px;
        padding: 12px;
        background: white;
        border-radius: 4px;
        border: 1px solid #e0e0e0;
        transition: box-shadow 0.2s ease;
    }

    .milestone-item:hover {
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    }

    .milestone-badge {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .status-circle {
        width: 20px;
        height: 20px;
    }

    .milestone-content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .milestone-name {
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
        word-wrap: break-word;
    }

    .milestone-date {
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
        font-size: 12px;
        color: #999;
        margin-bottom: 2px;
    }

    .milestone-status {
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
        font-size: 11px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

@code {
    [Parameter]
    public IReadOnlyList<Milestone> Milestones { get; set; } = new List<Milestone>().AsReadOnly();

    private IReadOnlyList<Milestone> SortedMilestones { get; set; }

    protected override void OnParametersSet()
    {
        if (Milestones != null)
        {
            SortedMilestones = Milestones
                .OrderBy(m => m.Date)
                .ToList()
                .AsReadOnly();
        }
        else
        {
            SortedMilestones = new List<Milestone>().AsReadOnly();
        }
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Completed" => "#4CAF50",
            "On Track" => "#FFC107",
            "At Risk" => "#f44336",
            _ => "#999999"
        };
    }
}