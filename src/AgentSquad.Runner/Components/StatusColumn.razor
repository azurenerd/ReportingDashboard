@using AgentSquad.Runner.Models

<div class="status-column">
    <h5 class="mb-3">@Title <span class="badge @BadgeClass">@(Items?.Count ?? 0)</span></h5>
    @if (Items != null && Items.Count > 0)
    {
        @foreach (var item in Items.OrderByDescending(i => i.CompletedDate).Take(20))
        {
            <div class="card mb-2">
                <div class="card-body p-3">
                    <h6 class="card-title mb-1">@item.Title</h6>
                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p class="card-text small text-muted mb-2">@item.Description</p>
                    }
                    @if (item.CompletedDate.HasValue)
                    {
                        <small class="text-muted">@item.CompletedDate.Value.ToString("MMM dd, yyyy")</small>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted small">No items</p>
    }
</div>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public List<WorkItem>? Items { get; set; }

    [Parameter]
    public string BadgeClass { get; set; } = "bg-secondary";
}