@page "/"
@inject IProjectDataService DataService

<div class="container-fluid dashboard-container">
    <header class="dashboard-header">
        <div class="row">
            <div class="col-12">
                <h1 class="dashboard-title">Dashboard</h1>
            </div>
        </div>
    </header>

    <main class="dashboard-main" role="main">
        <section class="dashboard-timeline-section">
            <!-- Timeline Panel placeholder -->
        </section>

        <section class="dashboard-content-section">
            <!-- Status Grid placeholder -->
        </section>
    </main>

    <footer class="dashboard-footer">
        <div class="row">
            <div class="col-12">
                <!-- Metrics Footer placeholder -->
            </div>
        </div>
    </footer>
</div>

<style>
    .dashboard-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        padding: 0;
    }

    .dashboard-header {
        padding: 2rem;
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        flex-shrink: 0;
    }

    .dashboard-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 600;
        color: #212529;
    }

    .dashboard-main {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
    }

    .dashboard-timeline-section {
        margin-bottom: 2rem;
    }

    .dashboard-content-section {
        margin-bottom: 2rem;
    }

    .dashboard-footer {
        padding: 2rem;
        background-color: #f8f9fa;
        border-top: 1px solid #dee2e6;
        flex-shrink: 0;
    }
</style>

@code {
    private ProjectDashboard? Dashboard;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Dashboard = DataService.GetDashboard();
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            Dashboard = null;
            ErrorMessage = DataService.LastError ?? ex.Message;
        }

        await base.OnInitializedAsync();
    }
}