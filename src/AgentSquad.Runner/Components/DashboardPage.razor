@page "/"
@inject IProjectDataService DataService

<div class="container-fluid dashboard-container">
    @if (ErrorMessage != null)
    {
        <div class="alert alert-danger m-3" role="alert">
            <h4 class="alert-heading">Error Loading Dashboard</h4>
            <p class="mb-0">@ErrorMessage</p>
        </div>
    }
    else if (Dashboard != null)
    {
        <header class="dashboard-header">
            <div class="row">
                <div class="col-12">
                    <h1 class="dashboard-title">@Dashboard.ProjectName</h1>
                </div>
            </div>
        </header>

        <main class="dashboard-main" role="main">
            <section class="dashboard-timeline-section">
                <!-- Timeline Panel placeholder -->
                <div class="placeholder-section">
                    <p class="text-muted">Timeline Panel will render here</p>
                </div>
            </section>

            <section class="dashboard-content-section">
                <!-- Status Grid placeholder -->
                <div class="placeholder-section">
                    <p class="text-muted">Status Grid will render here</p>
                </div>
            </section>
        </main>

        <footer class="dashboard-footer">
            <div class="row">
                <div class="col-12">
                    <!-- Metrics Footer placeholder -->
                    <div class="placeholder-section">
                        <p class="text-muted">Metrics Footer will render here</p>
                    </div>
                </div>
            </div>
        </footer>
    }
    else
    {
        <div class="dashboard-loading">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading dashboard...</p>
        </div>
    }
</div>

<style>
    .dashboard-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        padding: 0;
    }

    .dashboard-header {
        padding: 2rem;
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        flex-shrink: 0;
    }

    .dashboard-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 600;
        color: #212529;
    }

    .dashboard-main {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
    }

    .dashboard-timeline-section {
        margin-bottom: 2rem;
    }

    .dashboard-content-section {
        margin-bottom: 2rem;
    }

    .dashboard-footer {
        padding: 2rem;
        background-color: #f8f9fa;
        border-top: 1px solid #dee2e6;
        flex-shrink: 0;
    }

    .placeholder-section {
        padding: 1.5rem;
        background-color: #f0f0f0;
        border: 1px dashed #ccc;
        border-radius: 0.25rem;
        min-height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .dashboard-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
    }

    .dashboard-loading .spinner-border {
        width: 3rem;
        height: 3rem;
    }
</style>

@code {
    private ProjectDashboard? Dashboard;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Dashboard = DataService.GetDashboard();
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            Dashboard = null;
            ErrorMessage = DataService.LastError ?? ex.Message;
        }

        await base.OnInitializedAsync();
    }
}