@using AgentSquad.Runner.Models

<div class="row g-3">
    <div class="col-md-4">
        <StatusColumn 
            Title="Shipped" 
            Items="Dashboard?.Shipped" 
            BadgeClass="success" />
    </div>
    <div class="col-md-4">
        <StatusColumn 
            Title="In Progress" 
            Items="Dashboard?.InProgress" 
            BadgeClass="primary" />
    </div>
    <div class="col-md-4">
        <StatusColumn 
            Title="Carried Over" 
            Items="Dashboard?.CarriedOver" 
            BadgeClass="warning" />
    </div>
</div>

@code {
    [CascadingParameter]
    public ProjectDashboard? Dashboard { get; set; }
}