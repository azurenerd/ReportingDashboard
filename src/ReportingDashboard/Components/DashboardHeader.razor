<header class="hdr">
    <div class="hdr-left">
        <h1>
            @Data.Title
            <a href="@Data.BacklogUrl" target="_blank" rel="noopener noreferrer">📋 ADO Backlog</a>
        </h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div class="legend">
        <span class="leg-item">
            <span class="diamond poc"></span>
            PoC Milestone
        </span>
        <span class="leg-item">
            <span class="diamond prod"></span>
            Production Release
        </span>
        <span class="leg-item">
            <span class="dot chk"></span>
            Checkpoint
        </span>
        <span class="leg-item">
            <span class="bar now"></span>
            Now
        </span>
    </div>
</header>

@code {
    [Parameter]
    public DashboardData Data { get; set; } = default!;
}