<div class="hdr">
    <div class="hdr-left">
        <h1>@Data.Title <a href="@Data.BacklogUrl" target="_blank">📋 ADO Backlog</a></h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div class="legend">
        <div class="legend-item">
            <span class="marker-diamond poc"></span>
            <span>PoC Milestone</span>
        </div>
        <div class="legend-item">
            <span class="marker-diamond prod"></span>
            <span>Production Release</span>
        </div>
        <div class="legend-item">
            <span class="marker-circle"></span>
            <span>Checkpoint</span>
        </div>
        <div class="legend-item">
            <span class="marker-now"></span>
            <span>Now</span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public DashboardData Data { get; set; } = default!;
}