@using System.Globalization

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in Timeline.Tracks)
        {
            <div class="tl-label">
                <span style="color:@track.Color;font-weight:600;">@track.Id</span>
                <span style="color:#444;font-weight:400;"> – @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" overflow="visible">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines *@
            @foreach (var mg in _monthGridlines)
            {
                <line x1="@F(mg.X)" y1="0" x2="@F(mg.X)" y2="185"
                      stroke="#bbb" stroke-opacity="0.4" />
                <text x="@F(mg.X + 4)" y="12" fill="#666" font-size="11" font-weight="600">@mg.Label</text>
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < Timeline.Tracks.Count; i++)
            {
                var track = Timeline.Tracks[i];
                var ty = TrackY(i);

                <line x1="0" y1="@F(ty)" x2="1560" y2="@F(ty)"
                      stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    var mx = DateToX(ms.Date);
                    var tooltipText = $"{FormatDate(ms.Date)} – {ms.Label} ({ms.Type})";

                    @if (ms.Type == "poc")
                    {
                        <g class="ms-marker">
                            <polygon points="@DiamondPoints(mx, ty)" fill="#F4B400" filter="url(#sh)" />
                            <title>@tooltipText</title>
                        </g>
                        <text x="@F(mx)" y="@F(ty - 16)" fill="#666" font-size="10"
                              text-anchor="middle">@ms.Label</text>
                    }
                    else if (ms.Type == "production")
                    {
                        <g class="ms-marker">
                            <polygon points="@DiamondPoints(mx, ty)" fill="#34A853" filter="url(#sh)" />
                            <title>@tooltipText</title>
                        </g>
                        <text x="@F(mx)" y="@F(ty + 22)" fill="#666" font-size="10"
                              text-anchor="middle">@ms.Label</text>
                    }
                    else
                    {
                        <g class="ms-marker">
                            <circle cx="@F(mx)" cy="@F(ty)" r="6" fill="white"
                                    stroke="@track.Color" stroke-width="2.5" />
                            <title>@tooltipText</title>
                        </g>
                        <text x="@F(mx)" y="@F(ty - 14)" fill="#666" font-size="10"
                              text-anchor="middle">@ms.Label</text>
                    }
                }
            }

            @* NOW line *@
            @if (_nowX >= 0 && _nowX <= 1560)
            {
                <line x1="@F(_nowX)" y1="0" x2="@F(_nowX)" y2="185"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(_nowX)" y="12" fill="#EA4335" font-size="10"
                      font-weight="700" text-anchor="middle">NOW</text>
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData Timeline { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = "";

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private DateTime _start;
    private DateTime _end;
    private double _totalDays;
    private double _nowX;
    private List<MonthGridline> _monthGridlines = new();

    private record MonthGridline(double X, string Label);

    protected override void OnParametersSet()
    {
        if (DateTime.TryParse(Timeline.StartDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out _start) &&
            DateTime.TryParse(Timeline.EndDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out _end))
        {
            _totalDays = (_end - _start).TotalDays;
        }
        else
        {
            _totalDays = 1;
        }

        _nowX = DateToX(CurrentDate);
        ComputeMonthGridlines();
    }

    private void ComputeMonthGridlines()
    {
        _monthGridlines.Clear();
        if (_totalDays <= 0) return;

        var current = new DateTime(_start.Year, _start.Month, 1);
        if (current < _start) current = current.AddMonths(1);

        while (current <= _end)
        {
            var x = DateToX(current);
            _monthGridlines.Add(new MonthGridline(x, current.ToString("MMM", CultureInfo.InvariantCulture)));
            current = current.AddMonths(1);
        }
    }

    public double DateToX(string dateStr)
    {
        if (DateTime.TryParse(dateStr, CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
        {
            return DateToX(date);
        }
        return 0;
    }

    public double DateToX(DateTime date)
    {
        if (_totalDays <= 0) return 0;
        return (date - _start).TotalDays / _totalDays * SvgWidth;
    }

    private double TrackY(int index)
    {
        return SvgHeight / (Timeline.Tracks.Count + 1) * (index + 1);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{F(cx)},{F(cy - radius)} {F(cx + radius)},{F(cy)} {F(cx)},{F(cy + radius)} {F(cx - radius)},{F(cy)}";
    }

    private static string F(double v) => Math.Round(v, 1).ToString(CultureInfo.InvariantCulture);

    private string FormatDate(string dateStr)
    {
        if (DateTime.TryParse(dateStr, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d))
        {
            return d.ToString("MMM d", CultureInfo.InvariantCulture);
        }
        return dateStr;
    }
}