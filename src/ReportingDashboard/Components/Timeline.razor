@* Timeline - SVG timeline component rendering milestone tracks with markers *@
@using ReportingDashboard.Models
@using System.Globalization

<div class="tl-area">
    <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px 16px 0; border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px; font-weight:600; color:@track.Color;">@track.Name</span>
                <span style="font-size:12px; font-weight:400; color:#444;"> @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@SvgWidth" height="@SvgHeight" style="overflow:visible;" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @foreach (var monthInfo in GetMonthGridLines())
            {
                <line x1="@F(monthInfo.X)" y1="0" x2="@F(monthInfo.X)" y2="@F(SvgHeight)"
                      stroke="#bbb" stroke-opacity="0.4" />
                @((MarkupString)$"<text x=\"{F(monthInfo.X + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\" font-family=\"'Segoe UI', Arial, sans-serif\">{monthInfo.Label}</text>")
            }

            @* Track horizontal lines *@
            @for (int i = 0; i < TimelineData.Tracks.Count; i++)
            {
                var track = TimelineData.Tracks[i];
                var y = TrackToY(i, TimelineData.Tracks.Count);
                <line x1="0" y1="@F(y)" x2="@F(SvgWidth)" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />

                @* Milestone markers for this track *@
                @foreach (var milestone in track.Milestones)
                {
                    var mx = DateToX(DateTime.Parse(milestone.Date, CultureInfo.InvariantCulture));
                    var my = y;

                    @if (milestone.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(mx, my)" fill="#F4B400" filter="url(#sh)">
                            @((MarkupString)$"<title>{System.Net.WebUtility.HtmlEncode(milestone.Label)}</title>")
                        </polygon>
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(my + 22)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"'Segoe UI', Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(milestone.Label)}</text>")
                    }
                    else if (milestone.Type == "production")
                    {
                        <polygon points="@DiamondPoints(mx, my)" fill="#34A853" filter="url(#sh)">
                            @((MarkupString)$"<title>{System.Net.WebUtility.HtmlEncode(milestone.Label)}</title>")
                        </polygon>
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(my + 22)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"'Segoe UI', Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(milestone.Label)}</text>")
                    }
                    else if (milestone.Type == "checkpoint")
                    {
                        <circle cx="@F(mx)" cy="@F(my)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5">
                            @((MarkupString)$"<title>{System.Net.WebUtility.HtmlEncode(milestone.Label)}</title>")
                        </circle>
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(my - 14)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"'Segoe UI', Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(milestone.Label)}</text>")
                    }
                }
            }

            @* NOW line *@
            @if (NowX.HasValue)
            {
                <line x1="@F(NowX.Value)" y1="0" x2="@F(NowX.Value)" y2="@F(SvgHeight)"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @((MarkupString)$"<text x=\"{F(NowX.Value)}\" y=\"{F(SvgHeight + 14)}\" text-anchor=\"middle\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" font-family=\"'Segoe UI', Arial, sans-serif\">NOW</text>")
            }
        </svg>
    </div>
</div>

@code {
    [Parameter]
    public TimelineData TimelineData { get; set; } = new();

    private double SvgWidth => 1560;
    private double SvgHeight => Math.Max(185, TimelineData.Tracks.Count * 56);

    private DateTime StartDate => DateTime.Parse(TimelineData.StartDate, CultureInfo.InvariantCulture);
    private DateTime EndDate => DateTime.Parse(TimelineData.EndDate, CultureInfo.InvariantCulture);

    private double? NowX
    {
        get
        {
            if (string.IsNullOrEmpty(TimelineData.NowDate)) return null;
            return DateToX(DateTime.Parse(TimelineData.NowDate, CultureInfo.InvariantCulture));
        }
    }

    private double DateToX(DateTime date)
    {
        double totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        double elapsed = (date - StartDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private double TrackToY(int trackIndex, int totalTracks)
    {
        double spacing = SvgHeight / (totalTracks + 1);
        return spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double value) => value.ToString("F1", CultureInfo.InvariantCulture);

    private List<MonthGridLine> GetMonthGridLines()
    {
        var lines = new List<MonthGridLine>();
        var current = new DateTime(StartDate.Year, StartDate.Month, 1);
        while (current <= EndDate)
        {
            var x = DateToX(current);
            lines.Add(new MonthGridLine { X = x, Label = current.ToString("MMM", CultureInfo.InvariantCulture) });
            current = current.AddMonths(1);
        }
        return lines;
    }

    private class MonthGridLine
    {
        public double X { get; set; }
        public string Label { get; set; } = string.Empty;
    }
}