@using System.Globalization
@using Microsoft.AspNetCore.Components.Rendering

<div class="tl-area">
    <div class="tl-labels">
        @for (var i = 0; i < TimelineData.Tracks.Count; i++)
        {
            var track = TimelineData.Tracks[i];
            <div class="tl-track tl-label" data-track-name="@track.Name"
                 style="color: @track.Color; top: @N(TrackToY(i, TimelineData.Tracks.Count))px;">
                <span class="tl-track-id">@track.Name</span>
                <span class="tl-track-name">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@N(SvgWidth)" height="@N(SvgHeight)" style="overflow: visible;">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3"/>
                </filter>
            </defs>

            @* Month grid lines *@
            @foreach (var mp in MonthPositions)
            {
                <line x1="@N(mp.X)" y1="0" x2="@N(mp.X)" y2="@N(SvgHeight)"
                      stroke="#bbb" stroke-opacity="0.4" />
                @RenderSvgText(N(mp.X + 5), "14", mp.Label, "#666", "11", "600", "start")
            }

            @* Track lines and milestones *@
            @for (var i = 0; i < TimelineData.Tracks.Count; i++)
            {
                var track = TimelineData.Tracks[i];
                var y = TrackToY(i, TimelineData.Tracks.Count);

                <line x1="0" y1="@N(y)" x2="@N(SvgWidth)" y2="@N(y)"
                      stroke="@track.Color" stroke-width="3"
                      class="tl-track-line" data-track="@track.Name" />

                @foreach (var ms in track.Milestones)
                {
                    var x = DateToX(ms.Date);
                    if (double.IsNaN(x)) continue;

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@N(x)" cy="@N(y)" r="6"
                                fill="white" stroke="@track.Color" stroke-width="2.5">
                            <title>@ms.Label (@ms.Date)</title>
                        </circle>
                    }
                    else if (ms.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(x, y, 8)"
                                 fill="#F4B400" filter="url(#sh)">
                            <title>@ms.Label (@ms.Date)</title>
                        </polygon>
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@DiamondPoints(x, y, 11)"
                                 fill="#34A853" filter="url(#sh)">
                            <title>@ms.Label (@ms.Date)</title>
                        </polygon>
                    }

                    @RenderSvgText(N(x), N(y - 14), ms.Label, "#666", "10", "400", "middle")
                }
            }

            @* NOW line *@
            @if (!string.IsNullOrWhiteSpace(TimelineData.NowDate))
            {
                var nowX = DateToX(TimelineData.NowDate);
                if (!double.IsNaN(nowX))
                {
                    <line x1="@N(nowX)" y1="0" x2="@N(nowX)" y2="@N(SvgHeight)"
                          stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                    @RenderSvgText(N(nowX), "-4", "NOW", "#EA4335", "10", "700", "middle")
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineData { get; set; } = default!;

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;

    private DateTime _startDate;
    private DateTime _endDate;
    private bool _datesValid;

    private record MonthPos(double X, string Label);
    private List<MonthPos> MonthPositions { get; set; } = new();

    protected override void OnParametersSet()
    {
        _datesValid = DateTime.TryParse(TimelineData.StartDate, CultureInfo.InvariantCulture,
                          DateTimeStyles.None, out _startDate)
                      && DateTime.TryParse(TimelineData.EndDate, CultureInfo.InvariantCulture,
                          DateTimeStyles.None, out _endDate)
                      && _endDate > _startDate;

        MonthPositions = CalculateMonthPositions();
    }

    private List<MonthPos> CalculateMonthPositions()
    {
        var positions = new List<MonthPos>();
        if (!_datesValid) return positions;

        var current = new DateTime(_startDate.Year, _startDate.Month, 1);
        while (current <= _endDate)
        {
            var x = DateToX(current);
            positions.Add(new MonthPos(x, current.ToString("MMM")));
            current = current.AddMonths(1);
        }
        return positions;
    }

    private double DateToX(string dateStr)
    {
        if (!_datesValid) return double.NaN;
        if (!DateTime.TryParse(dateStr, CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
            return double.NaN;
        return DateToX(date);
    }

    private double DateToX(DateTime date)
    {
        var totalDays = (_endDate - _startDate).TotalDays;
        if (totalDays <= 0) return 0;
        var elapsed = (date - _startDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private static double TrackToY(int trackIndex, int totalTracks)
    {
        var spacing = SvgHeight / (totalTracks + 1);
        return spacing * (trackIndex + 1);
    }

    private static string DiamondPoints(double cx, double cy, double size)
    {
        return string.Format(CultureInfo.InvariantCulture,
            "{0:F1},{1:F1} {2:F1},{3:F1} {4:F1},{5:F1} {6:F1},{7:F1}",
            cx, cy - size, cx + size, cy, cx, cy + size, cx - size, cy);
    }

    private static string N(double v) =>
        v.ToString("F1", CultureInfo.InvariantCulture);

    // RenderTreeBuilder approach to emit SVG <text> elements
    // without conflicting with Razor's <text> directive (RZ1023)
    private RenderFragment RenderSvgText(string x, string y, string content,
        string fill, string fontSize, string fontWeight, string textAnchor) => (RenderTreeBuilder builder) =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", x);
        builder.AddAttribute(2, "y", y);
        builder.AddAttribute(3, "fill", fill);
        builder.AddAttribute(4, "font-size", fontSize);
        builder.AddAttribute(5, "font-weight", fontWeight);
        builder.AddAttribute(6, "text-anchor", textAnchor);
        builder.AddContent(7, content);
        builder.CloseElement();
    };
}