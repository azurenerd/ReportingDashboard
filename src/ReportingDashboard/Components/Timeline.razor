@using System.Globalization

<div style="display:flex; align-items:stretch; height:196px; padding:6px 44px 0; background:#FAFAFA; border-bottom:2px solid #E8E8E8;">
    <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px 16px 0; border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px; font-weight:600; color:@track.Color;">@track.Name</span>
                <span style="font-size:12px; font-weight:400; color:#444; margin-left:6px;">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box" style="flex:1; padding-left:12px; padding-top:6px;">
        <svg width="@SvgWidth" height="@SvgHeight" style="overflow:visible;">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @for (int i = 0; i < MonthCount; i++)
            {
                var x = i * MonthWidth;
                <line x1="@F(x)" y1="0" x2="@F(x)" y2="@SvgHeight" stroke="#bbb" stroke-opacity="0.4" />
                <text x="@F(x + 5)" y="14" fill="#666" font-size="11" font-weight="600">@MonthLabels[i]</text>
            }

            @* Track lines *@
            @for (int i = 0; i < TimelineData.Tracks.Count; i++)
            {
                var y = TrackToY(i, TimelineData.Tracks.Count);
                <line x1="0" y1="@F(y)" x2="@SvgWidth" y2="@F(y)"
                      stroke="@TimelineData.Tracks[i].Color" stroke-width="3" />
            }

            @* Milestones *@
            @for (int ti = 0; ti < TimelineData.Tracks.Count; ti++)
            {
                var track = TimelineData.Tracks[ti];
                var y = TrackToY(ti, TimelineData.Tracks.Count);
                @foreach (var ms in track.Milestones)
                {
                    if (DateTime.TryParse(ms.Date, CultureInfo.InvariantCulture, DateTimeStyles.None, out var msDate))
                    {
                        var x = DateToX(msDate);
                        @if (ms.Type == "poc")
                        {
                            <polygon points="@DiamondPoints(x, y)" fill="#F4B400" filter="url(#sh)">
                                <title>@ms.Label</title>
                            </polygon>
                        }
                        else if (ms.Type == "production")
                        {
                            <polygon points="@DiamondPoints(x, y)" fill="#34A853" filter="url(#sh)">
                                <title>@ms.Label</title>
                            </polygon>
                        }
                        else
                        {
                            <circle cx="@F(x)" cy="@F(y)" r="7" fill="white"
                                    stroke="@track.Color" stroke-width="2.5">
                                <title>@ms.Label</title>
                            </circle>
                        }
                        <text x="@F(x)" y="@F(y - 16)" text-anchor="middle" fill="#666" font-size="10">@ms.Label</text>
                    }
                }
            }

            @* NOW line *@
            @if (DateTime.TryParse(TimelineData.NowDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var nowDate))
            {
                var nowX = DateToX(nowDate);
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@SvgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(nowX)" y="-4" text-anchor="middle" fill="#EA4335" font-size="10" font-weight="700">NOW</text>
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineData { get; set; } = default!;

    private const double SvgWidth = 1560;
    private double SvgHeight => Math.Max(185, TimelineData.Tracks.Count * 56);
    private DateTime StartDate => DateTime.TryParse(TimelineData.StartDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d) ? d : DateTime.Today;
    private DateTime EndDate => DateTime.TryParse(TimelineData.EndDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d) ? d : DateTime.Today.AddMonths(6);

    private int MonthCount
    {
        get
        {
            var months = (int)Math.Ceiling((EndDate - StartDate).TotalDays / 30.0);
            return Math.Max(1, months);
        }
    }

    private double MonthWidth => SvgWidth / MonthCount;

    private string[] MonthLabels
    {
        get
        {
            var labels = new string[MonthCount];
            var d = StartDate;
            for (int i = 0; i < MonthCount; i++)
            {
                labels[i] = d.ToString("MMM", CultureInfo.InvariantCulture);
                d = d.AddMonths(1);
            }
            return labels;
        }
    }

    private double DateToX(DateTime date)
    {
        double totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        double elapsed = (date - StartDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private double TrackToY(int trackIndex, int totalTracks)
    {
        double spacing = 185.0 / (totalTracks + 1);
        return spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double v) => v.ToString("F1", CultureInfo.InvariantCulture);
}