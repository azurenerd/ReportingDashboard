@using System.Globalization

<div class="tl-area">
    <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px 16px 0; border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px; font-weight:600; color:@track.Color;">@track.Name</span>
                <span style="font-size:12px; font-weight:400; color:#444; margin-left:6px;">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@SvgWidth" height="@SvgHeight" style="overflow:visible;">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3"/>
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @foreach (var monthInfo in GetMonthGridLines())
            {
                <line x1="@F(monthInfo.X)" y1="0" x2="@F(monthInfo.X)" y2="@SvgHeight"
                      stroke="#bbb" stroke-opacity="0.4" />
                <text x="@F(monthInfo.X + 5)" y="14" fill="#666" font-size="11" font-weight="600">@monthInfo.Label</text>
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < TimelineData.Tracks.Count; i++)
            {
                var track = TimelineData.Tracks[i];
                var y = TrackToY(i, TimelineData.Tracks.Count);

                <line x1="0" y1="@F(y)" x2="@SvgWidth" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />

                @foreach (var milestone in track.Milestones)
                {
                    var mx = DateToX(milestone.Date);
                    if (mx < 0) continue;

                    @if (milestone.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(mx, y)" fill="#F4B400" filter="url(#sh)">
                            <title>@milestone.Label</title>
                        </polygon>
                    }
                    else if (milestone.Type == "production")
                    {
                        <polygon points="@DiamondPoints(mx, y)" fill="#34A853" filter="url(#sh)">
                            <title>@milestone.Label</title>
                        </polygon>
                    }
                    else
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5">
                            <title>@milestone.Label</title>
                        </circle>
                    }

                    <text x="@F(mx)" y="@F(y - 14)" text-anchor="middle" fill="#666" font-size="10">@milestone.Label</text>
                }
            }

            @* NOW line *@
            @if (NowX >= 0 && NowX <= SvgWidth)
            {
                <line x1="@F(NowX)" y1="0" x2="@F(NowX)" y2="@SvgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(NowX)" y="@F(SvgHeight - 4)" text-anchor="middle"
                      fill="#EA4335" font-size="10" font-weight="700">NOW</text>
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineData { get; set; } = default!;

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;

    private DateTime StartDate => DateTime.TryParse(TimelineData.StartDate, out var d) ? d : DateTime.Now;
    private DateTime EndDate => DateTime.TryParse(TimelineData.EndDate, out var d) ? d : DateTime.Now.AddMonths(6);
    private DateTime NowDate => DateTime.TryParse(TimelineData.NowDate, out var d) ? d : DateTime.Now;
    private double NowX => DateToX(NowDate);

    private double DateToX(string dateStr)
    {
        if (!DateTime.TryParse(dateStr, out var date)) return -1;
        return DateToX(date);
    }

    private double DateToX(DateTime date)
    {
        double totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        double elapsed = (date - StartDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private double TrackToY(int trackIndex, int totalTracks)
    {
        double spacing = SvgHeight / (totalTracks + 1);
        return spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size = 9)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double v) => v.ToString("F1", CultureInfo.InvariantCulture);

    private List<(double X, string Label)> GetMonthGridLines()
    {
        var lines = new List<(double, string)>();
        var current = new DateTime(StartDate.Year, StartDate.Month, 1);
        while (current <= EndDate)
        {
            var x = DateToX(current);
            if (x >= 0 && x <= SvgWidth)
            {
                lines.Add((x, current.ToString("MMM", CultureInfo.InvariantCulture)));
            }
            current = current.AddMonths(1);
        }
        return lines;
    }
}