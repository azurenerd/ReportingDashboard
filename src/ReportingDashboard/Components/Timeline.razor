@using ReportingDashboard.Models
@using System.Globalization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Rendering

@if (TimelineData?.Tracks != null && TimelineData.Tracks.Count > 0)
{
    <div class="tl-area">
        <!-- Track Labels Sidebar -->
        <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px 16px 0; border-right:1px solid #E0E0E0;">
            @foreach (var track in TimelineData.Tracks)
            {
                <div style="font-size:12px;">
                    <span style="font-weight:600; color:@track.Color;">@track.Name</span>
                    <span style="font-weight:400; color:#444;"> @track.Label</span>
                </div>
            }
        </div>

        <!-- SVG Timeline Container -->
        <div class="tl-svg-box">
            <svg width="@SvgWidth" height="@SvgHeight" style="overflow:visible" xmlns="http://www.w3.org/2000/svg">

                <!-- Drop shadow filter for diamond markers -->
                <defs>
                    <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                    </filter>
                </defs>

                <!-- Month grid lines at 260px intervals -->
                @for (int i = 0; i < MonthCount; i++)
                {
                    var xVal = i * GridInterval;
                    <line x1="@Fmt(xVal)" y1="0" x2="@Fmt(xVal)" y2="@Fmt(SvgHeight)"
                          stroke="#bbb" stroke-opacity="0.4" />
                }

                <!-- Month labels -->
                @for (int i = 0; i < MonthCount; i++)
                {
                    var xVal = i * GridInterval + 5;
                    var monthLabel = GetMonthLabel(i);
                    @RenderSvgText(Fmt(xVal), "14", "#666", "11", "600", null, monthLabel)
                }

                <!-- Horizontal track lines -->
                @for (int i = 0; i < TimelineData.Tracks.Count; i++)
                {
                    var track = TimelineData.Tracks[i];
                    var yVal = TrackToY(i);
                    <line x1="0" y1="@Fmt(yVal)" x2="@Fmt(SvgWidth)" y2="@Fmt(yVal)"
                          stroke="@track.Color" stroke-width="3" />
                }

                <!-- Milestone markers and labels -->
                @for (int trackIdx = 0; trackIdx < TimelineData.Tracks.Count; trackIdx++)
                {
                    var track = TimelineData.Tracks[trackIdx];
                    var trackY = TrackToY(trackIdx);

                    @if (track.Milestones != null)
                    {
                        @foreach (var milestone in track.Milestones)
                        {
                            var mx = DateToX(milestone.Date);
                            var labelY = trackY - 16;

                            @if (milestone.Type == "poc")
                            {
                                <polygon points="@DiamondPoints(mx, trackY)"
                                         fill="#F4B400" filter="url(#sh)">
                                    <title>@milestone.Label</title>
                                </polygon>
                            }
                            else if (milestone.Type == "production")
                            {
                                <polygon points="@DiamondPoints(mx, trackY)"
                                         fill="#34A853" filter="url(#sh)">
                                    <title>@milestone.Label</title>
                                </polygon>
                            }
                            else
                            {
                                <circle cx="@Fmt(mx)" cy="@Fmt(trackY)" r="6"
                                        fill="white" stroke="@track.Color" stroke-width="2.5">
                                    <title>@milestone.Label</title>
                                </circle>
                            }

                            @RenderSvgText(Fmt(mx), Fmt(labelY), "#666", "10", null, "middle", milestone.Label)
                        }
                    }
                }

                <!-- NOW dashed line -->
                @{
                    var nowX = DateToX(TimelineData.NowDate);
                }
                <line x1="@Fmt(nowX)" y1="0" x2="@Fmt(nowX)" y2="@Fmt(SvgHeight)"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @RenderSvgText(Fmt(nowX), "10", "#EA4335", "10", "700", "middle", "NOW")

            </svg>
        </div>
    </div>
}

@code {
    [Parameter]
    public TimelineData? TimelineData { get; set; }

    private const int SvgWidth = 1560;
    private const int GridInterval = 260;
    private const int MonthCount = 6;

    private int SvgHeight => TimelineData?.Tracks != null
        ? Math.Max(185, TimelineData.Tracks.Count * 56)
        : 185;

    private DateTime StartDate => ParseDate(TimelineData?.StartDate);
    private DateTime EndDate => ParseDate(TimelineData?.EndDate);

    private double DateToX(string? isoDate)
    {
        var date = ParseDate(isoDate);
        double totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        double elapsed = (date - StartDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private double TrackToY(int trackIndex)
    {
        int trackCount = TimelineData?.Tracks?.Count ?? 1;
        double spacing = (double)SvgHeight / (trackCount + 1);
        return spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return FormattableString.Invariant(
            $"{cx},{cy - size} {cx + size},{cy} {cx},{cy + size} {cx - size},{cy}");
    }

    private string GetMonthLabel(int gridIndex)
    {
        var monthDate = StartDate.AddMonths(gridIndex);
        return monthDate.ToString("MMM", CultureInfo.InvariantCulture);
    }

    private static string Fmt(double value) =>
        value.ToString("0.##", CultureInfo.InvariantCulture);

    private static string Fmt(int value) =>
        value.ToString(CultureInfo.InvariantCulture);

    private static DateTime ParseDate(string? isoDate)
    {
        if (string.IsNullOrEmpty(isoDate)) return DateTime.Today;
        return DateTime.TryParse(isoDate, CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt)
            ? dt
            : DateTime.Today;
    }

    private RenderFragment RenderSvgText(string x, string y, string fill, string fontSize, string? fontWeight, string? textAnchor, string content) => builder =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", x);
        builder.AddAttribute(2, "y", y);
        builder.AddAttribute(3, "fill", fill);
        builder.AddAttribute(4, "font-size", fontSize);
        if (fontWeight != null)
            builder.AddAttribute(5, "font-weight", fontWeight);
        if (textAnchor != null)
            builder.AddAttribute(6, "text-anchor", textAnchor);
        builder.AddAttribute(7, "font-family", "'Segoe UI', Arial, sans-serif");
        builder.AddContent(8, content);
        builder.CloseElement();
    };
}