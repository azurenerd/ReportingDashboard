@using System.Globalization
@using ReportingDashboard.Models
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components

<div class="tl-area">
    @* Left sidebar with milestone track labels *@
    <div class="tl-sidebar">
        @if (Milestones is not null)
        {
            @foreach (var milestone in Milestones)
            {
                <div class="tl-label">
                    <span class="tl-id" style="color: @milestone.Color">@milestone.Label</span>
                    <span class="tl-desc"> - @milestone.Description</span>
                </div>
            }
        }
    </div>

    @* Right SVG timeline area *@
    <div class="tl-svg-box">
        @((MarkupString)BuildSvgMarkup())
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();

    [Parameter]
    public DateTime TimelineStart { get; set; }

    [Parameter]
    public DateTime TimelineEnd { get; set; }

    [Parameter]
    public DateTime CurrentDate { get; set; }

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;
    private const double TopMargin = 28;
    private const double TrackStartY = TopMargin + 14.0;
    private const double TrackEndY = SvgHeight - 31.0;

    private double GetXPosition(DateTime date)
    {
        var totalDays = (TimelineEnd - TimelineStart).TotalDays;
        if (totalDays <= 0) return 0;
        var elapsed = (date - TimelineStart).TotalDays;
        return Math.Clamp((elapsed / totalDays) * SvgWidth, 0, SvgWidth);
    }

    private static double GetTrackY(int trackIndex, int trackCount)
    {
        if (trackCount <= 1) return (TrackStartY + TrackEndY) / 2.0;
        return TrackStartY + (trackIndex * (TrackEndY - TrackStartY) / (trackCount - 1));
    }

    private static string DiamondPoints(double cx, double cy, double r = 11)
    {
        return $"{Fmt(cx)},{Fmt(cy - r)} {Fmt(cx + r)},{Fmt(cy)} {Fmt(cx)},{Fmt(cy + r)} {Fmt(cx - r)},{Fmt(cy)}";
    }

    private static string Fmt(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    private string BuildSvgMarkup()
    {
        var sb = new System.Text.StringBuilder(4096);

        sb.Append("<svg width=\"1560\" height=\"185\" ");
        sb.Append("style=\"overflow: visible; font-family: 'Segoe UI', Arial, sans-serif;\" ");
        sb.Append("xmlns=\"http://www.w3.org/2000/svg\">");

        // Defs with drop shadow filter
        sb.Append("<defs>");
        sb.Append("<filter id=\"sh\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">");
        sb.Append("<feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\" />");
        sb.Append("</filter>");
        sb.Append("</defs>");

        // Month gridlines and labels
        var monthGridlines = BuildMonthGridlines(TimelineStart, TimelineEnd);
        foreach (var month in monthGridlines)
        {
            var x = GetXPosition(month.Date);
            sb.Append($"<line x1=\"{Fmt(x)}\" y1=\"0\" x2=\"{Fmt(x)}\" y2=\"{Fmt(SvgHeight)}\" ");
            sb.Append("stroke=\"#bbb\" stroke-opacity=\"0.4\" stroke-width=\"1\" />");
            sb.Append($"<text x=\"{Fmt(x + 5)}\" y=\"14\" ");
            sb.Append($"font-size=\"11\" font-weight=\"600\" fill=\"#666\">");
            sb.Append(System.Net.WebUtility.HtmlEncode(month.Label));
            sb.Append("</text>");
        }

        // Milestone tracks and markers
        if (Milestones is not null)
        {
            for (var i = 0; i < Milestones.Count; i++)
            {
                var milestone = Milestones[i];
                var trackY = GetTrackY(i, Milestones.Count);

                // Horizontal track line
                sb.Append($"<line x1=\"0\" y1=\"{Fmt(trackY)}\" ");
                sb.Append($"x2=\"{Fmt(SvgWidth)}\" y2=\"{Fmt(trackY)}\" ");
                sb.Append($"stroke=\"{milestone.Color}\" stroke-width=\"3\" />");

                // Markers
                for (var j = 0; j < milestone.Markers.Count; j++)
                {
                    var marker = milestone.Markers[j];
                    var mx = GetXPosition(marker.Date);
                    var labelAbove = (j % 2 == 0);
                    var labelY = labelAbove ? trackY - 18 : trackY + 24;

                    if (marker.Type == "checkpoint")
                    {
                        sb.Append($"<circle cx=\"{Fmt(mx)}\" cy=\"{Fmt(trackY)}\" r=\"6\" ");
                        sb.Append($"fill=\"white\" stroke=\"{milestone.Color}\" stroke-width=\"2.5\" />");
                    }
                    else if (marker.Type == "smallCheckpoint")
                    {
                        sb.Append($"<circle cx=\"{Fmt(mx)}\" cy=\"{Fmt(trackY)}\" r=\"4\" fill=\"#999\" />");
                    }
                    else if (marker.Type == "poc")
                    {
                        sb.Append($"<polygon points=\"{DiamondPoints(mx, trackY)}\" ");
                        sb.Append("fill=\"#F4B400\" filter=\"url(#sh)\" />");
                    }
                    else if (marker.Type == "production")
                    {
                        sb.Append($"<polygon points=\"{DiamondPoints(mx, trackY)}\" ");
                        sb.Append("fill=\"#34A853\" filter=\"url(#sh)\" />");
                    }

                    if (!string.IsNullOrWhiteSpace(marker.Label))
                    {
                        sb.Append($"<text x=\"{Fmt(mx)}\" y=\"{Fmt(labelY)}\" ");
                        sb.Append("text-anchor=\"middle\" font-size=\"10\" fill=\"#666\">");
                        sb.Append(System.Net.WebUtility.HtmlEncode(marker.Label));
                        sb.Append("</text>");
                    }
                }
            }
        }

        // NOW dashed vertical line
        var nowX = GetXPosition(CurrentDate);
        sb.Append($"<line x1=\"{Fmt(nowX)}\" y1=\"0\" ");
        sb.Append($"x2=\"{Fmt(nowX)}\" y2=\"{Fmt(SvgHeight)}\" ");
        sb.Append("stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"5,3\" />");
        sb.Append($"<text x=\"{Fmt(nowX)}\" y=\"24\" ");
        sb.Append("text-anchor=\"middle\" font-size=\"10\" font-weight=\"bold\" fill=\"#EA4335\">");
        sb.Append("NOW</text>");

        sb.Append("</svg>");
        return sb.ToString();
    }

    private static List<MonthGridlineInfo> BuildMonthGridlines(DateTime timelineStart, DateTime timelineEnd)
    {
        var gridlines = new List<MonthGridlineInfo>();
        var current = new DateTime(timelineStart.Year, timelineStart.Month, 1);
        if (current < timelineStart)
            current = current.AddMonths(1);

        while (current <= timelineEnd)
        {
            gridlines.Add(new MonthGridlineInfo
            {
                Date = current,
                Label = current.ToString("MMM", CultureInfo.InvariantCulture)
            });
            current = current.AddMonths(1);
        }

        return gridlines;
    }

    private class MonthGridlineInfo
    {
        public DateTime Date { get; init; }
        public string Label { get; init; } = string.Empty;
    }
}