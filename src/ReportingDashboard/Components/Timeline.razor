@using System.Globalization
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components

<div class="tl-area">
    <div class="tl-sidebar">
        @foreach (var milestone in Milestones)
        {
            <div class="tl-label">
                <span class="tl-id" style="color: @milestone.Color;">@milestone.Label</span>
                <span class="tl-desc"> – @milestone.Description</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" overflow="visible" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines and labels *@
            @foreach (var monthInfo in GetMonthGridlines())
            {
                <line x1="@F(monthInfo.X)" y1="0" x2="@F(monthInfo.X)" y2="185"
                      stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                @RenderSvgText(F(monthInfo.X + 5), "14", "start", "11", "600", "#666", monthInfo.Label)
            }

            @* Milestone tracks *@
            @for (int i = 0; i < Milestones.Count; i++)
            {
                var milestone = Milestones[i];
                var y = GetTrackY(i);
                <line x1="0" y1="@F(y)" x2="1560" y2="@F(y)"
                      stroke="@milestone.Color" stroke-width="3" />

                @* Markers *@
                if (milestone.Markers != null)
                {
                    @foreach (var marker in milestone.Markers)
                    {
                        var x = GetXPosition(marker.Date);
                        @if (marker.Type == "checkpoint")
                        {
                            <circle cx="@F(x)" cy="@F(y)" r="6"
                                    fill="white" stroke="@milestone.Color" stroke-width="2.5" />
                            @if (!string.IsNullOrEmpty(marker.Label))
                            {
                                @RenderSvgText(F(x), F(y - 12), "middle", "10", "400", "#666", marker.Label)
                            }
                        }
                        else if (marker.Type == "poc")
                        {
                            <polygon points="@DiamondPoints(x, y)"
                                     fill="#F4B400" filter="url(#sh)" />
                            @if (!string.IsNullOrEmpty(marker.Label))
                            {
                                @RenderSvgText(F(x), F(y - 16), "middle", "10", "400", "#666", marker.Label)
                            }
                        }
                        else if (marker.Type == "production")
                        {
                            <polygon points="@DiamondPoints(x, y)"
                                     fill="#34A853" filter="url(#sh)" />
                            @if (!string.IsNullOrEmpty(marker.Label))
                            {
                                @RenderSvgText(F(x), F(y + 24), "middle", "10", "400", "#666", marker.Label)
                            }
                        }
                        else if (marker.Type == "smallCheckpoint")
                        {
                            <circle cx="@F(x)" cy="@F(y)" r="4"
                                    fill="#999" />
                            @if (!string.IsNullOrEmpty(marker.Label))
                            {
                                @RenderSvgText(F(x), F(y - 10), "middle", "10", "400", "#666", marker.Label)
                            }
                        }
                    }
                }
            }

            @* NOW line *@
            @{
                var nowX = GetXPosition(CurrentDate);
            }
            <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="185"
                  stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
            @RenderSvgText(F(nowX), F(SvgHeight - 2), "middle", "10", "700", "#EA4335", "NOW")
        </svg>
    </div>
</div>

@code {
    [Parameter] public required List<Milestone> Milestones { get; set; }
    [Parameter] public DateTime TimelineStart { get; set; }
    [Parameter] public DateTime TimelineEnd { get; set; }
    [Parameter] public DateTime CurrentDate { get; set; }

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;
    private const double TopMargin = 28;

    private static string F(double value) => value.ToString("F1", CultureInfo.InvariantCulture);

    private RenderFragment RenderSvgText(string x, string y, string anchor, string fontSize, string fontWeight, string fill, string content) => builder =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", x);
        builder.AddAttribute(2, "y", y);
        builder.AddAttribute(3, "text-anchor", anchor);
        builder.AddAttribute(4, "font-size", fontSize);
        builder.AddAttribute(5, "font-weight", fontWeight);
        builder.AddAttribute(6, "fill", fill);
        builder.AddAttribute(7, "font-family", "'Segoe UI', Arial, sans-serif");
        builder.AddContent(8, content);
        builder.CloseElement();
    };

    private double GetXPosition(DateTime date)
    {
        var totalDays = (TimelineEnd - TimelineStart).TotalDays;
        if (totalDays <= 0) return 0;
        var elapsed = (date - TimelineStart).TotalDays;
        return Math.Clamp((elapsed / totalDays) * SvgWidth, 0, SvgWidth);
    }

    private double GetTrackY(int trackIndex)
    {
        var count = Milestones.Count;
        if (count == 1) return SvgHeight / 2.0;
        var usableHeight = SvgHeight - TopMargin - 16;
        return TopMargin + 14 + (trackIndex * usableHeight / (count - 1));
    }

    private string DiamondPoints(double cx, double cy, double r = 11)
    {
        return $"{F(cx)},{F(cy - r)} {F(cx + r)},{F(cy)} {F(cx)},{F(cy + r)} {F(cx - r)},{F(cy)}";
    }

    private record MonthGridline(double X, string Label);

    private List<MonthGridline> GetMonthGridlines()
    {
        var gridlines = new List<MonthGridline>();
        var current = new DateTime(TimelineStart.Year, TimelineStart.Month, 1);
        if (current < TimelineStart)
            current = current.AddMonths(1);

        while (current <= TimelineEnd)
        {
            var x = GetXPosition(current);
            var label = current.ToString("MMM", CultureInfo.InvariantCulture);
            gridlines.Add(new MonthGridline(x, label));
            current = current.AddMonths(1);
        }

        return gridlines;
    }
}