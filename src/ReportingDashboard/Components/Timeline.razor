@{
    var tracks = TimelineData.Tracks;
    var trackCount = tracks.Count;
    var svgWidth = 1560;
    var svgHeight = Math.Max(185, trackCount * 56);
    var startDate = DateTime.Parse(TimelineData.StartDate);
    var endDate = DateTime.Parse(TimelineData.EndDate);
    var nowDate = DateTime.Parse(TimelineData.NowDate);
    var totalDays = (endDate - startDate).TotalDays;
}

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in tracks)
        {
            <div class="tl-track-label">
                <span class="tl-track-id" style="color:@track.Color">@track.Name</span>
                <span class="tl-track-name"> @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@svgWidth" height="@svgHeight" overflow="visible"
             style="font-family:'Segoe UI',Arial,sans-serif">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @{
                var current = new DateTime(startDate.Year, startDate.Month, 1);
                while (current <= endDate)
                {
                    var x = DateToX(current, startDate, totalDays, svgWidth);
                    var monthLabel = current.ToString("MMM");
                    <line x1="@F(x)" y1="0" x2="@F(x)" y2="@svgHeight"
                          stroke="#bbb" stroke-opacity="0.4" />
                    @((MarkupString)$"<text x=\"{F(x + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\">{monthLabel}</text>")
                    current = current.AddMonths(1);
                }
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < trackCount; i++)
            {
                var track = tracks[i];
                var y = TrackToY(i, trackCount, svgHeight);

                <line x1="0" y1="@F(y)" x2="@svgWidth" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    var msDate = DateTime.Parse(ms.Date);
                    var mx = DateToX(msDate, startDate, totalDays, svgWidth);
                    var labelY = (i % 2 == 0) ? y - 18 : y + 22;

                    @if (ms.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(mx, y, 11)"
                                 fill="#F4B400" filter="url(#sh)">
                            <title>@ms.Label</title>
                        </polygon>
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@DiamondPoints(mx, y, 11)"
                                 fill="#34A853" filter="url(#sh)">
                            <title>@ms.Label</title>
                        </polygon>
                    }
                    else
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="7"
                                fill="white" stroke="@track.Color" stroke-width="2.5">
                            <title>@ms.Label</title>
                        </circle>
                    }

                    @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(labelY)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                }
            }

            @* NOW line *@
            @{
                var nowX = DateToX(nowDate, startDate, totalDays, svgWidth);
            }
            <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@svgHeight"
                  stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
            @((MarkupString)$"<text x=\"{F(nowX)}\" y=\"{svgHeight - 4}\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">NOW</text>")
        </svg>
    </div>
</div>

@code {
    [Parameter]
    public TimelineData TimelineData { get; set; } = default!;

    private static double DateToX(DateTime date, DateTime startDate, double totalDays, int svgWidth)
    {
        var elapsed = (date - startDate).TotalDays;
        return (elapsed / totalDays) * svgWidth;
    }

    private static double TrackToY(int trackIndex, int totalTracks, int svgHeight)
    {
        double spacing = (double)svgHeight / (totalTracks + 1);
        return spacing * (trackIndex + 1);
    }

    private static string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double value) => value.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
}