@using System.Globalization
@using System.Net
@using ReportingDashboard.Models

@if (TimelineData is null || TimelineData.Tracks.Count == 0)
{
    return;
}

<div class="tl-area" style="height:196px;background:#FAFAFA;border-bottom:2px solid #E8E8E8;display:flex;flex-direction:row;align-items:stretch;padding:6px 44px 0;">

    @* ── Left sidebar: track labels ── *@
    <div style="width:230px;flex-shrink:0;display:flex;flex-direction:column;justify-content:space-around;padding:16px 12px 16px 0;border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px;font-weight:600;color:@track.Color;">@track.Name</span>
                <span style="font-size:12px;font-weight:400;color:#444;margin-left:4px;">@track.Label</span>
            </div>
        }
    </div>

    @* ── Right SVG area ── *@
    <div class="tl-svg-box" style="flex:1;padding-left:12px;padding-top:6px;">
        @((MarkupString)RenderSvg())
    </div>
</div>

@code {
    [Parameter] public TimelineData? TimelineData { get; set; }

    private DateTime StartDate;
    private DateTime EndDate;
    private DateTime NowDate;
    private double SvgHeight;

    protected override void OnParametersSet()
    {
        if (TimelineData is null) return;

        DateTime.TryParse(TimelineData.StartDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out StartDate);
        DateTime.TryParse(TimelineData.EndDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out EndDate);
        DateTime.TryParse(TimelineData.NowDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out NowDate);

        SvgHeight = Math.Max(185, TimelineData.Tracks.Count * 56);
    }

    private string RenderSvg()
    {
        if (TimelineData is null) return string.Empty;

        var sb = new System.Text.StringBuilder();
        var tracks = TimelineData.Tracks;
        var trackCount = tracks.Count;

        sb.Append($"<svg width=\"1560\" height=\"{F(SvgHeight)}\" style=\"overflow:visible;\" xmlns=\"http://www.w3.org/2000/svg\">");

        // Defs: drop-shadow filter
        sb.Append("<defs>");
        sb.Append("<filter id=\"sh\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">");
        sb.Append("<feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\" />");
        sb.Append("</filter>");
        sb.Append("</defs>");

        // Month grid lines & labels — use DateToX for consistent positioning
        if (EndDate > StartDate)
        {
            var cursor = new DateTime(StartDate.Year, StartDate.Month, 1);
            while (cursor <= EndDate)
            {
                var x = DateToX(cursor);
                var label = cursor.ToString("MMM", CultureInfo.InvariantCulture);
                sb.Append($"<line x1=\"{F(x)}\" y1=\"0\" x2=\"{F(x)}\" y2=\"{F(SvgHeight)}\" stroke=\"#bbb\" stroke-width=\"1\" opacity=\"0.4\" />");
                sb.Append($"<text x=\"{F(x + 5)}\" y=\"14\" fill=\"#666\" style=\"font-size:11px;font-weight:600;\">{Enc(label)}</text>");
                cursor = cursor.AddMonths(1);
            }
        }

        // Horizontal track lines
        for (int t = 0; t < trackCount; t++)
        {
            var track = tracks[t];
            var ty = TrackToY(t, trackCount);
            sb.Append($"<line x1=\"0\" y1=\"{F(ty)}\" x2=\"1560\" y2=\"{F(ty)}\" stroke=\"{Enc(track.Color)}\" stroke-width=\"3\" />");
        }

        // Milestone markers
        for (int t = 0; t < trackCount; t++)
        {
            var track = tracks[t];
            var cy = TrackToY(t, trackCount);

            for (int mi = 0; mi < track.Milestones.Count; mi++)
            {
                var ms = track.Milestones[mi];
                if (!DateTime.TryParse(ms.Date, CultureInfo.InvariantCulture, DateTimeStyles.None, out var msDate))
                    continue;

                var cx = DateToX(msDate);
                var tooltip = Enc($"{ms.Label} ({msDate:MMM dd})");
                var labelY = (mi % 2 == 0) ? cy - 18 : cy + 22;

                switch (ms.Type?.ToLowerInvariant())
                {
                    case "checkpoint":
                        sb.Append($"<g><title>{tooltip}</title>");
                        sb.Append($"<circle cx=\"{F(cx)}\" cy=\"{F(cy)}\" r=\"7\" fill=\"white\" stroke=\"{Enc(track.Color)}\" stroke-width=\"2.5\" />");
                        sb.Append("</g>");
                        break;

                    case "poc":
                        sb.Append($"<g><title>{tooltip}</title>");
                        sb.Append($"<polygon points=\"{DiamondPoints(cx, cy)}\" fill=\"#F4B400\" filter=\"url(#sh)\" />");
                        sb.Append("</g>");
                        break;

                    case "production":
                        sb.Append($"<g><title>{tooltip}</title>");
                        sb.Append($"<polygon points=\"{DiamondPoints(cx, cy)}\" fill=\"#34A853\" filter=\"url(#sh)\" />");
                        sb.Append("</g>");
                        break;

                    default:
                        sb.Append($"<g><title>{tooltip}</title>");
                        sb.Append($"<circle cx=\"{F(cx)}\" cy=\"{F(cy)}\" r=\"4\" fill=\"#999\" />");
                        sb.Append("</g>");
                        break;
                }

                sb.Append($"<text x=\"{F(cx)}\" y=\"{F(labelY)}\" fill=\"#666\" style=\"font-size:10px;\" text-anchor=\"middle\">{Enc(ms.Label)}</text>");
            }
        }

        // NOW dashed line
        if (NowDate > StartDate && NowDate < EndDate)
        {
            var nowX = DateToX(NowDate);
            sb.Append($"<line x1=\"{F(nowX)}\" y1=\"0\" x2=\"{F(nowX)}\" y2=\"{F(SvgHeight)}\" stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"5,3\" />");
            sb.Append($"<text x=\"{F(nowX)}\" y=\"10\" fill=\"#EA4335\" style=\"font-size:10px;font-weight:700;\" text-anchor=\"middle\">NOW</text>");
        }

        sb.Append("</svg>");
        return sb.ToString();
    }

    private double DateToX(DateTime date)
    {
        var totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        return ((date - StartDate).TotalDays / totalDays) * 1560;
    }

    private static double TrackToY(int index, int count)
    {
        var spacing = 185.0 / (count + 1);
        return spacing * (index + 1);
    }

    /// <summary>
    /// Generates SVG polygon points for a diamond shape.
    /// The size parameter is the full offset from center to each point tip.
    /// </summary>
    private static string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static string Enc(string s) => WebUtility.HtmlEncode(s);
}