@* Timeline component — full SVG implementation in T5 *@
<div class="tl-area" style="height:196px; background:#FAFAFA; display:flex; border-bottom:1px solid #E0E0E0;">
    <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px; border-right:1px solid #E0E0E0;">
        @if (TimelineData?.Tracks is not null)
        {
            @foreach (var track in TimelineData.Tracks)
            {
                <div style="display:flex; align-items:center; gap:6px;">
                    <span style="font-size:13px; font-weight:700; color:@track.Color;">@track.Name</span>
                    <span style="font-size:12px; color:#555;">@track.Label</span>
                </div>
            }
        }
    </div>
    <div class="tl-svg-box" style="flex:1; display:flex; align-items:center; justify-content:center;">
        <span style="color:#999; font-size:13px;">Timeline visualization — implemented in T5</span>
    </div>
</div>

@code {
    [Parameter] public TimelineData? TimelineData { get; set; }
}