@if (TimelineModel is not null)
{
    <div class="tl-labels">
        @foreach (var track in TimelineModel.Tracks)
        {
            <div class="tl-label">
                <span class="tl-id" style="color:@track.Color;">@track.Id</span>
                <span class="tl-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        @{
            var startDate = ParseDate(TimelineModel.StartDate);
            var endDate = ParseDate(TimelineModel.EndDate);
            var nowDate = ParseDate(TimelineModel.NowDate);
            var totalDays = (endDate - startDate).TotalDays;
            var trackCount = TimelineModel.Tracks.Count;
            var svgWidth = 1560;
            var trackSpacing = 56;
            var firstTrackY = 42;
            var svgHeight = firstTrackY + (trackCount - 1) * trackSpacing + 30;
            var months = GetMonthPositions(startDate, endDate, svgWidth);
        }
        <svg width="@svgWidth" height="@svgHeight" overflow="visible"
             xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @foreach (var m in months)
            {
                <line x1="@m.X" y1="0" x2="@m.X" y2="@svgHeight"
                      stroke="#bbb" stroke-opacity="0.4" />
                <g class="svg-text"><text x="@(m.X + 5)" y="14" fill="#666"
                      font-size="11" font-weight="600">@m.Label</text></g>
            }

            @* NOW line *@
            @if (nowDate >= startDate && nowDate <= endDate)
            {
                var nowX = DateToX(nowDate, startDate, totalDays, svgWidth);
                <line x1="@nowX" y1="0" x2="@nowX" y2="@svgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <g class="svg-text"><text x="@nowX" y="@(svgHeight - 2)" fill="#EA4335"
                      font-size="10" font-weight="700" text-anchor="middle">NOW</text></g>
            }

            @* Tracks *@
            @for (int i = 0; i < trackCount; i++)
            {
                var track = TimelineModel.Tracks[i];
                var y = firstTrackY + i * trackSpacing;

                @* Track horizontal line *@
                <line x1="0" y1="@y" x2="@svgWidth" y2="@y"
                      stroke="@track.Color" stroke-width="3" />

                @* Milestones *@
                @foreach (var ms in track.Milestones)
                {
                    var msDate = ParseDate(ms.Date);
                    var x = DateToX(msDate, startDate, totalDays, svgWidth);
                    var labelY = (track.Milestones.IndexOf(ms) % 2 == 0) ? y - 16 : y + 22;

                    @if (ms.Type == "poc")
                    {
                        @* Gold diamond *@
                        var pts = DiamondPoints(x, y, 9);
                        <polygon points="@pts" fill="#F4B400" filter="url(#shadow)">
                            <title>@ms.Label</title>
                        </polygon>
                    }
                    else if (ms.Type == "production")
                    {
                        @* Green diamond *@
                        var pts = DiamondPoints(x, y, 9);
                        <polygon points="@pts" fill="#34A853" filter="url(#shadow)">
                            <title>@ms.Label</title>
                        </polygon>
                    }
                    else
                    {
                        @* Checkpoint circle *@
                        <circle cx="@x" cy="@y" r="5" fill="white"
                                stroke="@track.Color" stroke-width="2.5">
                            <title>@ms.Label</title>
                        </circle>
                    }

                    <g class="svg-text"><text x="@x" y="@labelY" fill="#666" font-size="10"
                          text-anchor="middle">@ms.Label</text></g>
                }
            }
        </svg>
    </div>
}

@code {
    [Parameter] public TimelineData? TimelineModel { get; set; }

    private static DateTime ParseDate(string date) =>
        DateTime.TryParse(date, out var d) ? d : DateTime.Now;

    private static double DateToX(DateTime date, DateTime start, double totalDays, int width) =>
        Math.Round(((date - start).TotalDays / totalDays) * width, 1);

    private static string DiamondPoints(double cx, double cy, double r) =>
        $"{cx},{cy - r} {cx + r},{cy} {cx},{cy + r} {cx - r},{cy}";

    private record MonthPos(double X, string Label);

    private static List<MonthPos> GetMonthPositions(DateTime start, DateTime end, int width)
    {
        var positions = new List<MonthPos>();
        var totalDays = (end - start).TotalDays;
        var current = new DateTime(start.Year, start.Month, 1);
        while (current <= end)
        {
            var x = DateToX(current, start, totalDays, width);
            positions.Add(new MonthPos(x, current.ToString("MMM")));
            current = current.AddMonths(1);
        }
        return positions;
    }
}
