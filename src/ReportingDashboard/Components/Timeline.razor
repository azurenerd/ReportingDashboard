<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in Data.Tracks)
        {
            <div class="tl-track-label">
                <span class="tl-track-id" style="color:@track.Color;">@track.Id</span>
                <span class="tl-track-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        @((MarkupString)BuildSvg())
    </div>
</div>

@code {
    [Parameter] public TimelineData Data { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = string.Empty;

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;

    private string BuildSvg()
    {
        if (!DateOnly.TryParse(Data.StartDate, out var startDate) ||
            !DateOnly.TryParse(Data.EndDate, out var endDate))
            return "<svg></svg>";

        var totalDays = (endDate.ToDateTime(TimeOnly.MinValue) - startDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
        if (totalDays <= 0) return "<svg></svg>";

        double GetX(DateOnly date)
        {
            var days = (date.ToDateTime(TimeOnly.MinValue) - startDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
            return (days / totalDays) * SvgWidth;
        }

        double GetXFromStr(string dateStr)
        {
            return DateOnly.TryParse(dateStr, out var d) ? GetX(d) : 0;
        }

        double GetTrackY(int index)
        {
            var count = Data.Tracks.Count;
            if (count <= 1) return 98;
            return 42.0 + (index * (154.0 - 42.0) / (count - 1));
        }

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{SvgWidth}\" height=\"{SvgHeight}\" style=\"overflow:visible;display:block\">");
        sb.Append("<defs><filter id=\"sh\"><feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\"/></filter></defs>");

        // Month gridlines
        var current = new DateOnly(startDate.Year, startDate.Month, 1);
        while (current < endDate)
        {
            var x = GetX(current);
            var label = current.ToString("MMM");
            sb.Append($"<line x1=\"{F(x)}\" y1=\"0\" x2=\"{F(x)}\" y2=\"{SvgHeight}\" stroke=\"#bbb\" stroke-opacity=\"0.4\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{F(x + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\" font-family=\"Segoe UI,Arial\">{Enc(label)}</text>");
            current = current.AddMonths(1);
        }

        // NOW line
        if (DateOnly.TryParse(CurrentDate, out var nowDate))
        {
            var nowX = GetX(nowDate);
            sb.Append($"<line x1=\"{F(nowX)}\" y1=\"0\" x2=\"{F(nowX)}\" y2=\"{SvgHeight}\" stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/>");
            sb.Append($"<text x=\"{F(nowX + 4)}\" y=\"14\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" font-family=\"Segoe UI,Arial\">NOW</text>");
        }

        // Track lines and milestones
        for (int i = 0; i < Data.Tracks.Count; i++)
        {
            var track = Data.Tracks[i];
            var y = GetTrackY(i);

            sb.Append($"<line x1=\"0\" y1=\"{F(y)}\" x2=\"{SvgWidth}\" y2=\"{F(y)}\" stroke=\"{Enc(track.Color)}\" stroke-width=\"3\"/>");

            for (int j = 0; j < track.Milestones.Count; j++)
            {
                var ms = track.Milestones[j];
                var mx = GetXFromStr(ms.Date);
                var above = (j % 2 == 0);
                var ly = above ? y - 16 : y + 24;

                if (ms.Type == "checkpoint")
                {
                    if (string.IsNullOrEmpty(ms.Label))
                    {
                        sb.Append($"<circle cx=\"{F(mx)}\" cy=\"{F(y)}\" r=\"4\" fill=\"#999\"/>");
                    }
                    else
                    {
                        sb.Append($"<circle cx=\"{F(mx)}\" cy=\"{F(y)}\" r=\"7\" fill=\"white\" stroke=\"{Enc(track.Color)}\" stroke-width=\"2.5\"/>");
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(ly)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{Enc(ms.Label)}</text>");
                    }
                }
                else if (ms.Type == "poc")
                {
                    sb.Append($"<polygon points=\"{Diamond(mx, y, 11)}\" fill=\"#F4B400\" filter=\"url(#sh)\"/>");
                    if (!string.IsNullOrEmpty(ms.Label))
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(ly)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{Enc(ms.Label)}</text>");
                }
                else if (ms.Type == "production")
                {
                    sb.Append($"<polygon points=\"{Diamond(mx, y, 11)}\" fill=\"#34A853\" filter=\"url(#sh)\"/>");
                    if (!string.IsNullOrEmpty(ms.Label))
                        sb.Append($"<text x=\"{F(mx)}\" y=\"{F(ly)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\" font-family=\"Segoe UI,Arial\">{Enc(ms.Label)}</text>");
                }
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }

    private static string Diamond(double cx, double cy, double size)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double val) => val.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

    private static string Enc(string s) => System.Net.WebUtility.HtmlEncode(s);
}
