<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in TimelineInfo.Tracks)
        {
            <div class="tl-track-label">
                <div class="tl-track-id" style="color: @track.Color; font-weight: 700;">@track.Id</div>
                <div class="tl-track-name">@track.Name</div>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@SvgWidth" height="@SvgHeight" style="overflow: visible;" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines and labels *@
            @foreach (var (date, label) in GetMonthGridlines())
            {
                var x = GetX(date);
                <line x1="@F(x)" y1="0" x2="@F(x)" y2="@SvgHeight"
                      stroke="#BBB" stroke-opacity="0.4" stroke-width="1" />
                <text x="@F(x + 5)" y="14"
                      font-size="11" font-weight="600" fill="#666"
                      font-family="Segoe UI, Arial">@label</text>
            }

            @* Track lines *@
            @for (var ti = 0; ti < TimelineInfo.Tracks.Count; ti++)
            {
                var track = TimelineInfo.Tracks[ti];
                var y = GetTrackY(ti);
                <line x1="0" y1="@F(y)" x2="@SvgWidth" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />
            }

            @* NOW line *@
            @if (_currentDateParsed)
            {
                var nowX = GetX(_currentDate);
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@SvgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(nowX)" y="@F(SvgHeight - 4)"
                      font-size="10" font-weight="bold" fill="#EA4335"
                      text-anchor="middle" font-family="Segoe UI, Arial">NOW</text>
            }

            @* Milestones *@
            @for (var ti = 0; ti < TimelineInfo.Tracks.Count; ti++)
            {
                var track = TimelineInfo.Tracks[ti];
                var trackY = GetTrackY(ti);

                @for (var mi = 0; mi < track.Milestones.Count; mi++)
                {
                    var ms = track.Milestones[mi];
                    if (!DateOnly.TryParse(ms.Date, out var msDate)) { continue; }
                    var msX = GetX(msDate);
                    var labelAbove = mi % 2 != 0;
                    var labelY = labelAbove ? trackY - 16 : trackY + 22;

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(msX)" cy="@F(trackY)" r="6"
                                fill="white" stroke="@track.Color" stroke-width="2.5" />
                    }
                    else if (ms.Type == "poc")
                    {
                        <polygon points="@GetDiamondPoints(msX, trackY, 11)"
                                 fill="#F4B400" filter="url(#sh)" />
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@GetDiamondPoints(msX, trackY, 11)"
                                 fill="#34A853" filter="url(#sh)" />
                    }

                    <text x="@F(msX)" y="@F(labelY)"
                          font-size="10" fill="#666" text-anchor="middle"
                          font-family="Segoe UI, Arial">@ms.Label</text>
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineInfo { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = string.Empty;

    private const int SvgWidth = 1560;
    private const int SvgHeight = 185;
    private const double TopTrackY = 42;
    private const double BottomTrackY = 154;

    private DateOnly _startDate;
    private DateOnly _endDate;
    private DateOnly _currentDate;
    private bool _currentDateParsed;
    private double _totalDays;

    protected override void OnParametersSet()
    {
        DateOnly.TryParse(TimelineInfo.StartDate, out _startDate);
        DateOnly.TryParse(TimelineInfo.EndDate, out _endDate);
        _currentDateParsed = DateOnly.TryParse(CurrentDate, out _currentDate);
        _totalDays = _endDate.DayNumber - _startDate.DayNumber;
    }

    private double GetX(DateOnly date)
    {
        if (_totalDays <= 0) return 0;
        return (date.DayNumber - _startDate.DayNumber) / _totalDays * SvgWidth;
    }

    private double GetTrackY(int index)
    {
        var count = TimelineInfo.Tracks.Count;
        if (count <= 1) return (TopTrackY + BottomTrackY) / 2.0;
        return TopTrackY + index * (BottomTrackY - TopTrackY) / (count - 1);
    }

    private IEnumerable<(DateOnly date, string label)> GetMonthGridlines()
    {
        var current = new DateOnly(_startDate.Year, _startDate.Month, 1);
        if (current < _startDate) current = current.AddMonths(1);

        while (current <= _endDate)
        {
            yield return (current, current.ToString("MMM"));
            current = current.AddMonths(1);
        }
    }

    private string GetDiamondPoints(double cx, double cy, double size)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double value) =>
        value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}