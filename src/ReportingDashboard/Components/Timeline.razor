@{
    var timelineStart = SafeParseDate(Data.StartDate);
    var timelineEnd = SafeParseDate(Data.EndDate);
    var nowDate = SafeParseDate(CurrentDate);
    var totalDays = (timelineEnd.ToDateTime(TimeOnly.MinValue) - timelineStart.ToDateTime(TimeOnly.MinValue)).TotalDays;
    var monthGridlines = BuildMonthGridlines(timelineStart, timelineEnd, totalDays);
    var nowX = CalcX(nowDate, timelineStart, totalDays);
}

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in Data.Tracks)
        {
            <div style="font-size:12px;font-weight:600;line-height:1.4;">
                <span style="color:@track.Color;font-weight:600;">@track.Id</span><br />
                <span style="font-weight:400;color:#444;">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg xmlns="http://www.w3.org/2000/svg" width="1560" height="185" style="overflow:visible;display:block;">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @foreach (var mg in monthGridlines)
            {
                <line x1="@F(mg.X)" y1="0" x2="@F(mg.X)" y2="185" stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                <SvgText X="@F(mg.X + 5)" Y="14" Fill="#666" FontSize="11" FontWeight="600" Content="@mg.Label" />
            }

            <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="185" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
            <SvgText X="@F(nowX + 4)" Y="14" Fill="#EA4335" FontSize="10" FontWeight="700" Content="NOW" />

            @for (int ti = 0; ti < Data.Tracks.Count; ti++)
            {
                var track = Data.Tracks[ti];
                var ty = CalcTrackY(ti, Data.Tracks.Count);

                <line x1="0" y1="@F(ty)" x2="1560" y2="@F(ty)" stroke="@track.Color" stroke-width="3" />

                @for (int mi = 0; mi < track.Milestones.Count; mi++)
                {
                    var ms = track.Milestones[mi];
                    var msDate = SafeParseDate(ms.Date);
                    var mx = CalcX(msDate, timelineStart, totalDays);
                    var ly = (mi % 2 == 0) ? ty - 16 : ty + 24;

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(mx)" cy="@F(ty)" r="6" fill="white" stroke="@track.Color" stroke-width="2.5" />
                    }
                    else if (ms.Type == "poc")
                    {
                        <polygon points="@Diamond(mx, ty, 11)" fill="#F4B400" filter="url(#sh)" />
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@Diamond(mx, ty, 11)" fill="#34A853" filter="url(#sh)" />
                    }

                    <SvgText X="@F(mx)" Y="@F(ly)" Fill="#666" FontSize="10" FontWeight="400" Content="@ms.Label" Anchor="middle" />
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter]
    public TimelineData Data { get; set; } = new();

    [Parameter]
    public string CurrentDate { get; set; } = string.Empty;

    private record MonthGrid(double X, string Label);

    private static DateOnly SafeParseDate(string s)
    {
        return DateOnly.TryParse(s, out var d) ? d : DateOnly.FromDateTime(DateTime.Today);
    }

    private static double CalcX(DateOnly date, DateOnly start, double totalDays)
    {
        if (totalDays <= 0) return 0;
        var elapsed = (date.ToDateTime(TimeOnly.MinValue) - start.ToDateTime(TimeOnly.MinValue)).TotalDays;
        return Math.Clamp(elapsed / totalDays * 1560.0, 0, 1560);
    }

    private static double CalcTrackY(int index, int count)
    {
        if (count <= 1) return 92.5;
        double top = 42;
        double bottom = 154;
        return top + index * (bottom - top) / (count - 1);
    }

    private static string Diamond(double cx, double cy, double s)
    {
        return $"{cx},{cy - s} {cx + s},{cy} {cx},{cy + s} {cx - s},{cy}";
    }

    private static string F(double v) => v.ToString("F0");

    private static List<MonthGrid> BuildMonthGridlines(DateOnly start, DateOnly end, double totalDays)
    {
        var result = new List<MonthGrid>();
        var current = new DateOnly(start.Year, start.Month, 1);
        while (current <= end)
        {
            var x = CalcX(current, start, totalDays);
            result.Add(new MonthGrid(x, current.ToString("MMM")));
            current = current.AddMonths(1);
        }
        return result;
    }
}