<div class="hm-cell @Category-cell @(IsCurrent ? Category + "-cur" : "")">
    @if (Items is not null && Items.Count > 0)
    {
        @foreach (var item in Items)
        {
            <div class="it @Category-dot">@item</div>
        }
    }
    else
    {
        <span class="empty-cell">&ndash;</span>
    }
</div>

@code {
    [Parameter] public string Category { get; set; } = "";
    [Parameter] public List<string>? Items { get; set; }
    [Parameter] public bool IsCurrent { get; set; }
}