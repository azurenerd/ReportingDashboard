<div class="cell-content" style="--dot-color: @DotColor">
    @if (Items is not null && Items.Count > 0)
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
    else
    {
        <div class="empty">–</div>
    }
</div>

@code {
    [Parameter]
    public List<string> Items { get; set; } = new();

    [Parameter]
    public string DotColor { get; set; } = "#999";
}