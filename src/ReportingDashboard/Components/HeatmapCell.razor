@{
    var cellClass = CssClass + (IsHighlighted ? " apr" : "");
    var cellStyle = IsLastColumn ? "border-right:none;" : "";
}

<div class="hm-cell @cellClass" style="@cellStyle">
    @if (Items is null || Items.Count == 0)
    {
        <div class="it empty">—</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
</div>

@code {
    [Parameter] public List<string>? Items { get; set; }
    [Parameter] public string CssClass { get; set; } = string.Empty;
    [Parameter] public bool IsHighlighted { get; set; }
    [Parameter] public bool IsLastColumn { get; set; }
}
