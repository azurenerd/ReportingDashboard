@{
    var cellClass = $"hm-cell {CssPrefix}-cell" + (IsHighlighted ? " apr" : "");
    var style = IsLastColumn ? "border-right:none;" : "";
}

<div class="@cellClass" style="@style">
    @if (Items == null || Items.Count == 0)
    {
        <div class="it empty">—</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
</div>

@code {
    [Parameter] public List<string> Items { get; set; } = new();
    [Parameter] public string CssPrefix { get; set; } = "ship";
    [Parameter] public bool IsHighlighted { get; set; }
    [Parameter] public bool IsLastColumn { get; set; }
}
