@{
    var cellClass = $"hm-cell {CssPrefix}-cell{(IsCurrentMonth ? " apr" : "")}";
}

<div class="@cellClass">
    @if (Items.Count > 0)
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
    else
    {
        <div class="empty-cell">&ndash;</div>
    }
</div>

@code {
    [Parameter] public List<string> Items { get; set; } = new();
    [Parameter] public string CssPrefix { get; set; } = "";
    [Parameter] public bool IsCurrentMonth { get; set; }
}