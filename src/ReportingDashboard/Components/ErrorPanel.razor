<div class="error-panel">
    <div class="error-content">
        <div style="font-size:48px;color:#EA4335;margin-bottom:16px;">⚠</div>
        <div style="font-size:20px;font-weight:700;color:#333;margin-bottom:12px;">Dashboard data could not be loaded</div>
        <div style="font-size:14px;color:#666;font-family:'Consolas','Courier New',monospace;margin-bottom:16px;max-width:600px;word-break:break-word;">@Message</div>
        <div style="font-size:12px;color:#888;">Check data.json for errors and restart the application.</div>
    </div>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = string.Empty;
}