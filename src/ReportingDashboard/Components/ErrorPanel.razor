<div class="error-panel">
    <div class="error-icon">⚠️</div>
    <h2 class="error-title">Dashboard Data Error</h2>
    <p class="error-detail">@ErrorMessage</p>
    <p class="error-help">
        Check that <code>wwwroot/data.json</code> exists, contains valid JSON,
        and includes all required fields (title, subtitle, backlogLink, currentMonth, months, timeline, heatmap).
        Then restart the application with <code>dotnet run</code>.
    </p>
</div>

@code {
    [Parameter]
    public string ErrorMessage { get; set; } = "";
}