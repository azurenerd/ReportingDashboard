@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

@if (_error is not null)
{
    <div class="error-container">
        <p class="error-message">@_error</p>
    </div>
}
else if (_data is not null)
{
    <div class="dashboard">
        <div class="hdr">
            <div>
                <h1>
                    @_data.Title
                    @if (!string.IsNullOrWhiteSpace(_data.BacklogLink))
                    {
                        <a href="@_data.BacklogLink" target="_blank" rel="noopener">&#x2197; ADO Backlog</a>
                    }
                </h1>
                <div class="sub">@_data.Subtitle</div>
            </div>
            <div class="legend">
                <span class="legend-item">
                    <span class="legend-diamond legend-poc"></span> PoC Milestone
                </span>
                <span class="legend-item">
                    <span class="legend-diamond legend-prod"></span> Production Release
                </span>
                <span class="legend-item">
                    <span class="legend-circle"></span> Checkpoint
                </span>
                <span class="legend-item">
                    <span class="legend-now-bar"></span> Now
                </span>
            </div>
        </div>

        @* Timeline and Heatmap sections rendered by subsequent tasks *@
    </div>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        if (DataService.IsError)
        {
            var msg = DataService.ErrorMessage ?? "";
            if (msg.Contains("not found", StringComparison.OrdinalIgnoreCase))
            {
                _error = "Dashboard data not found. Please ensure data.json exists in the wwwroot folder.";
            }
            else
            {
                _error = $"Error reading dashboard data: {msg}";
            }
            return;
        }

        _data = DataService.Data;
        if (_data is null)
        {
            _error = "Dashboard data not found. Please ensure data.json exists in the wwwroot folder.";
        }
    }
}