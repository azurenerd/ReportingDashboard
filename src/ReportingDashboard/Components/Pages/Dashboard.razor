@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

<PageTitle>@(DataService.Data?.Title ?? "Executive Reporting Dashboard")</PageTitle>

<div class="dashboard-container">
    @if (DataService.IsError)
    {
        <div class="error-banner">
            <strong>⚠ Data Error:</strong> @DataService.ErrorMessage
        </div>
    }
    else if (DataService.Data is not null)
    {
        <HeaderSection ProjectInfo="@DataService.Data.Project" />
        <TimelineSection Milestones="@DataService.Data.Milestones" />
        <StatusSections ShippedItems="@DataService.Data.Shipped"
                        InProgressItems="@DataService.Data.InProgress"
                        CarriedOverItems="@DataService.Data.CarriedOver" />
    }
    else
    {
        <p class="loading-text">Loading...</p>
    }
</div>