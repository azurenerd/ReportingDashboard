@page "/"
@using ReportingDashboard.Services
@using ReportingDashboard.Models
@inject DataService DataService
@implements IDisposable

@{
    var data = DataService.GetData();
    var error = DataService.GetError();
    var currentMonth = DataService.GetCurrentMonthName();
}

@if (error is not null && data is not null)
{
    <div class="error-banner">⚠ data.json has errors - showing last valid data. Error: @error</div>
}

@if (data is null && error is not null)
{
    <div class="error-page">
        <div class="error-message">
            <h2>⚠ Dashboard Data Error</h2>
            <p>@error</p>
            <p>Fix <code>wwwroot/data.json</code> and save - the dashboard will reload automatically.</p>
        </div>
    </div>
}
else if (data is null)
{
    <div class="error-page">
        <div class="error-message">
            <h2>Loading...</h2>
        </div>
    </div>
}
else
{
    <div class="dashboard">
        <DashboardHeader Data="@data" />

        @* Timeline Band *@
        <div class="timeline-band">
            @{
                var tlStartDate = DateOnly.ParseExact(data.Timeline.StartDate, "yyyy-MM-dd");
                var tlEndDate = DateOnly.ParseExact(data.Timeline.EndDate, "yyyy-MM-dd");
                var totalDays = (double)(tlEndDate.DayNumber - tlStartDate.DayNumber);
                var leftMargin = 180.0;
                var rightMargin = 40.0;
                var trackWidth = 1920.0 - leftMargin - rightMargin;

                double DateToX(DateOnly d)
                {
                    var dayOffset = d.DayNumber - tlStartDate.DayNumber;
                    return leftMargin + (dayOffset / totalDays) * trackWidth;
                }

                var effectiveDate = DataService.GetEffectiveDate();
                var nowX = DateToX(effectiveDate);

                var gridlines = new List<(double x, string label)>();
                var gridDate = new DateOnly(tlStartDate.Year, tlStartDate.Month, 1).AddMonths(1);
                while (gridDate < tlEndDate)
                {
                    gridlines.Add((DateToX(gridDate), gridDate.ToString("MMM yyyy")));
                    gridDate = gridDate.AddMonths(1);
                }

                var showNow = effectiveDate >= tlStartDate && effectiveDate <= tlEndDate;

                var workstreamData = new List<(Workstream ws, int trackY, int labelY, List<(Milestone ms, double mx, bool isPast, string diamondFill, string labelPos, int labelDy)> milestones)>();
                var wsIndex = 0;
                foreach (var ws in data.Timeline.Workstreams)
                {
                    var trackY = 60 + wsIndex * 50;
                    var labelY = trackY + 5;
                    var milestones = new List<(Milestone ms, double mx, bool isPast, string diamondFill, string labelPos, int labelDy)>();
                    var miIndex = 0;
                    foreach (var ms in ws.Milestones)
                    {
                        var msDate = DateOnly.ParseExact(ms.Date, "yyyy-MM-dd");
                        var mx = DateToX(msDate);
                        var isPast = msDate <= effectiveDate;
                        var diamondFill = isPast ? ws.Color : "#FFF";
                        var labelPos = ms.LabelPosition ?? (miIndex % 2 == 0 ? "above" : "below");
                        var labelDy = labelPos == "above" ? -14 : 18;
                        milestones.Add((ms, mx, isPast, diamondFill, labelPos, labelDy));
                        miIndex++;
                    }
                    workstreamData.Add((ws, trackY, labelY, milestones));
                    wsIndex++;
                }
            }
            <svg width="1920" height="260" viewBox="0 0 1920 260" xmlns="http://www.w3.org/2000/svg">
                @foreach (var gl in gridlines)
                {
                    <line x1="@gl.x" y1="30" x2="@gl.x" y2="240" stroke="#E0E0E0" stroke-width="1" />
                    <svg x="@gl.x" y="20" overflow="visible">
                        <text x="0" y="0" text-anchor="middle" font-size="11" fill="#888">@gl.label</text>
                    </svg>
                }

                @if (showNow)
                {
                    <line x1="@nowX" y1="30" x2="@nowX" y2="240" stroke="#F4B400" stroke-width="2" stroke-dasharray="6,3" />
                    <rect x="@(nowX - 20)" y="24" width="40" height="16" rx="3" fill="#FFF0D0" stroke="#F4B400" stroke-width="1" />
                    <svg x="@nowX" y="36" overflow="visible">
                        <text x="0" y="0" text-anchor="middle" font-size="9" font-weight="bold" fill="#C07700">NOW</text>
                    </svg>
                }

                @foreach (var (ws, trackY, labelY, milestones) in workstreamData)
                {
                    <svg x="10" y="@labelY" overflow="visible">
                        <text x="0" y="0" font-size="12" font-weight="600" fill="@ws.Color">@ws.Id</text>
                    </svg>
                    <svg x="35" y="@labelY" overflow="visible">
                        <text x="0" y="0" font-size="11" fill="#333">@ws.Name</text>
                    </svg>
                    <line x1="@leftMargin" y1="@trackY" x2="@(1920 - rightMargin)" y2="@trackY" stroke="@ws.Color" stroke-width="3" opacity="0.3" />

                    @foreach (var (ms, mx, isPast, diamondFill, labelPos, labelDy) in milestones)
                    {
                        if (ms.Type == "checkpoint")
                        {
                            <circle cx="@mx" cy="@trackY" r="5" fill="@(isPast ? "#999" : "#FFF")" stroke="#999" stroke-width="2" />
                        }
                        else
                        {
                            <g transform="translate(@mx, @trackY) rotate(45)">
                                <rect x="-6" y="-6" width="12" height="12" fill="@diamondFill" stroke="@ws.Color" stroke-width="2" />
                            </g>
                        }

                        <svg x="@mx" y="@(trackY + labelDy)" overflow="visible">
                            <text x="0" y="0" text-anchor="middle" font-size="9" fill="#666">@ms.Label</text>
                        </svg>
                    }
                }
            </svg>
        </div>

        @* Heatmap Band *@
        <div class="heatmap">
            <table class="heatmap-table">
                <thead>
                    <tr>
                        <th class="cat-hdr"></th>
                        @foreach (var month in data.Heatmap.MonthColumns)
                        {
                            var isCurrentMonth = string.Equals(month, currentMonth, StringComparison.OrdinalIgnoreCase);
                            <th class="month-hdr @(isCurrentMonth ? "now" : "")">@month</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in data.Heatmap.Categories)
                    {
                        <tr>
                            <td class="cat-label @cat.CssClass">@cat.Emoji @cat.Name</td>
                            @foreach (var monthData in cat.Months)
                            {
                                var isCurrentMonth = string.Equals(monthData.Month, currentMonth, StringComparison.OrdinalIgnoreCase);
                                <td class="cell @cat.CssClass @(isCurrentMonth ? "active" : "")">
                                    @foreach (var item in monthData.Items)
                                    {
                                        <div class="item">@item</div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += OnDataChanged;
    }

    private async void OnDataChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Circuit may be gone
        }
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= OnDataChanged;
    }
}