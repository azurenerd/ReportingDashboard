@page "/"
@implements IDisposable
@inject DashboardDataService DataService

@if (DataService.IsError)
{
    <div class="error-panel">
        <div class="error-icon">&#x26A0;</div>
        <div class="error-message">@DataService.ErrorMessage</div>
        <div class="error-hint">Fix the file and save &#x2014; the dashboard will reload automatically.</div>
    </div>
}
else if (DataService.Data is not null)
{
    var data = DataService.Data;
    <Header Project="data.Project" />
    <Timeline TimelineInfo="data.Timeline" CurrentDate="data.Project.CurrentDate" />
    <Heatmap HeatmapInfo="data.Heatmap" />
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private async void HandleDataChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}