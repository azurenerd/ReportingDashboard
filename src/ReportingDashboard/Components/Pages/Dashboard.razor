@page "/"
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

@if (DataService.IsError)
{
    <div class="error-panel">
        <h2>Dashboard Configuration Error</h2>
        <p>@DataService.ErrorMessage</p>
        <p>Please check wwwroot/data.json and restart the application.</p>
    </div>
}
else if (_data is not null)
{
    @* ── Header Region (implemented by #1017) ── *@

    @* ── Timeline Region (implemented by #1018) ── *@

    @* ── Heatmap Region ── *@
    <div class="hm-wrap">
        <div class="hm-title">MONTHLY EXECUTION HEATMAP &mdash; Shipped &bull; In Progress &bull; Carryover &bull; Blockers</div>

        <div class="hm-grid" style="grid-template-columns: 160px repeat(@_data.Months.Count, 1fr); grid-template-rows: 36px repeat(@_heatmapRows.Count, 1fr);">

            @* Corner cell *@
            <div class="hm-corner">STATUS</div>

            @* Column headers — one per month *@
            @foreach (var month in _data.Months)
            {
                var isCurrentMonth = string.Equals(month, _data.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                <div class="hm-col-hdr @(isCurrentMonth ? "cur-month-hdr" : "")">@month</div>
            }

            @* Category rows *@
            @foreach (var row in _heatmapRows)
            {
                var prefix = CategoryCssPrefix(row.Category);

                @* Row header *@
                <div class="hm-row-hdr @(prefix)-hdr">@row.Label</div>

                @* Data cells for each month *@
                @foreach (var month in _data.Months)
                {
                    var isCurrentMonth = string.Equals(month, _data.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                    var cellClass = $"hm-cell {prefix}-cell{(isCurrentMonth ? " " + prefix + "-cur" : "")}";
                    var items = GetItemsForMonth(row.Items, month);

                    <div class="@cellClass">
                        @if (items.Count > 0)
                        {
                            @foreach (var item in items)
                            {
                                <div class="it @(prefix)-dot">@item</div>
                            }
                        }
                        else
                        {
                            <span style="color:#AAA;">-</span>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private List<HeatmapRowInfo> _heatmapRows = new();

    protected override void OnInitialized()
    {
        _data = DataService.Data;
        if (_data is not null)
        {
            _heatmapRows = BuildHeatmapRows(_data.Heatmap);
        }
    }

    /// <summary>
    /// Maps the flat HeatmapData dictionaries into an ordered list of row descriptors
    /// so the grid can iterate uniformly over all four categories.
    /// </summary>
    private static List<HeatmapRowInfo> BuildHeatmapRows(HeatmapData heatmap)
    {
        return new List<HeatmapRowInfo>
        {
            new("shipped",     "SHIPPED",      heatmap.Shipped),
            new("in-progress", "IN PROGRESS",  heatmap.InProgress),
            new("carryover",   "CARRYOVER",    heatmap.Carryover),
            new("blockers",    "BLOCKERS",     heatmap.Blockers),
        };
    }

    /// <summary>
    /// Returns the CSS class prefix for a given heatmap category.
    /// Used to compose row-header, cell, current-month, and dot class names.
    /// </summary>
    private static string CategoryCssPrefix(string category) => category switch
    {
        "shipped"     => "ship",
        "in-progress" => "prog",
        "carryover"   => "carry",
        "blockers"    => "block",
        _             => "ship"
    };

    /// <summary>
    /// Safely retrieves items for a given month from the category dictionary.
    /// Returns an empty list when the month key is missing or the dictionary is null.
    /// </summary>
    private static List<string> GetItemsForMonth(Dictionary<string, List<string>>? items, string month)
    {
        if (items is null) return new();
        return items.TryGetValue(month, out var list) ? list : new();
    }

    private record HeatmapRowInfo(string Category, string Label, Dictionary<string, List<string>> Items);
}