@page "/"
@inject IDashboardDataService DataService
@implements IDisposable

@if (_error is not null)
{
    <div class="error-panel">
        <div class="error-icon">⚠</div>
        <div class="error-message">@_error</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}
else if (_data is not null)
{
    <Header Project="@_data.Project" />
    <Timeline TimelineInfo="@_data.Timeline" CurrentDate="@_data.Project.CurrentDate" />
    <Heatmap HeatmapInfo="@_data.Heatmap" />
}

@code {
    private DashboardData? _data;
    private string? _error;
    private bool _disposed;

    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
        _data = DataService.GetData();
        _error = DataService.GetError();
    }

    private async void HandleDataChanged()
    {
        if (_disposed) return;
        _data = DataService.GetData();
        _error = DataService.GetError();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _disposed = true;
        DataService.OnDataChanged -= HandleDataChanged;
    }
}