@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

<div class="dashboard-container">
    @if (DataService.IsError)
    {
        <div class="error-banner">
            <strong>⚠ Data Error:</strong> @DataService.ErrorMessage
        </div>
    }
    else if (DataService.Data is not null)
    {
        <Header Data="@DataService.Data" />
        <Timeline Data="@DataService.Data.Timeline" />
        <Heatmap HeatmapData="@DataService.Data.Heatmap" Months="@(DataService.Data.Timeline?.Tracks?.FirstOrDefault()?.Milestones?.Select(m => m.Date).ToList() ?? new())" CurrentMonth="@DateTime.Now.ToString("MMM")" />
    }
    else
    {
        <ErrorPanel Message="Dashboard data is not available" />
    }
</div>