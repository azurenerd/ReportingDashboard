@page "/"
@inject DashboardDataService DataService

@if (DataService.IsError)
{
    <ErrorPanel Message="@DataService.ErrorMessage" />
}
else if (DataService.Data is not null)
{
    var data = DataService.Data;
    <div class="hdr">
        <Header Title="@data.Title"
                Subtitle="@data.Subtitle"
                BacklogLink="@data.BacklogLink"
                CurrentMonth="@data.CurrentMonth"
                NowDate="@data.Timeline.NowDate" />
    </div>
    <div class="tl-area">
        <Timeline Timeline="@data.Timeline" />
    </div>
    <div class="hm-wrap">
        <Heatmap Heatmap="@data.Heatmap"
                 Months="@data.Months"
                 CurrentMonth="@data.CurrentMonth" />
    </div>
}