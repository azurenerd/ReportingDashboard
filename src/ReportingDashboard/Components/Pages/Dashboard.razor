@page "/"
@inject DataService DataService
@implements IDisposable

@code {
    private DashboardData? data;
    private string? error;
    private DateOnly effectiveDate;
    private string currentMonthName = "";

    private DateOnly tlStart;
    private DateOnly tlEnd;
    private double tlTotalDays;
    private double svgWidth = 1560.0;
    private int svgHeight = 185;
    private int ySpacing;
    private double nowXPos;
    private List<GridlineInfo> monthGridlines = new();
    private int monthCount;

    protected override void OnInitialized()
    {
        RefreshState();
        DataService.OnDataChanged += OnDataChanged;
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(() =>
        {
            RefreshState();
            StateHasChanged();
        });
    }

    private void RefreshState()
    {
        data = DataService.GetData();
        error = DataService.GetError();
        effectiveDate = DataService.GetEffectiveDate();
        currentMonthName = effectiveDate.ToString("MMM", CultureInfo.InvariantCulture);

        if (data != null)
        {
            tlStart = DateOnly.ParseExact(data.Timeline.StartDate, "yyyy-MM-dd", CultureInfo.InvariantCulture);
            tlEnd = DateOnly.ParseExact(data.Timeline.EndDate, "yyyy-MM-dd", CultureInfo.InvariantCulture);
            tlTotalDays = (double)(tlEnd.DayNumber - tlStart.DayNumber);

            var wsCount = data.Timeline.Workstreams.Length;
            ySpacing = wsCount > 0 ? svgHeight / (wsCount + 1) : svgHeight / 2;

            nowXPos = CalcX(effectiveDate.ToString("yyyy-MM-dd"));

            monthGridlines = new List<GridlineInfo>();
            var gridCursor = new DateOnly(tlStart.Year, tlStart.Month, 1);
            if (gridCursor < tlStart) gridCursor = gridCursor.AddMonths(1);
            while (gridCursor <= tlEnd)
            {
                var gx = (double)(gridCursor.DayNumber - tlStart.DayNumber) / tlTotalDays * svgWidth;
                monthGridlines.Add(new GridlineInfo(gridCursor.ToString("MMM", CultureInfo.InvariantCulture), gx));
                gridCursor = gridCursor.AddMonths(1);
            }

            monthCount = data.Heatmap.MonthColumns.Length;
        }
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= OnDataChanged;
    }

    private static string Fmt(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static string DiamondPoints(double cx, double cy, double r)
    {
        return $"{Fmt(cx)},{Fmt(cy - r)} {Fmt(cx + r)},{Fmt(cy)} {Fmt(cx)},{Fmt(cy + r)} {Fmt(cx - r)},{Fmt(cy)}";
    }

    private double CalcX(string dateStr)
    {
        var d = DateOnly.ParseExact(dateStr, "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var elapsed = d.DayNumber - tlStart.DayNumber;
        return (double)elapsed / tlTotalDays * svgWidth;
    }

    private bool IsCurrentMonth(string month)
    {
        return string.Equals(month, currentMonthName, StringComparison.OrdinalIgnoreCase);
    }

    private record GridlineInfo(string Label, double X);
}

@if (data == null && error != null)
{
    <div class="error-page">
        <div class="error-message">
            <h2>Warning: Dashboard Data Error</h2>
            <p>@error</p>
            <p>Place a valid <code>data.json</code> file in the <code>wwwroot/</code> directory.</p>
        </div>
    </div>
}
else if (data != null)
{
    @if (error != null)
    {
        <div class="error-banner">
            Warning: data.json has errors - showing last valid data. Error: @error
        </div>
    }

    <div class="hdr">
        <div>
            <h1>@data.Title <a href="@data.BacklogUrl">&#8599; ADO Backlog</a></h1>
            <div class="sub">@data.Subtitle</div>
        </div>
        <div class="legend">
            <span class="legend-item"><span class="icon-diamond gold"></span>PoC Milestone</span>
            <span class="legend-item"><span class="icon-diamond green"></span>Production Release</span>
            <span class="legend-item"><span class="icon-circle"></span>Checkpoint</span>
            <span class="legend-item"><span class="icon-now-line"></span>Now</span>
        </div>
    </div>

    <div class="tl-area">
        <div class="tl-sidebar">
            @foreach (var ws in data.Timeline.Workstreams)
            {
                <div class="tl-ws">
                    <span class="tl-ws-id" style="color: @ws.Color;">@ws.Id</span>
                    <span class="tl-ws-name">@ws.Name</span>
                </div>
            }
        </div>
        <div class="tl-svg-box">
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="@Fmt(svgWidth)" height="@svgHeight"
                 style="overflow:visible;display:block">
                <defs>
                    <filter id="sh">
                        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3"/>
                    </filter>
                </defs>

                @foreach (var gl in monthGridlines)
                {
                    <line x1="@Fmt(gl.X)" y1="0" x2="@Fmt(gl.X)" y2="@svgHeight"
                          stroke="#bbb" stroke-opacity="0.4" stroke-width="1"/>
                    <svgtext x="@Fmt(gl.X + 5)" y="14" fill="#666"
                             font-size="11" font-weight="600"
                             font-family="Segoe UI,Arial">@gl.Label</svgtext>
                }

                <line x1="@Fmt(nowXPos)" y1="0" x2="@Fmt(nowXPos)" y2="@svgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3"/>
                <svgtext x="@Fmt(nowXPos + 4)" y="14" fill="#EA4335"
                         font-size="10" font-weight="700"
                         font-family="Segoe UI,Arial">NOW</svgtext>

                @for (int wi = 0; wi < data.Timeline.Workstreams.Length; wi++)
                {
                    var ws = data.Timeline.Workstreams[wi];
                    var yLane = ySpacing * (wi + 1);

                    <line x1="0" y1="@yLane" x2="@Fmt(svgWidth)" y2="@yLane"
                          stroke="@ws.Color" stroke-width="3"/>

                    @for (int mi = 0; mi < ws.Milestones.Length; mi++)
                    {
                        var ms = ws.Milestones[mi];
                        var mx = CalcX(ms.Date);
                        var above = ms.LabelPosition == "above" || (ms.LabelPosition == null && mi % 2 == 0);
                        var ly = above ? yLane - 18 : yLane + 26;

                        if (ms.Type == "start")
                        {
                            <circle cx="@Fmt(mx)" cy="@yLane" r="7"
                                    fill="white" stroke="@ws.Color" stroke-width="2.5"/>
                        }
                        else if (ms.Type == "checkpoint")
                        {
                            <circle cx="@Fmt(mx)" cy="@yLane" r="4" fill="#999"/>
                        }
                        else if (ms.Type == "poc")
                        {
                            <polygon points="@DiamondPoints(mx, yLane, 11)"
                                     fill="#F4B400" filter="url(#sh)"/>
                        }
                        else if (ms.Type == "production")
                        {
                            <polygon points="@DiamondPoints(mx, yLane, 11)"
                                     fill="#34A853" filter="url(#sh)"/>
                        }

                        <svgtext x="@Fmt(mx)" y="@ly" text-anchor="middle"
                                 fill="#666" font-size="10"
                                 font-family="Segoe UI,Arial">@ms.Label</svgtext>
                    }
                }
            </svg>
        </div>
    </div>

    <div class="hm-wrap">
        <div class="hm-title">Monthly Execution Heatmap &#8212; Shipped &#183; In Progress &#183; Carryover &#183; Blockers</div>
        <div class="hm-grid" style="grid-template-columns: 160px repeat(@monthCount, 1fr);">

            <div class="hm-corner">STATUS</div>
            @foreach (var month in data.Heatmap.MonthColumns)
            {
                var isCur = IsCurrentMonth(month);
                <div class="hm-col-hdr @(isCur ? "now-hdr" : "")">
                    @month @(isCur ? "▸ Now" : "")
                </div>
            }

            @foreach (var cat in data.Heatmap.Categories)
            {
                <div class="hm-row-hdr @(cat.CssClass)-hdr">@cat.Emoji @cat.Name</div>
                @foreach (var mi in cat.Months)
                {
                    var isCur = IsCurrentMonth(mi.Month);
                    <div class="hm-cell @(cat.CssClass)-cell @(isCur ? "now" : "")">
                        @if (mi.Items.Length == 0)
                        {
                            <div class="it empty">-</div>
                        }
                        else
                        {
                            @foreach (var item in mi.Items)
                            {
                                <div class="it">@item</div>
                            }
                        }
                    </div>
                }
            }
        </div>
    </div>
}