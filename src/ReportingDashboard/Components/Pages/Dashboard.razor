@page "/"
@rendermode InteractiveServer
@inject DashboardDataService DataService

@if (errorMessage is not null)
{
    <div class="dashboard-root">
        <div class="error-state">
            <div class="error-icon">⚠</div>
            <div class="error-title">Dashboard Data Error</div>
            <div class="error-detail">@errorMessage</div>
            <div class="error-hint">Fix the issue in <code>wwwroot/data.json</code> and refresh the browser.</div>
        </div>
    </div>
}
else if (config is not null)
{
    <div class="dashboard-root">
        @* Section 1: Header Bar *@
        <div class="hdr">
            <div>
                <h1>
                    @(config.ProjectName ?? "Untitled Dashboard")
                    <a href="@(config.BacklogUrl ?? "#")" target="_blank"> ↗ ADO Backlog</a>
                </h1>
                <div class="sub">@(config.Workstream ?? "") • @(config.ReportMonth ?? "")</div>
            </div>
            <div class="legend">
                <span class="legend-item"><span class="legend-poc"></span> PoC Milestone</span>
                <span class="legend-item"><span class="legend-prod"></span> Production Release</span>
                <span class="legend-item"><span class="legend-chk"></span> Checkpoint</span>
                <span class="legend-item"><span class="legend-now"></span> Now (@(config.ReportMonth ?? ""))</span>
            </div>
        </div>

        @* Section 2: Timeline Area *@
        @if (config.Timeline is not null)
        {
            var milestones = config.Timeline.Milestones ?? new List<Milestone>();
            var totalMilestones = milestones.Count;
            var hasStart = DateOnly.TryParse(config.Timeline.StartDate, out var tlStart);
            var hasEnd = DateOnly.TryParse(config.Timeline.EndDate, out var tlEnd);

            <div class="tl-area">
                <div class="tl-sidebar">
                    @foreach (var ms in milestones)
                    {
                        <div class="tl-label">
                            <span class="tl-id" style="color:@(ms.Color ?? "#666")">@(ms.Id ?? "")</span>
                            <span class="tl-desc">@(ms.Label ?? "")</span>
                        </div>
                    }
                </div>
                <div class="tl-svg-box">
                    @if (hasStart && hasEnd)
                    {
                        var gridLines = ComputeGridLines(tlStart, tlEnd);
                        var nowInfo = ComputeNowLine(config.Timeline.NowDate, tlStart, tlEnd);
                        var laneData = ComputeLaneData(milestones, tlStart, tlEnd);

                        <svg width="1560" height="185" style="overflow:visible">
                            <defs>
                                <filter id="sh">
                                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                                </filter>
                            </defs>

                            @foreach (var gl in gridLines)
                            {
                                <line x1="@gl.X" y1="0" x2="@gl.X" y2="185"
                                      stroke="#bbb" stroke-width="1" opacity="0.4" />
                                <svg x="@gl.LabelX" y="0" style="overflow:visible">
                                    <text x="0" y="14"
                                          font-size="11" font-weight="600" fill="#666">@gl.Label</text>
                                </svg>
                            }

                            @if (nowInfo is not null)
                            {
                                <line x1="@nowInfo.X" y1="0" x2="@nowInfo.X" y2="185"
                                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                                <svg x="@nowInfo.X" y="0" style="overflow:visible">
                                    <text x="0" y="-2"
                                          font-size="10" font-weight="bold" fill="#EA4335"
                                          text-anchor="middle">NOW</text>
                                </svg>
                            }

                            @foreach (var lane in laneData)
                            {
                                <line x1="0" y1="@lane.Y" x2="1560" y2="@lane.Y"
                                      stroke="@lane.Color" stroke-width="3" />

                                @foreach (var marker in lane.Markers)
                                {
                                    if (marker.MarkerType == "poc")
                                    {
                                        <polygon points="@marker.DiamondPoints"
                                                 fill="#F4B400" filter="url(#sh)" />
                                    }
                                    else if (marker.MarkerType == "production")
                                    {
                                        <polygon points="@marker.DiamondPoints"
                                                 fill="#34A853" filter="url(#sh)" />
                                    }
                                    else
                                    {
                                        <circle cx="@marker.X" cy="@lane.Y" r="7"
                                                fill="white" stroke="@lane.Color" stroke-width="2.5" />
                                    }

                                    <svg x="@marker.X" y="@marker.LabelY" style="overflow:visible">
                                        <text x="0" y="0"
                                              text-anchor="middle" fill="#666" font-size="10">@marker.Label</text>
                                    </svg>
                                }
                            }
                        </svg>
                    }
                </div>
            </div>
        }

        @* Section 3: Heatmap Grid *@
        @if (config.Heatmap is not null)
        {
            var columns = config.Heatmap.Columns ?? new List<string>();
            var columnCount = columns.Count;

            <div class="hm-wrap">
                <div class="hm-title">MONTHLY EXECUTION HEATMAP — SHIPPED • IN PROGRESS • CARRYOVER • BLOCKERS</div>
                <div class="hm-grid" style="grid-template-columns: 160px repeat(@columnCount, 1fr);">

                    <div class="hm-corner">Status / Month</div>
                    @foreach (var col in columns)
                    {
                        var isCur = IsCurrentColumn(col);
                        <div class="hm-col-hdr @(isCur ? "apr-hdr" : "")">
                            @col @(isCur ? " ▸ Now" : "")
                        </div>
                    }

                    @foreach (var row in GetHeatmapRows())
                    {
                        <div class="hm-row-hdr @(row.Prefix)-hdr">@row.Label</div>
                        @foreach (var col in columns)
                        {
                            var items = GetCellItems(row.Data, col);
                            var isCur = IsCurrentColumn(col);
                            <div class="hm-cell @(row.Prefix)-cell @(isCur ? "cur" : "")">
                                @if (items.Count == 0)
                                {
                                    <span class="empty-dash">–</span>
                                }
                                else
                                {
                                    @foreach (var item in items)
                                    {
                                        <div class="it @(row.Prefix)-it">@item</div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private DashboardConfig? config;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            config = await DataService.LoadAsync();
        }
        catch (DashboardDataException ex)
        {
            errorMessage = ex.Message;
        }
    }

    private static string F(double value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string GetDiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private List<string> GetCellItems(Dictionary<string, List<string>>? dict, string column)
    {
        if (dict is null) return new List<string>();
        return dict.TryGetValue(column, out var items) ? items : new List<string>();
    }

    private bool IsCurrentColumn(string column) => column == config?.Heatmap?.CurrentColumn;

    private record HeatmapRow(string Label, string Prefix, Dictionary<string, List<string>>? Data);

    private List<HeatmapRow> GetHeatmapRows()
    {
        return new List<HeatmapRow>
        {
            new("✅ Shipped", "ship", config?.Heatmap?.Shipped),
            new("🔵 In Progress", "prog", config?.Heatmap?.InProgress),
            new("🟡 Carryover", "carry", config?.Heatmap?.Carryover),
            new("🔴 Blockers", "block", config?.Heatmap?.Blockers)
        };
    }

    // Pre-computed data structures to avoid nested @{} blocks in Razor markup

    private record GridLineInfo(string X, string LabelX, string Label);

    private static List<GridLineInfo> ComputeGridLines(DateOnly tlStart, DateOnly tlEnd)
    {
        var results = new List<GridLineInfo>();
        var gridDate = new DateOnly(tlStart.Year, tlStart.Month, 1);
        while (gridDate <= tlEnd)
        {
            var gx = DashboardDataService.GetXPosition(gridDate, tlStart, tlEnd, 1560);
            results.Add(new GridLineInfo(F(gx), F(gx + 5), gridDate.ToString("MMM")));
            gridDate = gridDate.AddMonths(1);
        }
        return results;
    }

    private record NowLineInfo(string X);

    private static NowLineInfo? ComputeNowLine(string? nowDateStr, DateOnly tlStart, DateOnly tlEnd)
    {
        if (!DateOnly.TryParse(nowDateStr, out var nowDate)) return null;
        var nowX = DashboardDataService.GetXPosition(nowDate, tlStart, tlEnd, 1560);
        return new NowLineInfo(F(nowX));
    }

    private record MarkerInfo(string X, string LabelY, string Label, string MarkerType, string DiamondPoints);
    private record LaneInfo(string Y, string Color, List<MarkerInfo> Markers);

    private static List<LaneInfo> ComputeLaneData(List<Milestone> milestones, DateOnly tlStart, DateOnly tlEnd)
    {
        var lanes = new List<LaneInfo>();
        var totalMilestones = milestones.Count;

        for (var mi = 0; mi < totalMilestones; mi++)
        {
            var ms = milestones[mi];
            var laneY = DashboardDataService.GetMilestoneLaneY(mi, totalMilestones, 185);
            var msColor = ms.Color ?? "#666";
            var markers = new List<MarkerInfo>();

            if (ms.Events is not null)
            {
                var evtIndex = 0;
                foreach (var evt in ms.Events)
                {
                    if (DateOnly.TryParse(evt.Date, out var evtDate))
                    {
                        var ex = DashboardDataService.GetXPosition(evtDate, tlStart, tlEnd, 1560);
                        var labelBelow = evtIndex % 2 == 0;
                        var labelYVal = labelBelow ? laneY + 22 : laneY - 16;
                        var evtType = evt.Type?.ToLowerInvariant() ?? "checkpoint";

                        markers.Add(new MarkerInfo(
                            F(ex),
                            F(labelYVal),
                            evt.Label ?? "",
                            evtType,
                            GetDiamondPoints(ex, laneY, 11)
                        ));
                    }
                    evtIndex++;
                }
            }

            lanes.Add(new LaneInfo(F(laneY), msColor, markers));
        }

        return lanes;
    }
}