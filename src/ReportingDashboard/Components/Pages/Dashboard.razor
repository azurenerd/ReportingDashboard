@page "/"
@using System.Text.Json
@inject DashboardDataService DataService
@inject NavigationManager Navigation

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="error-container">
        <p class="error-message">@_errorMessage</p>
    </div>
}
else if (_data is not null)
{
    <div class="placeholder">
        <h2>✅ Dashboard data loaded successfully</h2>
        <p><strong>Title:</strong> @_data.Header.Title</p>
        <p><strong>Subtitle:</strong> @_data.Header.Subtitle</p>
        <p><strong>Timeline Tracks:</strong> @_data.Timeline.Tracks.Count</p>
        <p><strong>Heatmap Columns:</strong> @_data.Heatmap.Columns.Count</p>
        <p><strong>Heatmap Rows:</strong> @_data.Heatmap.Rows.Count</p>
        <p><strong>Schema Version:</strong> @_data.SchemaVersion</p>
        <p><strong>Current Date:</strong> @_currentDate.ToString("yyyy-MM-dd")</p>
    </div>
}

@code {
    private DashboardData? _data;
    private string? _errorMessage;
    private DateOnly _currentDate;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var filename = query["data"];

            _data = await DataService.LoadAsync(filename);
            _currentDate = DateOnly.Parse(_data.Header.CurrentDate);
        }
        catch (FileNotFoundException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (JsonException ex)
        {
            _errorMessage = $"Failed to load dashboard data: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unexpected error: {ex.Message}";
        }
    }
}