@page "/"
@implements IDisposable
@rendermode InteractiveServer

@inject DashboardDataService DataService

@if (!string.IsNullOrEmpty(_error))
{
    <div class="error-container">
        <div class="error-icon">⚠</div>
        <div class="error-message">@_error</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}
else if (_data != null)
{
    <Header Project="@_data.Project" />
    <Timeline Data="@_data.Timeline" CurrentDate="@_data.Project.CurrentDate" />
    <Heatmap Data="@_data.Heatmap" />
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        _data = DataService.GetData();
        _error = DataService.GetError();
        DataService.OnDataChanged += HandleDataChanged;
    }

    private void HandleDataChanged()
    {
        _data = DataService.GetData();
        _error = DataService.GetError();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}
