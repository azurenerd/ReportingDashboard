@page "/"
@inject DashboardDataService DataService

@if (!string.IsNullOrEmpty(DataService.ErrorMessage))
{
    <ErrorPanel Message="@DataService.ErrorMessage" />
}
else if (DataService.Data is not null)
{
    <div class="dashboard">
        <Header Data="@DataService.Data" />

        <div class="tl-area">
            <p style="padding:24px;color:#888;">Timeline placeholder – implemented in a later step.</p>
        </div>

        <div class="hm-wrap">
            <p style="padding:24px;color:#888;">Heatmap placeholder – implemented in a later step.</p>
        </div>
    </div>
}
else
{
    <ErrorPanel Message="Dashboard data is not available." />
}