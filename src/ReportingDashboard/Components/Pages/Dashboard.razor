@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject DashboardDataService DataService

@if (DataService.IsError)
{
    <ErrorPanel ErrorMessage="@DataService.ErrorMessage" />
}
else if (DataService.Data is not null)
{
    var data = DataService.Data;

    <ReportingDashboard.Components.Header Data="@data" />

    <Timeline TimelineData="@data.Timeline" />

    <Heatmap HeatmapData="@data.Heatmap"
             Months="@data.Months"
             CurrentMonth="@data.CurrentMonth" />
}
else
{
    <ErrorPanel ErrorMessage="Dashboard data is not available" />
}

