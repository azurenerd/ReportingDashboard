@page "/"
@inject IDashboardDataService DataService
@implements IDisposable
@rendermode RenderMode.InteractiveServer

@{
    var data = DataService.GetData();
    var error = DataService.GetError();
}

@if (data is null)
{
    <div class="error-panel">
        <div class="error-icon">⚠</div>
        <div class="error-message">@(error ?? "Loading dashboard data...")</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}
else
{
    <Header Project="data.Project" />
    <Timeline TimelineInfo="data.Timeline" CurrentDate="data.Project.CurrentDate" />
    <Heatmap HeatmapInfo="data.Heatmap" />
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private async void HandleDataChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}