@page "/"
@inject IDashboardDataService DataService
@implements IDisposable
@rendermode RenderMode.InteractiveServer

@{
    var data = DataService.GetData();
    var error = DataService.GetError();
}

@if (error is not null)
{
    <div class="error-container">
        <div class="error-icon">⚠</div>
        <div class="error-text">@error</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}
else if (data is not null)
{
    <div class="page">
        <Header Project="data.Project" />
        <Timeline TimelineData="data.Timeline" CurrentDate="data.Project.CurrentDate" />
        <Heatmap HeatmapData="data.Heatmap" />
    </div>
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private void HandleDataChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}