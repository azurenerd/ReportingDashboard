@page "/"
@inject DashboardDataService DataService
@implements IDisposable
@rendermode RenderMode.InteractiveServer

@if (DataService.HasError)
{
    <div class="error-container">
        <div class="error-icon">⚠</div>
        <div class="error-text">@DataService.ErrorMessage</div>
    </div>
}
else if (DataService.Data is not null)
{
    var data = DataService.Data;
    <div class="page">
        <Header Project="data.Project" />
        <Timeline TimelineData="data.Timeline" CurrentDate="data.Project.CurrentDate" />
        <Heatmap HeatmapData="data.Heatmap" />
    </div>
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private void HandleDataChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}