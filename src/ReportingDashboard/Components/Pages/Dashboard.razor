@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

@if (_error is not null)
{
    <div class="error-container">
        <div class="error-message">@_error</div>
    </div>
}
else if (_data is not null)
{
    <div class="dashboard">
        <div class="hdr">
            <div>
                <h1>
                    @_data.Title
                    @if (!string.IsNullOrEmpty(_data.BacklogLink))
                    {
                        <a href="@_data.BacklogLink" target="_blank">&#x2197; ADO Backlog</a>
                    }
                </h1>
                <div class="sub">@_data.Subtitle</div>
            </div>
        </div>

        @* Timeline and heatmap sections will be added in subsequent steps *@
    </div>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        if (DataService.IsError)
        {
            if (string.IsNullOrEmpty(DataService.ErrorMessage) ||
                DataService.ErrorMessage.Contains("not found", StringComparison.OrdinalIgnoreCase) ||
                DataService.ErrorMessage.Contains("could not be loaded", StringComparison.OrdinalIgnoreCase))
            {
                _error = "Dashboard data not found. Please ensure data.json exists in the wwwroot folder.";
            }
            else
            {
                _error = $"Error reading dashboard data: {DataService.ErrorMessage}";
            }
        }
        else
        {
            _data = DataService.Data;
        }
    }
}