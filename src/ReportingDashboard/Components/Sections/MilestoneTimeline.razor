@inject DashboardDataService DataService

@if (DataService.Data?.Milestones is { Count: > 0 })
{
    <div class="section">
        <h2>Milestone Timeline</h2>
        <div class="timeline-track">
            @foreach (var milestone in DataService.Data.Milestones)
            {
                <div class="timeline-item @GetMilestoneClass(milestone.Status)">
                    <div class="timeline-marker"></div>
                    <span class="milestone-title">@milestone.Title</span>
                    <span class="milestone-date">@milestone.TargetDate</span>
                    <span class="milestone-status">@milestone.Status</span>
                </div>
            }
        </div>
    </div>
}

@code {
    private static string GetMilestoneClass(string status) => status.ToLowerInvariant().Replace(" ", "-") switch
    {
        "completed" => "milestone-completed",
        "in-progress" => "milestone-in-progress",
        "at-risk" => "milestone-at-risk",
        "upcoming" => "milestone-upcoming",
        _ => "milestone-upcoming"
    };
}