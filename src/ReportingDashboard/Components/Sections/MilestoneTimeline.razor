@using ReportingDashboard.Models

@if (SortedMilestones.Count > 0)
{
    <section class="milestone-timeline">
        <div class="section-header">
            <h2>Milestones</h2>
            <span class="item-count">@SortedMilestones.Count</span>
        </div>
        <div class="timeline-track">
        </div>
    </section>
}

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = [];

    private List<Milestone> SortedMilestones =>
        (Milestones ?? []).OrderBy(m => m.Date).ToList();

    private string GetStatusClass(string status) => status switch
    {
        "completed" => "completed",
        "in-progress" => "in-progress",
        "at-risk" => "at-risk",
        "upcoming" => "upcoming",
        _ => "upcoming"
    };
}