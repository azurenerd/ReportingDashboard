@using ReportingDashboard.Models

@if (SortedMilestones.Count > 0)
{
    <section class="milestone-timeline">
        <div class="section-header">
            <h2>Milestones</h2>
            <span class="item-count">@SortedMilestones.Count</span>
        </div>
        <div class="timeline-track" style="grid-template-columns: repeat(@SortedMilestones.Count, 1fr)">
            @foreach (var milestone in SortedMilestones)
            {
                <div class="timeline-milestone">
                    <div class="milestone-title">@milestone.Title</div>
                    <div class="milestone-marker @GetStatusClass(milestone.Status)"></div>
                    <span class="status-badge @GetStatusClass(milestone.Status)">@FormatStatusLabel(milestone.Status)</span>
                    <div class="milestone-date">@FormatDate(milestone.Date)</div>
                    @if (!string.IsNullOrWhiteSpace(milestone.Description))
                    {
                        <div class="milestone-description">@milestone.Description</div>
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = [];

    private List<Milestone> SortedMilestones =>
        (Milestones ?? []).OrderBy(m => m.Date).ToList();

    private string GetStatusClass(string status) => status switch
    {
        "completed" => "completed",
        "in-progress" => "in-progress",
        "at-risk" => "at-risk",
        "upcoming" => "upcoming",
        _ => "upcoming"
    };

    private string FormatDate(string? date)
    {
        if (string.IsNullOrWhiteSpace(date))
            return "TBD";

        if (DateTime.TryParse(date, out var parsed))
            return parsed.ToString("MMM d, yyyy");

        return date;
    }

    private string FormatStatusLabel(string status) => status switch
    {
        "completed" => "Complete",
        "in-progress" => "In Progress",
        "at-risk" => "At Risk",
        "upcoming" => "Upcoming",
        _ => "Upcoming"
    };
}