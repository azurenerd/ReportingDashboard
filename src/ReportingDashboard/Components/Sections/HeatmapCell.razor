<div class="hm-cell @(CssCategory)-cell @(IsHighlight ? CssCategory + "-hl" : "")" style="@(IsLastColumn ? "border-right:none;" : "")">
    @if (Items.Count == 0)
    {
        <div class="it @(CssCategory)-it empty">&ndash;</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="it @(CssCategory)-it">@item</div>
        }
    }
</div>

@code {
    [Parameter]
    public List<string> Items { get; set; } = new();

    [Parameter]
    public string CssCategory { get; set; } = "";

    [Parameter]
    public bool IsHighlight { get; set; }

    [Parameter]
    public bool IsLastColumn { get; set; }
}