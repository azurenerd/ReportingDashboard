<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap — Shipped · In Progress · Carryover · Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@HeatmapInfo.Months.Count, 1fr);">
        @* Header row *@
        <div class="hm-corner">Status</div>
        @for (int i = 0; i < HeatmapInfo.Months.Count; i++)
        {
            var month = HeatmapInfo.Months[i];
            var isHighlight = month == HeatmapInfo.HighlightMonth;
            var isLast = i == HeatmapInfo.Months.Count - 1;
            <div class="hm-col-hdr @(isHighlight ? "apr-hdr" : "")" style="@(isLast ? "border-right:none;" : "")">
                @month@(isHighlight ? " ★ Now" : "")
            </div>
        }

        @* Data rows *@
        @foreach (var row in HeatmapInfo.Rows)
        {
            var cssPrefix = GetCssPrefix(row.Category);
            var emoji = GetEmoji(row.Category);

            <div class="hm-row-hdr @(cssPrefix)-hdr">@emoji @row.Category</div>

            @for (int i = 0; i < HeatmapInfo.Months.Count; i++)
            {
                var month = HeatmapInfo.Months[i];
                var isHighlight = month == HeatmapInfo.HighlightMonth;
                var isLast = i == HeatmapInfo.Months.Count - 1;
                var items = row.Items.TryGetValue(month, out var list) ? list : new List<string>();

                <HeatmapCell Items="items"
                             CssClass="@(cssPrefix)-cell"
                             IsHighlighted="isHighlight"
                             IsLastColumn="isLast" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData HeatmapInfo { get; set; } = new();

    private static string GetCssPrefix(string category) => category switch
    {
        "Shipped" => "ship",
        "In Progress" => "prog",
        "Carryover" => "carry",
        "Blockers" => "block",
        _ => "ship"
    };

    private static string GetEmoji(string category) => category switch
    {
        "Shipped" => "✅",
        "In Progress" => "🔵",
        "Carryover" => "🟡",
        "Blockers" => "🔴",
        _ => ""
    };
}