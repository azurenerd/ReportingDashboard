@namespace ReportingDashboard.Components.Sections

@if (Project is null)
{
    <div class="project-header project-header--empty">No project data available</div>
}
else
{
    <section class="project-header">
        <div class="project-header__title-row">
            <h1 class="project-header__name">@Project.Name</h1>
            <span class="status-badge status-badge--@GetHealthCssClass(Project.OverallHealth)">@(Project.OverallHealth ?? Project.Status)</span>
        </div>
        <div class="project-header__meta">
            <span><strong>Lead:</strong> @(Project.Lead ?? "N/A")</span>
            <span><strong>Last Updated:</strong> @(Project.LastUpdated ?? "N/A")</span>
        </div>
        @if (Project.Summary is not null)
        {
            <p class="project-header__summary">@Project.Summary</p>
        }
    </section>
}

@code {
    [Parameter] public ProjectInfo? Project { get; set; }

    private static string GetHealthCssClass(string? health)
    {
        return health?.ToLowerInvariant() switch
        {
            "on-track" => "on-track",
            "at-risk" => "at-risk",
            "behind" => "behind",
            _ => "unknown"
        };
    }
}