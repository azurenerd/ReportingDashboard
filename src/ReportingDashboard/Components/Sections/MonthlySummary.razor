<div class="section monthly-summary">
    <h2>📊 Monthly Summary</h2>
    @if (Summary is not null)
    {
        <div class="metrics-grid">
            <div class="metric-card">
                <span class="metric-value">@Summary.Month</span>
                <span class="metric-label">Current Month</span>
            </div>
            <div class="metric-card">
                <span class="metric-value">@Summary.TotalItems</span>
                <span class="metric-label">Total Items</span>
            </div>
            <div class="metric-card">
                <span class="metric-value">@Summary.CompletedItems</span>
                <span class="metric-label">Completed</span>
            </div>
            <div class="metric-card">
                <span class="metric-value health-@GetHealthClass()">@Summary.OverallHealth</span>
                <span class="metric-label">Overall Health</span>
            </div>
        </div>
    }
    else
    {
        <p style="color:#888;">No monthly summary data available.</p>
    }
</div>

@code {
    [Parameter] public MonthSummary? Summary { get; set; }

    private string GetHealthClass()
    {
        return (Summary?.OverallHealth?.ToLowerInvariant()) switch
        {
            "on track" or "on-track" => "on-track",
            "at risk" or "at-risk" => "at-risk",
            "behind" => "behind",
            _ => ""
        };
    }
}