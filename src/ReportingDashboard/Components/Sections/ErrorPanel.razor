@namespace ReportingDashboard.Components.Sections

<div class="error-panel">
    <div class="error-panel-content">
        <div class="error-icon" style="font-size:48px; color:#EA4335;">&#x26A0;</div>
        <div class="error-title" style="font-size:20px; font-weight:700; color:#333; margin:16px 0 8px;">Dashboard data could not be loaded</div>
        <div class="error-details" style="font-size:14px; color:#666; font-family:Consolas,monospace; max-width:600px; word-break:break-word; margin:0 auto 12px;">@ErrorMessage</div>
        <div class="error-help" style="font-size:12px; color:#888;">Check data.json for errors and restart the application.</div>
    </div>
</div>

@code {
    [Parameter]
    public string? ErrorMessage { get; set; }
}