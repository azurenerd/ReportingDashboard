<section class="carried-over-items">
    <!-- Full implementation in T7 -->
    @if (Items.Count > 0)
    {
        <h2>Carried Over <span class="item-count">@Items.Count</span></h2>
        @foreach (var item in Items)
        {
            <div class="work-item-stub">@item.Title</div>
        }
    }
</section>

@code {
    [Parameter]
    public List<WorkItem> Items { get; set; } = [];
}