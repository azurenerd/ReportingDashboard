@using ReportingDashboard.Models

@if (SafeItems.Count > 0)
{
    <section class="dashboard-section carried-over-section">
        <div class="section-header">
            <h2>Carried Over</h2>
            <span class="item-count">@SafeItems.Count</span>
        </div>

        @foreach (var item in SafeItems)
        {
            <div class="work-item-card carried-over">
                <div class="card-header">
                    <h3>@item.Title</h3>
                    @if (!string.IsNullOrWhiteSpace(item.Category))
                    {
                        <span class="category-tag">@item.Category</span>
                    }
                </div>
                <div class="carry-over-reason">
                    @if (!string.IsNullOrWhiteSpace(item.CarryOverReason))
                    {
                        <p><strong>Reason:</strong> @item.CarryOverReason</p>
                    }
                    else
                    {
                        <p class="text-muted"><em>No reason provided</em></p>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Description))
                {
                    <div class="card-body">
                        <p>@item.Description</p>
                    </div>
                }
                @if (GetPercent(item) > 0)
                {
                    <div class="card-footer">
                        <div class="progress-track">
                            <div class="progress-fill carried-over" style="width: @(GetPercent(item))%"></div>
                        </div>
                        <span class="progress-label">@(GetPercent(item))%</span>
                    </div>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public List<WorkItem>? Items { get; set; }

    private List<WorkItem> SafeItems => Items ?? [];

    private int GetPercent(WorkItem item) => Math.Clamp(item.PercentComplete ?? 0, 0, 100);
}