@using ReportingDashboard.Models

<div class="status-sections">
    @* Shipped Column *@
    <div class="status-column">
        <div class="status-header status-header--shipped">
            <span class="status-header__title">Shipped</span>
            <span class="status-header__badge">@ShippedItems.Count</span>
        </div>
        <div class="status-card-list">
            @if (ShippedItems.Count == 0)
            {
                <div class="status-card status-card--empty">
                    <span class="status-card__empty-text">No shipped items</span>
                </div>
            }
            else
            {
                @foreach (var item in ShippedItems)
                {
                    <div class="status-card">
                        <div class="status-card__header">
                            <span class="status-indicator status-indicator--shipped"></span>
                            <span class="status-card__title">@item.Title</span>
                        </div>
                        @if (!string.IsNullOrEmpty(item.Owner))
                        {
                            <span class="status-card__owner">@item.Owner</span>
                        }
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <p class="status-card__notes">@item.Notes</p>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* In Progress Column *@
    <div class="status-column">
        <div class="status-header status-header--in-progress">
            <span class="status-header__title">In Progress</span>
            <span class="status-header__badge">@InProgressItems.Count</span>
        </div>
        <div class="status-card-list">
            @if (InProgressItems.Count == 0)
            {
                <div class="status-card status-card--empty">
                    <span class="status-card__empty-text">No in-progress items</span>
                </div>
            }
            else
            {
                @foreach (var item in InProgressItems)
                {
                    <div class="status-card">
                        <div class="status-card__header">
                            <span class="status-indicator status-indicator--in-progress"></span>
                            <span class="status-card__title">@item.Title</span>
                        </div>
                        @if (!string.IsNullOrEmpty(item.Owner))
                        {
                            <span class="status-card__owner">@item.Owner</span>
                        }
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <p class="status-card__notes">@item.Notes</p>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* Carried Over Column *@
    <div class="status-column">
        <div class="status-header status-header--carried-over">
            <span class="status-header__title">Carried Over</span>
            <span class="status-header__badge">@CarriedOverItems.Count</span>
        </div>
        <div class="status-card-list">
            @if (CarriedOverItems.Count == 0)
            {
                <div class="status-card status-card--empty">
                    <span class="status-card__empty-text">No carried-over items</span>
                </div>
            }
            else
            {
                @foreach (var item in CarriedOverItems)
                {
                    <div class="status-card">
                        <div class="status-card__header">
                            <span class="status-indicator status-indicator--carried-over"></span>
                            <span class="status-card__title">@item.Title</span>
                        </div>
                        @if (!string.IsNullOrEmpty(item.Owner))
                        {
                            <span class="status-card__owner">@item.Owner</span>
                        }
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <p class="status-card__notes">@item.Notes</p>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<WorkItem> ShippedItems { get; set; } = new();

    [Parameter]
    public List<WorkItem> InProgressItems { get; set; } = new();

    [Parameter]
    public List<WorkItem> CarriedOverItems { get; set; } = new();
}