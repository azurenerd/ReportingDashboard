@using ReportingDashboard.Models

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in TimelineData.Tracks)
        {
            <div class="tl-label">
                <span class="tl-track-id" style="color: @track.Color;">@track.Name</span>
                <span class="tl-track-name">@track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        @((MarkupString)RenderSvg())
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineData { get; set; } = default!;

    private const double SvgWidth = 1560;
    private double SvgHeight => Math.Max(185, TimelineData.Tracks.Count * 56);
    private DateTime StartDate => DateTime.Parse(TimelineData.StartDate);
    private DateTime EndDate => DateTime.Parse(TimelineData.EndDate);
    private int MonthCount => (int)Math.Ceiling((EndDate - StartDate).TotalDays / 30.44);
    private double MonthWidth => SvgWidth / MonthCount;

    private List<string> MonthLabels
    {
        get
        {
            var labels = new List<string>();
            var current = new DateTime(StartDate.Year, StartDate.Month, 1);
            while (current < EndDate)
            {
                labels.Add(current.ToString("MMM"));
                current = current.AddMonths(1);
            }
            return labels;
        }
    }

    private double DateToX(string dateStr)
    {
        if (!DateTime.TryParse(dateStr, out var date)) return 0;
        var totalDays = (EndDate - StartDate).TotalDays;
        var elapsed = (date - StartDate).TotalDays;
        return (elapsed / totalDays) * SvgWidth;
    }

    private double TrackToY(int trackIndex)
    {
        var spacing = SvgHeight / (TimelineData.Tracks.Count + 1);
        return spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double v) => v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private static string Enc(string s) => System.Net.WebUtility.HtmlEncode(s);

    private string RenderSvg()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg width=\"{SvgWidth}\" height=\"{F(SvgHeight)}\" overflow=\"visible\" style=\"font-family: 'Segoe UI', Arial, sans-serif;\">");
        sb.Append("<defs><filter id=\"sh\"><feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\" /></filter></defs>");

        // Month grid lines and labels
        var monthLabels = MonthLabels;
        for (int i = 0; i < MonthCount && i < monthLabels.Count; i++)
        {
            var x = i * MonthWidth;
            sb.Append($"<line x1=\"{F(x)}\" y1=\"0\" x2=\"{F(x)}\" y2=\"{F(SvgHeight)}\" stroke=\"#bbb\" stroke-opacity=\"0.4\" />");
            sb.Append($"<text x=\"{F(x + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\">{Enc(monthLabels[i])}</text>");
        }

        // Track lines and milestones
        for (int i = 0; i < TimelineData.Tracks.Count; i++)
        {
            var track = TimelineData.Tracks[i];
            var y = TrackToY(i);
            sb.Append($"<line x1=\"0\" y1=\"{F(y)}\" x2=\"{F(SvgWidth)}\" y2=\"{F(y)}\" stroke=\"{Enc(track.Color)}\" stroke-width=\"3\" />");

            foreach (var ms in track.Milestones)
            {
                var msX = DateToX(ms.Date);
                if (ms.Type == "poc")
                {
                    sb.Append($"<polygon points=\"{DiamondPoints(msX, y)}\" fill=\"#F4B400\" filter=\"url(#sh)\"><title>{Enc(ms.Label)}</title></polygon>");
                }
                else if (ms.Type == "production")
                {
                    sb.Append($"<polygon points=\"{DiamondPoints(msX, y)}\" fill=\"#34A853\" filter=\"url(#sh)\"><title>{Enc(ms.Label)}</title></polygon>");
                }
                else
                {
                    sb.Append($"<circle cx=\"{F(msX)}\" cy=\"{F(y)}\" r=\"5\" fill=\"white\" stroke=\"{Enc(track.Color)}\" stroke-width=\"2.5\"><title>{Enc(ms.Label)}</title></circle>");
                }
                sb.Append($"<text x=\"{F(msX)}\" y=\"{F(y - 16)}\" text-anchor=\"middle\" fill=\"#666\" font-size=\"10\">{Enc(ms.Label)}</text>");
            }
        }

        // NOW line
        var nowX = DateToX(TimelineData.NowDate);
        sb.Append($"<line x1=\"{F(nowX)}\" y1=\"0\" x2=\"{F(nowX)}\" y2=\"{F(SvgHeight)}\" stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"5,3\" />");
        sb.Append($"<text x=\"{F(nowX)}\" y=\"{F(SvgHeight - 4)}\" text-anchor=\"middle\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\">NOW</text>");

        sb.Append("</svg>");
        return sb.ToString();
    }
}