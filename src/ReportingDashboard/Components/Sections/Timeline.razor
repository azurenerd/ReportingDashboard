@{
    var startDate = ParseDate(TimelineData.StartDate);
    var endDate = ParseDate(TimelineData.EndDate);
    var now = ParseDate(CurrentDate);
    var totalDays = (endDate - startDate).TotalDays;
    if (totalDays <= 0) totalDays = 1;
    var tracks = TimelineData.Tracks;
    var trackCount = tracks.Count;
    const double svgWidth = 1560;
    const double svgHeight = 185;
    var trackSpacing = trackCount > 1 ? (svgHeight - 56) / (trackCount - 1) : 0.0;
}

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in tracks)
        {
            <div class="tl-track-label">
                <span class="tl-track-id" style="color: @track.Color;">@track.Id</span>
                <span class="tl-track-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-wrap">
        <svg width="@svgWidth" height="@svgHeight" overflow="visible" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="ds" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines *@
            @{
                var cursor = new DateTime(startDate.Year, startDate.Month, 1);
                if (cursor < startDate) cursor = cursor.AddMonths(1);
            }
            @while (cursor <= endDate)
            {
                var x = DateToX(cursor, startDate, totalDays, svgWidth);
                var monthLabel = cursor.ToString("MMM", CultureInfo.InvariantCulture);
                <line x1="@F(x)" y1="0" x2="@F(x)" y2="@F(svgHeight)" stroke="#BBB" stroke-opacity="0.4" stroke-width="1" />
                <text x="@F(x + 5)" y="14" font-size="11" font-weight="600" fill="#666" font-family="Segoe UI, Arial">@monthLabel</text>
                cursor = cursor.AddMonths(1);
            }

            @* NOW line *@
            @if (now >= startDate && now <= endDate)
            {
                var nowX = DateToX(now, startDate, totalDays, svgWidth);
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@F(svgHeight)" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(nowX)" y="@F(svgHeight - 2)" font-size="10" font-weight="700" fill="#EA4335" text-anchor="middle">NOW</text>
            }

            @* Track lines and milestones *@
            @for (int t = 0; t < trackCount; t++)
            {
                var track = tracks[t];
                var y = 28 + (trackCount > 1 ? t * trackSpacing : svgHeight / 2.0 - 28);

                <line x1="0" y1="@F(y)" x2="@F(svgWidth)" y2="@F(y)" stroke="@track.Color" stroke-width="3" />

                @for (int m = 0; m < track.Milestones.Count; m++)
                {
                    var ms = track.Milestones[m];
                    var msDate = ParseDate(ms.Date);
                    var mx = DateToX(msDate, startDate, totalDays, svgWidth);
                    var labelAbove = m % 2 == 0;
                    var labelY = labelAbove ? y - 16 : y + 22;

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="6" fill="white" stroke="@(string.IsNullOrEmpty(track.Color) ? "#888" : track.Color)" stroke-width="2.5" />
                    }
                    else if (ms.Type == "poc")
                    {
                        <polygon points="@Diamond(mx, y, 11)" fill="#F4B400" filter="url(#ds)" />
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@Diamond(mx, y, 11)" fill="#34A853" filter="url(#ds)" />
                    }

                    <text x="@F(mx)" y="@F(labelY)" font-size="10" fill="#666" text-anchor="middle" font-family="Segoe UI, Arial">@ms.Label</text>
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TimelineData TimelineData { get; set; } = default!;

    [Parameter]
    public string CurrentDate { get; set; } = "";

    private static DateTime ParseDate(string dateStr)
    {
        if (DateTime.TryParse(dateStr, CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt))
            return dt;
        return DateTime.Today;
    }

    private static double DateToX(DateTime date, DateTime start, double totalDays, double width)
    {
        var days = (date - start).TotalDays;
        return days / totalDays * width;
    }

    private static string F(double val) => val.ToString("0.#", CultureInfo.InvariantCulture);

    private static string Diamond(double cx, double cy, double size)
    {
        var half = size / 2.0;
        return $"{F(cx)},{F(cy - half)} {F(cx + half)},{F(cy)} {F(cx)},{F(cy + half)} {F(cx - half)},{F(cy)}";
    }
}