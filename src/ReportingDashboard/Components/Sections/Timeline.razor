<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in TimelineInfo.Tracks)
        {
            <div class="tl-track-label" style="color: @track.Color;">
                @track.Id<br />
                <span class="tl-track-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg xmlns="http://www.w3.org/2000/svg" width="1560" height="185" style="overflow:visible;display:block">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines *@
            @foreach (var mg in _monthGridlines)
            {
                <line x1="@F(mg.X)" y1="0" x2="@F(mg.X)" y2="185" stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                <text x="@F(mg.X + 5)" y="14" fill="#666" font-size="11" font-weight="600" font-family="Segoe UI,Arial">@mg.Label</text>
            }

            @* NOW line *@
            @if (_nowX >= 0)
            {
                <line x1="@F(_nowX)" y1="0" x2="@F(_nowX)" y2="185" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(_nowX + 4)" y="14" fill="#EA4335" font-size="10" font-weight="700" font-family="Segoe UI,Arial">NOW</text>
            }

            @* Track lines and milestones *@
            @for (int t = 0; t < TimelineInfo.Tracks.Count; t++)
            {
                var track = TimelineInfo.Tracks[t];
                var trackY = GetTrackY(t);

                <line x1="0" y1="@F(trackY)" x2="1560" y2="@F(trackY)" stroke="@track.Color" stroke-width="3" />

                @for (int m = 0; m < track.Milestones.Count; m++)
                {
                    var ms = track.Milestones[m];
                    var msX = GetXPosition(ms.Date);
                    var labelAbove = (m % 2 == 0);

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(msX)" cy="@F(trackY)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5" />
                        @if (labelAbove)
                        {
                            <text x="@F(msX)" y="@F(trackY - 16)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                        else
                        {
                            <text x="@F(msX)" y="@F(trackY + 24)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                    }
                    else if (ms.Type == "poc")
                    {
                        var pts = DiamondPoints(msX, trackY, 11);
                        <polygon points="@pts" fill="#F4B400" filter="url(#sh)" />
                        @if (labelAbove)
                        {
                            <text x="@F(msX)" y="@F(trackY - 16)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                        else
                        {
                            <text x="@F(msX)" y="@F(trackY + 24)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                    }
                    else if (ms.Type == "production")
                    {
                        var pts = DiamondPoints(msX, trackY, 11);
                        <polygon points="@pts" fill="#34A853" filter="url(#sh)" />
                        @if (labelAbove)
                        {
                            <text x="@F(msX)" y="@F(trackY - 16)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                        else
                        {
                            <text x="@F(msX)" y="@F(trackY + 24)" text-anchor="middle" fill="#666" font-size="10" font-family="Segoe UI,Arial">@ms.Label</text>
                        }
                    }
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineInfo { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = "";

    private record MonthGridline(double X, string Label);
    private List<MonthGridline> _monthGridlines = new();
    private double _nowX = -1;
    private DateOnly _startDate;
    private DateOnly _endDate;
    private double _totalDays;

    protected override void OnParametersSet()
    {
        if (!DateOnly.TryParse(TimelineInfo.StartDate, out _startDate) ||
            !DateOnly.TryParse(TimelineInfo.EndDate, out _endDate))
            return;

        _totalDays = (_endDate.ToDateTime(TimeOnly.MinValue) - _startDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
        if (_totalDays <= 0) return;

        // Build month gridlines
        _monthGridlines = new List<MonthGridline>();
        var current = new DateOnly(_startDate.Year, _startDate.Month, 1);
        while (current <= _endDate)
        {
            var x = GetXForDate(current);
            _monthGridlines.Add(new MonthGridline(x, current.ToString("MMM")));
            current = current.AddMonths(1);
        }

        // NOW line
        if (DateOnly.TryParse(CurrentDate, out var nowDate))
        {
            _nowX = GetXForDate(nowDate);
        }
    }

    private double GetXForDate(DateOnly date)
    {
        var days = (date.ToDateTime(TimeOnly.MinValue) - _startDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
        return (days / _totalDays) * 1560.0;
    }

    private double GetXPosition(string dateStr)
    {
        if (DateOnly.TryParse(dateStr, out var date))
            return GetXForDate(date);
        return 0;
    }

    private double GetTrackY(int trackIndex)
    {
        int count = TimelineInfo.Tracks.Count;
        if (count <= 1) return 92; // centered
        double top = 42;
        double bottom = 154;
        return top + (trackIndex * (bottom - top) / (count - 1));
    }

    private static string DiamondPoints(double cx, double cy, double size)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private static string F(double v) => v.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
}