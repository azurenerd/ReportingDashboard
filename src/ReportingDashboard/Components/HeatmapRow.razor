<div class="hm-row-hdr @Category-hdr">@Label</div>
@foreach (var month in Months)
{
    var items = Items.TryGetValue(month, out var list) ? list : null;
    var isCurrent = month == CurrentMonth;
    <HeatmapCell Category="@Category" Items="@items" IsCurrent="@isCurrent" />
}

@code {
    [Parameter] public string Category { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public List<string> Months { get; set; } = new();
    [Parameter] public string CurrentMonth { get; set; } = "";
    [Parameter] public Dictionary<string, List<string>> Items { get; set; } = new();
}