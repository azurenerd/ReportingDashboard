<div class="hm-row-hdr @(CssPrefix)-hdr">@CategoryLabel</div>
@foreach (var month in Months)
{
    var key = month.ToLower(System.Globalization.CultureInfo.InvariantCulture);
    var items = Items.GetValueOrDefault(key, new List<string>());
    var isCurrentMonth = month.Equals(CurrentMonth, StringComparison.OrdinalIgnoreCase);

    <HeatmapCell Items="@items"
                 CssPrefix="@CssPrefix"
                 IsCurrentMonth="@isCurrentMonth" />
}

@code {
    [Parameter]
    public string CategoryLabel { get; set; } = default!;

    [Parameter]
    public string CssPrefix { get; set; } = default!;

    [Parameter]
    public Dictionary<string, List<string>> Items { get; set; } = default!;

    [Parameter]
    public List<string> Months { get; set; } = default!;

    [Parameter]
    public string CurrentMonth { get; set; } = default!;
}