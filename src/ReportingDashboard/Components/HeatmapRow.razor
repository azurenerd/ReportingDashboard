@* HeatmapRow component — full styling in T6 *@
<div class="@CssPrefix-row-hdr" style="padding:8px 12px; font-size:12px; font-weight:600; background:#FAFAFA; border-bottom:1px solid #E0E0E0; border-right:1px solid #E0E0E0;">
    @CategoryLabel
</div>
@if (Months is not null)
{
    @foreach (var month in Months)
    {
        var items = Items?.ContainsKey(month) == true ? Items[month] : new List<string>();
        <HeatmapCell Items="@items" CssPrefix="@CssPrefix" IsCurrentMonth="@(month == CurrentMonth)" />
    }
}

@code {
    [Parameter] public string CategoryLabel { get; set; } = "";
    [Parameter] public string CssPrefix { get; set; } = "";
    [Parameter] public Dictionary<string, List<string>>? Items { get; set; }
    [Parameter] public List<string>? Months { get; set; }
    [Parameter] public string CurrentMonth { get; set; } = "";
}