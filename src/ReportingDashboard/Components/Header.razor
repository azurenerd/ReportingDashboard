<div class="hdr">
    <div>
        <h1>
            @(Data?.Title ?? "Untitled Project")
            @if (!string.IsNullOrEmpty(Data?.BacklogLink))
            {
                <a href="@Data.BacklogLink" target="_blank" rel="noopener noreferrer">📋 ADO Backlog</a>
            }
        </h1>
        <div class="sub">@(Data?.Subtitle ?? "")</div>
    </div>
    <div class="legend">
        <span class="legend-item">
            <span class="legend-diamond-poc"></span> PoC Milestone
        </span>
        <span class="legend-item">
            <span class="legend-diamond-prod"></span> Production Release
        </span>
        <span class="legend-item">
            <span class="legend-checkpoint"></span> Checkpoint
        </span>
        <span class="legend-item">
            <span class="legend-now"></span> Now@(NowLabel)
        </span>
    </div>
</div>

@code {
    [Parameter]
    public DashboardData? Data { get; set; }

    private string NowLabel =>
        string.IsNullOrEmpty(Data?.CurrentMonth) ? "" : $" ({Data.CurrentMonth})";
}