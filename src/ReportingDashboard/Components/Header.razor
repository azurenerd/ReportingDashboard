@* Header component — full implementation in T2 *@
<div class="hdr" style="padding:16px 24px; border-bottom:1px solid #E0E0E0; display:flex; justify-content:space-between; align-items:flex-start;">
    <div>
        @if (Data is not null)
        {
            <div style="display:flex; align-items:center; gap:12px;">
                <h1 style="font-size:24px; font-weight:700; margin:0;">@Data.Title</h1>
                @if (!string.IsNullOrEmpty(Data.BacklogLink))
                {
                    <a href="@Data.BacklogLink" target="_blank" style="color:#0078D4; font-size:13px; text-decoration:none;">📋 ADO Backlog</a>
                }
            </div>
            <p class="sub" style="font-size:12px; color:#888; margin-top:4px;">@Data.Subtitle</p>
        }
    </div>
    <div style="display:flex; gap:22px; align-items:center; font-size:12px; color:#666;">
        <span>◆ PoC Milestone</span>
        <span>◆ Production Release</span>
        <span>● Checkpoint</span>
        <span style="color:#EA4335;">| NOW</span>
    </div>
</div>

@code {
    [Parameter] public DashboardData? Data { get; set; }
}