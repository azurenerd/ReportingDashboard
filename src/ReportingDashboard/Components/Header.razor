<div class="hdr">
    <div>
        <h1 class="hdr-title">
            @Data.Title
            @if (!string.IsNullOrEmpty(Data.BacklogLink))
            {
                <a href="@Data.BacklogLink" style="color:#0078D4; text-decoration:none; font-size:14px; margin-left:12px;" target="_blank" rel="noopener noreferrer">↗ ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div style="display:flex; gap:22px; align-items:center; font-size:12px;">
        <span style="display:flex; align-items:center; gap:6px;">
            <span style="display:inline-block; width:12px;height:12px; background:#F4B400; transform:rotate(45deg);"></span> PoC Milestone
        </span>
        <span style="display:flex; align-items:center; gap:6px;">
            <span style="display:inline-block; width:12px;height:12px; background:#34A853; transform:rotate(45deg);"></span> Production Release
        </span>
        <span style="display:flex; align-items:center; gap:6px;">
            <span style="display:inline-block; width:8px;height:8px; border-radius:50%; background:#999;"></span> Checkpoint
        </span>
        <span style="display:flex; align-items:center; gap:6px;">
            <span style="display:inline-block; width:2px; height:14px; background:#EA4335;"></span> @NowLabel
        </span>
    </div>
</div>

@code {
    [Parameter] public DashboardData Data { get; set; } = default!;

    private string NowLabel
    {
        get
        {
            var month = Data.CurrentMonth;
            if (string.IsNullOrEmpty(month))
                return "Now ()";
            if (Data.Timeline != null && DateTime.TryParse(Data.Timeline.NowDate, out var nowDate))
                return $"Now ({month} {nowDate.Year})";
            if (Data.Timeline != null && DateTime.TryParse(Data.Timeline.StartDate, out var startDate))
                return $"Now ({month} {startDate.Year})";
            return $"Now ({month})";
        }
    }
}