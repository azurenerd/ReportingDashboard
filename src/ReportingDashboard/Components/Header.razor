@using ReportingDashboard.Models

<div class="hdr">
    <div>
        <h1>@Data.Title <a href="@Data.BacklogLink" target="_blank" style="color:#0078D4;text-decoration:none;font-size:14px;font-weight:400;">📋 ADO Backlog</a></h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div class="hdr-legend">
        <span class="legend-item">
            <span class="legend-diamond" style="background:#F4B400;"></span> PoC Milestone
        </span>
        <span class="legend-item">
            <span class="legend-diamond" style="background:#34A853;"></span> Production Release
        </span>
        <span class="legend-item">
            <span class="legend-dot"></span> Checkpoint
        </span>
        <span class="legend-item">
            <span class="legend-now"></span> Now (@Data.CurrentMonth)
        </span>
    </div>
</div>

@code {
    [Parameter]
    public DashboardData Data { get; set; } = default!;
}