<div class="hdr">
    <div class="hdr-left">
        <h1>
            @Project.Title
            @if (!string.IsNullOrEmpty(Project.BacklogUrl))
            {
                <a href="@Project.BacklogUrl" target="_blank">&#x1F4CB; ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Project.Subtitle</div>
    </div>
    <div class="hdr-right">
        <div class="legend-item">
            <span class="legend-diamond poc"></span>
            <span>PoC Milestone</span>
        </div>
        <div class="legend-item">
            <span class="legend-diamond prod"></span>
            <span>Production Release</span>
        </div>
        <div class="legend-item">
            <span class="legend-circle"></span>
            <span>Checkpoint</span>
        </div>
        <div class="legend-item">
            <span class="legend-bar"></span>
            <span>Now</span>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ProjectInfo Project { get; set; } = new();
}