<div class="hdr">
    <div>
        <h1>
            @Project.Title
            @if (!string.IsNullOrEmpty(Project.BacklogUrl))
            {
                <a href="@Project.BacklogUrl" target="_blank">↗ ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Project.Subtitle</div>
    </div>
    <div class="legend">
        <div class="legend-item">
            <span class="icon-diamond-gold"></span> PoC Milestone
        </div>
        <div class="legend-item">
            <span class="icon-diamond-green"></span> Production Release
        </div>
        <div class="legend-item">
            <span class="icon-checkpoint"></span> Checkpoint
        </div>
        <div class="legend-item">
            <span class="icon-now"></span> Now
        </div>
    </div>
</div>

@code {
    [Parameter] public ProjectInfo Project { get; set; } = default!;
}
