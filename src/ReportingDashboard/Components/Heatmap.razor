<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap — Shipped · In Progress · Carryover · Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@HeatmapInfo.Months.Count, 1fr);">
        @* Corner cell *@
        <div class="hm-corner">Status</div>

        @* Month headers *@
        @for (int m = 0; m < HeatmapInfo.Months.Count; m++)
        {
            var month = HeatmapInfo.Months[m];
            var isHighlight = month == HeatmapInfo.HighlightMonth;
            var isLast = m == HeatmapInfo.Months.Count - 1;
            <div class="hm-col-hdr @(isHighlight ? "apr-hdr" : "") @(isLast ? "no-right-border" : "")">
                @month@(isHighlight ? " ★ Now" : "")
            </div>
        }

        @* Data rows *@
        @foreach (var row in HeatmapInfo.Rows)
        {
            <div class="hm-row-hdr @GetHeaderClass(row.Category)">
                @GetEmoji(row.Category)&nbsp;@row.Category
            </div>

            @for (int m = 0; m < HeatmapInfo.Months.Count; m++)
            {
                var month = HeatmapInfo.Months[m];
                var isHighlight = month == HeatmapInfo.HighlightMonth;
                var isLast = m == HeatmapInfo.Months.Count - 1;
                var items = row.Items.ContainsKey(month) ? row.Items[month] : new List<string>();

                <HeatmapCell Items="items"
                             CssClass="@GetCellClass(row.Category)"
                             IsHighlighted="isHighlight"
                             IsLastColumn="isLast" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData HeatmapInfo { get; set; } = default!;

    private string GetCellClass(string category) => category switch
    {
        "Shipped" => "ship-cell",
        "In Progress" => "prog-cell",
        "Carryover" => "carry-cell",
        "Blockers" => "block-cell",
        _ => ""
    };

    private string GetHeaderClass(string category) => category switch
    {
        "Shipped" => "ship-hdr",
        "In Progress" => "prog-hdr",
        "Carryover" => "carry-hdr",
        "Blockers" => "block-hdr",
        _ => ""
    };

    private string GetEmoji(string category) => category switch
    {
        "Shipped" => "✅",
        "In Progress" => "🔄",
        "Carryover" => "⚠️",
        "Blockers" => "🚫",
        _ => ""
    };
}
