<div class="hm-wrap">
    <div class="hm-title">
        MONTHLY EXECUTION HEATMAP — SHIPPED · IN PROGRESS · CARRYOVER · BLOCKERS
    </div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@Months.Count, 1fr);">
        @* Corner cell *@
        <div class="hm-corner">STATUS</div>

        @* Column headers *@
        @for (int i = 0; i < Months.Count; i++)
        {
            var isCurrent = i == CurrentMonthIndex;
            <div class="hm-col-hdr @(isCurrent ? "current-month-hdr" : "")">
                @Months[i]@(isCurrent ? " ▸ Now" : "")
            </div>
        }

        @* Category rows *@
        @foreach (var category in Categories)
        {
            <div class="hm-row-hdr @GetHeaderClass(category.Key)">
                @category.Name
            </div>
            @for (int i = 0; i < Months.Count; i++)
            {
                var month = Months[i];
                var items = category.Items.TryGetValue(month, out var list) ? list : new List<string>();
                var isCurrent = i == CurrentMonthIndex;
                <div class="@GetCellClass(category.Key) @(isCurrent ? "current" : "")">
                    <HeatmapCell Items="@items" DotColor="@GetDotColor(category.Key)" />
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public List<HeatmapCategory> Categories { get; set; } = new();

    [Parameter, EditorRequired]
    public List<string> Months { get; set; } = new();

    [Parameter, EditorRequired]
    public int CurrentMonthIndex { get; set; }

    private static string GetCellClass(string key) => key switch
    {
        "shipped" => "ship-cell",
        "inProgress" => "prog-cell",
        "carryover" => "carry-cell",
        "blockers" => "block-cell",
        _ => ""
    };

    private static string GetHeaderClass(string key) => key switch
    {
        "shipped" => "ship-hdr",
        "inProgress" => "prog-hdr",
        "carryover" => "carry-hdr",
        "blockers" => "block-hdr",
        _ => ""
    };

    private static string GetDotColor(string key) => key switch
    {
        "shipped" => "#34A853",
        "inProgress" => "#0078D4",
        "carryover" => "#F4B400",
        "blockers" => "#EA4335",
        _ => "#999"
    };
}