@{
    var months = Data.Months ?? new List<string>();
    var rows = Data.Rows ?? new List<HeatmapRow>();
    var monthCount = months.Count;
    var gridCols = $"160px repeat({monthCount}, 1fr)";
    var gridRows = $"36px repeat({rows.Count}, 1fr)";

    var categoryClasses = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Shipped"] = "ship",
        ["In Progress"] = "prog",
        ["Carryover"] = "carry",
        ["Blockers"] = "block"
    };
}

<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap — Shipped · In Progress · Carryover · Blockers</div>
    <div class="hm-grid" style="grid-template-columns:@gridCols;grid-template-rows:@gridRows;">
        @* Header row *@
        <div class="hm-corner">Status</div>
        @for (int m = 0; m < monthCount; m++)
        {
            var month = months[m];
            var isHighlight = month.Equals(Data.HighlightMonth, StringComparison.OrdinalIgnoreCase);
            var isLast = m == monthCount - 1;
            var cls = "hm-col-hdr" + (isHighlight ? " apr-hdr" : "");
            var style = isLast ? "border-right:none;" : "";

            if (isHighlight)
            {
                <div class="@cls" style="@style">@month ◂ Now</div>
            }
            else
            {
                <div class="@cls" style="@style">@month</div>
            }
        }

        @* Data rows *@
        @foreach (var row in rows)
        {
            var prefix = categoryClasses.GetValueOrDefault(row.Category, "ship");

            <div class="hm-row-hdr @(prefix)-hdr">@row.Emoji @row.Category.ToUpper()</div>

            @for (int m = 0; m < monthCount; m++)
            {
                var items = (m < row.Items.Count) ? row.Items[m] : new List<string>();
                var isHighlight = months[m].Equals(Data.HighlightMonth, StringComparison.OrdinalIgnoreCase);
                var isLast = m == monthCount - 1;
                var cellClass = $"{prefix}-cell";

                <HeatmapCell Items="@items" CssClass="@cellClass" IsHighlighted="@isHighlight" IsLastColumn="@isLast" AccentClass="@prefix" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData Data { get; set; } = new();
}
