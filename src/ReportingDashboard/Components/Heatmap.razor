<div class="hm-title">MONTHLY EXECUTION HEATMAP &mdash; Shipped &bull; In Progress &bull; Carryover &bull; Blockers</div>
<div class="hm-grid" style="grid-template-columns: 160px repeat(@Months.Count, 1fr); grid-template-rows: 36px repeat(4, 1fr);">
    <div class="hm-corner">STATUS</div>
    @foreach (var month in Months)
    {
        var isCurrent = month == CurrentMonth;
        <div class="hm-col-hdr @(isCurrent ? "cur-month-hdr" : "")">
            @month @(isCurrent ? "▸ Now" : "")
        </div>
    }

    <HeatmapRow Category="shipped"
                Label="✓ Shipped"
                Months="@Months"
                CurrentMonth="@CurrentMonth"
                Items="@(Heatmap?.Shipped ?? new())" />

    <HeatmapRow Category="prog"
                Label="▶ In Progress"
                Months="@Months"
                CurrentMonth="@CurrentMonth"
                Items="@(Heatmap?.InProgress ?? new())" />

    <HeatmapRow Category="carry"
                Label="⟳ Carryover"
                Months="@Months"
                CurrentMonth="@CurrentMonth"
                Items="@(Heatmap?.Carryover ?? new())" />

    <HeatmapRow Category="block"
                Label="✕ Blockers"
                Months="@Months"
                CurrentMonth="@CurrentMonth"
                Items="@(Heatmap?.Blockers ?? new())" />
</div>

@code {
    [Parameter] public HeatmapData? Heatmap { get; set; }
    [Parameter] public List<string> Months { get; set; } = new();
    [Parameter] public string CurrentMonth { get; set; } = "";
}