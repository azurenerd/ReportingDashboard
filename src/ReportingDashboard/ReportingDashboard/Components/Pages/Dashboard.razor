@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject DashboardDataService DataService
@rendermode RenderMode.InteractiveServer

@if (DataService.IsError)
{
    <div class="error-panel">
        <h2>Dashboard Configuration Error</h2>
        <p class="error-detail">@DataService.ErrorMessage</p>
        <p>Please check wwwroot/data.json and restart the application.</p>
    </div>
}
else if (_config is not null)
{
    @* ── Section 1: Header Bar ── *@
    <div class="hdr">
        <div class="hdr-left">
            <h1>
                @_titleBeforeLink
                @if (!string.IsNullOrEmpty(_config.BacklogLink))
                {
                    <a href="@_config.BacklogLink" target="_blank">@(" ")&#x1F4CB; ADO Backlog</a>
                }
            </h1>
            <div class="sub">@_config.Subtitle</div>
        </div>
        <div class="legend">
            <span class="legend-item">
                <span class="legend-diamond" style="background:#F4B400;"></span>
                PoC Milestone
            </span>
            <span class="legend-item">
                <span class="legend-diamond" style="background:#34A853;"></span>
                Production Release
            </span>
            <span class="legend-item">
                <span class="legend-circle"></span>
                Checkpoint
            </span>
            <span class="legend-item">
                <span class="legend-now-bar"></span>
                Now (@_nowMonthLabel)
            </span>
        </div>
    </div>

    @* ── Section 2: Timeline Area (placeholder for future implementation) ── *@
    <div class="tl-area">
        <div class="tl-sidebar">
            @if (_config.Timeline.Tracks.Any())
            {
                @foreach (var track in _config.Timeline.Tracks)
                {
                    <div class="tl-milestone-label">
                        <span class="tl-ml-id" style="color:@track.Color;">@track.Id</span>
                        <span class="tl-ml-desc">@track.Label</span>
                    </div>
                }
            }
        </div>
        <div class="tl-svg-box">
            @* Timeline SVG will be implemented in a subsequent task *@
        </div>
    </div>

    @* ── Section 3: Heatmap Grid (placeholder for future implementation) ── *@
    <div class="hm-wrap">
        <div class="hm-title">MONTHLY EXECUTION HEATMAP &mdash; Shipped &bull; In Progress &bull; Carryover &bull; Blockers</div>
        <div class="hm-grid" style="grid-template-columns: 160px repeat(@_config.Months.Count, 1fr);">
            @* Heatmap grid will be implemented in a subsequent task *@
        </div>
    </div>
}

@code {
    private DashboardData? _config;
    private string _titleBeforeLink = "";
    private string _nowMonthLabel = "";

    protected override void OnInitialized()
    {
        _config = DataService.Data;

        if (_config is not null)
        {
            // Parse title: the title field contains the full project name for the h1
            _titleBeforeLink = _config.Title;

            // Compute "Now" month label from currentMonth or DateTime
            _nowMonthLabel = !string.IsNullOrEmpty(_config.CurrentMonth)
                ? $"{_config.CurrentMonth} {DateTime.Today.Year}"
                : DateTime.Today.ToString("MMM yyyy");
        }
    }
}