@if (DashboardData != null)
{
	<section class="status-summary">
		<div class="summary-content">
			<h2>@DashboardData.ProjectName</h2>
			<div class="status-badge @GetHealthClass()">
				@DashboardData.ProjectStatus
			</div>
			<div class="metrics-summary">
				<div class="metric-count">
					<span class="label">Shipped</span>
					<span class="value">@DashboardData.ShippedItems.Count</span>
				</div>
				<div class="metric-count">
					<span class="label">In Progress</span>
					<span class="value">@DashboardData.InProgressItems.Count</span>
				</div>
				<div class="metric-count">
					<span class="label">Carryover</span>
					<span class="value">@DashboardData.CarryoverItems.Count</span>
				</div>
			</div>
		</div>
	</section>
}

@code {
	[CascadingParameter]
	public DashboardData? DashboardData { get; set; }

	private string GetHealthClass()
	{
		return DashboardData?.ProjectStatus switch
		{
			"On Track" => "badge-success",
			"At Risk" => "badge-warning",
			"Off Track" => "badge-danger",
			_ => "badge-secondary"
		};
	}
}