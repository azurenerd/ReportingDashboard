@using AgentSquad.Dashboard.Models

<div class="card status-card border-@CardColor">
    <div class="card-header bg-@CardColor text-white">
        <h5 class="mb-0">@StatusCategory</h5>
        <div class="task-count">@TaskCount</div>
    </div>
    <div class="card-body">
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#tasks-@StatusCategory">
            View Tasks (@Tasks.Count)
        </button>
        <div class="collapse mt-3" id="tasks-@StatusCategory">
            <ul class="list-group list-group-flush">
                @foreach (var task in Tasks ?? new())
                {
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>
                                <i class="bi bi-check-circle"></i> @task.Name
                            </span>
                            <small class="text-muted">@task.AssignedTo</small>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task> Tasks { get; set; }

    [Parameter]
    public string CardColor { get; set; }
}