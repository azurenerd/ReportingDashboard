@using AgentSquad.Dashboard.Models

<div class="card @CardColor text-white h-100">
    <div class="card-body">
        <h3 class="card-title mb-2">@StatusCategory</h3>
        <div class="display-4 fw-bold mb-3">@TaskCount</div>
        
        <button class="btn btn-outline-light btn-sm" @onclick="ToggleExpanded">
            @(isExpanded ? "Hide" : "Show") Tasks
        </button>
        
        @if (isExpanded && Tasks != null)
        {
            <ul class="list-unstyled mt-3">
                @foreach (var task in Tasks)
                {
                    <li class="mb-2">
                        <span class="task-icon">@(StatusCategory == "Shipped" ? "✓" : "→")</span>
                        <span>@task.Name</span>
                        <small class="d-block text-opacity-75">@task.AssignedTo</small>
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<AgentSquad.Dashboard.Models.Task> Tasks { get; set; }

    [Parameter]
    public string CardColor { get; set; } = "bg-primary";

    private bool isExpanded = false;

    private void ToggleExpanded()
    {
        isExpanded = !isExpanded;
    }
}