@using AgentSquad.Dashboard.Models

<div class="dashboard">
    <div class="section-milestone">
        <h2>Project Timeline</h2>
        <MilestoneTimeline Milestones="ProjectData.Milestones" 
                          ProjectStartDate="ProjectData.Project.StartDate"
                          ProjectEndDate="ProjectData.Project.EndDate" />
    </div>

    <div class="section-status mt-5">
        <h2>Task Status Breakdown</h2>
        <div class="row">
            <div class="col-md-4">
                <StatusCard StatusCategory="Shipped" 
                           TaskCount="StatusSummary.ShippedCount"
                           Tasks="GetTasksByStatus(TaskStatus.Shipped)"
                           CardColor="success" />
            </div>
            <div class="col-md-4">
                <StatusCard StatusCategory="In-Progress"
                           TaskCount="StatusSummary.InProgressCount"
                           Tasks="GetTasksByStatus(TaskStatus.InProgress)"
                           CardColor="info" />
            </div>
            <div class="col-md-4">
                <StatusCard StatusCategory="Carried-Over"
                           TaskCount="StatusSummary.CarriedOverCount"
                           Tasks="GetTasksByStatus(TaskStatus.CarriedOver)"
                           CardColor="warning" />
            </div>
        </div>
    </div>

    <div class="section-metrics mt-5">
        <h2>Progress Metrics</h2>
        <ProgressMetrics CompletionPercentage="ProjectData.Metrics.CompletionPercentage"
                        TotalTasks="ProjectData.Metrics.TotalTasks"
                        CompletedTasks="ProjectData.Metrics.CompletedTasks" />
    </div>
</div>

@code {
    [Parameter]
    public ProjectData ProjectData { get; set; }

    private TaskStatusSummary StatusSummary { get; set; }

    protected override void OnInitialized()
    {
        StatusSummary = CalculateStatusSummary();
    }

    private List<Task> GetTasksByStatus(TaskStatus status)
    {
        return ProjectData?.Tasks?.Where(t => t.Status == status).ToList() ?? new();
    }

    private TaskStatusSummary CalculateStatusSummary()
    {
        return new TaskStatusSummary
        {
            ShippedCount = ProjectData?.Tasks?.Count(t => t.Status == TaskStatus.Shipped) ?? 0,
            InProgressCount = ProjectData?.Tasks?.Count(t => t.Status == TaskStatus.InProgress) ?? 0,
            CarriedOverCount = ProjectData?.Tasks?.Count(t => t.Status == TaskStatus.CarriedOver) ?? 0
        };
    }
}