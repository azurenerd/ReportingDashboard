@using AgentSquad.Dashboard.Models

<div class="timeline-container">
    <div class="timeline">
        @foreach (var milestone in Milestones ?? new())
        {
            <div class="timeline-item" data-status="@milestone.Status.ToString()">
                <div class="timeline-marker">
                    @if (milestone.Status == MilestoneStatus.Completed)
                    {
                        <span class="badge bg-success">✓</span>
                    }
                    else if (milestone.Status == MilestoneStatus.InProgress)
                    {
                        <span class="badge bg-info">→</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">○</span>
                    }
                </div>
                <div class="timeline-content">
                    <h5>@milestone.Name</h5>
                    <p class="text-muted">Target: @milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                    @if (milestone.Status == MilestoneStatus.Completed)
                    {
                        <p class="text-success">Completed: @milestone.ActualDate?.ToString("MMM dd, yyyy")</p>
                    }
                    <div class="progress">
                        <div class="progress-bar" role="progressbar" 
                             style="width: @(milestone.CompletionPercentage)%"
                             aria-valuenow="@milestone.CompletionPercentage" 
                             aria-valuemin="0" aria-valuemax="100">
                            @milestone.CompletionPercentage%
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }
}