@using AgentSquad.Dashboard.Models

<div class="milestone-timeline mb-5">
    <h2 class="mb-4">Project Milestones</h2>
    <div class="timeline-container">
        @foreach (var milestone in Milestones ?? new())
        {
            <div class="timeline-item">
                <div class="timeline-marker @GetStatusClass(milestone.Status)">
                    @GetStatusIcon(milestone.Status)
                </div>
                <div class="timeline-content">
                    <h5 class="mb-1">@milestone.Name</h5>
                    <p class="text-muted mb-2">Target: @milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                    @if (milestone.Status == MilestoneStatus.Completed)
                    {
                        <p class="text-success">✓ Completed @milestone.ActualDate?.ToString("MMM dd, yyyy")</p>
                    }
                    else
                    {
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width: @milestone.CompletionPercentage%">
                                @milestone.CompletionPercentage%
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    [Parameter]
    public int ProjectDurationDays { get; set; }

    private string GetStatusClass(MilestoneStatus status) =>
        status switch
        {
            MilestoneStatus.Completed => "completed",
            MilestoneStatus.InProgress => "in-progress",
            _ => "pending"
        };

    private string GetStatusIcon(MilestoneStatus status) =>
        status switch
        {
            MilestoneStatus.Completed => "✓",
            MilestoneStatus.InProgress => "→",
            _ => "○"
        };
}