@page "/"
@using AgentSquad.Dashboard.Services
@using AgentSquad.Dashboard.Components
@inject ProjectDataService ProjectDataService
@inject ILogger<Dashboard> Logger

<div class="container-fluid mt-4">
    @if (loadError != null)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Error Loading Project Data</h4>
            <p>@loadError</p>
            <button class="btn btn-primary btn-sm" @onclick="RetryLoad">Refresh</button>
        </div>
    }
    else if (projectData == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <MilestoneTimeline Milestones="projectData.Milestones" 
                          ProjectDurationDays="(int)(projectData.Project.EndDate - projectData.Project.StartDate).TotalDays" />
        
        <div class="row mt-5 mb-5">
            <div class="col-md-4">
                <StatusCard StatusCategory="Shipped" TaskCount="projectData.Metrics.CompletedTasks" 
                           Tasks="GetTasksByStatus(0)" CardColor="bg-success" />
            </div>
            <div class="col-md-4">
                <StatusCard StatusCategory="In-Progress" TaskCount="projectData.Metrics.InProgressTasks" 
                           Tasks="GetTasksByStatus(1)" CardColor="bg-info" />
            </div>
            <div class="col-md-4">
                <StatusCard StatusCategory="Carried-Over" TaskCount="projectData.Metrics.CarriedOverTasks" 
                           Tasks="GetTasksByStatus(2)" CardColor="bg-warning" />
            </div>
        </div>

        <ProgressMetrics CompletionPercentage="projectData.Metrics.CompletionPercentage" 
                        TotalTasks="projectData.Metrics.TotalTasks" 
                        CompletedTasks="projectData.Metrics.CompletedTasks" 
                        BurndownRate="projectData.Metrics.EstimatedBurndownRate" />
    }
</div>

@code {
    private ProjectData projectData;
    private string loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        try
        {
            loadError = null;
            projectData = await ProjectDataService.LoadProjectDataAsync("wwwroot/data/data.json");
        }
        catch (Exception ex)
        {
            loadError = $"Error loading project data: {ex.Message}";
            Logger.LogError(ex, "Failed to load project data");
        }
    }

    private async Task RetryLoad()
    {
        await LoadProjectData();
        StateHasChanged();
    }

    private List<AgentSquad.Dashboard.Models.Task> GetTasksByStatus(int status)
    {
        if (projectData?.Tasks == null) return new();
        return projectData.Tasks.Where(t => (int)t.Status == status).ToList();
    }
}