@namespace AgentSquad.Dashboard.Components

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Project Milestone Timeline</h5>
    </div>
    <div class="card-body">
        @if (Milestones == null || Milestones.Count == 0)
        {
            <p class="text-muted">No milestones defined.</p>
        }
        else
        {
            <div class="timeline">
                @foreach (var milestone in Milestones.OrderBy(m => m.TargetDate))
                {
                    <div class="timeline-item">
                        <div class="timeline-marker @GetStatusClass(milestone.Status)">
                            @GetStatusIcon(milestone.Status)
                        </div>
                        <div class="timeline-content">
                            <h6 class="fw-bold">@milestone.Name</h6>
                            <p class="text-muted small mb-1">
                                Target: @milestone.TargetDate.ToString("MMM dd, yyyy")
                                @if (milestone.ActualDate.HasValue)
                                {
                                    <span class="ms-2">Completed: @milestone.ActualDate.Value.ToString("MMM dd, yyyy")</span>
                                }
                            </p>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar @GetProgressBarClass(milestone.Status)" 
                                     role="progressbar" 
                                     style="width: @milestone.CompletionPercentage%"
                                     aria-valuenow="@milestone.CompletionPercentage" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                </div>
                            </div>
                            <small class="text-muted">@milestone.CompletionPercentage% Complete</small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetStatusClass(MilestoneStatus status) =>
        status switch
        {
            MilestoneStatus.Completed => "completed",
            MilestoneStatus.InProgress => "in-progress",
            MilestoneStatus.Pending => "pending",
            _ => "pending"
        };

    private string GetProgressBarClass(MilestoneStatus status) =>
        status switch
        {
            MilestoneStatus.Completed => "bg-success",
            MilestoneStatus.InProgress => "bg-info",
            MilestoneStatus.Pending => "bg-secondary",
            _ => "bg-secondary"
        };

    private string GetStatusIcon(MilestoneStatus status) =>
        status switch
        {
            MilestoneStatus.Completed => "✓",
            MilestoneStatus.InProgress => "→",
            MilestoneStatus.Pending => "○",
            _ => "○"
        };
}