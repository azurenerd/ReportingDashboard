@using AgentSquad.Dashboard.Models

<div class="card border-0 shadow-sm mb-5">
    <div class="card-header bg-light border-0">
        <h3 class="card-title mb-0">Project Milestones Timeline</h3>
    </div>
    <div class="card-body">
        @if (Milestones == null || !Milestones.Any())
        {
            <p class="text-muted">No milestones defined</p>
        }
        else
        {
            <div class="timeline">
                @foreach (var milestone in Milestones.OrderBy(m => m.TargetDate))
                {
                    var statusClass = milestone.Status switch
                    {
                        MilestoneStatus.Completed => "timeline-completed",
                        MilestoneStatus.InProgress => "timeline-in-progress",
                        _ => "timeline-pending"
                    };

                    <div class="timeline-item @statusClass">
                        <div class="timeline-marker">
                            @if (milestone.Status == MilestoneStatus.Completed)
                            {
                                <span class="badge bg-success">✓</span>
                            }
                            else if (milestone.Status == MilestoneStatus.InProgress)
                            {
                                <span class="badge bg-primary">◐</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">○</span>
                            }
                        </div>
                        <div class="timeline-content">
                            <h5 class="mb-1">@milestone.Name</h5>
                            <p class="text-muted mb-0 small">
                                Target: <strong>@milestone.TargetDate.ToString("MMM dd, yyyy")</strong>
                                @if (milestone.ActualDate.HasValue)
                                {
                                    <span class="ms-2">Completed: <strong>@milestone.ActualDate.Value.ToString("MMM dd, yyyy")</strong></span>
                                }
                            </p>
                            @if (milestone.CompletionPercentage > 0)
                            {
                                <div class="progress mt-2" style="height: 6px;">
                                    <div class="progress-bar" role="progressbar" 
                                         style="width: @(milestone.CompletionPercentage)%" 
                                         aria-valuenow="@milestone.CompletionPercentage" 
                                         aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.timeline {
    position: relative;
    padding: 20px 0;
}

.timeline-item {
    display: flex;
    margin-bottom: 30px;
    padding: 15px;
    border-radius: 8px;
    background-color: #f9f9f9;
}

.timeline-item.timeline-completed {
    background-color: #e8f5e9;
    border-left: 4px solid #4caf50;
}

.timeline-item.timeline-in-progress {
    background-color: #e3f2fd;
    border-left: 4px solid #2196f3;
}

.timeline-item.timeline-pending {
    background-color: #f5f5f5;
    border-left: 4px solid #9e9e9e;
}

.timeline-marker {
    min-width: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20px;
}

.timeline-content {
    flex: 1;
}
</style>

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    [Parameter]
    public int ProjectDurationDays { get; set; }
}