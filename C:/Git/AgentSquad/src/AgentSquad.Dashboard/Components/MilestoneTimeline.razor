@using AgentSquad.Dashboard.Models

<svg width="100%" height="@Height" viewBox="0 0 1000 @Height" class="milestone-timeline">
    @if (Milestones != null && Milestones.Count > 0)
    {
        <defs>
            <style>
                .milestone-bar { fill: #007bff; }
                .milestone-completed { fill: #28a745; }
                .milestone-at-risk { fill: #ffc107; }
                .milestone-delayed { fill: #dc3545; }
                .milestone-text { font-size: 12px; fill: #333; }
                .milestone-date { font-size: 10px; fill: #666; }
            </style>
        </defs>

        @{
            var barHeight = 30;
            var spacing = Height / (Milestones.Count + 1);
            var minDate = Milestones.Min(m => m.TargetDate);
            var maxDate = Milestones.Max(m => m.TargetDate);
            var daySpan = (maxDate - minDate).TotalDays + 1;
        }

        @for (int i = 0; i < Milestones.Count; i++)
        {
            var milestone = Milestones[i];
            var yPos = (i + 1) * spacing;
            var xStart = 50;
            var xEnd = 950;
            var barWidth = xEnd - xStart;
            var dayOffset = (milestone.TargetDate - minDate).TotalDays;
            var xPos = xStart + (barWidth * (dayOffset / Math.Max(daySpan, 1)));

            var barClass = milestone.Status switch
            {
                "Completed" => "milestone-completed",
                "At Risk" => "milestone-at-risk",
                "Delayed" => "milestone-delayed",
                _ => "milestone-bar"
            };

            <rect class="@barClass" x="@xPos" y="@(yPos - barHeight / 2)" width="30" height="@barHeight" rx="3" />
            <text class="milestone-text" x="@(xPos + 40)" y="@(yPos + 5)">@milestone.Name</text>
            <text class="milestone-date" x="@(xPos + 40)" y="@(yPos + 18)">@milestone.TargetDate.ToString("MMM dd, yyyy")</text>
        }
    }
</svg>

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    [Parameter]
    public int Height { get; set; } = 300;

    [Parameter]
    public string ThemeColor { get; set; } = "dark";
}