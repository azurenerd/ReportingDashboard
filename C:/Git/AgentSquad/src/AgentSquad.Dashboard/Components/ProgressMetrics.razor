@namespace AgentSquad.Dashboard.Components

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Project Progress & Metrics</h5>
    </div>
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h6 class="text-muted mb-3">Overall Completion</h6>
                <div class="progress" style="height: 30px;">
                    <div class="progress-bar bg-success" 
                         role="progressbar" 
                         style="width: @CompletionPercentage%"
                         aria-valuenow="@CompletionPercentage" 
                         aria-valuemin="0" 
                         aria-valuemax="100">
                        @CompletionPercentage%
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="display-4 fw-bold">@CompletionPercentage%</div>
                <small class="text-muted">@CompletedTasks of @TotalTasks tasks completed</small>
            </div>
        </div>

        <hr class="my-4" />

        <div class="row text-center">
            <div class="col-md-4">
                <h6 class="text-muted">Estimated Burn Rate</h6>
                <p class="display-6">@BurndownRate.ToString("F1")</p>
                <small class="text-muted">tasks/day</small>
            </div>
            <div class="col-md-4">
                <h6 class="text-muted">Completed</h6>
                <p class="display-6 text-success">@CompletedTasks</p>
                <small class="text-muted">tasks shipped</small>
            </div>
            <div class="col-md-4">
                <h6 class="text-muted">Remaining</h6>
                <p class="display-6 text-warning">@(TotalTasks - CompletedTasks)</p>
                <small class="text-muted">tasks in progress</small>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int CompletionPercentage { get; set; }

    [Parameter]
    public int CompletedTasks { get; set; }

    [Parameter]
    public int TotalTasks { get; set; }

    [Parameter]
    public double BurndownRate { get; set; }
}