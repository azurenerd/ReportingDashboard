@using AgentSquad.Dashboard.Models
@using CurrieTechnologies.Razor.ChartJS

<div style="width: 100%; height: 300px;">
    <Chart @ref="chart" Config="config" />
</div>

@code {
    [Parameter]
    public DashboardData Data { get; set; } = new();

    [Parameter]
    public bool AnimationEnabled { get; set; } = false;

    private Chart? chart;
    private ChartConfiguration? config;

    protected override async Task OnInitializedAsync()
    {
        config = CreateChartConfig();
        await Task.Delay(100);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (config != null)
        {
            config = CreateChartConfig();
            if (chart != null)
            {
                await chart.Update();
            }
        }
    }

    private ChartConfiguration CreateChartConfig()
    {
        return new ChartConfiguration
        {
            Type = ChartType.Bar,
            Data = new ChartData
            {
                Labels = new() { "Completed", "In Progress", "Carried Over" },
                Datasets = new()
                {
                    new BarChartDataset
                    {
                        Label = "Item Count",
                        Data = new() { (decimal)Data.CompletedCount, (decimal)Data.InProgressCount, (decimal)Data.CarriedOverCount },
                        BackgroundColor = new() { "#28a745", "#ffc107", "#dc3545" },
                        BorderColor = new() { "#1e7e34", "#e0a800", "#bd2130" },
                        BorderWidth = 1
                    }
                }
            },
            Options = new ChartOptions
            {
                IndexAxis = "y",
                Responsive = true,
                MaintainAspectRatio = false,
                Animation = new() { Enabled = AnimationEnabled },
                Plugins = new()
                {
                    Legend = new() { Display = true }
                }
            }
        };
    }
}