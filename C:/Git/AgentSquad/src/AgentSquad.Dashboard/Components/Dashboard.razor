@page "/"
@using AgentSquad.Dashboard.Services
@inject ProjectDataService ProjectDataService
@inject ILogger<Dashboard> Logger

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">@ProjectTitle</h1>
            <p class="lead text-muted">@ProjectDescription</p>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="alert alert-info" role="alert">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Loading project data...
        </div>
    }
    @else if (_error != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error loading project data:</strong> @_error
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="RefreshData">
                Retry
            </button>
        </div>
    }
    else if (_data != null)
    {
        <div class="row mb-5">
            <div class="col-12">
                <MilestoneTimeline 
                    Milestones="@_data.Milestones"
                    ProjectStartDate="@_data.Project.StartDate"
                    ProjectEndDate="@_data.Project.EndDate" />
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12 col-md-4">
                <StatusCard 
                    StatusCategory="Shipped"
                    TaskCount="@GetShippedCount()"
                    Tasks="@_data.Tasks.Where(t => t.Status == TaskStatus.Shipped).ToList()"
                    CardColor="success" />
            </div>
            <div class="col-12 col-md-4">
                <StatusCard 
                    StatusCategory="In Progress"
                    TaskCount="@GetInProgressCount()"
                    Tasks="@_data.Tasks.Where(t => t.Status == TaskStatus.InProgress).ToList()"
                    CardColor="primary" />
            </div>
            <div class="col-12 col-md-4">
                <StatusCard 
                    StatusCategory="Carried Over"
                    TaskCount="@GetCarriedOverCount()"
                    Tasks="@_data.Tasks.Where(t => t.Status == TaskStatus.CarriedOver).ToList()"
                    CardColor="warning" />
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <ProgressMetrics 
                    CompletionPercentage="@_data.Metrics.CompletionPercentage"
                    CompletedTasks="@_data.Metrics.CompletedTasks"
                    TotalTasks="@_data.Metrics.TotalTasks"
                    BurndownRate="@_data.Metrics.EstimatedBurndownRate" />
            </div>
        </div>
    }
</div>

@code {
    private ProjectData? _data;
    private bool _isLoading = true;
    private string? _error;

    private string ProjectTitle => _data?.Project.Name ?? "Project Dashboard";
    private string ProjectDescription => _data?.Project.Description ?? "Loading...";

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        _isLoading = true;
        _error = null;
        
        try
        {
            _data = await ProjectDataService.LoadProjectDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load project data");
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private int GetShippedCount() =>
        _data?.Tasks.Count(t => t.Status == TaskStatus.Shipped) ?? 0;

    private int GetInProgressCount() =>
        _data?.Tasks.Count(t => t.Status == TaskStatus.InProgress) ?? 0;

    private int GetCarriedOverCount() =>
        _data?.Tasks.Count(t => t.Status == TaskStatus.CarriedOver) ?? 0;
}