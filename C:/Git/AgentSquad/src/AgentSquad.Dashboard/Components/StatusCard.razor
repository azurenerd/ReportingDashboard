@namespace AgentSquad.Dashboard.Components

<div class="card shadow-sm h-100">
    <div class="card-header @GetHeaderClass()">
        <h5 class="mb-0 text-white">@StatusCategory</h5>
    </div>
    <div class="card-body d-flex flex-column">
        <div class="display-6 fw-bold text-@CardColor mb-3">@TaskCount</div>
        
        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted small">No tasks in this category.</p>
        }
        else
        {
            <div class="task-list flex-grow-1">
                <button class="btn btn-sm btn-outline-secondary mb-2" 
                        @onclick="@((ToggleExpanded)()" type="button">
                    @if (_expanded) { <span>▼</span> } else { <span>▶</span> }
                    View Tasks (@Tasks.Count)
                </button>
                
                @if (_expanded)
                {
                    <ul class="list-unstyled small">
                        @foreach (var task in Tasks)
                        {
                            <li class="mb-2 pb-2 border-bottom">
                                <strong>@task.Name</strong>
                                <br />
                                <span class="text-muted">@task.AssignedTo</span>
                                <br />
                                <span class="text-muted small">Due: @task.DueDate.ToString("MMM dd")</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task>? Tasks { get; set; }

    [Parameter]
    public string? CardColor { get; set; }

    private bool _expanded = false;

    private string GetHeaderClass() =>
        CardColor switch
        {
            "success" => "bg-success",
            "primary" => "bg-primary",
            "warning" => "bg-warning",
            _ => "bg-secondary"
        };

    private void ToggleExpanded()
    {
        _expanded = !_expanded;
    }
}