@using AgentSquad.Dashboard.Models

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-success h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Completed <span class="badge bg-light text-dark">@Data.CompletedCount</span></h5>
            </div>
            <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                @if (Data.Completed?.Count > 0)
                {
                    @foreach (var item in Data.Completed.OrderByDescending(x => x.AddedDate).Take(20))
                    {
                        <div class="mb-3">
                            <h6 class="fw-bold">@item.Title</h6>
                            <p class="text-muted small mb-1">@item.Description</p>
                            <p class="text-muted small">
                                <strong>Owner:</strong> @item.Owner | <strong>Date:</strong> @item.AddedDate.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No completed items</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-warning h-100">
            <div class="card-header bg-warning">
                <h5 class="mb-0">In Progress <span class="badge bg-light text-dark">@Data.InProgressCount</span></h5>
            </div>
            <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                @if (Data.InProgress?.Count > 0)
                {
                    @foreach (var item in Data.InProgress.OrderBy(x => x.AddedDate).Take(20))
                    {
                        <div class="mb-3">
                            <h6 class="fw-bold">@item.Title</h6>
                            <p class="text-muted small mb-1">@item.Description</p>
                            <p class="text-muted small">
                                <strong>Owner:</strong> @item.Owner | <strong>Start:</strong> @item.AddedDate.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No in-progress items</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-danger h-100">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Carried Over <span class="badge bg-light text-dark">@Data.CarriedOverCount</span></h5>
            </div>
            <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                @if (Data.CarriedOver?.Count > 0)
                {
                    @foreach (var item in Data.CarriedOver.OrderBy(x => x.AddedDate).Take(20))
                    {
                        <div class="mb-3">
                            <h6 class="fw-bold">@item.Title</h6>
                            <p class="text-muted small mb-1">@item.Description</p>
                            <p class="text-muted small">
                                <strong>Owner:</strong> @item.Owner | <strong>Original:</strong> @item.AddedDate.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No carried-over items</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public DashboardData Data { get; set; } = new();

    [Parameter]
    public EventCallback OnItemClicked { get; set; }
}