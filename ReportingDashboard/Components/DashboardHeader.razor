@using ReportingDashboard.Models

<div class="hdr">
    <div>
        <h1 style="font-size:24px;font-weight:700;color:#111;margin:0;line-height:1.2;">
            @Data.Title
            <a href="@Data.BacklogUrl" style="color:#0078D4;text-decoration:none;font-size:14px;font-weight:400;margin-left:10px;">&#x1F4CB; ADO Backlog</a>
        </h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div style="display:flex;align-items:center;gap:22px;font-size:12px;color:#666;">
        <div style="display:flex;align-items:center;gap:6px;">
            <span style="display:inline-block;width:12px;height:12px;background:#F4B400;transform:rotate(45deg);"></span>
            <span>PoC Milestone</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <span style="display:inline-block;width:12px;height:12px;background:#34A853;transform:rotate(45deg);"></span>
            <span>Production Release</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <span style="display:inline-block;width:8px;height:8px;background:#999;border-radius:50%;"></span>
            <span>Checkpoint</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <span style="display:inline-block;width:2px;height:14px;background:#EA4335;"></span>
            <span>Now (@Data.Heatmap.CurrentMonth)</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public required DashboardData Data { get; set; }
}