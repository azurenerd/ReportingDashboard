<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="rc">
        <RouteView RouteData="@rc" DefaultLayout="typeof(Layout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <p>Page not found.</p>
        </LayoutView>
    </NotFound>
</Router>