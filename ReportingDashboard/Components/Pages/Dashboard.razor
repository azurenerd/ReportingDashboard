@page "/"

<div class="dashboard">
    <div class="hdr">
        <div>
            <h1>Executive Reporting Dashboard</h1>
            <div class="sub">Organization · Workstream · Reporting Period</div>
        </div>
        <div class="legend">
            <span class="legend-item">
                <span class="legend-diamond-poc"></span>PoC Milestone
            </span>
            <span class="legend-item">
                <span class="legend-diamond-prod"></span>Production Release
            </span>
            <span class="legend-item">
                <span class="legend-checkpoint"></span>Checkpoint
            </span>
            <span class="legend-item">
                <span class="legend-now"></span>Now
            </span>
        </div>
    </div>

    <div class="tl-area">
        <div class="tl-labels">
            <!-- Track labels will be rendered by Timeline component (task #2235) -->
        </div>
        <div class="tl-svg-box">
            <!-- SVG timeline will be rendered by Timeline component (task #2235) -->
        </div>
    </div>

    <div class="hm-wrap">
        <div class="hm-title">Monthly Execution Heatmap — Shipped · In Progress · Carryover · Blockers</div>
        <div class="hm-grid">
            <!-- Heatmap grid content will be rendered by HeatmapGrid component (task #2236) -->
        </div>
    </div>
</div>