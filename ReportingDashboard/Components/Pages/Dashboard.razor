@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject DashboardDataService DataService

@if (_error is not null)
{
    <div class="error-display">
        <p style="font-size:24px; font-weight:700;">⚠ Dashboard Error</p>
        <p style="font-size:16px; margin-top:12px;">@_error</p>
        <p style="font-size:14px; color:#888; margin-top:8px;">Please check your data.json file and refresh the browser.</p>
    </div>
}
else if (_data is not null)
{
    <DashboardHeader Data="@_data" />
    <TimelineSection Data="@_data" />
    <HeatmapGrid Data="@_data" />
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        DataService.Reload();
        _error = DataService.GetError();
        _data = DataService.GetDashboardData();
    }
}