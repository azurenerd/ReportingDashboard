@page "/"
@implements IDisposable
@inject ReportingDashboard.Services.DashboardDataService DataService
@using ReportingDashboard.Models

@if (DataService.ErrorMessage is not null && DataService.Data is null)
{
    <div class="error-container">
        <p>Unable to load dashboard data. Please check that data.json exists and contains valid JSON.</p>
        <p><span style="font-size:14px; color:#999;">@DataService.ErrorMessage</span></p>
    </div>
}
else if (DataService.Data is { } data)
{
    <p>Dashboard loaded: @data.Title</p>
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private async void HandleDataChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}