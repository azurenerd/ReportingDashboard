@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject IDashboardDataService DataService
@rendermode InteractiveServer

<PageTitle>Executive Reporting Dashboard</PageTitle>

@if (_data is null)
{
    <div class="loading">Loading dashboard data…</div>
}
else
{
    <div class="dashboard">
        <!-- Project Health Summary Header -->
        <ProjectHealthSummary Data="@_data" />
        <p class="executive-summary">@_data.Project.Summary</p>

        <!-- Milestone Timeline -->
        @if (_data.Milestones.Any())
        {
            <section class="milestones-section">
                <h2 class="section-title">Milestone Timeline</h2>
                <div class="timeline">
                    @foreach (var milestone in _data.Milestones)
                    {
                        <div class="timeline-item status-@milestone.Status.ToLowerInvariant()">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <span class="milestone-title">@milestone.Title</span>
                                <span class="milestone-date">@milestone.TargetDate.ToString("MMM dd, yyyy")</span>
                                @if (milestone.CompletionDate.HasValue)
                                {
                                    <span class="milestone-completed">Completed @milestone.CompletionDate.Value.ToString("MMM dd")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- Work Item Sections -->
        <div class="work-items-grid">
            @{ var shipped = _data.WorkItems.Where(w => w.Category.Equals("shipped", StringComparison.OrdinalIgnoreCase)).ToList(); }
            @{ var inProgress = _data.WorkItems.Where(w => w.Category.Equals("in-progress", StringComparison.OrdinalIgnoreCase)).ToList(); }
            @{ var carriedOver = _data.WorkItems.Where(w => w.Category.Equals("carried-over", StringComparison.OrdinalIgnoreCase)).ToList(); }

            @if (shipped.Any())
            {
                <section class="work-section shipped-section">
                    <h2 class="section-title"><span class="section-icon">✅</span> Shipped</h2>
                    <div class="card-list">
                        @foreach (var item in shipped)
                        {
                            <div class="work-card">
                                <div class="card-header">
                                    <span class="card-title">@item.Title</span>
                                    <span class="card-priority priority-@item.Priority.ToLowerInvariant()">@item.Priority</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p class="card-description">@item.Description</p>
                                }
                                <div class="card-footer">
                                    <span class="card-owner">@item.Owner</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <span class="card-notes">@item.Notes</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (inProgress.Any())
            {
                <section class="work-section in-progress-section">
                    <h2 class="section-title"><span class="section-icon">🔄</span> In Progress</h2>
                    <div class="card-list">
                        @foreach (var item in inProgress)
                        {
                            <div class="work-card">
                                <div class="card-header">
                                    <span class="card-title">@item.Title</span>
                                    <span class="card-priority priority-@item.Priority.ToLowerInvariant()">@item.Priority</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p class="card-description">@item.Description</p>
                                }
                                <div class="card-footer">
                                    <span class="card-owner">@item.Owner</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <span class="card-notes">@item.Notes</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (carriedOver.Any())
            {
                <section class="work-section carried-over-section">
                    <h2 class="section-title"><span class="section-icon">⏳</span> Carried Over</h2>
                    <div class="card-list">
                        @foreach (var item in carriedOver)
                        {
                            <div class="work-card">
                                <div class="card-header">
                                    <span class="card-title">@item.Title</span>
                                    <span class="card-priority priority-@item.Priority.ToLowerInvariant()">@item.Priority</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p class="card-description">@item.Description</p>
                                }
                                <div class="card-footer">
                                    <span class="card-owner">@item.Owner</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <span class="card-notes">@item.Notes</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    </div>
}

@code {
    private DashboardData? _data;

    protected override async Task OnInitializedAsync()
    {
        _data = await DataService.LoadDataAsync();
    }
}