@page "/"
@inject DashboardDataService DataService

<div class="dashboard-root">
    <!-- SECTION:ERROR-START -->
    @if (Data == null)
    {
        <div style="padding: 20px; color: #666;">
            @if (!string.IsNullOrEmpty(Error))
            {
                <p>@Error</p>
            }
            else
            {
                <p>Loading...</p>
            }
        </div>
    }
    <!-- SECTION:ERROR-END -->

    @if (Data != null)
    {
        <!-- SECTION:HEADER-START -->
        <div class="hdr">
            <div>
                <h1>@Data.Title
                    @if (!string.IsNullOrEmpty(Data.BacklogUrl))
                    {
                        <a href="@Data.BacklogUrl" target="_blank">⧉ ADO Backlog</a>
                    }
                </h1>
                <div class="sub">@Data.Subtitle</div>
            </div>
            <div class="legend">
                <span class="legend-item">
                    <span class="legend-diamond poc-diamond"></span>PoC Milestone
                </span>
                <span class="legend-item">
                    <span class="legend-diamond prod-diamond"></span>Production Release
                </span>
                <span class="legend-item">
                    <span class="legend-checkpoint"></span>Checkpoint
                </span>
                <span class="legend-item">
                    <span class="legend-now"></span>Now (@Data.CurrentMonth 2026)
                </span>
            </div>
        </div>
        <!-- SECTION:HEADER-END -->

        <!-- SECTION:TIMELINE-START -->
        <div style="height: 196px; background: #FAFAFA; padding: 6px 44px 0; border-bottom: 2px solid #E8E8E8;">Timeline placeholder</div>
        <!-- SECTION:TIMELINE-END -->

        <!-- SECTION:HEATMAP-START -->
        <div style="flex: 1; padding: 10px 44px;">Heatmap placeholder</div>
        <!-- SECTION:HEATMAP-END -->
    }
</div>

@code {
    private DashboardData? Data { get; set; }
    private string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Data = await DataService.GetDashboardDataAsync();
        Error = DataService.GetError();
    }
}