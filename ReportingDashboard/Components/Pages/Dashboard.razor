@page "/"
@using System.Globalization
@inject DashboardDataService DataService

<div class="dashboard-root">
    <!-- SECTION:ERROR-START -->
    @if (Data == null)
    {
        <div style="padding: 20px; color: #666;">
            @if (!string.IsNullOrEmpty(Error))
            {
                <p>@Error</p>
            }
            else
            {
                <p>Loading...</p>
            }
        </div>
    }
    <!-- SECTION:ERROR-END -->

    @if (Data != null)
    {
        <!-- SECTION:HEADER-START -->
        <div style="padding: 12px 44px 10px; border-bottom: 1px solid #E0E0E0;">
            <h1 style="font-size: 24px; font-weight: 700; color: #111; margin: 0;">@Data.Title</h1>
        </div>
        <!-- SECTION:HEADER-END -->

        <!-- SECTION:TIMELINE-START -->
        <div class="tl-area">
            <div class="tl-sidebar">
                @if (Data.Milestones != null)
                {
                    @foreach (var track in Data.Milestones)
                    {
                        <div class="tl-label" style="color: @track.Color;">
                            <strong>@track.Id</strong> @track.Label
                        </div>
                    }
                }
            </div>
            <div class="tl-svg-box">
                @((MarkupString)RenderTimelineSvg())
            </div>
        </div>
        <!-- SECTION:TIMELINE-END -->

        <!-- SECTION:HEATMAP-START -->
        <div style="flex: 1; padding: 10px 44px;">Heatmap placeholder</div>
        <!-- SECTION:HEATMAP-END -->
    }
</div>

@code {
    private DashboardData? Data { get; set; }
    private string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Data = await DataService.GetDashboardDataAsync();
        Error = DataService.GetError();
    }

    private string F(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    private int InferTimelineStartYear()
    {
        if (Data?.Milestones == null || Data.Milestones.Length == 0)
            return DateOnly.FromDateTime(DateTime.Today).Year;

        var allEvents = Data.Milestones
            .Where(t => t.Events != null && t.Events.Length > 0)
            .SelectMany(t => t.Events)
            .ToList();

        if (allEvents.Count == 0)
            return DateOnly.FromDateTime(DateTime.Today).Year;

        return allEvents.Min(e => e.Date).Year;
    }

    private double DateToX(DateOnly date)
    {
        var months = Data?.TimelineMonths ?? Array.Empty<string>();
        int monthCount = months.Length > 0 ? months.Length : 6;
        int startYear = InferTimelineStartYear();
        var startDate = new DateOnly(startYear, 1, 1);
        var endDate = startDate.AddMonths(monthCount);
        double totalDays = endDate.DayNumber - startDate.DayNumber;
        if (totalDays <= 0) return 0;
        double dayOffset = date.DayNumber - startDate.DayNumber;
        double x = (dayOffset / totalDays) * 1560.0;
        return Math.Clamp(x, 0, 1560);
    }

    private double GetTrackY(int trackIndex, int trackCount)
    {
        if (trackCount <= 0) return 92.5;
        return (185.0 / (trackCount + 1)) * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double size)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private double GetNowX()
    {
        var months = Data?.TimelineMonths ?? Array.Empty<string>();
        var currentMonth = Data?.CurrentMonth ?? "";
        if (months.Length == 0 || string.IsNullOrEmpty(currentMonth))
            return -1;

        double segmentWidth = 1560.0 / months.Length;
        for (int i = 0; i < months.Length; i++)
        {
            if (string.Equals(months[i], currentMonth, StringComparison.OrdinalIgnoreCase))
            {
                return (i * segmentWidth) + (segmentWidth / 2.0);
            }
        }
        return -1;
    }

    private string RenderTimelineSvg()
    {
        if (Data == null) return "";

        var months = Data.TimelineMonths ?? Array.Empty<string>();
        var milestones = Data.Milestones ?? Array.Empty<MilestoneTrack>();
        int monthCount = months.Length > 0 ? months.Length : 6;
        double segmentWidth = 1560.0 / monthCount;
        int trackCount = milestones.Length;

        var sb = new System.Text.StringBuilder();
        sb.Append("<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"1560\" height=\"185\" viewBox=\"0 0 1560 185\">");

        // Defs: drop shadow filter
        sb.Append("<defs>");
        sb.Append("<filter id=\"sh\"><feDropShadow dx=\"0\" dy=\"1\" stdDeviation=\"1.5\" flood-opacity=\"0.3\"/></filter>");
        sb.Append("</defs>");

        // Month gridlines and labels
        for (int i = 0; i < monthCount; i++)
        {
            double x = i * segmentWidth;
            sb.Append($"<line x1=\"{F(x)}\" y1=\"0\" x2=\"{F(x)}\" y2=\"185\" stroke=\"#E0E0E0\" stroke-width=\"1\"/>");
            string label = i < months.Length ? System.Net.WebUtility.HtmlEncode(months[i]) : "";
            double labelX = x + (segmentWidth / 2.0);
            sb.Append($"<text x=\"{F(labelX)}\" y=\"14\" fill=\"#999\" font-size=\"11\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{label}</text>");
        }
        // Right edge gridline
        sb.Append("<line x1=\"1560\" y1=\"0\" x2=\"1560\" y2=\"185\" stroke=\"#E0E0E0\" stroke-width=\"1\"/>");

        // NOW line
        double nowX = GetNowX();
        if (nowX >= 0)
        {
            sb.Append($"<line x1=\"{F(nowX)}\" y1=\"0\" x2=\"{F(nowX)}\" y2=\"185\" stroke=\"#EA4335\" stroke-width=\"2\" stroke-dasharray=\"6,3\"/>");
            sb.Append($"<text x=\"{F(nowX)}\" y=\"180\" fill=\"#EA4335\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"bold\" font-family=\"Segoe UI, Arial, sans-serif\">NOW</text>");
        }

        // Track lines and events
        for (int t = 0; t < trackCount; t++)
        {
            var track = milestones[t];
            double y = GetTrackY(t, trackCount);
            string color = System.Net.WebUtility.HtmlEncode(track.Color);

            // Horizontal track line
            sb.Append($"<line x1=\"0\" y1=\"{F(y)}\" x2=\"1560\" y2=\"{F(y)}\" stroke=\"{color}\" stroke-width=\"2\" opacity=\"0.4\"/>");

            if (track.Events == null) continue;

            foreach (var evt in track.Events)
            {
                double ex = DateToX(evt.Date);
                string encodedLabel = System.Net.WebUtility.HtmlEncode(evt.Label);

                switch (evt.Type)
                {
                    case "checkpoint":
                        // Open circle: white fill, colored stroke
                        sb.Append($"<circle cx=\"{F(ex)}\" cy=\"{F(y)}\" r=\"6\" fill=\"white\" stroke=\"{color}\" stroke-width=\"2\"/>");
                        break;

                    case "checkpoint-minor":
                        // Small filled dot
                        sb.Append($"<circle cx=\"{F(ex)}\" cy=\"{F(y)}\" r=\"3.5\" fill=\"{color}\" opacity=\"0.6\"/>");
                        break;

                    case "poc":
                        // Gold diamond with drop shadow
                        string pocPoints = DiamondPoints(ex, y, 11);
                        sb.Append($"<polygon points=\"{pocPoints}\" fill=\"#F4B400\" stroke=\"#D49B00\" stroke-width=\"1\" filter=\"url(#sh)\"/>");
                        break;

                    case "production":
                        // Green diamond with drop shadow
                        string prodPoints = DiamondPoints(ex, y, 11);
                        sb.Append($"<polygon points=\"{prodPoints}\" fill=\"#34A853\" stroke=\"#1B7A28\" stroke-width=\"1\" filter=\"url(#sh)\"/>");
                        break;
                }

                // Event label (skip empty labels)
                if (!string.IsNullOrWhiteSpace(evt.Label))
                {
                    // Alternate label position: above for even tracks, below for odd
                    double labelY = (t % 2 == 0) ? y - 16 : y + 22;
                    sb.Append($"<text x=\"{F(ex)}\" y=\"{F(labelY)}\" fill=\"#555\" font-size=\"9\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{encodedLabel}</text>");
                }
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }
}