@page "/"
@inject DashboardDataService DataService

@if (ErrorMessage is not null)
{
    <div class="error-container">
        <h2>Unable to load dashboard data.</h2>
        <p>Please check that data.json exists and contains valid JSON.</p>
        <p class="error-detail">@ErrorMessage</p>
    </div>
}
else if (Data is not null)
{
    <div class="dash-root">
        <!-- TODO: SECTION HDR - header bar -->
        <div class="hdr">
        </div>

        <!-- TODO: SECTION TIMELINE - SVG milestone timeline -->
        <div class="tl-area">
        </div>

        <!-- TODO: SECTION HEATMAP - monthly execution heatmap -->
        <div class="hm-wrap">
        </div>
    </div>
}

@code {
    private DashboardReport? Data;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Data = await DataService.GetDataAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private double DateToX(string dateStr)
    {
        throw new NotImplementedException();
    }

    private double TrackY(int index)
    {
        throw new NotImplementedException();
    }

    private string DiamondPoints(double cx, double cy)
    {
        throw new NotImplementedException();
    }

    private string CategoryCellClass(string category)
    {
        throw new NotImplementedException();
    }

    private string CategoryHeaderClass(string category)
    {
        throw new NotImplementedException();
    }
}