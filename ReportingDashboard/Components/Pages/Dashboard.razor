@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject DashboardDataService DataService
@implements IDisposable

@if (_data is not null)
{
    <div class="dashboard-container">
        <header class="dashboard-header">
            <h1>@_data.ProjectName</h1>
            <div class="header-meta">
                <span class="reporting-period">@_data.ReportingPeriod</span>
                <span class="status-badge status-@_data.OverallStatus.ToLowerInvariant()">@_data.OverallStatus</span>
            </div>
            <p class="executive-summary">@_data.Summary</p>
        </header>

        <section class="milestones-section">
            <h2>Milestones</h2>
            @if (_data.Milestones.Any())
            {
                <div class="milestone-timeline">
                    @foreach (var milestone in _data.Milestones)
                    {
                        <div class="milestone-item milestone-@milestone.Status">
                            <span class="milestone-marker" style="background-color: @milestone.Color;"></span>
                            <span class="milestone-name">@milestone.Name</span>
                            <span class="milestone-date">@milestone.TargetDate.ToString("MMM dd, yyyy")</span>
                            <span class="milestone-status">@milestone.Status</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-section">No milestones defined.</p>
            }
        </section>

        <section class="work-items-section">
            @if (_data.ShippedItems.Any())
            {
                <div class="work-category shipped-category">
                    <h3>Shipped (@_data.ShippedItems.Count)</h3>
                    @foreach (var item in _data.ShippedItems)
                    {
                        <div class="work-item-card">
                            <strong>@item.Title</strong>
                            <span class="work-item-owner">@item.Owner</span>
                            <span class="work-item-priority priority-@item.Priority">@item.Priority</span>
                        </div>
                    }
                </div>
            }

            @if (_data.InProgressItems.Any())
            {
                <div class="work-category in-progress-category">
                    <h3>In Progress (@_data.InProgressItems.Count)</h3>
                    @foreach (var item in _data.InProgressItems)
                    {
                        <div class="work-item-card">
                            <strong>@item.Title</strong>
                            <span class="work-item-owner">@item.Owner</span>
                            <span class="work-item-priority priority-@item.Priority">@item.Priority</span>
                        </div>
                    }
                </div>
            }

            @if (_data.CarriedOverItems.Any())
            {
                <div class="work-category carried-over-category">
                    <h3>Carried Over (@_data.CarriedOverItems.Count)</h3>
                    @foreach (var item in _data.CarriedOverItems)
                    {
                        <div class="work-item-card">
                            <strong>@item.Title</strong>
                            <span class="work-item-owner">@item.Owner</span>
                            <span class="work-item-priority priority-@item.Priority">@item.Priority</span>
                        </div>
                    }
                </div>
            }

            @if (_data.BlockedItems.Any())
            {
                <div class="work-category blocked-category">
                    <h3>Blocked (@_data.BlockedItems.Count)</h3>
                    @foreach (var item in _data.BlockedItems)
                    {
                        <div class="work-item-card">
                            <strong>@item.Title</strong>
                            <span class="work-item-owner">@item.Owner</span>
                            <span class="work-item-priority priority-@item.Priority">@item.Priority</span>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
}
else
{
    <div class="dashboard-container">
        <p>Loading dashboard...</p>
    </div>
}

@code {
    private DashboardData? _data;

    protected override void OnInitialized()
    {
        _data = DataService.GetDashboardData();
        DataService.DataChanged += OnDataChanged;
    }

    private void OnDataChanged()
    {
        InvokeAsync(() =>
        {
            _data = DataService.GetDashboardData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        DataService.DataChanged -= OnDataChanged;
    }
}