@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject DashboardDataService DataService

@if (_error is not null)
{
    <div class="error-display">
        <div class="error-content">
            <p class="error-icon">⚠ Dashboard Error</p>
            <p class="error-detail">@_error</p>
            <p class="error-hint">Please check your data.json file and refresh the browser.</p>
        </div>
    </div>
}
else if (_data is not null)
{
    <div class="dashboard">
        <!-- DashboardHeader -->
        <div class="hdr">
            <div>
                <h1>@_data.Title <a href="@(string.IsNullOrEmpty(_data.BacklogUrl) ? "#" : _data.BacklogUrl)" target="_blank">📋 ADO Backlog</a></h1>
                <div class="sub">@_data.Subtitle</div>
            </div>
            <div class="legend">
                <span class="leg-item"><span class="leg-diamond" style="background:#F4B400;"></span> PoC Milestone</span>
                <span class="leg-item"><span class="leg-diamond" style="background:#34A853;"></span> Production Release</span>
                <span class="leg-item"><span class="leg-circle"></span> Checkpoint</span>
                <span class="leg-item"><span class="leg-bar"></span> Now</span>
            </div>
        </div>

        <!-- TimelineSection placeholder -->
        <div class="tl-area">
            <div class="tl-sidebar">
                @foreach (var track in _data.Tracks)
                {
                    <div class="tl-track-label">
                        <span style="color:@track.Color; font-weight:600;">@track.Id</span>
                        <span style="color:#444; font-weight:400;"> @track.Label</span>
                    </div>
                }
            </div>
            <div class="tl-svg-box">
                <!-- SVG Timeline will be implemented in TimelineSection component -->
            </div>
        </div>

        <!-- HeatmapGrid placeholder -->
        <div class="hm-wrap">
            <div class="hm-title">MONTHLY EXECUTION HEATMAP — SHIPPED · IN PROGRESS · CARRYOVER · BLOCKERS</div>
            <div class="hm-grid" style="grid-template-columns: 160px repeat(@_data.Months.Count, 1fr); grid-template-rows: 36px repeat(4, 1fr);">
                <!-- Heatmap Grid will be implemented in HeatmapGrid component -->
            </div>
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        DataService.Reload();
        _data = DataService.GetDashboardData();
        _error = DataService.GetError();
    }
}