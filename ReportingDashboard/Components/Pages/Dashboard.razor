@page "/"
@inject DashboardDataService DataService

@if (!DataService.HasData)
{
    <div class="error-overlay">
        <div class="error-card">
            <div class="error-card-icon">
                @switch (DataService.ErrorType)
                {
                    case DataErrorType.FileNotFound:
                        <text>&#128194;</text>
                        break;
                    case DataErrorType.JsonParseError:
                        <text>&#9888;</text>
                        break;
                    case DataErrorType.ValidationError:
                        <text>&#9432;</text>
                        break;
                    default:
                        <text>&#9888;</text>
                        break;
                }
            </div>
            <h2 class="error-card-title">
                @switch (DataService.ErrorType)
                {
                    case DataErrorType.FileNotFound:
                        <text>Data File Not Found</text>
                        break;
                    case DataErrorType.JsonParseError:
                        <text>JSON Syntax Error</text>
                        break;
                    case DataErrorType.ValidationError:
                        <text>Invalid Configuration</text>
                        break;
                    default:
                        <text>Dashboard Error</text>
                        break;
                }
            </h2>
            <p class="error-card-message">@DataService.ErrorMessage</p>
            @if (!string.IsNullOrEmpty(DataService.ErrorDetails))
            {
                <div class="error-card-details">
                    <pre>@DataService.ErrorDetails</pre>
                </div>
            }
            <p class="error-card-hint">Fix the issue and refresh the browser to reload the dashboard.</p>
        </div>
    </div>
}
else
{
    <div class="dashboard" style="width:1920px;height:1080px;overflow:hidden;display:flex;flex-direction:column;">
        <Header Project="DataService.Data!.Project" />
        <Timeline Tracks="DataService.Data!.Timeline.Tracks"
                  StartDate="DataService.Data!.Timeline.StartDate"
                  EndDate="DataService.Data!.Timeline.EndDate"
                  NowDate="DataService.Data!.Timeline.NowDate" />
        <HeatmapGrid Heatmap="DataService.Data!.Heatmap" />
    </div>
}