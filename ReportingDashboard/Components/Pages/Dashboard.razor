@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject IDashboardDataService DataService
@rendermode InteractiveServer

<PageTitle>Executive Reporting Dashboard</PageTitle>

@if (_data is null)
{
    <div class="loading">Loading dashboard data…</div>
}
else
{
    <div class="dashboard">
        <!-- Project Health Summary Header -->
        <ProjectHealthSummary Data="@_data" />
        <p class="executive-summary">@_data.Project.Summary</p>

        <!-- Milestone Timeline -->
        @if (_data.Milestones.Any())
        {
            <section class="milestones-section">
                <h2 class="section-title">Milestone Timeline</h2>
                <div class="timeline">
                    @foreach (var milestone in _data.Milestones)
                    {
                        <div class="timeline-item status-@milestone.Status.ToLowerInvariant()">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <span class="milestone-title">@milestone.Title</span>
                                <span class="milestone-date">@milestone.TargetDate.ToString("MMM dd, yyyy")</span>
                                @if (milestone.CompletionDate.HasValue)
                                {
                                    <span class="milestone-completed">Completed @milestone.CompletionDate.Value.ToString("MMM dd")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- Work Items Heatmap Grid -->
        <div class="hm-wrap">
            <div class="hm-title">Monthly Execution Heatmap — Shipped · In Progress · Carryover</div>
            <div class="hm-grid" style="grid-template-columns: 160px repeat(@_months.Count, 1fr); grid-template-rows: 36px repeat(3, 1fr);">
                <!-- Header row -->
                <div class="hm-corner">Status</div>
                @for (int i = 0; i < _months.Count; i++)
                {
                    var isActive = i == _activeMonthIndex;
                    var hdrClass = "hm-col-hdr" + (isActive ? " hm-col-hdr-active" : "");
                    <div class="@hdrClass">
                        @_months[i]@(isActive ? " ◂ Now" : "")
                    </div>
                }

                <!-- Shipped row -->
                <WorkItemSection
                    Title="Shipped"
                    Icon="✓"
                    HeaderCssClass="ship-hdr"
                    CellCssClass="ship-cell"
                    ActiveCellCssClass="hm-cell-active"
                    Items="@_shipped"
                    Months="@_months"
                    ActiveMonthIndex="@_activeMonthIndex" />

                <!-- In Progress row -->
                <WorkItemSection
                    Title="In Progress"
                    Icon="●"
                    HeaderCssClass="prog-hdr"
                    CellCssClass="prog-cell"
                    ActiveCellCssClass="hm-cell-active"
                    Items="@_inProgress"
                    Months="@_months"
                    ActiveMonthIndex="@_activeMonthIndex" />

                <!-- Carried Over row -->
                <WorkItemSection
                    Title="Carryover"
                    Icon="↩"
                    HeaderCssClass="carry-hdr"
                    CellCssClass="carry-cell"
                    ActiveCellCssClass="hm-cell-active"
                    Items="@_carriedOver"
                    Months="@_months"
                    ActiveMonthIndex="@_activeMonthIndex" />
            </div>
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private List<WorkItem> _shipped = new();
    private List<WorkItem> _inProgress = new();
    private List<WorkItem> _carriedOver = new();
    private List<string> _months = new();
    private int _activeMonthIndex;

    protected override async Task OnInitializedAsync()
    {
        _data = await DataService.LoadDataAsync();

        if (_data is not null)
        {
            _shipped = _data.WorkItems
                .Where(w => w.Category.Equals("shipped", StringComparison.OrdinalIgnoreCase))
                .ToList();
            _inProgress = _data.WorkItems
                .Where(w => w.Category.Equals("in-progress", StringComparison.OrdinalIgnoreCase))
                .ToList();
            _carriedOver = _data.WorkItems
                .Where(w => w.Category.Equals("carried-over", StringComparison.OrdinalIgnoreCase))
                .ToList();

            BuildMonthColumns();
        }
    }

    private void BuildMonthColumns()
    {
        // Derive a 4-month window centered on the current reporting period
        var now = DateTime.Now;
        var startMonth = new DateTime(now.Year, now.Month, 1).AddMonths(-1);

        _months = Enumerable.Range(0, 4)
            .Select(i => startMonth.AddMonths(i).ToString("MMMM"))
            .ToList();

        // Active month is index 1 (current month, second column)
        _activeMonthIndex = 1;
    }
}