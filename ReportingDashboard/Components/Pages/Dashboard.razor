@page "/"

@inject DashboardDataService DataService

@if (DataService.HasError)
{
    <div style="padding:40px;margin:40px;border:2px solid #EA4335;border-radius:8px;font-family:'Segoe UI',Arial,sans-serif;font-size:16px;color:#991B1B;">
        <h2 style="margin-bottom:12px;">⚠ Dashboard Error</h2>
        <p>@DataService.ErrorMessage</p>
        <p style="margin-top:12px;color:#666;font-size:13px;">
            Fix the issue in <code>wwwroot/data/data.json</code> and restart the application.
        </p>
    </div>
}