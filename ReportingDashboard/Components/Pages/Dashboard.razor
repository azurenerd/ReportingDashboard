@page "/"
@inject DashboardDataService DataService

@if (_error is not null)
{
    <div class="error-container">
        <div class="error-message">
            @_error
        </div>
    </div>
}
else if (_data is not null)
{
    <!-- DashboardHeader -->
    <div class="hdr">
        <div class="hdr-left">
            <h1>@_data.Project.Title</h1>
            <div class="sub">@_data.Project.Subtitle</div>
        </div>
    </div>

    <!-- TimelineSection -->
    <div class="tl-area">
        <div class="tl-labels">
            <span style="color:#888;font-size:12px;">Timeline placeholder — child components will render here</span>
        </div>
        <div class="tl-svg-box"></div>
    </div>

    <!-- HeatmapSection -->
    <div class="hm-wrap">
        <div class="hm-title">MONTHLY EXECUTION HEATMAP</div>
        <div class="hm-grid" style="grid-template-columns:160px repeat(@(_data.Heatmap.Months.Count), 1fr);grid-template-rows:36px repeat(@(_data.Heatmap.Categories.Count), 1fr);">
            <div class="hm-corner">STATUS</div>
            @foreach (var month in _data.Heatmap.Months)
            {
                var isCurrent = month.StartsWith(_data.Project.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                <div class="hm-col-hdr @(isCurrent ? "now-hdr" : "")">
                    @month
                    @if (isCurrent)
                    {
                        <span class="now-badge">⬤ Now</span>
                    }
                </div>
            }
            @foreach (var category in _data.Heatmap.Categories)
            {
                <div class="hm-row-hdr @(category.CssClass)-hdr">@category.Emoji @category.Name.ToUpperInvariant()</div>
                @foreach (var month in _data.Heatmap.Months)
                {
                    var isCurrent = month.StartsWith(_data.Project.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                    var hasItems = category.Items.TryGetValue(month, out var items) && items.Count > 0;
                    <div class="hm-cell @(category.CssClass)-cell @(isCurrent ? "current" : "")">
                        @if (hasItems)
                        {
                            @foreach (var item in items!)
                            {
                                <div class="it">@item</div>
                            }
                        }
                        else
                        {
                            <div class="empty-cell">-</div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override void OnInitialized()
    {
        var (data, error) = DataService.Load();
        _data = data;
        _error = error;
    }
}