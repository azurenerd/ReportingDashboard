@page "/"
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject IDashboardDataService DataService
@implements IDisposable

@if (_data is not null)
{
    <Header Project="_data.Project" />
    <Timeline TimelineData="_data.Timeline" CurrentDate="@_data.Project.CurrentDate" />
    <Heatmap HeatmapData="_data.Heatmap" />
}
else
{
    <div class="error-panel">
        <div class="error-icon">⚠</div>
        <div class="error-message">@(_errorMessage ?? "Loading...")</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}

@code {
    private DashboardData? _data;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        _data = DataService.GetData();
        _errorMessage = DataService.GetError();
        DataService.OnDataChanged += HandleDataChanged;
    }

    private async void HandleDataChanged()
    {
        _data = DataService.GetData();
        _errorMessage = DataService.GetError();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}