@namespace ReportingDashboard.Components
@using Microsoft.AspNetCore.Components

<div class="tl-area">
    @* Left sidebar with milestone labels *@
    <div class="tl-sidebar">
        @foreach (var (milestone, index) in OrderedMilestones.Select((m, i) => (m, i)))
        {
            <div class="tl-label" style="color: @GetStatusColor(milestone.Status);">
                <span class="tl-label-id">M@(index + 1)</span>
                <span class="tl-label-name">@milestone.Title</span>
            </div>
        }
    </div>

    @* SVG timeline area *@
    <div class="tl-svg-box">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="@SvgWidth" height="@SvgHeight"
             style="overflow:visible;display:block;">
            <defs>
                <filter id="marker-shadow">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @foreach (var monthLine in MonthGridLines)
            {
                <line x1="@monthLine.X" y1="0"
                      x2="@monthLine.X" y2="@SvgHeight"
                      stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                @SvgText(monthLine.X + 5, 14, "#666", "11", "600", null, monthLine.Label)
            }

            @* Current date indicator (red dashed vertical line) *@
            @if (NowX >= 0 && NowX <= SvgWidth)
            {
                <line x1="@NowX" y1="0"
                      x2="@NowX" y2="@SvgHeight"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @SvgText(NowX + 4, 14, "#EA4335", "10", "700", null, "NOW")
            }

            @* Milestone rows *@
            @foreach (var (milestone, index) in OrderedMilestones.Select((m, i) => (m, i)))
            {
                var y = GetRowY(index);
                var color = GetStatusColor(milestone.Status);
                var targetX = DateToX(milestone.TargetDate);
                var completionX = milestone.CompletionDate.HasValue
                    ? DateToX(milestone.CompletionDate.Value)
                    : (double?)null;

                @* Horizontal connecting line spanning the full width *@
                <line x1="0" y1="@y"
                      x2="@SvgWidth" y2="@y"
                      stroke="@color" stroke-width="3" />

                @* Completion date marker (small filled circle) if different from target *@
                @if (completionX.HasValue && Math.Abs(completionX.Value - targetX) > 5)
                {
                    <circle cx="@F(completionX.Value)" cy="@y" r="5"
                            fill="@color" opacity="0.5" />
                    @SvgText(completionX.Value, y - 14, "#666", "10", null, "middle", milestone.CompletionDate!.Value.ToString("MMM d"))
                }

                @* Target date marker *@
                @if (IsDiamondMarker(milestone))
                {
                    @* Diamond marker for major milestones (PoC, Production, Release, Launch, GA) *@
                    var halfSize = 11;
                    <polygon points="@F(targetX),@F(y - halfSize) @F(targetX + halfSize),@y @F(targetX),@F(y + halfSize) @F(targetX - halfSize),@y"
                             fill="@GetMarkerFill(milestone)" stroke="@GetMarkerStroke(milestone)"
                             stroke-width="@GetMarkerStrokeWidth(milestone)"
                             filter="url(#marker-shadow)" />
                }
                else
                {
                    @* Circle marker for checkpoints *@
                    <circle cx="@F(targetX)" cy="@y" r="7"
                            fill="@GetMarkerFill(milestone)" stroke="@GetMarkerStroke(milestone)"
                            stroke-width="2.5" />
                }

                @* Date label for target *@
                @SvgText(targetX, GetDateLabelY(index, y), "#666", "10", null, "middle", FormatDateLabel(milestone))
            }
        </svg>
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();

    private const int SvgWidth = 1560;
    private const int RowSpacing = 56;
    private const int TopPadding = 30;

    private List<Milestone> OrderedMilestones =>
        Milestones.OrderBy(m => m.TargetDate).ToList();

    private int SvgHeight => Math.Max(185, TopPadding + (OrderedMilestones.Count * RowSpacing));

    private DateTime RangeStart { get; set; }
    private DateTime RangeEnd { get; set; }
    private double NowX { get; set; }
    private List<MonthGridLine> MonthGridLines { get; set; } = new();

    // Renders an SVG <text> element as raw markup to avoid Razor's special <text> handling
    private static MarkupString SvgText(double x, double y, string fill, string fontSize, string? fontWeight, string? textAnchor, string content)
    {
        var xStr = F(x);
        var yStr = F(y);
        var anchorAttr = textAnchor != null ? $" text-anchor=\"{textAnchor}\"" : "";
        var weightAttr = fontWeight != null ? $" font-weight=\"{fontWeight}\"" : "";
        var escaped = System.Net.WebUtility.HtmlEncode(content);
        return new MarkupString(
            $"<text x=\"{xStr}\" y=\"{yStr}\" fill=\"{fill}\" font-size=\"{fontSize}\"{weightAttr}{anchorAttr} font-family=\"Segoe UI,Arial\">{escaped}</text>"
        );
    }

    protected override void OnParametersSet()
    {
        if (!OrderedMilestones.Any()) return;

        var allDates = OrderedMilestones
            .Select(m => m.TargetDate)
            .Concat(OrderedMilestones
                .Where(m => m.CompletionDate.HasValue)
                .Select(m => m.CompletionDate!.Value))
            .ToList();

        var minDate = allDates.Min();
        var maxDate = allDates.Max();

        RangeStart = new DateTime(minDate.Year, minDate.Month, 1);
        RangeEnd = new DateTime(maxDate.Year, maxDate.Month, 1).AddMonths(2);

        NowX = DateToX(DateTime.Today);

        MonthGridLines.Clear();
        var current = RangeStart;
        while (current < RangeEnd)
        {
            MonthGridLines.Add(new MonthGridLine
            {
                X = DateToX(current),
                Label = current.ToString("MMM")
            });
            current = current.AddMonths(1);
        }
    }

    private double DateToX(DateTime date)
    {
        var totalDays = (RangeEnd - RangeStart).TotalDays;
        if (totalDays <= 0) return 0;
        var dayOffset = (date - RangeStart).TotalDays;
        return (dayOffset / totalDays) * SvgWidth;
    }

    private int GetRowY(int index) => TopPadding + (index * RowSpacing) + (RowSpacing / 2);

    private string GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "completed" => "#34A853",
        "in-progress" => "#0078D4",
        _ => "#6c757d"
    };

    private bool IsDiamondMarker(Milestone m)
    {
        var title = m.Title.ToLowerInvariant();
        return title.Contains("release") || title.Contains("launch") ||
               title.Contains("ga ") || title.StartsWith("ga") ||
               title.Contains("production") || title.Contains("poc") ||
               title.Contains("go-live") || title.Contains("deploy");
    }

    private string GetMarkerFill(Milestone m)
    {
        if (m.Status?.ToLowerInvariant() == "upcoming")
            return "white";
        return GetStatusColor(m.Status);
    }

    private string GetMarkerStroke(Milestone m)
    {
        if (m.Status?.ToLowerInvariant() == "upcoming")
            return "#6c757d";
        return GetStatusColor(m.Status);
    }

    private string GetMarkerStrokeWidth(Milestone m)
    {
        return m.Status?.ToLowerInvariant() == "upcoming" ? "2.5" : "0";
    }

    private int GetDateLabelY(int index, int rowY)
    {
        return index % 2 == 0 ? rowY - 18 : rowY + 24;
    }

    private string FormatDateLabel(Milestone m)
    {
        var dateStr = m.CompletionDate.HasValue && m.Status?.ToLowerInvariant() == "completed"
            ? m.CompletionDate.Value.ToString("MMM d")
            : m.TargetDate.ToString("MMM d");

        if (m.Status?.ToLowerInvariant() == "completed")
            return $"{dateStr} \u2713";

        return dateStr;
    }

    private static string F(double value) =>
        value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private class MonthGridLine
    {
        public double X { get; set; }
        public string Label { get; set; } = string.Empty;
    }
}