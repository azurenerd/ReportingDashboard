@namespace ReportingDashboard.Components

<header class="health-header">
    @if (Data?.Project is not null)
    {
        <div class="health-header-top">
            <div class="health-header-left">
                <h1 class="health-project-name">@Data.Project.Name</h1>
                @if (!string.IsNullOrWhiteSpace(Data.Project.ReportingPeriod))
                {
                    <div class="health-reporting-period">@Data.Project.ReportingPeriod</div>
                }
            </div>
            <div class="health-header-right">
                <span class="health-rag-indicator @GetRagCssClass()">
                    <span class="health-rag-dot"></span>
                    @((Data.Project.RagStatus ?? "Green").ToUpperInvariant())
                </span>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Data.Project.Summary))
        {
            <p class="health-summary-text">@Data.Project.Summary</p>
        }
    }
</header>

@code {
    [Parameter, EditorRequired]
    public DashboardData Data { get; set; } = default!;

    private string GetRagCssClass()
    {
        return Data?.Project?.RagStatus?.Trim().ToLowerInvariant() switch
        {
            "green" => "rag-status-green",
            "amber" or "yellow" => "rag-status-amber",
            "red" => "rag-status-red",
            _ => "rag-status-green"
        };
    }
}