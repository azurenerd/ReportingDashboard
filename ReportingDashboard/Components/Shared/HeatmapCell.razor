<div style="padding:8px 12px;border-right:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;overflow:hidden;">
    @if (Items == null || Items.Count == 0)
    {
        <div style="color:#999;text-align:center;">-</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div style="font-size:12px;color:#333;padding:2px 0;line-height:1.35;">@item</div>
        }
    }
</div>

@code {
    [Parameter] public required List<string> Items { get; set; }
    [Parameter] public required string CssClass { get; set; }
}