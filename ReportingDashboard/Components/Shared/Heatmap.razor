<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap &mdash; Shipped &bull; In Progress &bull; Carryover &bull; Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@HeatmapData.Months.Count, 1fr);">

        <div class="hm-corner">STATUS</div>
        @foreach (var month in HeatmapData.Months)
        {
            var isCurrent = month == HeatmapData.CurrentMonth;
            <div class="hm-col-hdr @(isCurrent ? "current-month-hdr" : "")">@month</div>
        }

        @foreach (var category in HeatmapData.Categories)
        {
            <div class="hm-row-hdr @(category.CssClass)-hdr">@category.Name</div>
            @foreach (var month in HeatmapData.Months)
            {
                var isCurrent = month == HeatmapData.CurrentMonth;
                List<string>? items = null;
                category.Items?.TryGetValue(month, out items);
                <div class="hm-cell @(category.CssClass)-cell @(isCurrent ? "current-month" : "")">
                    <HeatmapCell Items="items" CssClass="@category.CssClass" IsCurrentMonth="isCurrent" />
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public HeatmapConfig HeatmapData { get; set; } = default!;
}