@* Minimal stub — full implementation in T4 *@
<div class="hdr" style="display:flex;align-items:center;justify-content:space-between;padding:12px 44px 10px;border-bottom:1px solid #E0E0E0;">
    <div>
        <h1 style="font-size:24px;font-weight:700;margin:0;">
            @Project.Title
            <a href="@Project.BacklogUrl" target="_blank" style="color:#0078D4;text-decoration:none;font-size:14px;font-weight:400;">@(Project.BacklogLinkText ?? " ADO Backlog")</a>
        </h1>
        <div class="sub" style="font-size:12px;color:#888;margin-top:2px;">@Project.Subtitle</div>
    </div>
</div>

@code {
    [Parameter] public required ProjectInfo Project { get; set; }
}