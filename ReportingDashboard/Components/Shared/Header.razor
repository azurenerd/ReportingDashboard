@using ReportingDashboard.Models

<div class="hdr">
    <div>
        <h1>
            @Data.Title
            @if (!string.IsNullOrEmpty(Data.BacklogUrl))
            {
                <a href="@Data.BacklogUrl" target="_blank"> &#x1F4CB; ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Data.Subtitle</div>
    </div>
    <div style="display:flex;align-items:center;gap:22px;">
        <div style="display:flex;align-items:center;gap:6px;">
            <div style="width:12px;height:12px;background:#F4B400;transform:rotate(45deg);"></div>
            <span style="font-size:12px;color:#111;">PoC Milestone</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <div style="width:12px;height:12px;background:#34A853;transform:rotate(45deg);"></div>
            <span style="font-size:12px;color:#111;">Production Release</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <div style="width:8px;height:8px;background:#999;border-radius:50%;"></div>
            <span style="font-size:12px;color:#111;">Checkpoint</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
            <div style="width:2px;height:14px;background:#EA4335;"></div>
            <span style="font-size:12px;color:#111;">Now</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public DashboardData Data { get; set; } = default!;
}