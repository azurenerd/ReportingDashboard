<div class="hdr">
    <div class="hdr-left">
        <h1>@Project.Title <a href="@Project.BacklogUrl" target="_blank">@(Project.BacklogLinkText ?? "📋 ADO Backlog")</a></h1>
        <div class="sub">@Project.Subtitle</div>
    </div>
    <div class="hdr-legend">
        <span class="legend-item">
            <span class="legend-diamond poc-diamond"></span> PoC Milestone
        </span>
        <span class="legend-item">
            <span class="legend-diamond prod-diamond"></span> Production Release
        </span>
        <span class="legend-item">
            <span class="legend-circle"></span> Checkpoint
        </span>
        <span class="legend-item">
            <span class="legend-now-bar"></span> Now
        </span>
    </div>
</div>

@code {
    [Parameter] public required ProjectInfo Project { get; set; }
}