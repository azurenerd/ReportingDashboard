@using System.Globalization

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in Tracks)
        {
            <div class="tl-label">
                <span class="tl-label-id" style="color: @track.Color;">@track.Id</span><br />
                <span class="tl-label-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" overflow="visible" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month gridlines and labels *@
            @{
                var current = new DateTime(StartDate.Year, StartDate.Month, 1);
                while (current <= EndDate)
                {
                    var x = DateToX(current);
                    <line x1="@F(x)" y1="0" x2="@F(x)" y2="@F(SvgHeight)"
                          stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                    @RenderMonthLabel(x + 5, current.ToString("MMM"))
                    current = current.AddMonths(1);
                }
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < Tracks.Count; i++)
            {
                var track = Tracks[i];
                var y = TrackY(i, Tracks.Count);

                @if (track.Milestones.Count > 0)
                {
                    var firstX = DateToX(track.Milestones.First().Date);
                    var lastX = DateToX(track.Milestones.Last().Date);

                    <line x1="@F(firstX)" y1="@F(y)" x2="@F(lastX)" y2="@F(y)"
                          stroke="@track.Color" stroke-width="3" />
                }

                @foreach (var milestone in track.Milestones)
                {
                    var mx = DateToX(milestone.Date);

                    @switch (milestone.Type)
                    {
                        case "start":
                            <circle cx="@F(mx)" cy="@F(y)" r="7"
                                    fill="white" stroke="@track.Color" stroke-width="2.5" />
                            break;
                        case "checkpoint":
                            <circle cx="@F(mx)" cy="@F(y)" r="4"
                                    fill="#999" />
                            break;
                        case "poc":
                            <polygon points="@DiamondPoints(mx, y)"
                                     fill="#F4B400" filter="url(#sh)" />
                            break;
                        case "production":
                            <polygon points="@DiamondPoints(mx, y)"
                                     fill="#34A853" filter="url(#sh)" />
                            break;
                    }

                    @if (!string.IsNullOrEmpty(milestone.Label))
                    {
                        var labelY = milestone.LabelPosition == LabelPosition.Above ? y - 16 : y + 24;
                        @RenderSvgLabel(mx, labelY, milestone.Label, "#666", "10", "400")
                    }
                }
            }

            @* NOW line *@
            @{
                var nowX = DateToX(NowDate ?? DateTime.Now);
                if (nowX > 0 && nowX < SvgWidth)
                {
                    <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@F(SvgHeight)"
                          stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                    @RenderSvgLabel(nowX, SvgHeight + 12, "NOW", "#EA4335", "10", "700")
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public required List<TimelineTrack> Tracks { get; set; }
    [Parameter] public required DateTime StartDate { get; set; }
    [Parameter] public required DateTime EndDate { get; set; }
    [Parameter] public DateTime? NowDate { get; set; }

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private double DateToX(DateTime date)
    {
        var totalDays = (EndDate - StartDate).TotalDays;
        if (totalDays <= 0) return 0;
        var elapsed = (date - StartDate).TotalDays;
        return Math.Clamp(elapsed / totalDays * SvgWidth, 0, SvgWidth);
    }

    private double TrackY(int index, int count)
    {
        if (count <= 1) return SvgHeight / 2.0;
        var usableHeight = SvgHeight - 42 - 31;
        return 42 + (index * usableHeight / (double)(count - 1));
    }

    private string DiamondPoints(double cx, double cy, double r = 11)
        => $"{F(cx)},{F(cy - r)} {F(cx + r)},{F(cy)} {F(cx)},{F(cy + r)} {F(cx - r)},{F(cy)}";

    private static string F(double v) =>
        v.ToString("F1", CultureInfo.InvariantCulture);

    private RenderFragment RenderMonthLabel(double x, string label) => builder =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", F(x));
        builder.AddAttribute(2, "y", "14");
        builder.AddAttribute(3, "font-size", "11");
        builder.AddAttribute(4, "font-weight", "600");
        builder.AddAttribute(5, "fill", "#666");
        builder.AddAttribute(6, "font-family", "Segoe UI, Arial, sans-serif");
        builder.AddContent(7, label);
        builder.CloseElement();
    };

    private RenderFragment RenderSvgLabel(double x, double y, string content, string fill, string fontSize, string fontWeight) => builder =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", F(x));
        builder.AddAttribute(2, "y", F(y));
        builder.AddAttribute(3, "font-size", fontSize);
        builder.AddAttribute(4, "font-weight", fontWeight);
        builder.AddAttribute(5, "fill", fill);
        builder.AddAttribute(6, "text-anchor", "middle");
        builder.AddAttribute(7, "font-family", "Segoe UI, Arial, sans-serif");
        builder.AddContent(8, content);
        builder.CloseElement();
    };
}