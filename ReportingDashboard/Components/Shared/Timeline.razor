@* Minimal stub — full SVG implementation in T3 *@
<div class="tl-area" style="display:flex;align-items:stretch;padding:6px 44px 0;height:196px;background:#FAFAFA;border-bottom:2px solid #E8E8E8;">
    <div style="width:230px;flex-shrink:0;border-right:1px solid #E0E0E0;display:flex;flex-direction:column;justify-content:space-around;">
        @foreach (var track in Tracks)
        {
            <div style="padding:4px 8px;">
                <span style="font-size:12px;font-weight:600;color:@track.Color;">@track.Id</span><br/>
                <span style="font-size:12px;font-weight:400;color:#444;">@track.Name</span>
            </div>
        }
    </div>
    <div style="flex:1;padding-left:12px;padding-top:6px;">
        <svg width="1560" height="185" overflow="visible">
            @for (var i = 0; i < Tracks.Count; i++)
            {
                var y = Tracks.Count <= 1 ? 92.5 : 42 + (i * 112.0 / (Tracks.Count - 1));
                <line x1="0" y1="@y" x2="1560" y2="@y" stroke="@Tracks[i].Color" stroke-width="3" />
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public required List<TimelineTrack> Tracks { get; set; }
    [Parameter] public required DateTime StartDate { get; set; }
    [Parameter] public required DateTime EndDate { get; set; }
    [Parameter] public DateTime? NowDate { get; set; }
}