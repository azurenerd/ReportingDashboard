@using ReportingDashboard.Models
@using System.Globalization

<div class="tl-area">
    @* Left sidebar: track labels *@
    <div style="width:230px; flex-shrink:0; display:flex; flex-direction:column; justify-content:space-around; padding:16px 12px 16px 0; border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px; font-weight:600; color:@track.Color;">@track.Id</span>
                <span style="font-size:12px; font-weight:400; color:#444;"> @track.Label</span>
            </div>
        }
    </div>

    @* Right side: SVG timeline *@
    <div class="tl-svg-box" style="flex:1; padding-left:12px; padding-top:6px;">
        <svg width="1560" height="185" style="overflow:visible;" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-30%" y="-30%" width="160%" height="160%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @{ var monthGrid = GetMonthGridLines(); }
            @foreach (var (date, label) in monthGrid)
            {
                var x = GetXPosition(date);
                <line x1="@F(x)" y1="0" x2="@F(x)" y2="@F(SvgHeight)"
                      stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                @RenderSvgText(F(x + 4), "12", "11", "600", "#666", "start", label)
            }

            @* Track lines and milestones *@
            @{ var totalTracks = TimelineData.Tracks.Count; }
            @for (int i = 0; i < totalTracks; i++)
            {
                var track = TimelineData.Tracks[i];
                var trackY = GetTrackY(i, totalTracks);

                @* Horizontal track line *@
                <line x1="0" y1="@F(trackY)" x2="@F(SvgWidth)" y2="@F(trackY)"
                      stroke="@track.Color" stroke-width="3" />

                @* Milestones *@
                @foreach (var milestone in track.Milestones)
                {
                    var mDate = DateOnly.ParseExact(milestone.Date, "yyyy-MM-dd", CultureInfo.InvariantCulture);
                    var mx = GetXPosition(mDate);

                    @if (milestone.Type == "poc")
                    {
                        @* PoC diamond - gold *@
                        <polygon points="@DiamondPoints(mx, trackY, 11)"
                                 fill="#F4B400" filter="url(#sh)" />
                        @RenderSvgText(F(mx), F(trackY - 16), "10", null, "#666", "middle", milestone.Label)
                    }
                    else if (milestone.Type == "production")
                    {
                        @* Production diamond - green *@
                        <polygon points="@DiamondPoints(mx, trackY, 11)"
                                 fill="#34A853" filter="url(#sh)" />
                        @RenderSvgText(F(mx), F(trackY - 16), "10", null, "#666", "middle", milestone.Label)
                    }
                    else if (milestone.Type == "checkpoint-small")
                    {
                        @* Small checkpoint dot *@
                        <circle cx="@F(mx)" cy="@F(trackY)" r="4" fill="#999" />
                        @RenderSvgText(F(mx), F(trackY + 18), "10", null, "#666", "middle", milestone.Label)
                    }
                    else
                    {
                        @* Standard checkpoint circle *@
                        <circle cx="@F(mx)" cy="@F(trackY)" r="6"
                                fill="white" stroke="@track.Color" stroke-width="2.5" />
                        @RenderSvgText(F(mx), F(trackY + 20), "10", null, "#666", "middle", milestone.Label)
                    }
                }
            }

            @* NOW line *@
            @{
                var nowX = GetXPosition(NowDate);
            }
            @if (nowX > 0 && nowX < SvgWidth)
            {
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@F(SvgHeight)"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @RenderSvgText(F(nowX), F(SvgHeight - 2), "10", "700", "#EA4335", "middle", "NOW")
            }
        </svg>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TimelineConfig TimelineData { get; set; } = default!;

    [Parameter, EditorRequired]
    public DateOnly NowDate { get; set; }

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;

    private DateOnly _rangeStart;
    private DateOnly _rangeEnd;
    private int _totalDays;

    protected override void OnParametersSet()
    {
        _rangeStart = DateOnly.ParseExact(TimelineData.StartMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var endMonth = DateOnly.ParseExact(TimelineData.EndMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        _rangeEnd = endMonth.AddMonths(1).AddDays(-1);
        _totalDays = _rangeEnd.DayNumber - _rangeStart.DayNumber;
    }

    private double GetXPosition(DateOnly date)
    {
        if (_totalDays <= 0) return 0;
        var offset = date.DayNumber - _rangeStart.DayNumber;
        return Math.Clamp((offset / (double)_totalDays) * SvgWidth, 0, SvgWidth);
    }

    private double GetTrackY(int trackIndex, int totalTracks)
    {
        var usableHeight = SvgHeight - 30;
        var spacing = usableHeight / (totalTracks + 1);
        return 30 + spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{F(cx)},{F(cy - radius)} {F(cx + radius)},{F(cy)} {F(cx)},{F(cy + radius)} {F(cx - radius)},{F(cy)}";
    }

    private List<(DateOnly date, string label)> GetMonthGridLines()
    {
        var lines = new List<(DateOnly, string)>();
        var current = _rangeStart;
        var endMonth = DateOnly.ParseExact(TimelineData.EndMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        while (current <= endMonth)
        {
            lines.Add((current, current.ToString("MMM", CultureInfo.InvariantCulture)));
            current = current.AddMonths(1);
        }
        return lines;
    }

    private static string F(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    private Microsoft.AspNetCore.Components.MarkupString RenderSvgText(
        string x, string y, string fontSize, string? fontWeight, string fill, string textAnchor, string content)
    {
        var fw = fontWeight is not null ? $" font-weight=\"{fontWeight}\"" : "";
        var html = $"<text x=\"{x}\" y=\"{y}\" font-size=\"{fontSize}\"{fw} fill=\"{fill}\" text-anchor=\"{textAnchor}\" font-family=\"'Segoe UI', Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(content)}</text>";
        return new Microsoft.AspNetCore.Components.MarkupString(html);
    }
}