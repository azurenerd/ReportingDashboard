@using ReportingDashboard.Models
@using System.Globalization

<div class="tl-area">
    <div style="width:230px;flex-shrink:0;display:flex;flex-direction:column;justify-content:space-around;padding:16px 12px 16px 0;border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px;font-weight:600;color:@track.Color;">@track.Id</span>
                <span style="font-size:12px;font-weight:400;color:#444;"> @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" style="overflow:visible;" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @* Month grid lines and labels *@
            @foreach (var m in GetMonthGridLines())
            {
                var x = GetXPosition(m.date);
                <line x1="@F(x)" y1="10" x2="@F(x)" y2="185" stroke="#bbb" stroke-opacity="0.4" />
                @((MarkupString)$"<text x=\"{F(x + 5)}\" y=\"10\" font-size=\"11\" font-weight=\"600\" fill=\"#666\" font-family=\"Segoe UI, Arial, sans-serif\">{m.label}</text>")
            }

            @* Track lines and milestones *@
            @for (int i = 0; i < TimelineData.Tracks.Count; i++)
            {
                var track = TimelineData.Tracks[i];
                var y = GetTrackY(i, TimelineData.Tracks.Count);

                <line x1="0" y1="@F(y)" x2="1560" y2="@F(y)" stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    var msDate = DateOnly.ParseExact(ms.Date, "yyyy-MM-dd", CultureInfo.InvariantCulture);
                    var mx = GetXPosition(msDate);

                    @if (ms.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(mx, y)" fill="#F4B400" filter="url(#sh)" />
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(y - 16)}\" font-size=\"10\" fill=\"#666\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@DiamondPoints(mx, y)" fill="#34A853" filter="url(#sh)" />
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(y - 16)}\" font-size=\"10\" fill=\"#666\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                    }
                    else if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5" />
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(y + 20)}\" font-size=\"10\" fill=\"#666\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                    }
                    else if (ms.Type == "checkpoint-small")
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="4" fill="#999" />
                        @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(y + 20)}\" font-size=\"10\" fill=\"#666\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                    }
                }
            }

            @* NOW line *@
            @{
                var nowX = GetXPosition(NowDate);
            }
            <line x1="@F(nowX)" y1="10" x2="@F(nowX)" y2="185" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
            @((MarkupString)$"<text x=\"{F(nowX)}\" y=\"8\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">NOW</text>")
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineConfig TimelineData { get; set; } = default!;
    [Parameter] public DateOnly NowDate { get; set; }

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;

    private string F(double value) => value.ToString("0.#", CultureInfo.InvariantCulture);

    private double GetXPosition(DateOnly date)
    {
        var start = DateOnly.ParseExact(TimelineData.StartMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var endMonth = DateOnly.ParseExact(TimelineData.EndMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var end = endMonth.AddMonths(1).AddDays(-1);
        var totalDays = end.DayNumber - start.DayNumber;
        if (totalDays <= 0) return 0;
        var offset = date.DayNumber - start.DayNumber;
        return Math.Clamp((offset / (double)totalDays) * SvgWidth, 0, SvgWidth);
    }

    private double GetTrackY(int trackIndex, int totalTracks)
    {
        var usableHeight = SvgHeight - 30;
        var spacing = usableHeight / (totalTracks + 1);
        return 30 + spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11)
    {
        return $"{F(cx)},{F(cy - radius)} {F(cx + radius)},{F(cy)} {F(cx)},{F(cy + radius)} {F(cx - radius)},{F(cy)}";
    }

    private List<(DateOnly date, string label)> GetMonthGridLines()
    {
        var lines = new List<(DateOnly, string)>();
        var current = DateOnly.ParseExact(TimelineData.StartMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var endMonth = DateOnly.ParseExact(TimelineData.EndMonth + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
        while (current <= endMonth)
        {
            lines.Add((current, current.ToString("MMM", CultureInfo.InvariantCulture)));
            current = current.AddMonths(1);
        }
        return lines;
    }
}