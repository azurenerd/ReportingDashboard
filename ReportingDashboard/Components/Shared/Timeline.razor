@using ReportingDashboard.Models
@using System.Globalization

<div class="tl-area">
    @if (Milestones is not null && Milestones.Count > 0)
    {
        <div class="tl-sidebar">
            @for (var i = 0; i < Milestones.Count; i++)
            {
                var ms = Milestones[i];
                <div class="tl-ms-entry">
                    <span class="tl-ms-id" style="color:@ms.Color">@ms.Id</span>
                    <span class="tl-ms-label">@ms.Label</span>
                </div>
            }
        </div>
        <div class="tl-svg-box">
            <svg width="1560" height="185" style="overflow:visible;display:block" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3"/>
                    </filter>
                </defs>

                @* Month gridlines and labels *@
                @foreach (var month in GetMonthGridlines())
                {
                    <line x1="@F(month.X)" y1="0" x2="@F(month.X)" y2="185"
                          stroke="#bbb" stroke-opacity="0.4" stroke-width="1"/>
                    @((MarkupString)$"<text x=\"{F(month.X + 5)}\" y=\"14\" fill=\"#666\" font-size=\"11\" font-weight=\"600\" font-family=\"Segoe UI,Arial\">{month.Label}</text>")
                }

                @* NOW line *@
                @{
                    var nowX = GetXPosition(CurrentDate);
                }
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="185"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3"/>
                @((MarkupString)$"<text x=\"{F(nowX + 4)}\" y=\"14\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" font-family=\"Segoe UI,Arial\">NOW</text>")

                @* Milestone lanes and events *@
                @for (var mi = 0; mi < Milestones.Count; mi++)
                {
                    var ms = Milestones[mi];
                    var cy = GetYPosition(mi, Milestones.Count);

                    @* Horizontal milestone line *@
                    <line x1="0" y1="@F(cy)" x2="1560" y2="@F(cy)"
                          stroke="@ms.Color" stroke-width="3"/>

                    @* Events *@
                    var lastLabelX = -999.0;
                    var labelBelow = false;

                    @foreach (var evt in ms.Events)
                    {
                        if (!DateOnly.TryParse(evt.Date, out var evtDate))
                        {
                            continue;
                        }
                        var cx = GetXPosition(evtDate);

                        @if (evt.Type == "checkpoint")
                        {
                            <circle cx="@F(cx)" cy="@F(cy)" r="7"
                                    fill="white" stroke="@ms.Color" stroke-width="2.5"/>
                        }
                        else if (evt.Type == "checkpoint-small")
                        {
                            <circle cx="@F(cx)" cy="@F(cy)" r="4" fill="#999"/>
                        }
                        else if (evt.Type == "poc")
                        {
                            <polygon points="@GetDiamondPoints(cx, cy, 11)"
                                     fill="#F4B400" filter="url(#sh)"/>
                        }
                        else if (evt.Type == "production")
                        {
                            <polygon points="@GetDiamondPoints(cx, cy, 11)"
                                     fill="#34A853" filter="url(#sh)"/>
                        }

                        @* Event label *@
                        @if (!string.IsNullOrEmpty(evt.Label))
                        {
                            var useBelow = false;

                            if (!string.IsNullOrEmpty(evt.LabelPosition))
                            {
                                useBelow = evt.LabelPosition == "below";
                            }
                            else if (Math.Abs(cx - lastLabelX) < 60)
                            {
                                labelBelow = !labelBelow;
                                useBelow = labelBelow;
                            }
                            else
                            {
                                labelBelow = false;
                                useBelow = false;
                            }

                            var ly = useBelow ? cy + 20 : cy - 16;
                            lastLabelX = cx;

                            @((MarkupString)$"<text x=\"{F(cx)}\" y=\"{F(ly)}\" fill=\"#666\" font-size=\"10\" text-anchor=\"middle\" font-family=\"Segoe UI,Arial\">{System.Net.WebUtility.HtmlEncode(evt.Label)}</text>")
                        }
                    }
                }
            </svg>
        </div>
    }
</div>

@code {
    [Parameter] public List<Milestone> Milestones { get; set; } = new();
    [Parameter] public DateOnly TimelineStart { get; set; }
    [Parameter] public DateOnly TimelineEnd { get; set; }
    [Parameter] public DateOnly CurrentDate { get; set; }

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private static string F(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    private double GetXPosition(DateOnly date)
    {
        var totalDays = TimelineEnd.DayNumber - TimelineStart.DayNumber;
        if (totalDays <= 0) return 0;
        var dayOffset = date.DayNumber - TimelineStart.DayNumber;
        return Math.Clamp((dayOffset / (double)totalDays) * SvgWidth, 0, SvgWidth);
    }

    private double GetYPosition(int milestoneIndex, int milestoneCount)
    {
        var usableHeight = SvgHeight - 35;
        var spacing = usableHeight / Math.Max(milestoneCount, 1);
        return 35 + (milestoneIndex * spacing);
    }

    private string GetDiamondPoints(double cx, double cy, double size)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private List<MonthGridline> GetMonthGridlines()
    {
        var gridlines = new List<MonthGridline>();
        var current = new DateOnly(TimelineStart.Year, TimelineStart.Month, 1);
        var end = new DateOnly(TimelineEnd.Year, TimelineEnd.Month, 1);

        while (current <= end)
        {
            var x = GetXPosition(current);
            gridlines.Add(new MonthGridline
            {
                X = x,
                Label = current.ToString("MMM", CultureInfo.InvariantCulture)
            });
            current = current.AddMonths(1);
        }

        return gridlines;
    }

    private record MonthGridline
    {
        public double X { get; init; }
        public string Label { get; init; } = "";
    }
}