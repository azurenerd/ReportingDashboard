@using System.Globalization

<div class="tl-area">
    <div style="width:230px;flex-shrink:0;display:flex;flex-direction:column;justify-content:space-around;padding:16px 12px 16px 0;border-right:1px solid #E0E0E0;">
        @foreach (var track in TimelineData.Tracks)
        {
            <div>
                <span style="font-size:12px;font-weight:600;color:@track.Color;">@track.Id</span>
                <span style="font-size:12px;font-weight:400;color:#444;"> @track.Label</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="1560" height="185" style="overflow:visible;" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @{ var monthLines = GetMonthGridLines(); }
            @{ var totalTracks = TimelineData.Tracks.Count; }

            @foreach (var ml in monthLines)
            {
                var xPos = GetXPosition(ml.Date);
                <line x1="@Fmt(xPos)" y1="15" x2="@Fmt(xPos)" y2="185" stroke="#bbb" stroke-opacity="0.4" />
                @((MarkupString)$"<text x=\"{Fmt(xPos + 5)}\" y=\"12\" font-size=\"11\" font-weight=\"600\" fill=\"#666\" font-family=\"Segoe UI, Arial, sans-serif\">{ml.Label}</text>")
            }

            @for (int i = 0; i < totalTracks; i++)
            {
                var track = TimelineData.Tracks[i];
                var trackY = GetTrackY(i, totalTracks);

                <line x1="0" y1="@Fmt(trackY)" x2="1560" y2="@Fmt(trackY)" stroke="@track.Color" stroke-width="3" />

                @foreach (var ms in track.Milestones)
                {
                    if (!DateOnly.TryParseExact(ms.Date, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var msDate))
                        continue;

                    var msX = GetXPosition(msDate);
                    var labelYOffset = (i % 2 == 0) ? trackY - 18 : trackY + 22;

                    @if (ms.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(msX, trackY)" fill="#F4B400" filter="url(#sh)" />
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@DiamondPoints(msX, trackY)" fill="#34A853" filter="url(#sh)" />
                    }
                    else if (ms.Type == "checkpoint")
                    {
                        <circle cx="@Fmt(msX)" cy="@Fmt(trackY)" r="7" fill="white" stroke="@track.Color" stroke-width="2.5" />
                    }
                    else if (ms.Type == "checkpoint-small")
                    {
                        <circle cx="@Fmt(msX)" cy="@Fmt(trackY)" r="4" fill="#999" />
                    }

                    @((MarkupString)$"<text x=\"{Fmt(msX)}\" y=\"{Fmt(labelYOffset)}\" font-size=\"10\" fill=\"#666\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">{System.Net.WebUtility.HtmlEncode(ms.Label)}</text>")
                }
            }

            @{
                var nowXPos = GetXPosition(NowDate);
            }
            <line x1="@Fmt(nowXPos)" y1="5" x2="@Fmt(nowXPos)" y2="185" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
            @((MarkupString)$"<text x=\"{Fmt(nowXPos)}\" y=\"4\" fill=\"#EA4335\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\" font-family=\"Segoe UI, Arial, sans-serif\">NOW</text>")
        </svg>
    </div>
</div>

@code {
    [Parameter]
    public TimelineConfig TimelineData { get; set; } = default!;

    [Parameter]
    public DateOnly NowDate { get; set; }

    private const double SvgWidth = 1560.0;
    private const double SvgHeight = 185.0;

    private string Fmt(double val) => val.ToString("0.##", CultureInfo.InvariantCulture);

    private DateOnly ParseMonth(string yyyyMM)
    {
        return DateOnly.ParseExact(yyyyMM + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture);
    }

    private double GetXPosition(DateOnly date)
    {
        var start = ParseMonth(TimelineData.StartMonth);
        var endMonthStart = ParseMonth(TimelineData.EndMonth);
        var end = endMonthStart.AddMonths(1).AddDays(-1);
        var totalDays = end.DayNumber - start.DayNumber;
        if (totalDays <= 0) return 0;
        var offset = date.DayNumber - start.DayNumber;
        return Math.Clamp((offset / (double)totalDays) * SvgWidth, 0, SvgWidth);
    }

    private double GetTrackY(int trackIndex, int totalTracks)
    {
        var usableHeight = SvgHeight - 30.0;
        var spacing = usableHeight / (totalTracks + 1);
        return 30.0 + spacing * (trackIndex + 1);
    }

    private string DiamondPoints(double cx, double cy, double radius = 11.0)
    {
        return $"{Fmt(cx)},{Fmt(cy - radius)} {Fmt(cx + radius)},{Fmt(cy)} {Fmt(cx)},{Fmt(cy + radius)} {Fmt(cx - radius)},{Fmt(cy)}";
    }

    private record MonthGridLine(DateOnly Date, string Label);

    private List<MonthGridLine> GetMonthGridLines()
    {
        var lines = new List<MonthGridLine>();
        var current = ParseMonth(TimelineData.StartMonth);
        var endMonthStart = ParseMonth(TimelineData.EndMonth);
        while (current <= endMonthStart)
        {
            lines.Add(new MonthGridLine(current, current.ToString("MMM", CultureInfo.InvariantCulture)));
            current = current.AddMonths(1);
        }
        return lines;
    }
}