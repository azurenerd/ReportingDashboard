<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap – Shipped · In Progress · Carryover · Blockers</div>
    <div class="hm-grid" style="grid-template-columns:160px repeat(@Heatmap.Columns.Count, 1fr);grid-template-rows:36px repeat(4, 1fr);">
        @* Header row *@
        <div class="hm-corner">Status</div>
        @for (var i = 0; i < Heatmap.Columns.Count; i++)
        {
            var col = Heatmap.Columns[i];
            var isCurrent = col == Heatmap.CurrentColumn;
            var isLast = i == Heatmap.Columns.Count - 1;
            <div class="hm-col-hdr @(isCurrent ? "current-month-hdr" : "")" style="@(isLast ? "border-right:none;" : "")">
                @col
                @if (isCurrent)
                {
                    <text> ◀ Now</text>
                }
            </div>
        }

        @* Category rows *@
        @foreach (var row in Heatmap.Rows)
        {
            var prefix = GetCssPrefix(row.Category);
            var icon = GetCategoryIcon(row.Category);

            <div class="hm-row-hdr @(prefix)-hdr">@icon @row.Category</div>

            @for (var i = 0; i < Heatmap.Columns.Count; i++)
            {
                var col = Heatmap.Columns[i];
                var isCurrent = col == Heatmap.CurrentColumn;
                var isLast = i == Heatmap.Columns.Count - 1;
                var items = row.Items.TryGetValue(col, out var list) ? list : new List<string>();
                var cssClass = $"{prefix}-cell{(isCurrent ? " current" : "")}";

                <HeatmapCell Items="items" CssClass="@cssClass" IsLastColumn="isLast" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public required HeatmapData Heatmap { get; set; }

    private static readonly Dictionary<string, string> CssPrefixMap = new()
    {
        ["Shipped"] = "ship",
        ["In Progress"] = "prog",
        ["Carryover"] = "carry",
        ["Blockers"] = "block"
    };

    private static string GetCssPrefix(string category)
        => CssPrefixMap.TryGetValue(category, out var prefix) ? prefix : "ship";

    private static string GetCategoryIcon(string category) => category switch
    {
        "Shipped" => "✅",
        "In Progress" => "🔵",
        "Carryover" => "🟡",
        "Blockers" => "🔴",
        _ => ""
    };
}