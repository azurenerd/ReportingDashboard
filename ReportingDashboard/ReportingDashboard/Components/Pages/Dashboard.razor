@page "/"
@inject DashboardDataService DataService

@{
    var (data, error) = DataService.Load();
}

@if (error is not null)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100%;padding:44px;">
        <div style="font-size:18px;color:#EA4335;text-align:center;max-width:800px;">
            <div style="font-size:24px;font-weight:700;margin-bottom:12px;">⚠ Dashboard Error</div>
            <div>@error</div>
        </div>
    </div>
}
else if (data is not null)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#888;font-size:16px;">
        Dashboard loaded successfully. UI components will render here.
    </div>
}