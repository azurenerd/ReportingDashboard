@page "/"
@layout EmptyLayout
@using ReportingDashboard.Models
@using ReportingDashboard.Services
@inject DashboardDataService DataService

@if (_errorMessage is not null)
{
    <div class="error-panel">
        <h2>Dashboard Configuration Error</h2>
        <p class="error-detail">@_errorMessage</p>
        <p>Please check wwwroot/data/data.json and restart the application.</p>
    </div>
}
else if (_config is not null)
{
    @* - Header Region - *@
    <div class="hdr">
        <div class="hdr-left">
            <h1>@_config.Title
                @if (!string.IsNullOrEmpty(_config.BacklogLink))
                {
                    <a href="@_config.BacklogLink" target="_blank"
                       style="font-size:14px;font-weight:400;margin-left:12px;color:#0078D4;text-decoration:none;">?? ADO Backlog</a>
                }
            </h1>
            <div class="sub">@_config.Subtitle</div>
        </div>

        <div class="legend-row">
            <span class="legend-item">
                <span class="legend-diamond" style="background:#F4B400;"></span>PoC Milestone
            </span>
            <span class="legend-item">
                <span class="legend-diamond" style="background:#34A853;"></span>Production Release
            </span>
            <span class="legend-item">
                <span class="legend-circle"></span>Checkpoint
            </span>
            <span class="legend-item">
                <span class="legend-now-bar"></span>Now (@DateTime.Today.ToString("MMM yyyy"))
            </span>
        </div>
    </div>

    <!-- TIMELINE -->

    <!-- HEATMAP -->
}
else
{
    <div style="text-align:center;margin-top:200px;font-family:'Segoe UI',Arial,sans-serif;color:#888;">
        <p>Loading dashboard...</p>
    </div>
}

@code {
    private DashboardConfig? _config;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _config = await DataService.GetDashboardConfigAsync();

            if (_config is null)
            {
                _errorMessage = DataService.LoadError ?? "Failed to load dashboard configuration.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data.json: {ex.Message}";
        }
    }
}