@page "/"
@layout ReportingDashboard.Layout.EmptyLayout
@inject DashboardDataService DataService

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error-panel">
        <h2>Dashboard Configuration Error</h2>
        <p class="error-detail">@errorMessage</p>
        <p>Please check <code>wwwroot/data/data.json</code> and restart the application.</p>
    </div>
}
else if (Config is not null)
{
    @* === SECTION 1: HEADER BAR === *@
    <div class="hdr">
        <div>
            <h1>@Config.Title
                @if (!string.IsNullOrEmpty(Config.BacklogLink))
                {
                    <a href="@Config.BacklogLink" target="_blank"> ↗ ADO Backlog</a>
                }
            </h1>
            <div class="sub">@Config.Subtitle</div>
        </div>
        <div class="legend">
            <span class="leg-item">
                <span style="display:inline-block;width:12px;height:12px;background:#F4B400;transform:rotate(45deg);margin-right:4px;vertical-align:middle;"></span>
                PoC Milestone
            </span>
            <span class="leg-item">
                <span style="display:inline-block;width:12px;height:12px;background:#34A853;transform:rotate(45deg);margin-right:4px;vertical-align:middle;"></span>
                Production Release
            </span>
            <span class="leg-item">
                <span style="display:inline-block;width:8px;height:8px;background:#999;border-radius:50%;margin-right:4px;vertical-align:middle;"></span>
                Checkpoint
            </span>
            <span class="leg-item">
                <span style="display:inline-block;width:2px;height:14px;background:#EA4335;margin-right:4px;vertical-align:middle;"></span>
                Now (@DateTime.Today.ToString("MMM yyyy"))
            </span>
        </div>
    </div>

    @* === SECTION 2: TIMELINE AREA === *@
    <div class="tl-area">
        <div class="tl-sidebar">
            @foreach (var milestone in Config.Milestones)
            {
                <div class="tl-ms-label">
                    <span class="tl-ms-tag" style="color: @milestone.Color;">@milestone.Label</span>
                    <span class="tl-ms-desc">@milestone.Description</span>
                </div>
            }
        </div>
        <div class="tl-svg-box">
            <svg width="@SvgWidth" height="@SvgHeight" style="overflow: visible;" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <filter id="dropshadow" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                    </filter>
                </defs>

                @* Month grid lines and labels *@
                @for (int i = 0; i < timelineMonthDates.Count; i++)
                {
                    var x = MonthGridX(i);
                    <line x1="@F(x)" y1="0" x2="@F(x)" y2="@SvgHeight" stroke="#bbb" stroke-opacity="0.4" stroke-width="1" />
                    <text x="@F(x + 5)" y="14" font-size="11" font-weight="600" fill="#666" font-family="Segoe UI, Arial, sans-serif">@timelineMonthDates[i].ToString("MMM")</text>
                }

                @* Milestone track lines *@
                @for (int mi = 0; mi < Config.Milestones.Count; mi++)
                {
                    var ms = Config.Milestones[mi];
                    var y = MilestoneY(mi);
                    <line x1="0" y1="@F(y)" x2="@SvgWidth" y2="@F(y)" stroke="@ms.Color" stroke-width="3" />

                    @* Events on this milestone *@
                    @foreach (var evt in ms.Events)
                    {
                        if (DateTime.TryParse(evt.Date, out var evtDate))
                        {
                            var ex = DateToX(evtDate);

                            @if (evt.Type == "poc")
                            {
                                <polygon points="@DiamondPoints(ex, y)" fill="#F4B400" filter="url(#dropshadow)" />
                            }
                            else if (evt.Type == "production")
                            {
                                <polygon points="@DiamondPoints(ex, y)" fill="#34A853" filter="url(#dropshadow)" />
                            }
                            else
                            {
                                <circle cx="@F(ex)" cy="@F(y)" r="6" fill="white" stroke="@ms.Color" stroke-width="2.5" />
                            }

                            @* Event date label *@
                            <text x="@F(ex)" y="@F(y - 14)" font-size="10" text-anchor="middle" fill="#666" font-family="Segoe UI, Arial, sans-serif">@evt.Label</text>
                        }
                    }
                }

                @* NOW line *@
                @{
                    var nowX = DateToX(DateTime.Today);
                }
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="@SvgHeight" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                <text x="@F(nowX)" y="@(SvgHeight - 2)" font-size="10" font-weight="bold" text-anchor="middle" fill="#EA4335" font-family="Segoe UI, Arial, sans-serif">NOW</text>
            </svg>
        </div>
    </div>

    @* === SECTION 3: HEATMAP GRID === *@
    <div class="hm-wrap">
        <div class="hm-title">MONTHLY EXECUTION HEATMAP — Shipped · In Progress · Carryover · Blockers</div>
        <div class="hm-grid" style="grid-template-columns: 160px repeat(@Config.Months.Count, 1fr);">
            @* Corner cell *@
            <div class="hm-corner">STATUS</div>

            @* Column headers (months) *@
            @foreach (var month in Config.Months)
            {
                var isCurrentMonth = string.Equals(month, Config.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                <div class="hm-col-hdr @(isCurrentMonth ? "cur-month-hdr" : "")">@month</div>
            }

            @* Data rows *@
            @foreach (var row in Config.HeatmapRows)
            {
                var prefix = CategoryCssPrefix(row.Category);

                @* Row header *@
                <div class="hm-row-hdr @(prefix)-hdr">@row.Label.ToUpperInvariant()</div>

                @* Data cells for each month *@
                @foreach (var month in Config.Months)
                {
                    var isCurrentMonth = string.Equals(month, Config.CurrentMonth, StringComparison.OrdinalIgnoreCase);
                    var cellClass = $"hm-cell {prefix}-cell{(isCurrentMonth ? " " + prefix + "-cur" : "")}";
                    var items = row.Items.TryGetValue(month, out var list) ? list : null;

                    <div class="@cellClass">
                        @if (items is not null && items.Count > 0)
                        {
                            @foreach (var item in items)
                            {
                                <div class="it @(prefix)-dot">@item</div>
                            }
                        }
                        else
                        {
                            <span class="empty-cell">–</span>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private DashboardConfig? Config;
    private string? errorMessage;

    private const int SvgWidth = 1560;
    private const int SvgHeight = 185;

    private DateTime timelineStart;
    private DateTime timelineEnd;
    private List<DateTime> timelineMonthDates = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Config = await DataService.GetDashboardConfigAsync();

            if (Config is null)
            {
                errorMessage = DataService.LoadError ?? "Unknown error loading dashboard configuration.";
                return;
            }

            CalculateTimelineRange();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
    }

    private void CalculateTimelineRange()
    {
        if (Config?.Months is null || Config.Months.Count == 0) return;

        // Derive timeline range from the months array
        // Parse month abbreviations relative to a base year
        var year = DateTime.Today.Year;
        timelineMonthDates = new List<DateTime>();

        foreach (var monthAbbr in Config.Months)
        {
            if (DateTime.TryParseExact(monthAbbr + " " + year, "MMM yyyy",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dt))
            {
                timelineMonthDates.Add(dt);
            }
        }

        if (timelineMonthDates.Count > 0)
        {
            timelineStart = timelineMonthDates.First();
            // End is one month after the last displayed month
            timelineEnd = timelineMonthDates.Last().AddMonths(1);
        }
    }

    private double MonthGridX(int monthIndex)
    {
        if (timelineMonthDates.Count == 0) return 0;
        var date = timelineMonthDates[monthIndex];
        return DateToX(date);
    }

    private double DateToX(DateTime date)
    {
        double totalDays = (timelineEnd - timelineStart).TotalDays;
        if (totalDays <= 0) return 0;
        double dayOffset = (date - timelineStart).TotalDays;
        return Math.Clamp(dayOffset / totalDays * SvgWidth, 0, SvgWidth);
    }

    private double MilestoneY(int index)
    {
        return 42 + (index * 56);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private string CategoryCssPrefix(string category) => category switch
    {
        "shipped" => "ship",
        "in-progress" => "prog",
        "carryover" => "carry",
        "blockers" => "block",
        _ => "ship"
    };

    /// Format double for SVG attributes (invariant culture, no trailing zeros)
    private static string F(double value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}