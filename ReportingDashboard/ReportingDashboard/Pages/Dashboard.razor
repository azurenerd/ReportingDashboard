@page "/"
@layout EmptyLayout
@using ReportingDashboard.Services
@inject DashboardDataService DataService

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error-panel">
        <h2>Dashboard Configuration Error</h2>
        <p class="error-detail">@errorMessage</p>
        <p>Please check wwwroot/data/data.json and restart the application.</p>
    </div>
}
else if (config != null)
{
    <!-- HEADER -->
    <div class="hdr">
        <div class="hdr-left">
            <h1>@config.Title
                @if (!string.IsNullOrEmpty(config.BacklogLink))
                {
                    <a href="@config.BacklogLink" target="_blank"> &#x1f4cb; ADO Backlog</a>
                }
            </h1>
            <div class="sub">@config.Subtitle</div>
        </div>
        <div class="legend-row">
            <span class="legend-item">
                <span class="legend-diamond" style="background:#F4B400;"></span> PoC Milestone
            </span>
            <span class="legend-item">
                <span class="legend-diamond" style="background:#34A853;"></span> Production Release
            </span>
            <span class="legend-item">
                <span class="legend-circle"></span> Checkpoint
            </span>
            <span class="legend-item">
                <span class="legend-now-bar"></span> Now (@DateTime.Today.ToString("MMM yyyy"))
            </span>
        </div>
    </div>

    <!-- TIMELINE -->
    <div class="tl-area">
        <div class="tl-sidebar">
            @foreach (var ms in config.Milestones)
            {
                <div class="tl-ms-label">
                    <span class="tl-ms-code" style="color:@ms.Color;">@ms.Label</span>
                    <span class="tl-ms-desc">@ms.Description</span>
                </div>
            }
        </div>
        <div class="tl-svg-box">
            <svg width="1560" height="185" style="overflow:visible;">
                <defs>
                    <filter id="ds" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                    </filter>
                </defs>

                @{
                    var monthCount = config.Months.Count;
                    var colWidth = monthCount > 0 ? 1560.0 / monthCount : 260.0;
                }

                @for (int i = 0; i < monthCount; i++)
                {
                    var x = i * colWidth;
                    <line x1="@F(x)" y1="0" x2="@F(x)" y2="185" stroke="#bbb" stroke-opacity="0.4" />
                    @RenderSvgText(F(x + 5), "14", "11", "600", "#666", config.Months[i])
                }

                @for (int mi = 0; mi < config.Milestones.Count; mi++)
                {
                    var ms = config.Milestones[mi];
                    var y = MilestoneY(mi);
                    <line x1="0" y1="@F(y)" x2="1560" y2="@F(y)" stroke="@ms.Color" stroke-width="3" />

                    @foreach (var evt in ms.Events)
                    {
                        if (DateTime.TryParse(evt.Date, out var evtDate))
                        {
                            var ex = DateToX(evtDate);
                            @if (evt.Type == "poc")
                            {
                                <polygon points="@DiamondPoints(ex, y)" fill="#F4B400" filter="url(#ds)" />
                            }
                            else if (evt.Type == "production")
                            {
                                <polygon points="@DiamondPoints(ex, y)" fill="#34A853" filter="url(#ds)" />
                            }
                            else
                            {
                                <circle cx="@F(ex)" cy="@F(y)" r="6" fill="white" stroke="@ms.Color" stroke-width="2.5" />
                            }
                            @RenderSvgText(F(ex), F(y - 14), "10", "400", "#666", evt.Label, "middle")
                        }
                    }
                }

                @{
                    var nowX = DateToX(DateTime.Today);
                }
                <line x1="@F(nowX)" y1="0" x2="@F(nowX)" y2="185" stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @RenderSvgText(F(nowX), "-4", "10", "700", "#EA4335", "NOW", "middle")
            </svg>
        </div>
    </div>

    <!-- HEATMAP -->
    <div class="hm-wrap">
        <div class="hm-title">MONTHLY EXECUTION HEATMAP &mdash; Shipped &bull; In Progress &bull; Carryover &bull; Blockers</div>
        <div class="hm-grid" style="grid-template-columns: 160px repeat(@config.Months.Count, 1fr);">
            <div class="hm-corner">STATUS</div>

            @foreach (var month in config.Months)
            {
                var isCurrent = month == config.CurrentMonth;
                <div class="hm-col-hdr @(isCurrent ? "cur-hdr" : "")">@month</div>
            }

            @foreach (var row in config.HeatmapRows)
            {
                var prefix = CategoryCssPrefix(row.Category);

                <div class="hm-row-hdr @(prefix)-hdr">@row.Label.ToUpperInvariant()</div>

                @foreach (var month in config.Months)
                {
                    var isCurrent = month == config.CurrentMonth;
                    var items = row.Items.ContainsKey(month) ? row.Items[month] : null;
                    <div class="hm-cell @(prefix)-cell @(isCurrent ? prefix + "-cur" : "")">
                        @if (items != null && items.Count > 0)
                        {
                            @foreach (var item in items)
                            {
                                <div class="it @(prefix)-dot">@item</div>
                            }
                        }
                        else
                        {
                            <span style="color:#AAA;">-</span>
                        }
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    <div class="error-panel">
        <h2>Loading...</h2>
    </div>
}

@code {
    private Models.DashboardConfig? config;
    private string? errorMessage;

    private DateTime timelineStart;
    private DateTime timelineEnd;
    private const double SvgWidth = 1560;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            config = await DataService.GetDashboardConfigAsync();
            if (config == null)
            {
                errorMessage = DataService.LoadError ?? "Failed to load dashboard configuration.";
                return;
            }

            CalculateTimelineRange();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
    }

    private void CalculateTimelineRange()
    {
        if (config == null || config.Months.Count == 0) return;

        var year = DateTime.Today.Year;
        var firstMonthStr = config.Months[0];
        var lastMonthStr = config.Months[^1];

        if (DateTime.TryParseExact(firstMonthStr + " " + year, "MMM yyyy",
            System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var startDate))
        {
            timelineStart = startDate;
        }
        else
        {
            timelineStart = new DateTime(year, 1, 1);
        }

        if (DateTime.TryParseExact(lastMonthStr + " " + year, "MMM yyyy",
            System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var endDate))
        {
            timelineEnd = endDate.AddMonths(1);
        }
        else
        {
            timelineEnd = timelineStart.AddMonths(config.Months.Count);
        }
    }

    private double DateToX(DateTime date)
    {
        double totalDays = (timelineEnd - timelineStart).TotalDays;
        if (totalDays <= 0) return 0;
        double dayOffset = (date - timelineStart).TotalDays;
        return Math.Clamp(dayOffset / totalDays * SvgWidth, 0, SvgWidth);
    }

    private double MilestoneY(int index)
    {
        return 42 + (index * 56);
    }

    private string DiamondPoints(double cx, double cy, double size = 11)
    {
        return $"{F(cx)},{F(cy - size)} {F(cx + size)},{F(cy)} {F(cx)},{F(cy + size)} {F(cx - size)},{F(cy)}";
    }

    private string CategoryCssPrefix(string category) => category switch
    {
        "shipped" => "ship",
        "in-progress" => "prog",
        "carryover" => "carry",
        "blockers" => "block",
        _ => "ship"
    };

    private static string F(double value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private RenderFragment RenderSvgText(string x, string y, string fontSize, string fontWeight, string fill, string content, string? textAnchor = null) => builder =>
    {
        builder.OpenElement(0, "text");
        builder.AddAttribute(1, "x", x);
        builder.AddAttribute(2, "y", y);
        builder.AddAttribute(3, "font-size", fontSize);
        builder.AddAttribute(4, "font-weight", fontWeight);
        builder.AddAttribute(5, "fill", fill);
        if (textAnchor != null)
        {
            builder.AddAttribute(6, "text-anchor", textAnchor);
        }
        builder.AddContent(7, content);
        builder.CloseElement();
    };
}