<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1920, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="css/dashboard.css" />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="_framework/blazor.server.js" suppress-error="BL9992"></script>
    <script>
        // Hide Blazor reconnection UI and loading indicators
        (function() {
            var style = document.createElement('style');
            style.textContent = '#components-reconnect-modal,.components-reconnect-hide,.components-reconnect-show,.components-reconnect-rejected,.components-reconnect-failed,#blazor-error-ui,.loading-progress,.loading-progress-text{display:none!important;visibility:hidden!important;opacity:0!important;pointer-events:none!important;}';
            document.head.appendChild(style);
        })();
    </script>
</body>
</html>