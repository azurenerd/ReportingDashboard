@namespace ReportingDashboard.Web.Components.Sections
@using ReportingDashboard.Web.Models
@using ReportingDashboard.Web.Services
@inject IDashboardDataService DataService

@if (_milestones.Count > 0)
{
    <section class="timeline">
        <h2 class="timeline-heading">Milestone Timeline</h2>
        <div class="timeline-track">
            @for (var i = 0; i < _milestones.Count; i++)
            {
                var milestone = _milestones[i];
                var statusClass = GetStatusClass(milestone.Status);
                var isLast = i == _milestones.Count - 1;
                var connectorClass = isLast ? "" : GetConnectorClass(milestone.Status);

                <div class="timeline-item @statusClass @(isLast ? "timeline-item-last" : "") @connectorClass">
                    <span class="timeline-label">@milestone.Title</span>
                    <div class="timeline-dot-row">
                        <span class="timeline-dot"></span>
                    </div>
                    <span class="timeline-date">@FormatDate(milestone.TargetDate)</span>
                </div>
            }
        </div>
    </section>
}

@code {
    private List<Milestone> _milestones = new();

    protected override async Task OnInitializedAsync()
    {
        var data = await DataService.GetDashboardDataAsync();
        if (data?.Milestones is not null)
        {
            _milestones = data.Milestones
                .OrderBy(m => ParseDate(m.TargetDate))
                .ToList();
        }
    }

    private static string GetStatusClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "completed" => "completed",
            "inprogress" => "in-progress",
            "upcoming" => "upcoming",
            _ => "upcoming"
        };
    }

    private static string GetConnectorClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "completed" => "connector-completed",
            "inprogress" => "connector-inprogress",
            _ => "connector-upcoming"
        };
    }

    private static string FormatDate(string? date)
    {
        if (!string.IsNullOrEmpty(date) && DateTime.TryParse(date, out var dt))
        {
            return dt.ToString("MMM d, yyyy");
        }
        return date ?? "";
    }

    private static DateTime ParseDate(string? date)
    {
        if (!string.IsNullOrEmpty(date) && DateTime.TryParse(date, out var dt))
        {
            return dt;
        }
        return DateTime.MaxValue;
    }
}