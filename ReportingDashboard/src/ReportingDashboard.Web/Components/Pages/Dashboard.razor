@page "/"
@using ReportingDashboard.Web.Services
@inject IDashboardDataService DataService

@if (_error is not null)
{
    <div class="error-banner">@_error</div>
}
else if (_data is not null)
{
    <h1>@_data.Project.ProjectName</h1>
    <p>@_data.Project.ReportingPeriod - @_data.Project.ExecutiveSponsor</p>
    <p class="health-indicator status-@_data.Project.OverallStatus.ToLowerInvariant()">
        @_data.Project.OverallStatus: @_data.Project.Summary
    </p>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await DataService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}