@page "/"
@inject DashboardDataService DataService

@if (_error is not null)
{
    <div class="error-banner">@_error</div>
}
else if (_data is not null)
{
    <h1>@_data.ProjectInfo.ProjectName</h1>
    <p>@_data.ProjectInfo.ReportingPeriod — @_data.ProjectInfo.ExecutiveSponsor</p>
    <p class="health-indicator status-@_data.ProjectInfo.OverallStatus.ToLowerInvariant()">
        @_data.ProjectInfo.OverallStatus: @_data.ProjectInfo.Summary
    </p>
}

@code {
    private DashboardData? _data;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await DataService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}