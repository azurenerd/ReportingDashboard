        Assert.NotNull(result);
        Assert.Equal("Q2 Mobile App Release", result.Project.Name);
    }

    [Fact]
    public async Task GetCachedData_AfterRefresh_ReturnsNull()
    {
        var tempFile = CreateTempFile(CreateValidProjectDataJson());
        await _service.LoadProjectDataAsync(tempFile);
        _service.RefreshData();

        var result = _service.GetCachedData();

        Assert.Null(result);
    }

    [Fact]
    public void RefreshData_ClearsCache()
    {
        _service.RefreshData();
        var result = _service.GetCachedData();

        Assert.Null(result);
    }

    [Fact]
    public async Task RefreshData_AfterLoad_ClearsCache()
    {
        var tempFile = CreateTempFile(CreateValidProjectDataJson());
        await _service.LoadProjectDataAsync(tempFile);

        _service.RefreshData();

        var result = _service.GetCachedData();
        Assert.Null(result);
    }

    [Fact]
    public async Task RefreshData_AllowsReload()
    {
        var tempFile1 = CreateTempFile(CreateValidProjectDataJson());
        var tempFile2 = CreateTempFile(CreateComplexProjectDataJson());

        var firstLoad = await _service.LoadProjectDataAsync(tempFile1);
        Assert.Equal("Q2 Mobile App Release", firstLoad.Project.Name);

        _service.RefreshData();
        Assert.Null(_service.GetCachedData());

        var secondLoad = await _service.LoadProjectDataAsync(tempFile2);
        Assert.Equal("Complex Multi-Milestone Project", secondLoad.Project.Name);
    }

