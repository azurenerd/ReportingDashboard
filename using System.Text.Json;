    [Fact]
    public async Task LoadProjectDataAsync_WithValidJson_ReturnsProjectDataAndCaches()
    {
        var tempFile = CreateTempFile(CreateValidProjectDataJson());

        var result = await _service.LoadProjectDataAsync(tempFile);

        Assert.NotNull(result);
        Assert.NotNull(result.Project);
        Assert.Equal("Q2 Mobile App Release", result.Project.Name);
        Assert.Equal("Jane Smith", result.Project.ProjectManager);
        Assert.NotNull(result.Milestones);
        Assert.Single(result.Milestones);
        Assert.NotNull(result.Tasks);
        Assert.Single(result.Tasks);
        Assert.NotNull(result.Metrics);
        Assert.Equal(10, result.Metrics.TotalTasks);
        Assert.Equal(3, result.Metrics.CompletedTasks);
    }

    [Fact]
    public async Task LoadProjectDataAsync_WithComplexNestedJson_DeserializesAllData()
    {
        var tempFile = CreateTempFile(CreateComplexProjectDataJson());

        var result = await _service.LoadProjectDataAsync(tempFile);

        Assert.NotNull(result);
        Assert.Equal("Complex Multi-Milestone Project", result.Project.Name);
        Assert.Equal(3, result.Milestones.Count);
        Assert.Equal("Phase 1: Discovery", result.Milestones[0].Name);
        Assert.Equal("Completed", result.Milestones[0].Status);
        Assert.Equal(100, result.Milestones[0].CompletionPercentage);
        Assert.Equal("Phase 2: Development", result.Milestones[1].Name);
        Assert.Equal(65, result.Milestones[1].CompletionPercentage);
        Assert.Equal(4, result.Tasks.Count);
        Assert.Equal("Shipped", result.Tasks[0].Status);
        Assert.Equal("InProgress", result.Tasks[1].Status);
        Assert.Equal("CarriedOver", result.Tasks[3].Status);
    }

