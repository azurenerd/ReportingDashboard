    [Fact]
    public async Task LoadProjectDataAsync_LogsSuccessfulLoad()
    {
        var tempFile = CreateTempFile(CreateValidProjectDataJson());

        await _service.LoadProjectDataAsync(tempFile);

        _mockLogger.Verify(
            x => x.Log(
                LogLevel.Information,
                It.IsAny<EventId>(),
                It.Is<It.IsAnyType>((v, t) => v.ToString().Contains("loaded successfully")),
                It.IsAny<Exception>(),
                It.IsAny<Func<It.IsAnyType, Exception, string>>()),
            Times.Once);
    }

