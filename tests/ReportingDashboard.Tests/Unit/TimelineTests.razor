@using Bunit
@using Xunit
@using FluentAssertions
@using ReportingDashboard.Models
@inherits Bunit.TestContext

@code {
    private TimelineData CreateTestTimelineData()
    {
        return new TimelineData
        {
            StartDate = "2026-01-01",
            EndDate = "2026-07-01",
            Tracks = new List<TimelineTrack>
            {
                new TimelineTrack
                {
                    Id = "M1",
                    Name = "Chatbot & MS Role",
                    Color = "#0078D4",
                    Milestones = new List<MilestoneItem>
                    {
                        new MilestoneItem { Date = "2026-02-15", Label = "Design Review", Type = "checkpoint" },
                        new MilestoneItem { Date = "2026-04-01", Label = "PoC Complete", Type = "poc" },
                        new MilestoneItem { Date = "2026-06-01", Label = "GA Release", Type = "production" }
                    }
                },
                new TimelineTrack
                {
                    Id = "M2",
                    Name = "PDS & Data Inventory",
                    Color = "#00897B",
                    Milestones = new List<MilestoneItem>
                    {
                        new MilestoneItem { Date = "2026-03-01", Label = "Sprint 1", Type = "checkpoint" }
                    }
                }
            }
        };
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void Timeline_RendersTrackLabels()
    {
        var data = CreateTestTimelineData();

        var cut = Render(
            @<ReportingDashboard.Components.Sections.Timeline TimelineData="data" CurrentDate="2026-04-15" />
        );

        var labels = cut.FindAll(".tl-track-label");
        labels.Count.Should().Be(2);

        var ids = cut.FindAll(".tl-track-id");
        ids[0].TextContent.Should().Be("M1");
        ids[1].TextContent.Should().Be("M2");

        var names = cut.FindAll(".tl-track-name");
        names[0].TextContent.Should().Contain("Chatbot");
        names[1].TextContent.Should().Contain("PDS");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void Timeline_RendersSvgElement()
    {
        var data = CreateTestTimelineData();

        var cut = Render(
            @<ReportingDashboard.Components.Sections.Timeline TimelineData="data" CurrentDate="2026-04-15" />
        );

        var svg = cut.Find("svg");
        svg.Should().NotBeNull();
        svg.GetAttribute("width").Should().Be("1560");
        svg.GetAttribute("height").Should().Be("185");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void Timeline_RendersNowLine_WhenCurrentDateInRange()
    {
        var data = CreateTestTimelineData();

        var cut = Render(
            @<ReportingDashboard.Components.Sections.Timeline TimelineData="data" CurrentDate="2026-04-15" />
        );

        // NOW line is a dashed red line with stroke-dasharray
        cut.Markup.Should().Contain("stroke=\"#EA4335\"");
        cut.Markup.Should().Contain("stroke-dasharray=\"5,3\"");
        cut.Markup.Should().Contain("NOW");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void Timeline_RendersCheckpointAsCirle()
    {
        var data = CreateTestTimelineData();

        var cut = Render(
            @<ReportingDashboard.Components.Sections.Timeline TimelineData="data" CurrentDate="2026-04-15" />
        );

        // Checkpoint milestones render as circles
        var circles = cut.FindAll("circle");
        circles.Count.Should().BeGreaterOrEqualTo(2); // 2 checkpoints in test data
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void Timeline_RendersPocAndProductionDiamonds()
    {
        var data = CreateTestTimelineData();

        var cut = Render(
            @<ReportingDashboard.Components.Sections.Timeline TimelineData="data" CurrentDate="2026-04-15" />
        );

        // PoC diamond is gold #F4B400, production is green #34A853
        var polygons = cut.FindAll("polygon");
        polygons.Count.Should().BeGreaterOrEqualTo(2); // 1 poc + 1 production

        cut.Markup.Should().Contain("fill=\"#F4B400\""); // PoC
        cut.Markup.Should().Contain("fill=\"#34A853\""); // Production
    }
}