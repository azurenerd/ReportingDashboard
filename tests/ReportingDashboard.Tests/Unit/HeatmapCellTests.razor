@using Bunit
@using Xunit
@using FluentAssertions
@using ReportingDashboard.Models
@inherits Bunit.TestContext

@code {
    [Fact]
    [Trait("Category", "Unit")]
    public void EmptyItems_RendersDash()
    {
        var cut = Render(
            @<ReportingDashboard.Components.Sections.HeatmapCell
                Items="@(new List<string>())"
                CssCategory="ship"
                IsHighlight="false"
                IsLastColumn="false" />
        );

        var cell = cut.Find(".hm-cell");
        cell.Should().NotBeNull();

        var emptyDiv = cut.Find(".it.empty");
        emptyDiv.Should().NotBeNull();
        emptyDiv.TextContent.Should().Contain("\u2013"); // ndash
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void WithItems_RendersEachItem()
    {
        var items = new List<string> { "Feature A", "Feature B", "Feature C" };

        var cut = Render(
            @<ReportingDashboard.Components.Sections.HeatmapCell
                Items="items"
                CssCategory="prog"
                IsHighlight="false"
                IsLastColumn="false" />
        );

        var itemDivs = cut.FindAll(".it.prog-it");
        itemDivs.Count.Should().Be(3);
        itemDivs[0].TextContent.Should().Be("Feature A");
        itemDivs[1].TextContent.Should().Be("Feature B");
        itemDivs[2].TextContent.Should().Be("Feature C");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void IsHighlight_AppliesHighlightCssClass()
    {
        var items = new List<string> { "Item 1" };

        var cut = Render(
            @<ReportingDashboard.Components.Sections.HeatmapCell
                Items="items"
                CssCategory="ship"
                IsHighlight="true"
                IsLastColumn="false" />
        );

        var cell = cut.Find(".hm-cell");
        cell.ClassList.Should().Contain("ship-hl");
        cell.ClassList.Should().Contain("ship-cell");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void IsLastColumn_RemovesBorderRight()
    {
        var cut = Render(
            @<ReportingDashboard.Components.Sections.HeatmapCell
                Items="@(new List<string> { "X" })"
                CssCategory="block"
                IsHighlight="false"
                IsLastColumn="true" />
        );

        var cell = cut.Find(".hm-cell");
        cell.GetAttribute("style").Should().Contain("border-right:none");
    }

    [Fact]
    [Trait("Category", "Unit")]
    public void BlockerCategory_AppliesBlockCssClasses()
    {
        var items = new List<string> { "Blocker 1" };

        var cut = Render(
            @<ReportingDashboard.Components.Sections.HeatmapCell
                Items="items"
                CssCategory="block"
                IsHighlight="false"
                IsLastColumn="false" />
        );

        var cell = cut.Find(".hm-cell");
        cell.ClassList.Should().Contain("block-cell");

        var itemDiv = cut.Find(".it.block-it");
        itemDiv.TextContent.Should().Be("Blocker 1");
    }
}