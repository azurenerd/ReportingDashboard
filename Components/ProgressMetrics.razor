@using AgentSquad.Models

<div class="progress-metrics mt-4">
    <h3 class="mb-3">Project Progress</h3>
    @if (Metrics != null)
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Overall Completion</h5>
                        <div class="progress mb-2" style="height: 30px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @Metrics.CompletionPercentage%"></div>
                        </div>
                        <p class="text-center fs-5 fw-bold">@Metrics.CompletionPercentage%</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public ProjectMetrics Metrics { get; set; }
}