@using AgentSquad.Dashboard.Models

<div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px;">
    <h2 style="margin: 0 0 20px 0; font-size: 20px; font-weight: bold; color: #333;">Progress Metrics</h2>
    
    @if (Metrics == null)
    {
        <p style="color: #999; font-size: 14px;">No metrics available.</p>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 20px; margin-bottom: 24px;">
            <div style="text-align: center;">
                <div style="font-size: 32px; font-weight: bold; color: #0066cc;">@Metrics.CompletionPercentage%</div>
                <p style="margin: 8px 0 0 0; font-size: 13px; color: #666;">Overall Completion</p>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 32px; font-weight: bold; color: #28a745;">@Metrics.TasksCompleted</div>
                <p style="margin: 8px 0 0 0; font-size: 13px; color: #666;">Tasks Completed</p>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 32px; font-weight: bold; color: #0066cc;">@Metrics.TasksInProgress</div>
                <p style="margin: 8px 0 0 0; font-size: 13px; color: #666;">Tasks In Progress</p>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 32px; font-weight: bold; color: #ff9800;">@Metrics.TasksCarriedOver</div>
                <p style="margin: 8px 0 0 0; font-size: 13px; color: #666;">Carried Over</p>
            </div>
        </div>

        <div style="background-color: #f5f5f5; padding: 16px; border-radius: 4px;">
            <div style="margin-bottom: 12px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;">
                    <span style="font-weight: 500;">Progress</span>
                    <span style="color: #666;">@Metrics.CompletionPercentage% of @Metrics.TotalTasks tasks</span>
                </div>
                <div style="background-color: #e0e0e0; height: 12px; border-radius: 6px; overflow: hidden;">
                    <div style="background-color: #0066cc; height: 100%; width: @Metrics.CompletionPercentage%; transition: none;"></div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public ProjectMetrics Metrics { get; set; }

    [Parameter]
    public List<ProjectTask> Tasks { get; set; }
}