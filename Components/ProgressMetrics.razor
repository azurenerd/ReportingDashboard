@using AgentSquad.Runner.Data

<div class="progress-metrics">
    <h2 class="mb-4">Project Metrics</h2>
    
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Overall Completion</h5>
                </div>
                <div class="card-body">
                    <div class="completion-display">
                        <div class="completion-percentage">
                            @CompletionPercentage<span class="text-muted">%</span>
                        </div>
                        <div class="completion-label">Complete</div>
                    </div>
                    
                    <div class="progress my-4" style="height: 30px;">
                        <div class="progress-bar bg-success" 
                             role="progressbar" 
                             style="width: @CompletionPercentage%;" 
                             aria-valuenow="@CompletionPercentage" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
                            <strong>@CompletionPercentage%</strong>
                        </div>
                    </div>

                    <div class="task-breakdown">
                        <div class="row text-center g-2">
                            <div class="col">
                                <div class="breakdown-value">@CompletedTasks</div>
                                <div class="breakdown-label">Shipped</div>
                            </div>
                            <div class="col">
                                <div class="breakdown-value">@(TotalTasks - CompletedTasks)</div>
                                <div class="breakdown-label">Remaining</div>
                            </div>
                            <div class="col">
                                <div class="breakdown-value">@TotalTasks</div>
                                <div class="breakdown-label">Total</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Metrics Summary</h5>
                </div>
                <div class="card-body">
                    <div class="metrics-grid">
                        <div class="metric-item">
                            <div class="metric-label">Completion Rate</div>
                            <div class="metric-value">@CompletionPercentage%</div>
                        </div>
                        <div class="metric-item">
                            <div class="metric-label">Burn-down Rate</div>
                            <div class="metric-value">@BurndownRate.ToString("F1") <span class="text-muted">/day</span></div>
                        </div>
                        <div class="metric-item">
                            <div class="metric-label">Tasks Completed</div>
                            <div class="metric-value text-success">@CompletedTasks</div>
                        </div>
                        <div class="metric-item">
                            <div class="metric-label">Tasks Remaining</div>
                            <div class="metric-value text-warning">@(TotalTasks - CompletedTasks)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int CompletionPercentage { get; set; }

    [Parameter]
    public int CompletedTasks { get; set; }

    [Parameter]
    public int TotalTasks { get; set; }

    [Parameter]
    public double BurndownRate { get; set; }
}

<style>
.progress-metrics {
    padding: 1rem 0;
}

.completion-display {
    text-align: center;
    padding: 2rem 1rem;
    background-color: #f8f9fa;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
}

.completion-percentage {
    font-size: 3.5rem;
    font-weight: bold;
    color: #198754;
    line-height: 1;
    margin-bottom: 0.5rem;
}

.completion-percentage span {
    font-size: 1.5rem;
}

.completion-label {
    font-size: 1rem;
    color: #6c757d;
    font-weight: 500;
}

.task-breakdown {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #dee2e6;
}

.breakdown-value {
    font-size: 1.75rem;
    font-weight: bold;
    color: #0d6efd;
}

.breakdown-label {
    font-size: 0.85rem;
    color: #6c757d;
    margin-top: 0.25rem;
}

.metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
}

.metric-item {
    padding: 1rem;
    background-color: #f8f9fa;
    border-radius: 0.5rem;
    border-left: 4px solid #0d6efd;
}

.metric-label {
    font-size: 0.85rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    font-weight: 500;
}

.metric-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: #212529;
}

.progress {
    border-radius: 0.375rem;
}

.progress-bar {
    font-weight: 600;
    font-size: 0.95rem;
}

@media (max-width: 768px) {
    .completion-percentage {
        font-size: 2.5rem;
    }

    .metrics-grid {
        grid-template-columns: 1fr;
    }
}
</style>