@using AgentSquad.Runner.Models

<div class="progress-metrics card border-0 shadow-sm">
    <div class="card-body p-4">
        <h2 class="card-title mb-4">Project Progress</h2>

        @if (ProjectData != null)
        {
            <div class="row">
                <div class="col-md-6">
                    <div class="metric-box p-3 rounded" style="background-color: #f8f9fa;">
                        <p class="text-muted mb-2">Overall Completion</p>
                        <h3 class="mb-3">@GetOverallCompletion()%</h3>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: @GetOverallCompletion()%"></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="metric-box p-3 rounded" style="background-color: #f8f9fa;">
                        <p class="text-muted mb-2">Tasks Summary</p>
                        <div class="d-flex justify-content-between">
                            <div>
                                <span class="badge bg-success">@GetTaskCount("Shipped")</span>
                                <small class="d-block text-muted">Shipped</small>
                            </div>
                            <div>
                                <span class="badge bg-info">@GetTaskCount("InProgress")</span>
                                <small class="d-block text-muted">In Progress</small>
                            </div>
                            <div>
                                <span class="badge bg-warning text-dark">@GetTaskCount("CarriedOver")</span>
                                <small class="d-block text-muted">Carried Over</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public ProjectData ProjectData { get; set; }

    private int GetOverallCompletion()
    {
        if (ProjectData?.Milestones == null || ProjectData.Milestones.Count == 0)
            return 0;
        return (int)ProjectData.Milestones.Average(m => m.CompletionPercentage);
    }

    private int GetTaskCount(string status)
    {
        return ProjectData?.Tasks?.Count(t => t.Status == status) ?? 0;
    }
}