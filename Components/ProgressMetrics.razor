@using System
@using System.Collections.Generic
@using AgentSquad.Runner.Data
@inject ILogger<ProgressMetrics> Logger
@inject IJSRuntime JSRuntime

<div class="progress-metrics-container">
    <div class="row">
        <div class="col-12">
            @if (IsValidMetrics())
            {
                int completionPercentage = CalculateCompletionPercentage();
                
                <div class="metrics-content">
                    <div class="progress-section mb-4">
                        <h3 class="text-muted mb-3">Project Progress</h3>
                        
                        <div class="progress mb-4" style="height: 30px;">
                            <div class="progress-bar bg-success" 
                                 role="progressbar" 
                                 style="width: @(completionPercentage)%;" 
                                 aria-valuenow="@completionPercentage" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                            </div>
                        </div>
                        
                        <div class="completion-percentage text-center mb-4">
                            <div class="display-4 fw-bold" style="font-size: 24pt;">@completionPercentage%</div>
                            <p class="text-muted">Complete (@Metrics.CompletedTasks of @Metrics.TotalTasks tasks)</p>
                        </div>
                    </div>

                    <div class="burndown-section">
                        <h4 class="text-muted mb-3">Burn-down Chart</h4>
                        @if (ChartInitialized)
                        {
                            <canvas id="burndownChart" width="400" height="150"></canvas>
                        }
                        else if (ChartError)
                        {
                            <div class="alert alert-info" role="alert">
                                <p class="mb-0">Chart.js unavailable. Showing burn-down summary:</p>
                                <table class="table table-sm mt-2 mb-0">
                                    <thead>
                                        <tr>
                                            <th>Day</th>
                                            <th>Tasks Remaining</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var dataPoint in FallbackBurndownData)
                                        {
                                            <tr>
                                                <td>@dataPoint.Key</td>
                                                <td>@dataPoint.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading chart...</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (Metrics != null && Metrics.TotalTasks == 0)
            {
                <div class="alert alert-info" role="alert">
                    <strong>No tasks defined</strong>
                    <p class="mb-0">Project has no tasks configured. Please check data.json configuration.</p>
                </div>
            }
            else if (Metrics != null && !IsValidMetrics())
            {
                <div class="alert alert-warning" role="alert">
                    <strong>Invalid metrics data</strong>
                    <p class="mb-0">
                        @if (Metrics.TotalTasks < 0)
                        {
                            <span>TotalTasks cannot be negative. </span>
                        }
                        @if (Metrics.CompletedTasks < 0)
                        {
                            <span>CompletedTasks cannot be negative. </span>
                        }
                        @if (Metrics.CompletedTasks > Metrics.TotalTasks)
                        {
                            <span>CompletedTasks cannot exceed TotalTasks. </span>
                        }
                        @if (Metrics.ProjectStartDate >= Metrics.ProjectEndDate)
                        {
                            <span>ProjectEndDate must be after ProjectStartDate. </span>
                        }
                    </p>
                    <p class="mb-0">Please verify data.json configuration.</p>
                </div>
            }
            else
            {
                <div class="alert alert-warning" role="alert">
                    <strong>Metrics unavailable</strong>
                    <p class="mb-0">Project metrics data is not available. Please check data.json configuration.</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ProjectMetrics Metrics { get; set; }

    private bool ChartInitialized { get; set; }
    private bool ChartError { get; set; }
    private Dictionary<string, int> FallbackBurndownData { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Metrics == null)
            {
                Logger.LogWarning("ProgressMetrics component initialized with null metrics");
                return;
            }

            if (!IsValidMetrics())
            {
                Logger.LogWarning("ProgressMetrics component initialized with invalid metrics: TotalTasks={TotalTasks}, CompletedTasks={CompletedTasks}, StartDate={StartDate}, EndDate={EndDate}",
                    Metrics.TotalTasks, Metrics.CompletedTasks, Metrics.ProjectStartDate, Metrics.ProjectEndDate);
                return;
            }

            Logger.LogInformation("ProgressMetrics component initialized: TotalTasks={TotalTasks}, CompletedTasks={CompletedTasks}, StartDate={StartDate}, EndDate={EndDate}",
                Metrics.TotalTasks, Metrics.CompletedTasks, Metrics.ProjectStartDate, Metrics.ProjectEndDate);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error in ProgressMetrics OnInitializedAsync");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsValidMetrics() && Metrics.TotalTasks > 0)
        {
            try
            {
                Logger.LogInformation("Initializing burn-down chart for ProgressMetrics");
                
                var labels = GenerateSampleLabels();
                var data = GenerateSampleBurndownData();
                
                if (labels == null || labels.Count == 0 || data == null || data.Count == 0)
                {
                    ChartError = true;
                    Logger.LogWarning("Chart data generation produced empty results");
                    StateHasChanged();
                    return;
                }

                FallbackBurndownData = new Dictionary<string, int>();
                for (int i = 0; i < labels.Count && i < data.Count; i++)
                {
                    FallbackBurndownData[labels[i]] = data[i];
                }

                var result = await JSRuntime.InvokeAsync<bool>("ChartInterop.initializeBurndownChart", 
                    "burndownChart", labels.ToArray(), data.ToArray());

                if (result)
                {
                    ChartInitialized = true;
                    Logger.LogInformation("Burn-down chart initialized successfully");
                }
                else
                {
                    ChartError = true;
                    Logger.LogWarning("Burn-down chart initialization returned false");
                }

                StateHasChanged();
            }
            catch (JSDisconnectedException ex)
            {
                ChartError = true;
                Logger.LogError(ex, "JavaScript connection lost during chart initialization");
                StateHasChanged();
            }
            catch (JSException ex)
            {
                ChartError = true;
                Logger.LogError(ex, "JavaScript error during chart initialization: {Message}", ex.Message);
                StateHasChanged();
            }
            catch (TaskCanceledException ex)
            {
                ChartError = true;
                Logger.LogError(ex, "Chart initialization timed out");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                ChartError = true;
                Logger.LogError(ex, "Unexpected error initializing burn-down chart");
                StateHasChanged();
            }
        }
    }

    private bool IsValidMetrics()
    {
        if (Metrics == null)
        {
            return false;
        }

        if (Metrics.TotalTasks < 0)
        {
            return false;
        }

        if (Metrics.CompletedTasks < 0)
        {
            return false;
        }

        if (Metrics.CompletedTasks > Metrics.TotalTasks)
        {
            return false;
        }

        if (Metrics.ProjectStartDate == default(DateTime) || Metrics.ProjectEndDate == default(DateTime))
        {
            return false;
        }

        if (Metrics.ProjectStartDate >= Metrics.ProjectEndDate)
        {
            return false;
        }

        return true;
    }

    private int CalculateCompletionPercentage()
    {
        if (!IsValidMetrics() || Metrics.TotalTasks == 0)
        {
            return 0;
        }

        int percentage = (int)((Metrics.CompletedTasks / (double)Metrics.TotalTasks) * 100);
        return Math.Min(100, Math.Max(0, percentage));
    }

    private List<string> GenerateSampleLabels()
    {
        try
        {
            if (!IsValidMetrics())
            {
                return new List<string>();
            }

            var labels = new List<string>();
            var startDate = Metrics.ProjectStartDate;
            var endDate = Metrics.ProjectEndDate;
            var totalDays = (int)(endDate - startDate).TotalDays;
            
            if (totalDays <= 0)
            {
                labels.Add(DateTime.Now.ToString("MM-dd"));
                return labels;
            }

            var dayInterval = Math.Max(1, totalDays / 7);

            for (int i = 0; i <= totalDays; i += dayInterval)
            {
                labels.Add(startDate.AddDays(i).ToString("MM-dd"));
            }

            if (!labels.Contains(endDate.ToString("MM-dd")))
            {
                labels.Add(endDate.ToString("MM-dd"));
            }

            return labels.Count > 0 ? labels : new List<string> { DateTime.Now.ToString("MM-dd") };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating chart labels");
            return new List<string>();
        }
    }

    private List<int> GenerateSampleBurndownData()
    {
        try
        {
            if (!IsValidMetrics() || Metrics.TotalTasks == 0)
            {
                return new List<int>();
            }

            var data = new List<int>();
            var completedTasks = Math.Max(0, Math.Min(Metrics.CompletedTasks, Metrics.TotalTasks));
            var tasksRemaining = Metrics.TotalTasks - completedTasks;
            var daysRemaining = (int)(Metrics.ProjectEndDate - DateTime.Now).TotalDays;
            
            if (daysRemaining <= 0)
            {
                daysRemaining = 1;
            }

            var idealDailyBurnRate = tasksRemaining > 0 
                ? tasksRemaining / (double)daysRemaining 
                : 0;

            int currentRemaining = tasksRemaining;
            
            for (int i = 0; i < 8; i++)
            {
                data.Add(Math.Max(0, currentRemaining));
                currentRemaining = (int)(currentRemaining - idealDailyBurnRate);
            }

            return data.Count > 0 ? data : new List<int>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating burn-down data");
            return new List<int>();
        }
    }
}

<style>
    .progress-metrics-container {
        padding: 20px 0;
    }

    .metrics-content {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 24px;
        border: 1px solid #dee2e6;
    }

    .progress-section {
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 20px;
    }

    .completion-percentage {
        color: #495057;
    }

    .burndown-section {
        margin-top: 20px;
    }

    #burndownChart {
        max-width: 100%;
        height: auto;
    }

    .spinner-border {
        width: 2rem;
        height: 2rem;
    }
</style>