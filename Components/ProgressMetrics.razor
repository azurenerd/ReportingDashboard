<div class="progress-metrics-container">
    <div class="row">
        <div class="col-12">
            <h4>Overall Project Completion</h4>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="progress" style="height: 40px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: @CompletionPercentage%;" aria-valuenow="@CompletionPercentage" aria-valuemin="0" aria-valuemax="100">
                    <strong>@CompletionPercentage%</strong>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <p class="text-muted">
                <strong>@ProjectName</strong> is <strong>@CompletionPercentage% complete</strong>
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int CompletionPercentage { get; set; }

    [Parameter]
    public string ProjectName { get; set; }
}