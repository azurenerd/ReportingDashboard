<div class="progress-metrics-container">
    <div class="row">
        <div class="col-12">
            <h4>Overall Project Completion</h4>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="progress" style="height: 40px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: @CompletionPercentage%;" aria-valuenow="@CompletionPercentage" aria-valuemin="0" aria-valuemax="100">
                    <strong>@CompletionPercentage%</strong>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <p class="text-muted">
                <strong>@ProjectName</strong> is <strong>@CompletionPercentage% complete</strong>
            </p>
        </div>
    </div>
    @if (Metrics != null)
    {
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">@Metrics.TotalTasks</div>
                    <div class="metric-label">Total Tasks</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">@Metrics.CompletedTasks</div>
                    <div class="metric-label">Completed</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">@Metrics.InProgressTasks</div>
                    <div class="metric-label">In-Progress</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-box">
                    <div class="metric-value">@Metrics.CarriedOverTasks</div>
                    <div class="metric-label">Carried-Over</div>
                </div>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <p class="text-muted">
                    <strong>Estimated Burndown Rate:</strong> @Metrics.EstimatedBurndownRate.ToString("P")
                </p>
            </div>
        </div>
    }
</div>

<style>
.progress-metrics-container {
    padding: 16px 0;
}

.metric-box {
    background-color: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 16px;
    text-align: center;
}

.metric-value {
    font-size: 28pt;
    font-weight: bold;
    color: #007bff;
    margin-bottom: 8px;
}

.metric-label {
    font-size: 12pt;
    color: #666;
}
</style>

@code {
    [Parameter]
    public int CompletionPercentage { get; set; }

    [Parameter]
    public string ProjectName { get; set; }

    [Parameter]
    public ProjectMetrics Metrics { get; set; }
}