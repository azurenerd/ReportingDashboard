@using AgentSquad.Runner.Models

<div class="milestone-timeline">
    @if (Milestones == null || !Milestones.Any())
    {
        <p class="text-muted">No milestones available.</p>
    }
    else
    {
        <div class="timeline-container">
            @foreach (var milestone in Milestones)
            {
                <div class="timeline-item">
                    <div class="timeline-marker" style="@GetMilestoneMarkerStyle(milestone.Status)">
                        <span class="timeline-status">@GetStatusBadge(milestone.Status)</span>
                    </div>
                    <div class="timeline-content">
                        <h5>@milestone.Name</h5>
                        <p class="text-muted">Target Date: @milestone.TargetDate.ToShortDateString()</p>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" style="width: @milestone.CompletionPercentage%;" aria-valuenow="@milestone.CompletionPercentage" aria-valuemin="0" aria-valuemax="100">
                                @milestone.CompletionPercentage%
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetMilestoneMarkerStyle(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "background-color: #28a745;",
            MilestoneStatus.InProgress => "background-color: #007bff;",
            _ => "background-color: #6c757d;"
        };
    }

    private string GetStatusBadge(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "✓",
            MilestoneStatus.InProgress => "→",
            _ => "○"
        };
    }
}