@using System
@using System.Collections.Generic

<div class="timeline-container">
    @if (Milestones == null || Milestones.Count == 0)
    {
        <div class="timeline-empty-state">
            <p>No milestones available</p>
        </div>
    }
    else
    {
        @foreach (var milestone in Milestones)
        {
            <div class="timeline-item" data-status="@milestone.Status.ToString().ToLower()">
                <div class="milestone-status-badge"></div>
                <div class="milestone-name">@milestone.Name</div>
                <div class="milestone-date">@milestone.TargetDate.ToString("MMM dd, yyyy")</div>
                @if (!string.IsNullOrEmpty(milestone.Description))
                {
                    <div class="milestone-description">@milestone.Description</div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }
}