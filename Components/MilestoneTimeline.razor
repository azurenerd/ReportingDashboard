@inject ILogger<MilestoneTimeline> Logger

@if (_parsedMilestones.Count > 0)
{
    <div class="milestone-timeline">
        <div class="timeline-track"></div>

        @for (int i = 0; i < _parsedMilestones.Count; i++)
        {
            var entry = _parsedMilestones[i];
            var position = CalculatePosition(entry.Date);
            var statusClass = GetStatusClass(entry.Milestone.Status);
            var labelClass = i % 2 == 0 ? "label-below" : "label-above";

            <div class="milestone-marker @statusClass @labelClass"
                 style="left: @(position.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%">
                <div class="marker-dot"></div>
                <div class="milestone-label">
                    <span class="milestone-title" title="@entry.Milestone.Title">@entry.Milestone.Title</span>
                    <span class="milestone-date">@entry.Date.ToString("MMM dd, yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                </div>
            </div>
        }

        @if (_showTodayMarker)
        {
            <div class="today-marker"
                 style="left: @(_todayPosition.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%">
                <span class="today-marker-label">Today</span>
                <div class="today-line"></div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    private List<(Milestone Milestone, DateOnly Date)> _parsedMilestones = new();
    private DateOnly _rangeStart;
    private DateOnly _rangeEnd;
    private double _todayPosition;
    private bool _showTodayMarker;

    private static readonly string[] KnownStatuses = { "completed", "in-progress", "upcoming", "delayed" };

    protected override void OnParametersSet()
    {
        _showTodayMarker = false;

        if (Milestones is null || Milestones.Count == 0)
        {
            _parsedMilestones = new();
            return;
        }

        ParseMilestones();

        if (_parsedMilestones.Count == 0)
        {
            return;
        }

        _parsedMilestones = _parsedMilestones.OrderBy(m => m.Date).ToList();

        CalculateTimelineRange();

        var today = DateOnly.FromDateTime(DateTime.Today);
        _todayPosition = CalculatePosition(today);
        _showTodayMarker = today >= _rangeStart && today <= _rangeEnd;
    }

    private void ParseMilestones()
    {
        var parsed = new List<(Milestone Milestone, DateOnly Date)>();
        foreach (var milestone in Milestones!)
        {
            if (DateOnly.TryParseExact(milestone.Date, "yyyy-MM-dd",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var date))
            {
                parsed.Add((milestone, date));
            }
            else
            {
                Logger.LogWarning(
                    "Milestone '{Title}' has unparseable date '{Date}'. Excluding from timeline.",
                    milestone.Title, milestone.Date);
            }
        }
        _parsedMilestones = parsed;
    }

    private void CalculateTimelineRange()
    {
        var dates = _parsedMilestones.Select(p => p.Date).ToList();
        var minDate = dates.Min();
        var maxDate = dates.Max();

        if (minDate == maxDate)
        {
            _rangeStart = minDate.AddDays(-60);
            _rangeEnd = maxDate.AddDays(60);
        }
        else
        {
            _rangeStart = minDate.AddDays(-30);
            _rangeEnd = maxDate.AddDays(30);
        }
    }

    private double CalculatePosition(DateOnly date)
    {
        var totalDays = (double)(_rangeEnd.DayNumber - _rangeStart.DayNumber);
        if (totalDays == 0) return 50.0;

        var position = (date.DayNumber - _rangeStart.DayNumber) / totalDays * 100.0;
        return Math.Clamp(position, 0.0, 100.0);
    }

    private static string GetStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "status-upcoming";
        }

        var normalized = status.ToLowerInvariant().Replace(" ", "-");

        if (KnownStatuses.Contains(normalized))
        {
            return $"status-{normalized}";
        }

        return "status-upcoming";
    }
}