        background-color: #ff9800;
    }

    .milestone-item[data-status="future"] .milestone-status-badge {
        background-color: #999999;
    }

    .milestone-info {
        margin: 0;
    }

    .milestone-name {
        margin: 0 0 4px 0;
        font-size: 13px;
        font-weight: 600;
        color: #333;
    }

    .milestone-date {
        margin: 0 0 4px 0;
        font-size: 12px;
        color: #666;
    }

    .milestone-description {
        margin: 0;
        font-size: 11px;
        color: #999;
        line-height: 1.3;
    }
</style>