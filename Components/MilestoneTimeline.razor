@using AgentSquad.Runner.Models

<div class="milestone-timeline card border-0 shadow-sm">
    <div class="card-body p-4">
        <h2 class="card-title mb-4">Project Timeline</h2>
        <div class="timeline">
            @if (Milestones != null && Milestones.Count > 0)
            {
                @foreach (var milestone in Milestones)
                {
                    var statusClass = GetStatusClass(milestone.Status);
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker @statusClass"></div>
                        <div class="timeline-content">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="mb-1">@milestone.Name</h5>
                                    <p class="text-muted mb-0">Target: @FormatDate(milestone.TargetDate)</p>
                                </div>
                                <div class="text-end">
                                    <span class="badge @GetBadgeClass(milestone.Status)">
                                        @FormatStatus(milestone.Status)
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">@milestone.CompletionPercentage%</small>
                                        <div class="progress" style="height: 4px;">
                                            <div class="progress-bar" style="width: @milestone.CompletionPercentage%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    private string GetStatusClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "InProgress" => "bg-info",
        _ => "bg-secondary"
    };

    private string GetBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "InProgress" => "bg-info",
        _ => "bg-secondary"
    };

    private string FormatStatus(string status) => status switch
    {
        "Completed" => "✓ Completed",
        "InProgress" => "◐ In Progress",
        _ => "○ Pending"
    };

    private string FormatDate(string dateString)
    {
        if (DateTime.TryParse(dateString, out var date))
            return date.ToString("MMM d, yyyy");
        return dateString;
    }
}