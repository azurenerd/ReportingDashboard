@inject IJSRuntime JS

<div class="milestone-timeline-container">
    <h2 class="mb-4">Project Milestone Timeline</h2>
    
    @if (hasError)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> Failed to load milestone timeline. Please try refreshing the page.
        </div>
    }
    else if (Milestones == null || Milestones.Count == 0)
    {
        <div class="alert alert-info">
            No milestones to display.
        </div>
    }
    else
    {
        <div class="chart-wrapper">
            <canvas id="milestoneChart" style="max-width: 100%;"></canvas>
        </div>
        @if (isLoading)
        {
            <div class="alert alert-info d-flex align-items-center mt-2">
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Loading milestone timeline...</span>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();

    private IJSObjectReference? module;
    private bool isLoading = true;
    private bool hasError = false;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        try
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading chart-interop.js module: {ex.Message}");
            hasError = true;
            isLoading = false;
        }
    }

    protected override async System.Threading.Tasks.Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && module != null && Milestones?.Count > 0 && !hasError)
        {
            try
            {
                var transformedMilestones = TransformMilestonesToJavaScript(Milestones);
                if (transformedMilestones.Count > 0)
                {
                    await module.InvokeVoidAsync("initChart", "milestoneChart", transformedMilestones);
                }
                else
                {
                    Console.WriteLine("No valid milestones to render after transformation.");
                    hasError = true;
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Chart.js: {ex.Message}");
                hasError = true;
                StateHasChanged();
            }
        }
    }

    private List<MilestoneJavaScriptModel> TransformMilestonesToJavaScript(List<Milestone> milestones)
    {
        var transformed = new List<MilestoneJavaScriptModel>();

        if (milestones == null || milestones.Count == 0)
        {
            return transformed;
        }

        foreach (var milestone in milestones)
        {
            try
            {
                if (milestone == null)
                {
                    Console.WriteLine("Skipping null milestone.");
                    continue;
                }

                if (string.IsNullOrWhiteSpace(milestone.Name))
                {
                    Console.WriteLine("Skipping milestone with null or empty name.");
                    continue;
                }

                if (milestone.TargetDate == default(DateTime))
                {
                    Console.WriteLine($"Skipping milestone '{milestone.Name}' with invalid target date.");
                    continue;
                }

                var statusString = milestone.Status.ToString();
                if (!IsValidMilestoneStatus(statusString))
                {
                    Console.WriteLine($"Skipping milestone '{milestone.Name}' with invalid status '{statusString}'.");
                    continue;
                }

                var color = GetStatusColor(statusString);

                transformed.Add(new MilestoneJavaScriptModel
                {
                    Name = milestone.Name.Trim(),
                    TargetDate = milestone.TargetDate.ToString("O"),
                    Status = statusString,
                    Color = color
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error transforming milestone: {ex.Message}");
                continue;
            }
        }

        return transformed;
    }

    private bool IsValidMilestoneStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return false;
        }

        return status == "OnTrack" || status == "AtRisk" || status == "Completed";
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "OnTrack" => "#28a745",
            "AtRisk" => "#ffc107",
            "Completed" => "#007bff",
            _ => "#6c757d"
        };
    }

    private class MilestoneJavaScriptModel
    {
        public string Name { get; set; }
        public string TargetDate { get; set; }
        public string Status { get; set; }
        public string Color { get; set; }
    }
}

<style>
