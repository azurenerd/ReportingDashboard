@namespace AgentSquad.Components
@using AgentSquad.Models

<section class="milestone-timeline-section">
    <div class="container-fluid">
        <div class="milestone-timeline-header">
            <h2>Project Milestones</h2>
        </div>
        
        @if (IsInitialized)
        {
            @if (HasMilestones)
            {
                <div class="milestone-timeline-container">
                    <div class="timeline-row">
                        @foreach (var milestone in Milestones)
                        {
                            <div class="timeline-card-wrapper">
                                <div class="timeline-card @GetStatusClass(milestone.Status)">
                                    <div class="status-color-stripe"></div>
                                    <div class="timeline-card-header">
                                        <h3 class="milestone-name">@milestone.Name</h3>
                                    </div>
                                    <div class="timeline-card-body">
                                        <div class="milestone-info">
                                            <p class="info-label">Target Date:</p>
                                            <p class="info-value">@milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                                        </div>
                                        <div class="milestone-status-section">
                                            <p class="info-label">Status:</p>
                                            <div class="status-indicator @GetStatusIndicatorClass(milestone.Status)">
                                                @RenderStatusIcon(milestone.Status)
                                                <span class="status-text">@milestone.Status</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <p class="mb-0">No milestones available.</p>
                </div>
            }
        }
        else
        {
            <div class="loading-state">
                <p class="text-muted">Loading milestones...</p>
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    private bool IsInitialized { get; set; }
    private bool HasMilestones { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(0);
        InitializeMilestones();
        IsInitialized = true;
    }

    private void InitializeMilestones()
    {
        if (Milestones == null)
        {
            Milestones = new List<Milestone>();
            HasMilestones = false;
        }
        else
        {
            HasMilestones = Milestones.Count > 0;
        }

        foreach (var milestone in Milestones)
        {
            if (string.IsNullOrWhiteSpace(milestone.Name))
            {
                milestone.Name = "Untitled Milestone";
            }

            if (milestone.CompletionPercentage < 0)
            {
                milestone.CompletionPercentage = 0;
            }
            else if (milestone.CompletionPercentage > 100)
            {
                milestone.CompletionPercentage = 100;
            }
        }
    }

    private string GetStatusClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "status-completed",
            MilestoneStatus.InProgress => "status-in-progress",
            MilestoneStatus.Pending => "status-pending",
            _ => "status-pending"
        };
    }

    private string GetStatusIndicatorClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "indicator-completed",
            MilestoneStatus.InProgress => "indicator-in-progress",
            MilestoneStatus.Pending => "indicator-pending",
            _ => "indicator-pending"
        };
    }

    private MarkupString RenderStatusIcon(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => (MarkupString)@"<svg class='status-icon' viewBox='0 0 24 24' fill='currentColor'><path d='M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z'/></svg>",
            MilestoneStatus.InProgress => (MarkupString)@"<svg class='status-icon' viewBox='0 0 24 24' fill='currentColor'><circle cx='12' cy='12' r='10'/></svg>",
            MilestoneStatus.Pending => (MarkupString)@"<svg class='status-icon' viewBox='0 0 24 24' fill='currentColor'><circle cx='12' cy='12' r='9'/></svg>",
            _ => (MarkupString)""
        };
    }
}

