@using AgentSquad.Runner.Data

<div class="milestone-timeline">
    <h2 class="mb-4">Project Timeline</h2>
    <div class="timeline-container">
        @if (Milestones == null || Milestones.Count == 0)
        {
            <div class="alert alert-info">No milestones defined</div>
        }
        else
        {
            <div class="timeline-track">
                @foreach (var milestone in Milestones)
                {
                    <div class="timeline-item @GetMilestoneClass(milestone)">
                        <div class="timeline-marker">
                            <div class="timeline-dot @GetStatusClass(milestone.Status)"></div>
                        </div>
                        <div class="timeline-content">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header @GetHeaderClass(milestone.Status)">
                                    <h5 class="mb-0">@milestone.Name</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-2">
                                        <small class="text-muted d-block">
                                            <strong>Target Date:</strong> @milestone.TargetDate.ToString("MMM dd, yyyy")
                                        </small>
                                        @if (milestone.ActualDate.HasValue)
                                        {
                                            <small class="text-success d-block">
                                                <strong>Completed:</strong> @milestone.ActualDate.Value.ToString("MMM dd, yyyy")
                                            </small>
                                        }
                                    </div>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar @GetProgressBarClass(milestone.Status)" 
                                             role="progressbar" 
                                             style="width: @milestone.CompletionPercentage%;" 
                                             aria-valuenow="@milestone.CompletionPercentage" 
                                             aria-valuemin="0" 
                                             aria-valuemax="100">
                                            @milestone.CompletionPercentage%
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetStatusClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "timeline-dot-completed",
            MilestoneStatus.InProgress => "timeline-dot-in-progress",
            MilestoneStatus.Pending => "timeline-dot-pending",
            _ => "timeline-dot-pending"
        };
    }

    private string GetMilestoneClass(Milestone milestone)
    {
        return milestone.Status switch
        {
            MilestoneStatus.Completed => "completed",
            MilestoneStatus.InProgress => "in-progress",
            _ => "pending"
        };
    }

    private string GetHeaderClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "bg-success text-white",
            MilestoneStatus.InProgress => "bg-info text-white",
            _ => "bg-light text-dark"
        };
    }

    private string GetProgressBarClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "bg-success",
            MilestoneStatus.InProgress => "bg-info",
            _ => "bg-secondary"
        };
    }
}

<style>
.milestone-timeline {
    padding: 1rem 0;
}

.timeline-container {
    position: relative;
}

.timeline-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding: 1rem 0;
}

.timeline-item {
    flex: 0 0 300px;
    position: relative;
    display: flex;
    gap: 1rem;
}

.timeline-marker {
    flex: 0 0 40px;
    display: flex;
    justify-content: center;
    padding-top: 0.5rem;
}

.timeline-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 3px solid #dee2e6;
}

.timeline-dot-completed {
    background-color: #198754;
    border-color: #198754;
}

.timeline-dot-in-progress {
    background-color: #0dcaf0;
    border-color: #0dcaf0;
}

.timeline-dot-pending {
    background-color: #6c757d;
    border-color: #6c757d;
}

.timeline-content {
    flex: 1;
    min-width: 0;
}

.timeline-item.completed .card {
    border-left: 4px solid #198754;
}

.timeline-item.in-progress .card {
    border-left: 4px solid #0dcaf0;
}

.timeline-item.pending .card {
    border-left: 4px solid #6c757d;
}

.card-header h5 {
    font-size: 0.95rem;
    font-weight: 600;
}

@media (max-width: 1024px) {
    .timeline-track {
        flex-wrap: wrap;
    }
    
    .timeline-item {
        flex: 0 0 calc(50% - 0.75rem);
    }
}

@media (max-width: 768px) {
    .timeline-item {
        flex: 0 0 100%;
    }
}
</style>