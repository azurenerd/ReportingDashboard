@using AgentSquad.Runner.Models
@using System.Linq

@if (SortedMilestones.Any())
{
    <div class="milestone-timeline">
        <div class="milestones-container">
            @foreach (var milestone in SortedMilestones)
            {
                <div class="milestone-card">
                    <!-- Rendering logic will be added in Step 4 -->
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="milestone-empty">
        <p>No milestones scheduled</p>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<Milestone> Milestones { get; set; } = [];

    private IEnumerable<Milestone> SortedMilestones => Milestones?.OrderBy(m => m.Date) ?? [];

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
    }
}