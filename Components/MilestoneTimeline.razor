@using AgentSquad.Runner.Models
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject ILogger<MilestoneTimeline> Logger

<div class="timeline-container">
    <canvas id="milestoneChart" style="max-height: 400px;"></canvas>
</div>

@code {
    [CascadingParameter]
    public Milestone[] Milestones { get; set; }

    [CascadingParameter(Name = "LastRefreshTime")]
    public DateTime LastRefreshTime { get; set; }

    private int _lastRenderCount = 0;
    private bool _chartInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    protected override Task OnParametersSetAsync()
    {
        if (Milestones != null)
        {
            int currentCount = Milestones.Length;
            if (currentCount != _lastRenderCount)
            {
                Logger.LogInformation($"Milestone array changed: previous count={_lastRenderCount}, current count={currentCount}");
                _lastRenderCount = currentCount;
                _chartInitialized = false;
            }
        }
        else
        {
            Logger.LogInformation("Milestone array is null");
        }

        return base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Milestones == null || Milestones.Length == 0)
        {
            Logger.LogInformation("Skipping Chart.js initialization: Milestones array is null or empty");
            await base.OnAfterRenderAsync(firstRender);
            return;
        }

        if (!_chartInitialized || !firstRender)
        {
            try
            {
                var config = new
                {
                    milestones = Milestones,
                    containerId = "milestoneChart",
                    colorScheme = new
                    {
                        onTrack = "#28a745",
                        atRisk = "#ffc107",
                        delayed = "#dc3545",
                        completed = "#6c757d"
                    }
                };

                Logger.LogInformation($"Initializing Chart.js with {Milestones.Length} milestones");
                await JSRuntime.InvokeAsync<object>("initMilestoneChart", config);
                _chartInitialized = true;
                Logger.LogInformation("Chart.js initialization completed successfully");
            }
            catch (Exception ex)
            {
                Logger.LogError($"Failed to initialize Chart.js: {ex.Message}");
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "if (window.chartInstance) { window.chartInstance.destroy(); window.chartInstance = null; }");
        }
        catch
        {
            // Gracefully handle cleanup errors
        }
    }
}