@using AgentSquad.Dashboard.Models

<div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px;">
    <h2 style="margin: 0 0 20px 0; font-size: 20px; font-weight: bold; color: #333;">Milestone Timeline</h2>
    
    @if (Milestones == null || Milestones.Count == 0)
    {
        <p style="color: #999; font-size: 14px;">No milestones available.</p>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 16px;">
            @foreach (var milestone in Milestones)
            {
                <div style="padding: 12px; border-left: 4px solid @GetMilestoneColor(milestone.Status); background-color: #f9f9f9; border-radius: 2px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <p style="margin: 0 0 4px 0; font-size: 14px; font-weight: bold; color: #333;">@milestone.Name</p>
                            <p style="margin: 0; font-size: 13px; color: #666;">Target: @milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 24px; font-weight: bold; color: @GetMilestoneColor(milestone.Status);">@milestone.CompletionPercentage%</div>
                            <span style="font-size: 12px; color: #666; text-transform: capitalize;">@milestone.Status</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetMilestoneColor(string status)
    {
        return status?.ToLower() switch
        {
            "completed" => "#28a745",
            "inprogress" => "#0066cc",
            "pending" => "#cccccc",
            _ => "#999999"
        };
    }
}