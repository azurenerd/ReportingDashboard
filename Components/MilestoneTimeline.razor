@using AgentSquad.Runner.Models

<div class="milestone-timeline card border-0 shadow-sm">
    <div class="card-body p-4">
        <h2 class="card-title timeline-title mb-4">Project Timeline</h2>
        <div class="timeline">
            @if (Milestones != null && Milestones.Count > 0)
            {
                @foreach (var milestone in Milestones)
                {
                    var statusClass = GetStatusClass(milestone.Status);
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker @statusClass"></div>
                        <div class="timeline-content">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="milestone-name mb-1">@milestone.Name</h5>
                                    <p class="target-date text-muted mb-0">Target: @FormatDate(milestone.TargetDate)</p>
                                    @if (!string.IsNullOrEmpty(milestone.ActualDate))
                                    {
                                        <p class="actual-date text-muted mb-0">Actual: @FormatDate(milestone.ActualDate)</p>
                                    }
                                </div>
                                <div class="text-end">
                                    <span class="badge @GetBadgeClass(milestone.Status)">
                                        @FormatStatus(milestone.Status)
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">@milestone.CompletionPercentage%</small>
                                        <div class="progress" style="height: 4px;">
                                            <div class="progress-bar" style="width: @milestone.CompletionPercentage%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .milestone-timeline {
        border-radius: 8px;
        transition: box-shadow 0.2s ease;
    }

    .timeline-title {
        font-size: 18px;
        font-weight: 600;
        color: #212529;
    }

    .timeline {
        position: relative;
        padding-left: 20px;
    }

    .timeline-item {
        display: flex;
        align-items: flex-start;
        padding-left: 30px;
        position: relative;
    }

    .timeline-marker {
        position: absolute;
        left: 0;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid white;
        box-shadow: 0 0 0 2px #e9ecef;
    }

    .timeline-marker.bg-success {
        background-color: #198754;
    }

    .timeline-marker.bg-info {
        background-color: #0dcaf0;
    }

    .timeline-marker.bg-secondary {
        background-color: #6c757d;
    }

    .timeline-content {
        width: 100%;
    }

    .milestone-name {
        font-size: 14px;
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.5rem;
    }

    .target-date {
        font-size: 13px;
    }

    .actual-date {
        font-size: 13px;
    }

    .badge {
        font-size: 12px;
        font-weight: 600;
        padding: 0.5rem 0.75rem;
    }

    .progress {
        height: 4px;
        border-radius: 2px;
    }

    @media (max-width: 768px) {
        .timeline-title {
            font-size: 16px;
        }

        .milestone-name {
            font-size: 13px;
        }

        .target-date, .actual-date {
            font-size: 12px;
        }
    }

    @media print {
        .milestone-timeline {
            page-break-inside: avoid;
        }
    }
</style>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    private string GetStatusClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "InProgress" => "bg-info",
        _ => "bg-secondary"
    };

    private string GetBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "InProgress" => "bg-info",
        _ => "bg-secondary"
    };

    private string FormatStatus(string status) => status switch
    {
        "Completed" => "✓ Completed",
        "InProgress" => "◐ In Progress",
        _ => "○ Pending"
    };

    private string FormatDate(string dateString)
    {
        if (DateTime.TryParse(dateString, out var date))
            return date.ToString("MMM d, yyyy");
        return dateString;
    }
}