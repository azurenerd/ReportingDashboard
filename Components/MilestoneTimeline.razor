@using AgentSquad.Dashboard.Models

<div class="card border-0 shadow-sm">
    <div class="card-header bg-light border-0 py-3">
        <h3 class="mb-0">Milestone Timeline</h3>
    </div>
    <div class="card-body">
        @if (Milestones == null || Milestones.Count == 0)
        {
            <p class="text-muted">No milestones available.</p>
        }
        else
        {
            <div class="timeline">
                @foreach (var milestone in Milestones)
                {
                    <div class="milestone-item mb-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="badge @GetStatusBadgeClass(milestone.Status)">
                                    @milestone.Status
                                </span>
                            </div>
                            <div class="col">
                                <h5 class="mb-1" style="font-size: 14pt;">@milestone.Name</h5>
                                <p class="text-muted mb-0" style="font-size: 12pt;">
                                    Target: @milestone.TargetDate.ToString("MMMM d, yyyy") | 
                                    Completion: @milestone.CompletionPercentage%
                                </p>
                            </div>
                            <div class="col-auto">
                                <div class="progress" style="width: 100px; height: 20px;">
                                    <div class="progress-bar @GetProgressBarClass(milestone.Status)" 
                                         role="progressbar" 
                                         style="width: @milestone.CompletionPercentage%;" 
                                         aria-valuenow="@milestone.CompletionPercentage" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetStatusBadgeClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "bg-success",
            MilestoneStatus.InProgress => "bg-info",
            MilestoneStatus.Pending => "bg-secondary",
            _ => "bg-dark"
        };
    }

    private string GetProgressBarClass(MilestoneStatus status)
    {
        return status switch
        {
            MilestoneStatus.Completed => "bg-success",
            MilestoneStatus.InProgress => "bg-info",
            MilestoneStatus.Pending => "bg-secondary",
            _ => "bg-dark"
        };
    }
}