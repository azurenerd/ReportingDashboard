@using AgentSquad.Models

<div class="milestone-timeline mt-4 mb-4">
    <h3 class="mb-3">Project Milestones</h3>
    @if (Milestones != null && Milestones.Count > 0)
    {
        <div class="timeline-container">
            @foreach (var milestone in Milestones)
            {
                <div class="milestone-item @GetStatusClass(milestone.Status)">
                    <div class="milestone-marker"></div>
                    <div class="milestone-content">
                        <h5>@milestone.Name</h5>
                        <p class="text-muted mb-1">Target: @milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                        <p class="mb-0">
                            <span class="badge @GetBadgeClass(milestone.Status)">@milestone.Status</span>
                            <span class="ms-2">@milestone.CompletionPercentage% Complete</span>
                        </p>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; } = new();

    [Parameter]
    public DateTime ProjectStartDate { get; set; }

    [Parameter]
    public DateTime ProjectEndDate { get; set; }

    private string GetStatusClass(MilestoneStatus status) => status switch
    {
        MilestoneStatus.Completed => "completed",
        MilestoneStatus.InProgress => "in-progress",
        MilestoneStatus.Pending => "pending",
        _ => ""
    };

    private string GetBadgeClass(MilestoneStatus status) => status switch
    {
        MilestoneStatus.Completed => "bg-success",
        MilestoneStatus.InProgress => "bg-info",
        MilestoneStatus.Pending => "bg-secondary",
        _ => "bg-light"
    };
}