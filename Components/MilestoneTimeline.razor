@namespace AgentSquad.Runner.Components
@using AgentSquad.Runner.Models

@if (Milestones != null && Milestones.Count > 0)
{
    <div class="timeline-wrapper">
        <h3 class="timeline-title">Project Milestones</h3>
        <div class="milestone-timeline">
            @foreach (var milestone in Milestones.OrderBy(m => m.TargetDate))
            {
                <div class="milestone-item" data-status="@milestone.Status.ToString().ToLower()">
                    <div class="milestone-marker"></div>
                    <div class="milestone-content">
                        <h4 class="milestone-name">@milestone.Name</h4>
                        <p class="milestone-date">@milestone.TargetDate.ToString("MMM dd, yyyy")</p>
                        @if (!string.IsNullOrEmpty(milestone.Description))
                        {
                            <p class="milestone-description">@milestone.Description</p>
                        }
                        <span class="milestone-status-badge" title="@milestone.Status.ToString()">
                            @GetStatusLabel(milestone.Status)
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public List<Milestone>? Milestones { get; set; }

    private string GetStatusLabel(MilestoneStatus status) => status switch
    {
        MilestoneStatus.Completed => "✓ Completed",
        MilestoneStatus.InProgress => "⟳ In Progress",
        MilestoneStatus.AtRisk => "⚠ At Risk",
        MilestoneStatus.Future => "○ Future",
        _ => "Unknown"
    };
}

<style>
    .timeline-wrapper {
        padding: 1.5rem 0;
    }

    .timeline-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #0a3d62;
        margin: 0 0 1.5rem 0;
    }

    .milestone-timeline {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .milestone-item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.5rem;
        padding: 1rem;
        background-color: #f8f9fa;
        border-radius: 6px;
        border-left: 4px solid #bdc3c7;
        transition: all 0.3s ease;
    }

    .milestone-item[data-status="completed"] {
        border-left-color: #27ae60;
        background-color: #f0fdf4;
    }

    .milestone-item[data-status="inprogress"] {
        border-left-color: #3498db;
        background-color: #f0f9ff;
    }

    .milestone-item[data-status="atrisk"] {
        border-left-color: #e74c3c;
        background-color: #fef2f2;
    }

    .milestone-item[data-status="future"] {
        border-left-color: #95a5a6;
        background-color: #f8f9fa;
    }

    .milestone-marker {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        margin-top: 0.5rem;
        background-color: #bdc3c7;
    }

    .milestone-item[data-status="completed"] .milestone-marker {
        background-color: #27ae60;
    }

    .milestone-item[data-status="inprogress"] .milestone-marker {
        background-color: #3498db;
    }

    .milestone-item[data-status="atrisk"] .milestone-marker {
        background-color: #e74c3c;
    }

    .milestone-item[data-status="future"] .milestone-marker {
        background-color: #95a5a6;
    }

    .milestone-content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .milestone-name {
        font-size: 1rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0;
    }

    .milestone-date {
        font-size: 0.875rem;
        color: #7f8c8d;
        margin: 0;
    }

    .milestone-description {
        font-size: 0.875rem;
        color: #2c3e50;
        margin: 0.25rem 0 0 0;
    }

    .milestone-status-badge {
        display: inline-block;
        width: fit-content;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        background-color: rgba(0, 0, 0, 0.05);
        color: #2c3e50;
        margin-top: 0.25rem;
    }

    .milestone-item[data-status="completed"] .milestone-status-badge {
        background-color: #dcfce7;
        color: #166534;
    }

    .milestone-item[data-status="inprogress"] .milestone-status-badge {
        background-color: #dbeafe;
        color: #0c4a6e;
    }

    .milestone-item[data-status="atrisk"] .milestone-status-badge {
        background-color: #fee2e2;
        color: #7f1d1d;
    }
</style>