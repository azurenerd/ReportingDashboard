@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Components
@inherits LayoutComponentBase
@inject IDataProvider DataProvider
@inject IErrorHandler ErrorHandler
@inject ILogger<DashboardLayout> Logger

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <ErrorBoundary ErrorMessage="ErrorMessage" OnRetry="HandleRetry" />
}
else if (IsLoading)
{
    <div class="dashboard-loading">
        <div class="loading-spinner"></div>
        <p>Loading project dashboard...</p>
    </div>
}
else if (ProjectData != null)
{
    <div class="dashboard-container">
        <header class="dashboard-header">
            <h1>@ProjectData.Name</h1>
            @if (!string.IsNullOrEmpty(ProjectData.Description))
            {
                <p class="project-description">@ProjectData.Description</p>
            }
        </header>

        <section class="dashboard-section milestones-section">
            <h2>Project Timeline</h2>
            <MilestoneTimeline Milestones="ProjectData.Milestones" />
        </section>

        <section class="dashboard-section metrics-section">
            <h2>Project Metrics</h2>
            <ProjectMetrics 
                CompletionPercentage="ProjectData.CompletionPercentage"
                HealthStatus="ProjectData.HealthStatus"
                VelocityThisMonth="ProjectData.VelocityThisMonth"
                TotalMilestones="ProjectData.Milestones?.Count ?? 0"
                CompletedMilestones="ProjectData.Milestones?.Count(m => m.Status == MilestoneStatus.Completed) ?? 0" />
        </section>

        <section class="dashboard-section work-items-section">
            <h2>Work Items</h2>
            <WorkItemSummary WorkItems="ProjectData.WorkItems" />
        </section>
    </div>
}

<style>
    .dashboard-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        gap: 20px;
    }

    .loading-spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #3498db;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .dashboard-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        padding: 24px;
        background: #ffffff;
        min-height: 100vh;
    }

    .dashboard-header {
        grid-column: 1 / -1;
        border-bottom: 2px solid #e0e0e0;
        padding-bottom: 20px;
        margin-bottom: 10px;
    }

    .dashboard-header h1 {
        margin: 0 0 8px 0;
        font-size: 32px;
        font-weight: 700;
        color: #1a1a1a;
    }

    .project-description {
        margin: 0;
        font-size: 16px;
        color: #666;
    }

    .dashboard-section {
        grid-column: 1 / -1;
    }

    .dashboard-section h2 {
        font-size: 20px;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0 0 16px 0;
    }

    @media (min-width: 1024px) {
        .dashboard-container {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-header {
            grid-column: 1 / -1;
        }

        .milestones-section {
            grid-column: 1 / -1;
        }

        .metrics-section {
            grid-column: 1;
        }

        .work-items-section {
            grid-column: 2;
        }
    }

    @media print {
        .dashboard-container {
            gap: 12px;
            padding: 0;
        }

        .dashboard-section {
            page-break-inside: avoid;
        }
    }
</style>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private Project? ProjectData { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("[{Timestamp}] DashboardLayout initialized, loading project data", 
            DateTime.UtcNow:O);

        IsLoading = true;
        ErrorMessage = null;

        try
        {
            ProjectData = await DataProvider.LoadProjectDataAsync();
            IsLoading = false;
            Logger.LogInformation("[{Timestamp}] Project data loaded successfully. Project: {ProjectName}", 
                DateTime.UtcNow:O, ProjectData?.Name ?? "Unknown");
        }
        catch (FileNotFoundException ex)
        {
            Logger.LogError(ex, "[{Timestamp}] FileNotFoundException during data load", 
                DateTime.UtcNow:O);
            ErrorMessage = "Configuration file missing. Please ensure data.json exists in the application directory.";
            await ErrorHandler.CaptureErrorAsync(ex, ErrorContext.FileNotFound);
            IsLoading = false;
        }
        catch (JsonException ex)
        {
            Logger.LogError(ex, "[{Timestamp}] JsonException during data load", 
                DateTime.UtcNow:O);
            ErrorMessage = "Invalid JSON format in configuration file. Please check data.json syntax.";
            await ErrorHandler.CaptureErrorAsync(ex, ErrorContext.InvalidJson);
            IsLoading = false;
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogError(ex, "[{Timestamp}] InvalidOperationException during data load: {Message}", 
                DateTime.UtcNow:O, ex.Message);
            ErrorMessage = ex.Message.Contains("Required fields missing")
                ? ex.Message
                : "Configuration validation failed. Please verify data.json structure.";
            await ErrorHandler.CaptureErrorAsync(ex, ErrorContext.ValidationFailed);
            IsLoading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[{Timestamp}] Unexpected exception during data load: {ExceptionType}: {Message}", 
                DateTime.UtcNow:O, ex.GetType().Name, ex.Message);
            ErrorMessage = "An unexpected error occurred while loading the dashboard. Please try again.";
            await ErrorHandler.CaptureErrorAsync(ex, ErrorContext.UnknownError);
            IsLoading = false;
        }
    }

    private async Task HandleRetry()
    {
        Logger.LogInformation("[{Timestamp}] User initiated retry. Invalidating cache and reloading data.", 
            DateTime.UtcNow:O);

        DataProvider.InvalidateCache();
        ErrorMessage = null;
        ProjectData = null;
        IsLoading = true;

        await OnInitializedAsync();
    }
}