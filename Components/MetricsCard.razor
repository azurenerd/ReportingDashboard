@code {
    [Parameter]
    public MetricItem Item { get; set; }

    [Parameter]
    public string Category { get; set; }

    private string GetCardClass()
    {
        return Category switch
        {
            "Shipped" => "card-shipped",
            "InProgress" => "card-in-progress",
            "Carryover" => "card-carryover",
            _ => "card-default"
        };
    }

    private string GetCategoryBadgeClass()
    {
        return Category switch
        {
            "Shipped" => "badge-success",
            "InProgress" => "badge-warning",
            "Carryover" => "badge-danger",
            _ => "badge-secondary"
        };
    }

    private string GetCategoryLabel()
    {
        return Category switch
        {
            "Shipped" => "Shipped",
            "InProgress" => "In Progress",
            "Carryover" => "Carryover",
            _ => "Item"
        };
    }

    protected override void OnInitialized()
    {
        if (Item == null)
        {
            Item = new MetricItem { Id = "unknown", Title = "Unknown Item", Description = string.Empty };
        }
    }
}

<div class="metrics-card-wrapper">
    <div class="card @GetCardClass() shadow-sm border-0 h-100">
        <div class="card-body d-flex flex-column">
            <div class="card-header-section mb-3">
                <h4 class="card-title mb-2">@Item?.Title</h4>
                <span class="badge @GetCategoryBadgeClass() category-badge">
                    @GetCategoryLabel()
                </span>
            </div>

            @if (!string.IsNullOrEmpty(Item?.Description))
            {
                <p class="card-text flex-grow-1">@Item.Description</p>
            }
            else
            {
                <p class="card-text text-muted flex-grow-1" style="font-style: italic;">No description provided</p>
            }

            <div class="card-footer-section mt-3 pt-2 border-top" style="border-top: 1px solid #e9ecef;">
                <small class="text-muted">ID: @Item?.Id</small>
            </div>
        </div>
    </div>
</div>