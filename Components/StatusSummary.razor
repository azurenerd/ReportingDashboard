@code {
    [CascadingParameter]
    public DashboardData DashboardData { get; set; }

    protected override void OnInitialized()
    {
        if (DashboardData == null)
        {
            DashboardData = new DashboardData();
        }
    }

    private string GetHealthClass()
    {
        return DashboardData?.ProjectStatus switch
        {
            "On Track" => "badge-success",
            "At Risk" => "badge-warning",
            "Off Track" => "badge-danger",
            _ => "badge-secondary"
        };
    }

    private string GetHealthLabel()
    {
        return DashboardData?.ProjectStatus ?? "Unknown";
    }
}

<div class="status-summary mb-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row align-items-center mb-3">
                        <div class="col-md-6">
                            <h2 class="card-title mb-0">
                                @(!string.IsNullOrEmpty(DashboardData?.ProjectName) ? DashboardData.ProjectName : "Project Dashboard")
                            </h2>
                        </div>
                        <div class="col-md-6 text-md-end text-start">
                            <span class="badge @GetHealthClass() health-badge" style="font-size: 0.95rem; padding: 0.6rem 1.2rem;">
                                ● @GetHealthLabel()
                            </span>
                        </div>
                    </div>

                    <hr class="my-3" style="opacity: 0.2;">

                    <div class="row text-center gx-3">
                        <div class="col-md-4">
                            <div class="metric-summary">
                                <h3 class="metric-value text-shipped">@(DashboardData?.ShippedItems?.Count ?? 0)</h3>
                                <p class="metric-label">Shipped</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="metric-summary">
                                <h3 class="metric-value text-in-progress">@(DashboardData?.InProgressItems?.Count ?? 0)</h3>
                                <p class="metric-label">In Progress</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="metric-summary">
                                <h3 class="metric-value text-carryover">@(DashboardData?.CarryoverItems?.Count ?? 0)</h3>
                                <p class="metric-label">Carryover</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>