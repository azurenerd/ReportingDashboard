@using Microsoft.AspNetCore.Components.Web

<ErrorBoundary>
    <ChildContent>
        @ChildContent
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            <h4 class="alert-heading">An error has occurred</h4>
            <p>@ex.Message</p>
            @if (ShowDetails)
            {
                <hr />
                <pre class="small"><code>@ex.StackTrace</code></pre>
            }
            <button type="button" class="btn-close" @onclick="ResetError"></button>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool ShowDetails => !string.IsNullOrEmpty(Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT")) &&
                                 Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";

    private void ResetError()
    {
        // Error boundary will reset on next render
    }
}