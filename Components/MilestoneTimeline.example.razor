@* Example milestone timeline component structure for site.css compatibility *@

@if (Milestones?.Count > 0)
{
    <section class="timeline-container">
        <h2>Project Milestones</h2>
        <div class="timeline-wrapper">
            @foreach (var milestone in Milestones)
            {
                <div class="milestone-item @GetStatusClass(milestone.Status)">
                    <div class="milestone-name">@milestone.Name</div>
                    <div class="milestone-date">@milestone.TargetDate.ToString("yyyy-MM-dd")</div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public List<Milestone> Milestones { get; set; }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Completed" => "status-completed",
            "InProgress" => "status-inprogress",
            "AtRisk" => "status-atrisk",
            "Future" => "status-future",
            _ => ""
        };
    }
}

public class Milestone
{
    public string Name { get; set; }
    public DateTime TargetDate { get; set; }
    public string Status { get; set; }
    public string Description { get; set; }
}