@code {
    [CascadingParameter]
    public DashboardData DashboardData { get; set; }

    protected override void OnInitialized()
    {
        if (DashboardData == null)
        {
            DashboardData = new DashboardData();
        }
    }
}

<div class="metrics-container">
    <div class="row g-4">
        <!-- Shipped Items Column -->
        <div class="col-lg-4">
            <div class="metrics-column">
                <h3 class="column-title shipped-title">Shipped</h3>
                <div class="metrics-list">
                    @if (DashboardData?.ShippedItems != null && DashboardData.ShippedItems.Count > 0)
                    {
                        @foreach (var item in DashboardData.ShippedItems)
                        {
                            <MetricsCard @key="item.Id" Item="item" Category="Shipped" />
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <p class="text-muted">No shipped items</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- In Progress Items Column -->
        <div class="col-lg-4">
            <div class="metrics-column">
                <h3 class="column-title in-progress-title">In Progress</h3>
                <div class="metrics-list">
                    @if (DashboardData?.InProgressItems != null && DashboardData.InProgressItems.Count > 0)
                    {
                        @foreach (var item in DashboardData.InProgressItems)
                        {
                            <MetricsCard @key="item.Id" Item="item" Category="InProgress" />
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <p class="text-muted">No in-progress items</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Carryover Items Column -->
        <div class="col-lg-4">
            <div class="metrics-column">
                <h3 class="column-title carryover-title">Carryover</h3>
                <div class="metrics-list">
                    @if (DashboardData?.CarryoverItems != null && DashboardData.CarryoverItems.Count > 0)
                    {
                        @foreach (var item in DashboardData.CarryoverItems)
                        {
                            <MetricsCard @key="item.Id" Item="item" Category="Carryover" />
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <p class="text-muted">No carryover items</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>