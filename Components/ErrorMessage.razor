@namespace AgentSquad.Runner.Components
@using AgentSquad.Runner.Services
@inject IDataCache DataCache
@inject ILogger<ErrorMessage> Logger

<div class="error-overlay">
    <div class="error-container">
        <div class="error-icon">⚠️</div>
        <h2 class="error-title">Dashboard Error</h2>
        <p class="error-message">@Message</p>
        <div class="error-actions">
            <button class="retry-button" @onclick="HandleRetry" aria-label="Retry loading dashboard">
                Retry
            </button>
            @if (Environment.IsDevelopment())
            {
                <button class="dismiss-button" @onclick="HandleDismiss" aria-label="Dismiss error and return to dashboard">
                    Dismiss
                </button>
            }
        </div>
        @if (!string.IsNullOrEmpty(RetryMessage))
        {
            <p class="retry-message">@RetryMessage</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnRetry { get; set; }

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    public string RetryMessage { get; set; } = string.Empty;

    private async Task HandleRetry()
    {
        try
        {
            RetryMessage = "Configuration reloaded. Refreshing dashboard...";
            DataCache.Remove("project_data");
            Logger.LogInformation("Cache invalidated and retry initiated");
            await OnRetry.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during retry attempt");
            RetryMessage = "Retry failed. Please check the configuration file and try again.";
        }
    }

    private async Task HandleDismiss()
    {
        await OnDismiss.InvokeAsync();
    }
}

<style>
    .error-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.95);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .error-container {
        background-color: #fff3cd;
        border: 2px solid #ffc107;
        border-radius: 12px;
        padding: 2rem;
        max-width: 500px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        text-align: center;
    }

    .error-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .error-title {
        font-size: 1.5rem;
        color: #e74c3c;
        margin: 0 0 1rem 0;
        font-weight: 700;
    }

    .error-message {
        font-size: 1rem;
        color: #2c3e50;
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
    }

    .error-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .retry-button {
        background-color: #27ae60;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .retry-button:hover {
        background-color: #229954;
    }

    .retry-button:active {
        transform: scale(0.98);
    }

    .dismiss-button {
        background-color: #95a5a6;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .dismiss-button:hover {
        background-color: #7f8c8d;
    }

    .retry-message {
        font-size: 0.875rem;
        color: #27ae60;
        margin: 0;
        font-style: italic;
    }
</style>