@using AgentSquad.Runner.Models

<div class="container-fluid">
    <div class="row g-4">
        <!-- Completed Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <div class="mb-3">
                <h4 class="d-inline-block me-2">Completed</h4>
                <span class="badge bg-success">@Tasks.Count(t => t.Status == TaskStatus.Completed)</span>
            </div>
            @foreach (var task in Tasks.Where(t => t.Status == TaskStatus.Completed).OrderBy(t => t.DueDate))
            {
                <div class="card mb-2 border-light shadow-sm task-card" style="transition: box-shadow 0.3s ease;">
                    <div class="card-body p-3">
                        <h5 class="card-title fw-bold text-dark mb-2">@task.Title</h5>
                        <p class="card-text mb-2">
                            <small class="text-muted">@task.AssignedTo</small>
                        </p>
                        <p class="card-text text-end mb-0">
                            <small class="text-muted">@task.DueDate.ToString("MMMM d, yyyy")</small>
                        </p>
                    </div>
                </div>
            }
            @if (!Tasks.Any(t => t.Status == TaskStatus.Completed))
            {
                <p class="text-muted">No tasks</p>
            }
        </div>

        <!-- In Progress Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <div class="mb-3">
                <h4 class="d-inline-block me-2">In Progress</h4>
                <span class="badge bg-primary">@Tasks.Count(t => t.Status == TaskStatus.InProgress)</span>
            </div>
            @foreach (var task in Tasks.Where(t => t.Status == TaskStatus.InProgress).OrderBy(t => t.DueDate))
            {
                <div class="card mb-2 border-light shadow-sm task-card" style="transition: box-shadow 0.3s ease;">
                    <div class="card-body p-3">
                        <h5 class="card-title fw-bold text-dark mb-2">@task.Title</h5>
                        <p class="card-text mb-2">
                            <small class="text-muted">@task.AssignedTo</small>
                        </p>
                        <p class="card-text text-end mb-0">
                            <small class="text-muted">@task.DueDate.ToString("MMMM d, yyyy")</small>
                        </p>
                    </div>
                </div>
            }
            @if (!Tasks.Any(t => t.Status == TaskStatus.InProgress))
            {
                <p class="text-muted">No tasks</p>
            }
        </div>

        <!-- Carried Over Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <div class="mb-3">
                <h4 class="d-inline-block me-2">Carried Over</h4>
                <span class="badge bg-warning text-dark">@Tasks.Count(t => t.Status == TaskStatus.CarriedOver)</span>
            </div>
            @foreach (var task in Tasks.Where(t => t.Status == TaskStatus.CarriedOver).OrderBy(t => t.DueDate))
            {
                <div class="card mb-2 border-light shadow-sm task-card" style="transition: box-shadow 0.3s ease;">
                    <div class="card-body p-3">
                        <h5 class="card-title fw-bold text-dark mb-2">@task.Title</h5>
                        <p class="card-text mb-2">
                            <small class="text-muted">@task.AssignedTo</small>
                        </p>
                        <p class="card-text text-end mb-0">
                            <small class="text-muted">@task.DueDate.ToString("MMMM d, yyyy")</small>
                        </p>
                    </div>
                </div>
            }
            @if (!Tasks.Any(t => t.Status == TaskStatus.CarriedOver))
            {
                <p class="text-muted">No tasks</p>
            }
        </div>
    </div>
</div>

<style>
    .task-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    [Parameter]
    public List<Task> Tasks { get; set; }

    protected override void OnInitialized()
    {
        Tasks ??= new();
    }
}