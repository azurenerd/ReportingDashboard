@using AgentSquad.Runner.Models

<div class="container-fluid">
    <div class="row g-4">
        <!-- Completed Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <h4>Completed</h4>
            <p class="text-muted">Column placeholder - tasks will display here</p>
        </div>

        <!-- In Progress Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <h4>In Progress</h4>
            <p class="text-muted">Column placeholder - tasks will display here</p>
        </div>

        <!-- Carried Over Column -->
        <div class="col-lg-4 col-md-6 col-12">
            <h4>Carried Over</h4>
            <p class="text-muted">Column placeholder - tasks will display here</p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<Task> Tasks { get; set; }

    protected override void OnInitialized()
    {
        Tasks ??= new();
    }
}