@inherits ComponentBase
@using System.Collections.Generic
@using AgentSquad.Runner.Models

<div class="grid grid-cols-3 gap-4 p-6">
    <!-- Shipped Column -->
    <div>
        <h3 class="font-bold text-gray-900 text-lg mb-4">Shipped (@ShippedTasks.Count)</h3>
        <div class="h-96 overflow-y-auto scroll-smooth rounded border border-gray-200 p-4">
            @foreach (var task in ShippedTasks)
            {
                <!-- TaskCard component will be rendered here -->
            }
        </div>
    </div>

    <!-- In-Progress Column -->
    <div>
        <h3 class="font-bold text-gray-900 text-lg mb-4">In-Progress (@InProgressTasks.Count)</h3>
        <div class="h-96 overflow-y-auto scroll-smooth rounded border border-gray-200 p-4">
            @foreach (var task in InProgressTasks)
            {
                <!-- TaskCard component will be rendered here -->
            }
        </div>
    </div>

    <!-- Carried-Over Column -->
    <div>
        <h3 class="font-bold text-gray-900 text-lg mb-4">Carried-Over (@CarriedOverTasks.Count)</h3>
        <div class="h-96 overflow-y-auto scroll-smooth rounded border border-gray-200 p-4">
            @foreach (var task in CarriedOverTasks)
            {
                <!-- TaskCard component will be rendered here -->
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<Task> ShippedTasks { get; set; } = new List<Task>();

    [Parameter]
    public List<Task> InProgressTasks { get; set; } = new List<Task>();

    [Parameter]
    public List<Task> CarriedOverTasks { get; set; } = new List<Task>();
}