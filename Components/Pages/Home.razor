@page "/"
@using AgentSquad.Runner.Data

<PageTitle>Executive Dashboard</PageTitle>

<div class="container-fluid px-4">
    <div class="py-4">
        <h1 class="section-title">Project Dashboard</h1>
        
        <div class="dashboard-section">
            <div class="timeline-container">
                <h2 class="section-title">Milestones</h2>
                <div class="timeline-placeholder">
                    <p class="text-muted">Milestone timeline will be displayed here.</p>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <h2 class="section-title">Task Status</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="status-card">
                        <div class="status-card-header shipped">
                            <p class="status-card-count">0</p>
                            <p class="status-card-label">Shipped</p>
                        </div>
                        <div class="status-card-body">
                            <p class="text-muted small">No tasks shipped yet.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="status-card">
                        <div class="status-card-header in-progress">
                            <p class="status-card-count">0</p>
                            <p class="status-card-label">In Progress</p>
                        </div>
                        <div class="status-card-body">
                            <p class="text-muted small">No tasks in progress.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="status-card">
                        <div class="status-card-header carried-over">
                            <p class="status-card-count">0</p>
                            <p class="status-card-label">Carried Over</p>
                        </div>
                        <div class="status-card-body">
                            <p class="text-muted small">No carried over tasks.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <h2 class="section-title">Progress Metrics</h2>
            <div class="metrics-grid">
                <div class="metric-card">
                    <p class="metric-label">Overall Completion</p>
                    <p class="metric-value">0%</p>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Total Tasks</p>
                    <p class="metric-value">0</p>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Completion Rate</p>
                    <p class="metric-value">0%</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline-placeholder {
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
        border-radius: 0.375rem;
        padding: 3rem 2rem;
        text-align: center;
    }
</style>

@code {
    protected override void OnInitialized()
    {
    }
}