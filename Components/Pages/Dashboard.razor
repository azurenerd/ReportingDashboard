@page "/"
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Models
@inject ProjectDataService DataService

<div class="container-fluid p-4">
    @if (_isLoading)
    {
        <div class="alert alert-info" role="alert">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Loading project data...
        </div>
    }
    else if (_errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @_errorMessage
        </div>
    }
    else if (_projectData != null)
    {
        <div class="row mb-5">
            <div class="col-12">
                <h1 class="display-4">@_projectData.Project.Name</h1>
                <p class="text-muted">@_projectData.Project.Description</p>
            </div>
        </div>

        <!-- Milestones Section -->
        <div class="row mb-5">
            <div class="col-12">
                <h2>Project Milestones</h2>
                <MilestoneTimeline 
                    Milestones="@_projectData.Milestones"
                    ProjectStartDate="@_projectData.Project.StartDate"
                    ProjectEndDate="@_projectData.Project.EndDate">
                </MilestoneTimeline>
            </div>
        </div>

        <!-- Status Cards Section -->
        <div class="row mb-5">
            <div class="col-12">
                <h2>Task Status</h2>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="Shipped"
                    TaskCount="@_shippedTasks.Count"
                    Tasks="@_shippedTasks"
                    CardColor="success">
                </StatusCard>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="In-Progress"
                    TaskCount="@_inProgressTasks.Count"
                    Tasks="@_inProgressTasks"
                    CardColor="primary">
                </StatusCard>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="Carried-Over"
                    TaskCount="@_carriedOverTasks.Count"
                    Tasks="@_carriedOverTasks"
                    CardColor="warning">
                </StatusCard>
            </div>
        </div>

        <!-- Progress Metrics Section -->
        <div class="row">
            <div class="col-12">
                <ProgressMetrics 
                    Metrics="@_projectData.Metrics"
                    ProjectName="@_projectData.Project.Name"
                    CompletionPercentage="@_projectData.Project.CompletionPercentage">
                </ProgressMetrics>
            </div>
        </div>
    }
</div>

@code {
    private ProjectData _projectData;
    private string _errorMessage;
    private bool _isLoading = true;
    private List<ProjectTask> _shippedTasks;
    private List<ProjectTask> _inProgressTasks;
    private List<ProjectTask> _carriedOverTasks;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _projectData = await DataService.LoadProjectDataAsync();
            OrganizeTasksByStatus();
        }
        catch (FileNotFoundException ex)
        {
            _errorMessage = $"Data file not found. Please ensure data.json exists in the wwwroot/data directory. Details: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = $"Failed to load project data. The data.json file may be corrupted or invalid. Details: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred while loading project data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OrganizeTasksByStatus()
    {
        _shippedTasks = _projectData?.Tasks?.Where(t => t.Status == TaskStatus.Shipped).ToList() ?? new List<ProjectTask>();
        _inProgressTasks = _projectData?.Tasks?.Where(t => t.Status == TaskStatus.InProgress).ToList() ?? new List<ProjectTask>();
        _carriedOverTasks = _projectData?.Tasks?.Where(t => t.Status == TaskStatus.CarriedOver).ToList() ?? new List<ProjectTask>();
    }
}