@page "/"
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Models
@inject ProjectDataService DataService

<div class="container-fluid p-4">
    @if (_isLoading)
    {
        <div class="alert alert-info" role="alert">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Loading project data...
        </div>
    }
    else if (_errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @_errorMessage
        </div>
    }
    else if (_projectData != null)
    {
        <div class="row mb-5">
            <div class="col-12">
                <h1 class="display-4">@_projectData.ProjectName</h1>
            </div>
        </div>

        <!-- Milestones Section -->
        <div class="row mb-5">
            <div class="col-12">
                <h2>Project Milestones</h2>
                <!-- MilestoneTimeline component will be added in step 5 -->
            </div>
        </div>

        <!-- Status Cards Section -->
        <div class="row mb-5">
            <div class="col-12">
                <h2>Task Status</h2>
                <!-- StatusCard components will be added in step 5 -->
            </div>
        </div>

        <!-- Progress Metrics Section -->
        <div class="row">
            <div class="col-12">
                <h2>Progress Metrics</h2>
                <!-- ProgressMetrics component will be added in step 5 -->
            </div>
        </div>
    }
</div>

@code {
    private ProjectData _projectData;
    private string _errorMessage;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _projectData = await DataService.LoadProjectDataAsync();
        }
        catch (FileNotFoundException ex)
        {
            _errorMessage = $"Data file not found. Please ensure data.json exists in the wwwroot/data directory. Details: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = $"Failed to load project data. The data.json file may be corrupted or invalid. Details: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred while loading project data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}