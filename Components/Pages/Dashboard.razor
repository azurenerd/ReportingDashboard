@page "/"
@using AgentSquad.Dashboard.Models
@using AgentSquad.Dashboard.Services
@inject ProjectDataService ProjectDataService
@inject ILogger<Dashboard> Logger

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">Executive Dashboard</h1>
            @if (ProjectData?.Project != null)
            {
                <p class="text-muted">@ProjectData.Project.Name</p>
            }
        </div>
    </div>

    @if (ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error Loading Dashboard</strong>
            <p>@ErrorMessage</p>
            <button type="button" class="btn-close" @onclick="@(() => ErrorMessage = null)"></button>
        </div>
    }

    @if (ProjectData != null && ProjectData.Project != null)
    {
        <div class="row mb-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h3 class="card-title">@ProjectData.Project.Name</h3>
                                <p class="text-muted mb-1">@ProjectData.Project.Description</p>
                                <p class="small text-muted mb-0">
                                    <strong>Sponsor:</strong> @ProjectData.Project.Sponsor<br/>
                                    <strong>PM:</strong> @ProjectData.Project.ProjectManager<br/>
                                    <strong>Status:</strong> <span class="badge bg-info">@ProjectData.Project.Status</span>
                                </p>
                            </div>
                            <div class="col-md-6 text-end">
                                <p class="text-muted small">
                                    @ProjectData.Project.ProjectStartDate.ToString("MMMM d, yyyy") - @ProjectData.Project.ProjectEndDate.ToString("MMMM d, yyyy")
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <MilestoneTimeline 
                    Milestones="@ProjectData.Milestones" 
                    ProjectStartDate="@ProjectData.Project.ProjectStartDate" 
                    ProjectEndDate="@ProjectData.Project.ProjectEndDate">
                </MilestoneTimeline>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <h3 class="mb-4">Task Status Breakdown</h3>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="Shipped" 
                    Tasks="@GetTasksByStatus("Shipped")" 
                    CardColor="success">
                </StatusCard>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="In-Progress" 
                    Tasks="@GetTasksByStatus("InProgress")" 
                    CardColor="info">
                </StatusCard>
            </div>
            <div class="col-md-4 mb-3">
                <StatusCard 
                    StatusCategory="Carried-Over" 
                    Tasks="@GetTasksByStatus("CarriedOver")" 
                    CardColor="warning">
                </StatusCard>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <ProgressMetrics 
                    Metrics="@ProjectData.Metrics"
                    ProjectData="@ProjectData">
                </ProgressMetrics>
            </div>
        </div>
    }
    else if (!IsLoading)
    {
        <div class="alert alert-warning">
            <p>No project data available. Please check that data.json is properly configured.</p>
        </div>
    }
</div>

@code {
    private ProjectData? ProjectData;
    private string? ErrorMessage;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            ProjectData = await ProjectDataService.LoadProjectDataAsync();
        }
        catch (FileNotFoundException ex)
        {
            ErrorMessage = $"Data file not found: {ex.Message}";
            Logger.LogError(ex, "Data file not found");
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Invalid data format: {ex.Message}. Please ensure data.json is valid JSON.";
            Logger.LogError(ex, "Invalid data format");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load dashboard: {ex.Message}";
            Logger.LogError(ex, "Unexpected error loading dashboard");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private List<ProjectTask> GetTasksByStatus(string status)
    {
        if (ProjectData?.Tasks == null)
            return new List<ProjectTask>();

        return ProjectData.Tasks
            .Where(t => t.Status == status)
            .ToList();
    }
}