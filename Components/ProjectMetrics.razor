@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IDataProvider DataProvider

<div class="metrics-container" id="projectMetricsContainer">
    @if (IsLoading)
    {
        <div class="metrics-loading">
            <div class="spinner"></div>
            <span>Loading metrics...</span>
        </div>
    }
    @else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="metrics-error">
            <span>⚠️ @ErrorMessage</span>
        </div>
    }
    @else if (Metrics != null)
    {
        <div class="metric-card">
            <div class="metric-label">Completion</div>
            <div class="metric-content">
                <div class="progress-wrapper">
                    <svg class="circular-progress" 
                         viewBox="0 0 100 100" 
                         role="progressbar" 
                         aria-valuenow="@Metrics.CompletionPercentage" 
                         aria-valuemin="0" 
                         aria-valuemax="100"
                         aria-label="@($"Project completion: {Metrics.CompletionPercentage}%")">
                        <circle class="progress-bg" cx="50" cy="50" r="45"></circle>
                        <circle class="progress-fill" 
                                cx="50" cy="50" r="45"
                                style="stroke-dasharray: 283; stroke-dashoffset: @(283 - (Metrics.CompletionPercentage * 2.83));">
                        </circle>
                    </svg>
                    <div class="progress-text">@Metrics.CompletionPercentage%</div>
                </div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Health Status</div>
            <div class="metric-content">
                <div class="status-badge" style="background-color: @Metrics.GetStatusColor();" role="status" aria-label="@($"Health status: {Metrics.GetStatusLabel()}")">
                    @Metrics.GetStatusLabel()
                </div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-label">This Month Velocity</div>
            <div class="metric-content">
                <div>
                    <div class="metric-value">@Metrics.VelocityThisMonth</div>
                    <div class="metric-sublabel">Items Completed</div>
                </div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Previous Month</div>
            <div class="metric-content">
                <div>
                    <div class="metric-value">@Metrics.VelocityLastMonth</div>
                    <div class="metric-sublabel">Items Completed</div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public ProjectMetrics Metrics { get; set; }

    private bool IsLoading { get; set; } = false;
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Metrics == null)
            {
                IsLoading = true;
                ErrorMessage = null;
                Metrics = await DataProvider.GetProjectMetricsAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load project metrics: {ex.Message}";
            Metrics = null;
        }
        finally
        {
            IsLoading = false;
        }
    }
}