@if (Metrics == null)
{
    <section class="metrics-container metrics-loading">
        <article class="metric-card metric-placeholder">
            <div class="metric-body">
                <p class="metric-loading-text">Loading metrics...</p>
            </div>
        </article>
    </section>
}
else
{
    <section class="metrics-container" data-health-status="@Metrics.HealthStatus.ToString().ToLowerInvariant()">
        <!-- Completion Percentage Card -->
        <article class="metric-card metric-completion">
            <div class="metric-header">
                <h3 class="metric-label">Completion</h3>
            </div>
            <div class="metric-body">
                <div class="progress-container">
                    <div class="progress-circle" style="--completion-percentage: @Metrics.CompletionPercentage%;">
                        <span class="progress-value">@Metrics.CompletionPercentage%</span>
                    </div>
                </div>
            </div>
            <div class="metric-footer">
                <span class="metric-description">of project scope</span>
            </div>
        </article>

        <!-- Health Status Card -->
        <article class="metric-card metric-status">
            <div class="metric-header">
                <h3 class="metric-label">Project Status</h3>
            </div>
            <div class="metric-body">
                <div class="health-badge" data-status="@Metrics.HealthStatus.ToString().ToLowerInvariant()">
                    <span class="badge-icon">●</span>
                    <span class="badge-text">@GetHealthStatusLabel(Metrics.HealthStatus)</span>
                </div>
            </div>
            <div class="metric-footer">
                <span class="metric-description">current health</span>
            </div>
        </article>

        <!-- Velocity Card -->
        <article class="metric-card metric-velocity">
            <div class="metric-header">
                <h3 class="metric-label">Velocity</h3>
            </div>
            <div class="metric-body">
                <div class="metric-value-large">
                    @Metrics.VelocityThisMonth
                </div>
            </div>
            <div class="metric-footer">
                <span class="metric-description">items this month</span>
            </div>
        </article>

        <!-- Milestones Card -->
        <article class="metric-card metric-milestones">
            <div class="metric-header">
                <h3 class="metric-label">Milestones</h3>
            </div>
            <div class="metric-body">
                <div class="metric-value-large">
                    <span class="milestone-completed">@Metrics.CompletedMilestones</span>
                    <span class="milestone-separator">/</span>
                    <span class="milestone-total">@Metrics.TotalMilestones</span>
                </div>
            </div>
            <div class="metric-footer">
                <span class="metric-description">completed</span>
            </div>
        </article>
    </section>
}

@code {
    [Parameter]
    public ProjectMetrics? Metrics { get; set; }

    private string GetHealthStatusLabel(HealthStatus status) => status switch
    {
        HealthStatus.OnTrack => "On Track",
        HealthStatus.AtRisk => "At Risk",
        HealthStatus.Blocked => "Blocked",
        _ => "Unknown"
    };
}