@using AgentSquad.Runner.Models
@namespace AgentSquad.Runner.Components

<div class="metrics-grid">
    <div class="metric-card completion-card">
        <div class="metric-label">Completion</div>
        <div class="metric-value">@CompletionPercentage%</div>
        <div class="metric-bar">
            <div class="metric-bar-fill" style="width: @CompletionPercentage%"></div>
        </div>
    </div>

    <div class="metric-card health-card">
        <div class="metric-label">Health Status</div>
        <div class="metric-badge health-@HealthStatus.ToString().ToLower()">
            @HealthStatus.ToString()
        </div>
    </div>

    <div class="metric-card velocity-card">
        <div class="metric-label">Velocity (This Month)</div>
        <div class="metric-value">@VelocityThisMonth</div>
        <div class="metric-subtext">items completed</div>
    </div>

    <div class="metric-card milestones-card">
        <div class="metric-label">Milestones</div>
        <div class="metric-value">@CompletedMilestones / @TotalMilestones</div>
        <div class="metric-subtext">completed</div>
    </div>
</div>

<style>
    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
    }

    .metric-card {
        padding: 16px;
        border-radius: 8px;
        background: #f9f9f9;
        border: 1px solid #e0e0e0;
    }

    .metric-label {
        font-size: 12px;
        font-weight: 600;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    .metric-value {
        font-size: 32px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 8px;
    }

    .metric-subtext {
        font-size: 12px;
        color: #999;
    }

    .metric-bar {
        height: 8px;
        background: #e0e0e0;
        border-radius: 4px;
        overflow: hidden;
    }

    .metric-bar-fill {
        height: 100%;
        background: #4caf50;
        transition: width 0.3s ease;
    }

    .metric-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 12px;
    }

    .health-ontrack {
        background: #c8e6c9;
        color: #2e7d32;
    }

    .health-atrisk {
        background: #ffe0b2;
        color: #e65100;
    }

    .health-blocked {
        background: #ffcdd2;
        color: #c62828;
    }
</style>

@code {
    [Parameter]
    public int CompletionPercentage { get; set; }

    [Parameter]
    public HealthStatus HealthStatus { get; set; }

    [Parameter]
    public int VelocityThisMonth { get; set; }

    [Parameter]
    public int TotalMilestones { get; set; }

    [Parameter]
    public int CompletedMilestones { get; set; }
}