@* Example Blazor component structure for site.css class compatibility *@
@* This demonstrates expected HTML hierarchy and class usage *@

<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>Executive Project Dashboard</h1>
        <p>Real-time project status and milestone tracking</p>
    </header>

    <section class="metrics-grid">
        <article class="metric-card status-ontrack">
            <h3>Completion</h3>
            <div class="metric-value">75%</div>
        </article>
        <article class="metric-card status-ontrack">
            <h3>Health Status</h3>
            <div class="metric-value">On Track</div>
        </article>
        <article class="metric-card">
            <h3>Velocity</h3>
            <div class="metric-value">12 items</div>
        </article>
        <article class="metric-card">
            <h3>Milestones</h3>
            <div class="metric-value">8 / 12</div>
        </article>
    </section>

    <section class="timeline-container">
        <h2>Project Milestones</h2>
        <div class="timeline-wrapper">
            <div class="milestone-item status-completed">
                <div class="milestone-name">Phase 1</div>
                <div class="milestone-date">2025-12-31</div>
            </div>
            <div class="milestone-item status-inprogress">
                <div class="milestone-name">Phase 2</div>
                <div class="milestone-date">2026-03-31</div>
            </div>
            <div class="milestone-item status-future">
                <div class="milestone-name">Phase 3</div>
                <div class="milestone-date">2026-06-30</div>
            </div>
        </div>
    </section>

    <section class="work-items-section">
        <h2>Work Item Status</h2>
        <div class="work-items-grid">
            <div class="work-item-column status-shipped">
                <h3>Shipped This Month <span class="item-count">5</span></h3>
                <div class="work-item status-shipped">
                    <div class="work-item-title">Feature A</div>
                    <div class="work-item-description">Dashboard UI framework</div>
                </div>
            </div>
            <div class="work-item-column status-inprogress">
                <h3>In Progress <span class="item-count">3</span></h3>
                <div class="work-item status-inprogress">
                    <div class="work-item-title">Feature B</div>
                    <div class="work-item-description">Data integration layer</div>
                </div>
            </div>
            <div class="work-item-column status-carriedover">
                <h3>Carried Over <span class="item-count">2</span></h3>
                <div class="work-item status-carriedover">
                    <div class="work-item-title">Feature C</div>
                    <div class="work-item-description">Advanced reporting</div>
                </div>
            </div>
        </div>
    </section>
</div>