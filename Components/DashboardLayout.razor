@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IDataProvider DataProvider

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="loading-overlay">
            <div class="loading-spinner">
                <p>Loading dashboard...</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-overlay">
            <div class="error-container">
                <h2>Dashboard Error</h2>
                <p>@ErrorMessage</p>
                <p class="error-hint">Please ensure data.json exists in the wwwroot directory and is valid JSON.</p>
                <button class="retry-button" @onclick="RetryLoadData">Retry</button>
            </div>
        </div>
    }
    else if (ProjectData != null)
    {
        <div class="dashboard-grid">
            <header class="dashboard-header">
                <h1>@ProjectData.Name</h1>
                @if (!string.IsNullOrEmpty(ProjectData.Description))
                {
                    <p class="project-description">@ProjectData.Description</p>
                }
            </header>

            @if (ProjectData.Milestones != null && ProjectData.Milestones.Count > 0)
            {
                <section class="dashboard-section">
                    <h2>Milestones</h2>
                    <!-- MilestoneTimeline component will be rendered here in Step 7 -->
                </section>
            }

            <section class="dashboard-section work-items-section">
                <WorkItemSummary WorkItems="@ProjectData.WorkItems" />
            </section>
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the loaded project data from data.json.
    /// </summary>
    public Project? ProjectData { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether data is currently being loaded.
    /// </summary>
    public bool IsLoading { get; set; } = true;

    /// <summary>
    /// Gets or sets the error message to display if data loading fails.
    /// </summary>
    public string? ErrorMessage { get; set; }

    /// <summary>
    /// Lifecycle method called after component initialization.
    /// Loads project data from the data provider asynchronously.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadProjectDataAsync();
    }

    /// <summary>
    /// Loads project data from the data provider and updates component state.
    /// Handles errors gracefully by setting ErrorMessage for display to user.
    /// </summary>
    private async Task LoadProjectDataAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            ProjectData = await DataProvider.LoadProjectDataAsync();

            if (ProjectData == null)
            {
                ErrorMessage = "Failed to load project data: Data is null.";
            }
        }
        catch (FileNotFoundException ex)
        {
            ErrorMessage = $"Configuration file not found: {ex.Message}";
        }
        catch (System.Text.Json.JsonException ex)
        {
            ErrorMessage = $"Invalid JSON format in data.json: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Invalid project structure: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An unexpected error occurred while loading dashboard: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    /// <summary>
    /// Allows user to retry loading data after an error occurs.
    /// </summary>
    private async Task RetryLoadData()
    {
        await LoadProjectDataAsync();
    }
}