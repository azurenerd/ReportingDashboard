@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@using AgentSquad.Runner.Components
@inject IDataProvider DataProvider

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="loading-overlay">
            <div class="spinner"></div>
            <p>Loading dashboard data...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-overlay">
            <div class="error-content">
                <h2>⚠️ Error Loading Dashboard</h2>
                <p>@ErrorMessage</p>
                <details>
                    <summary>Technical Details</summary>
                    <pre>@ErrorDetails</pre>
                </details>
                <button @onclick="RetryLoad" class="retry-button">Retry</button>
            </div>
        </div>
    }
    else if (ProjectData != null)
    {
        <div class="dashboard-layout">
            <header class="dashboard-header">
                <h1>@ProjectData.Name</h1>
                @if (!string.IsNullOrEmpty(ProjectData.Description))
                {
                    <p class="project-description">@ProjectData.Description</p>
                }
            </header>

            <div class="dashboard-content">
                @if (ProjectData.WorkItems != null && ProjectData.WorkItems.Count > 0)
                {
                    <section class="work-items-section">
                        <h2>Work Items</h2>
                        <WorkItemSummary WorkItems="@ProjectData.WorkItems" />
                    </section>
                }
            </div>
        </div>
    }
</div>

@code {
    private Project ProjectData { get; set; }
    private bool IsLoading { get; set; } = true;
    private string ErrorMessage { get; set; }
    private string ErrorDetails { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            ErrorDetails = null;

            ProjectData = await DataProvider.LoadProjectDataAsync();
            IsLoading = false;
        }
        catch (FileNotFoundException ex)
        {
            ErrorMessage = "Configuration file not found. Please ensure data.json exists in the wwwroot directory.";
            ErrorDetails = ex.Message;
            IsLoading = false;
        }
        catch (System.Text.Json.JsonException ex)
        {
            ErrorMessage = "Invalid JSON format in configuration file. Please check data.json for syntax errors.";
            ErrorDetails = ex.Message;
            IsLoading = false;
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Invalid project data: {ex.Message}";
            ErrorDetails = ex.StackTrace ?? "No additional details available";
            IsLoading = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred while loading the dashboard.";
            ErrorDetails = $"{ex.GetType().Name}: {ex.Message}\n\n{ex.StackTrace ?? "No stack trace"}";
            IsLoading = false;
        }
    }

    private async Task RetryLoad()
    {
        await LoadProjectData();
    }
}