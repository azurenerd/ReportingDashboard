@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IDataProvider DataProvider
@inject IDataCache DataCache
@inject ILogger<DashboardLayout> Logger

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <ErrorMessage Message="@ErrorMessage" OnRetry="HandleRetry" OnDismiss="HandleDismiss" />
}
else if (ProjectData != null)
{
    <div class="dashboard-container">
        <header class="dashboard-header">
            <h1>@ProjectData.Name</h1>
            <p>@ProjectData.Description</p>
        </header>

        <section class="dashboard-timeline">
            <!-- MilestoneTimeline component will be placed here in Step 4 -->
            <div class="placeholder">Timeline Section</div>
        </section>

        <section class="dashboard-metrics">
            <!-- ProjectMetrics component will be placed here in Step 4 -->
            <div class="placeholder">Metrics Section</div>
        </section>

        <section class="dashboard-workitems">
            <!-- WorkItemSummary component will be placed here in Step 4 -->
            <div class="placeholder">Work Items Section</div>
        </section>
    </div>
}
else
{
    <div class="dashboard-container">
        <div class="empty-state">
            <p>No project data available.</p>
        </div>
    </div>
}

@code {
    public Project? ProjectData { get; set; }
    public bool IsLoading { get; set; }
    public string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = string.Empty;
            Logger.LogInformation("Starting to load project data");

            ProjectData = await DataProvider.LoadProjectDataAsync();

            Logger.LogInformation("Project data loaded successfully: {ProjectName}", ProjectData?.Name);
            IsLoading = false;
        }
        catch (FileNotFoundException ex)
        {
            Logger.LogError(ex, "Project data file not found at expected location");
            ErrorMessage = "Configuration file not found. Please ensure data.json exists in the application directory.";
            IsLoading = false;
        }
        catch (JsonException ex)
        {
            Logger.LogError(ex, "Failed to parse project data JSON - syntax error in data.json");
            ErrorMessage = "Invalid JSON format in configuration file. Please check data.json for syntax errors.";
            IsLoading = false;
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogError(ex, "Project data validation failed - missing required fields");
            ErrorMessage = $"Configuration validation failed: {ex.Message}";
            IsLoading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error occurred while loading project data");
            ErrorMessage = "An unexpected error occurred while loading the dashboard. Please try again.";
            IsLoading = false;
        }
    }

    private async Task HandleRetry()
    {
        await LoadProjectData();
    }

    private Task HandleDismiss()
    {
        ErrorMessage = string.Empty;
        return Task.CompletedTask;
    }
}