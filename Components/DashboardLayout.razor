@page "/"
@inject IDataProvider DataProvider

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading dashboard data...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-state">
            <p>Error loading dashboard: @ErrorMessage</p>
        </div>
    }
    else if (ProjectData != null)
    {
        <div class="dashboard-grid">
            <!-- Placeholder sections for child components -->
            <header class="dashboard-header">
                <h1>@ProjectData.Name</h1>
            </header>
            <section class="timeline-section">
                <!-- MilestoneTimeline component will be rendered here -->
            </section>
            <section class="metrics-section">
                <!-- ProjectMetrics component will be rendered here -->
            </section>
            <section class="workitems-section">
                <!-- WorkItemSummary component will be rendered here -->
            </section>
        </div>
    }
</div>

@code {
    public Project ProjectData { get; set; }
    public bool IsLoading { get; set; }
    public string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }
}