@page "/"
@using AgentSquad.Models
@using AgentSquad.Services
@inject IDataProvider DataProvider
@inject ILogger<DashboardLayout> Logger

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="loading-overlay">
            <p>Loading project data...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-overlay">
            <h2>Error Loading Dashboard</h2>
            <p>@ErrorMessage</p>
            <p>Please check the data.json file and try refreshing the page.</p>
        </div>
    }
    else if (ProjectData != null)
    {
        <header class="dashboard-header">
            <h1>@ProjectData.Name</h1>
            <p class="project-description">@ProjectData.Description</p>
        </header>

        @if (ProjectData.Milestones?.Count > 0)
        {
            <section class="milestone-section">
                <MilestoneTimeline Milestones="@ProjectData.Milestones" />
            </section>
        }

        @if (ProjectMetrics != null)
        {
            <section class="metrics-section">
                <ProjectMetrics Metrics="@ProjectMetrics" />
            </section>
        }

        @if (ProjectData.WorkItems?.Count > 0)
        {
            <section class="work-items-section">
                <WorkItemSummary WorkItems="@ProjectData.WorkItems" />
            </section>
        }
    }
</div>

@code {
    private Project ProjectData { get; set; }
    private ProjectMetrics ProjectMetrics { get; set; }
    private bool IsLoading { get; set; }
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            ProjectData = await DataProvider.LoadProjectDataAsync();

            if (ProjectData != null)
            {
                // Construct metrics from project data
                ProjectMetrics = new ProjectMetrics
                {
                    CompletionPercentage = ProjectData.CompletionPercentage,
                    HealthStatus = ProjectData.HealthStatus,
                    VelocityThisMonth = ProjectData.VelocityThisMonth,
                    TotalMilestones = ProjectData.Milestones?.Count ?? 0,
                    CompletedMilestones = ProjectData.Milestones?
                        .Count(m => m.Status == MilestoneStatus.Completed) ?? 0
                };
            }
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = ex.Message;
            Logger.LogError(ex, "Failed to load project data");
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred while loading project data.";
            Logger.LogError(ex, "Unexpected error in DashboardLayout.OnInitializedAsync");
        }
        finally
        {
            IsLoading = false;
        }
    }
}