@using AgentSquad.Models
@using AgentSquad.Services
@inject IDataProvider DataProvider

<div class="dashboard-layout">
    @if (IsLoading)
    {
        <div class="loading-spinner">
            <p>Loading dashboard data...</p>
        </div>
    }
    @else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-overlay">
            <div class="error-content">
                <h2>Dashboard Error</h2>
                <p>@ErrorMessage</p>
                <button @onclick="Reload" class="btn-retry">Retry</button>
            </div>
        </div>
    }
    else if (ProjectData != null)
    {
        <div class="dashboard-header">
            <h1>@ProjectData.Name</h1>
            <p class="project-description">@ProjectData.Description</p>
        </div>

        @if (ProjectData.Milestones != null && ProjectData.Milestones.Count > 0)
        {
            <MilestoneTimeline Milestones="@ProjectData.Milestones" />
        }

        @if (ProjectData.Milestones != null)
        {
            <ProjectMetrics Milestones="@ProjectData.Milestones" CompletionPercentage="@ProjectData.CompletionPercentage" HealthStatus="@ProjectData.HealthStatus" VelocityThisMonth="@ProjectData.VelocityThisMonth" />
        }

        @if (ProjectData.WorkItems != null && ProjectData.WorkItems.Count > 0)
        {
            <WorkItemSummary WorkItems="@(ProjectData.WorkItems ?? new List<WorkItem>())" />
        }
    }
    else
    {
        <div class="error-overlay">
            <div class="error-content">
                <h2>No Data</h2>
                <p>Project data could not be loaded. Please check your data.json file.</p>
            </div>
        </div>
    }
</div>

@code {
    private Project ProjectData { get; set; }
    private bool IsLoading { get; set; } = true;
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            ProjectData = await DataProvider.LoadProjectDataAsync();
        }
        catch (FileNotFoundException)
        {
            ErrorMessage = "Configuration file not found. Please ensure data.json exists in the wwwroot directory.";
        }
        catch (System.Text.Json.JsonException ex)
        {
            ErrorMessage = $"Invalid JSON format: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Invalid project structure: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task Reload()
    {
        DataProvider.InvalidateCache();
        await LoadProjectData();
    }
}