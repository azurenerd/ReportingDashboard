@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject IDataProvider DataProvider

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="loading-overlay">
            <div class="spinner"></div>
            <p>Loading project data...</p>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-overlay">
            <div class="error-content">
                <h2>Error Loading Dashboard</h2>
                <p>@ErrorMessage</p>
            </div>
        </div>
    }
    @if (ProjectData != null && string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="dashboard-header">
            <h1>@ProjectData.Name</h1>
            <p class="project-description">@ProjectData.Description</p>
        </div>

        <div class="dashboard-grid">
            <div class="section timeline-section">
                <h2>Project Timeline</h2>
                <MilestoneTimeline Milestones="ProjectData.Milestones" />
            </div>

            <div class="section metrics-section">
                <h2>Project Health</h2>
                <ProjectMetrics Metrics="ProjectData.Metrics" Milestones="ProjectData.Milestones" />
            </div>

            <div class="section work-items-section">
                <h2>Work Item Status</h2>
                <WorkItemSummary WorkItems="ProjectData.WorkItems" />
            </div>
        </div>
    }
</div>

@code {
    private Project ProjectData { get; set; }
    private bool IsLoading { get; set; } = true;
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ProjectData = await DataProvider.LoadProjectDataAsync();
            IsLoading = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load project data: {ex.Message}";
            IsLoading = false;
        }
    }
}