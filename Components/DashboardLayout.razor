@namespace AgentSquad.Runner.Components
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@implements IAsyncDisposable
@inject IDataProvider DataProvider
@inject ILogger<DashboardLayout> Logger

<div class="dashboard-container">
    <div class="dashboard-header">
        @if (ProjectData != null)
        {
            <h1>@ProjectData.Name</h1>
            @if (!string.IsNullOrWhiteSpace(ProjectData.Description))
            {
                <p>@ProjectData.Description</p>
            }
        }
    </div>

    @if (IsLoading)
    {
        <div class="loading-spinner">
            <p>Loading project data...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            <strong>Error loading dashboard:</strong> @ErrorMessage
        </div>
    }
    else if (ProjectData != null)
    {
        <!-- Work Item Summary Section -->
        <WorkItemSummary WorkItems="@ProjectData.WorkItems" />
    }
    else
    {
        <div class="empty-state">
            <p>No project data available.</p>
        </div>
    }
</div>

@code {
    public Project ProjectData { get; set; }
    public bool IsLoading { get; set; } = true;
    public string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            ProjectData = await DataProvider.LoadProjectDataAsync();

            if (ProjectData == null)
            {
                ErrorMessage = "Project data is null or invalid.";
                Logger.LogWarning("ProjectData is null after loading from DataProvider");
            }
        }
        catch (FileNotFoundException ex)
        {
            ErrorMessage = "Configuration file not found. Please ensure data.json exists in the wwwroot directory.";
            Logger.LogError(ex, "data.json file not found");
        }
        catch (System.Text.Json.JsonException ex)
        {
            ErrorMessage = "Invalid JSON format in configuration file. Please check data.json syntax.";
            Logger.LogError(ex, "JSON parsing error");
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = $"Invalid project data: {ex.Message}";
            Logger.LogError(ex, "Project validation failed");
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred while loading project data.";
            Logger.LogError(ex, "Unexpected error loading project data");
        }
        finally
        {
            IsLoading = false;
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        // Cleanup if needed in future phases
        await ValueTask.CompletedTask;
    }
}