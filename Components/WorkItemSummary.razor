@using AgentSquad.Runner.Models

<div class="work-item-summary">
    @foreach (var status in new[] { WorkItemStatus.Shipped, WorkItemStatus.InProgress, WorkItemStatus.CarriedOver })
    {
        var itemsForStatus = WorkItems?.Where(w => w.Status == status).ToList() ?? new List<WorkItem>();
        var columnTitle = GetStatusColumnTitle(status);

        <div class="work-item-column">
            <h3 class="work-item-column-header">
                @columnTitle (@itemsForStatus.Count)
            </h3>

            @if (itemsForStatus.Count == 0)
            {
                <div class="work-item-empty-state">
                    No items
                </div>
            }
            else
            {
                <div class="work-item-list">
                    @foreach (var item in itemsForStatus)
                    {
                        <div class="work-item-card">
                            <div class="work-item-title">@(item?.Title ?? "Untitled")</div>
                            @if (!string.IsNullOrWhiteSpace(item?.Description))
                            {
                                <div class="work-item-description">
                                    @TruncateDescription(item.Description, 100)
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the list of work items to display, grouped by status.
    /// </summary>
    [Parameter]
    public List<WorkItem>? WorkItems { get; set; }

    /// <summary>
    /// Gets the display title for a work item status category.
    /// </summary>
    private string GetStatusColumnTitle(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "Shipped This Month",
        WorkItemStatus.InProgress => "In Progress",
        WorkItemStatus.CarriedOver => "Carried Over",
        _ => "Unknown"
    };

    /// <summary>
    /// Truncates description to specified maximum length with ellipsis if needed.
    /// Returns empty string for null or empty input.
    /// </summary>
    private string TruncateDescription(string? description, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(description))
            return string.Empty;

        if (description.Length <= maxLength)
            return description;

        return description[..maxLength] + "…";
    }
}