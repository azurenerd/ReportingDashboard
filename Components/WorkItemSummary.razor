@using AgentSquad.Runner.Models

<div class="work-item-summary">
    <div class="columns-container">
        @foreach (var statusGroup in GroupedWorkItems)
        {
            <div class="status-column" style="background-color: @GetColumnBackgroundColor(statusGroup.Key);">
                <div class="column-header">
                    <h3>@FormatStatusName(statusGroup.Key)</h3>
                    <span class="item-count">(@statusGroup.Count())</span>
                </div>
                
                @if (statusGroup.Count() == 0)
                {
                    <div class="no-items-placeholder">No items</div>
                }
                else
                {
                    <div class="items-list">
                        @foreach (var item in statusGroup)
                        {
                            <div class="work-item">
                                <div class="item-title">@item.Title</div>
                                @if (!string.IsNullOrWhiteSpace(item.AssignedTo))
                                {
                                    <div class="item-assigned-to">@item.AssignedTo</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <div class="item-description">@TruncateDescription(item.Description)</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<WorkItem> WorkItems { get; set; } = new();

    private IEnumerable<IGrouping<WorkItemStatus, WorkItem>> GroupedWorkItems => 
        WorkItems?.GroupByStatus() ?? Enumerable.Empty<IGrouping<WorkItemStatus, WorkItem>>();

    private string TruncateDescription(string description)
    {
        if (string.IsNullOrWhiteSpace(description))
            return string.Empty;

        const int maxCharacters = 150;
        const int maxLines = 2;

        var lines = description.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.None);
        var truncatedLines = lines.Take(maxLines).ToList();
        var textToTruncate = string.Join(" ", truncatedLines).Trim();

        if (textToTruncate.Length <= maxCharacters)
            return textToTruncate;

        var truncated = TruncateAtWordBoundary(textToTruncate, maxCharacters);
        return truncated + "…";
    }

    private string TruncateAtWordBoundary(string text, int maxLength)
    {
        if (text.Length <= maxLength)
            return text;

        var truncatedAt = maxLength;
        var lastSpaceIndex = text.LastIndexOf(' ', truncatedAt);

        if (lastSpaceIndex > 0 && lastSpaceIndex > maxLength - 20)
        {
            truncatedAt = lastSpaceIndex;
        }

        return text.Substring(0, truncatedAt).Trim();
    }

    private string FormatStatusName(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "Shipped This Month",
        WorkItemStatus.InProgress => "In Progress",
        WorkItemStatus.CarriedOver => "Carried Over",
        _ => status.ToString()
    };

    private string GetColumnBackgroundColor(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "#e8f5e9",
        WorkItemStatus.InProgress => "#e3f2fd",
        WorkItemStatus.CarriedOver => "#f5f5f5",
        _ => "#ffffff"
    };
}