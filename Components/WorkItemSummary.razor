@using AgentSquad.Models
@inject ILogger<WorkItemSummary> Logger

<div class="work-item-summary">
    @foreach (var statusGroup in GetStatusGroups())
    {
        var (status, items) = statusGroup;
        <div class="work-item-column">
            <div class="column-header">
                <h3>@GetStatusLabel(status)</h3>
                <span class="item-count">@items.Count</span>
            </div>

            @if (items.Count == 0)
            {
                <div class="no-items">No items in this category</div>
            }
            else
            {
                <div class="item-list">
                    @foreach (var item in items)
                    {
                        <div class="work-item">
                            <div class="item-title">@item.Title</div>
                            <div class="item-description">
                                @GetTruncatedDescription(item.Description)
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public List<WorkItem> WorkItems { get; set; }

    private List<(WorkItemStatus Status, List<WorkItem> Items)> GetStatusGroups()
    {
        var groups = new List<(WorkItemStatus Status, List<WorkItem> Items)>();
        
        var shipped = new List<WorkItem>();
        var inProgress = new List<WorkItem>();
        var carriedOver = new List<WorkItem>();

        if (WorkItems != null)
        {
            foreach (var item in WorkItems)
            {
                if (item == null)
                {
                    Logger.LogWarning("Encountered null WorkItem in collection");
                    continue;
                }

                // Validate enum value before grouping
                if (!Enum.IsDefined(typeof(WorkItemStatus), item.Status))
                {
                    Logger.LogWarning(
                        "WorkItem '{Title}' has invalid Status enum value: {Status}; item will be skipped",
                        item.Title ?? "(unknown)", item.Status);
                    continue;
                }

                switch (item.Status)
                {
                    case WorkItemStatus.Shipped:
                        shipped.Add(item);
                        break;
                    case WorkItemStatus.InProgress:
                        inProgress.Add(item);
                        break;
                    case WorkItemStatus.CarriedOver:
                        carriedOver.Add(item);
                        break;
                }
            }
        }

        groups.Add((WorkItemStatus.Shipped, shipped));
        groups.Add((WorkItemStatus.InProgress, inProgress));
        groups.Add((WorkItemStatus.CarriedOver, carriedOver));

        return groups;
    }

    private string GetStatusLabel(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "Shipped This Month",
        WorkItemStatus.InProgress => "In Progress",
        WorkItemStatus.CarriedOver => "Carried Over",
        _ => "Unknown Status"
    };

    private string GetTruncatedDescription(string description)
    {
        if (string.IsNullOrEmpty(description))
            return "No description provided";

        const int maxLength = 100;
        if (description.Length > maxLength)
            return description[..maxLength] + "...";

        return description;
    }
}