@using AgentSquad.Runner.Models

<div class="work-item-summary">
    <div class="work-item-column">
        <h3 class="column-header">
            Shipped This Month
            <span class="item-count">(@ShippedItems.Count)</span>
        </h3>
        @if (ShippedItems.Any())
        {
            <div class="item-list">
                @foreach (var item in ShippedItems)
                {
                    <div class="work-item">
                        <div class="item-title" title="@item.Title">@item.Title</div>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <div class="item-description" title="@item.Description">@TruncateDescription(item.Description)</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-items">No items in this category</div>
        }
    </div>

    <div class="work-item-column">
        <h3 class="column-header">
            In Progress
            <span class="item-count">(@InProgressItems.Count)</span>
        </h3>
        @if (InProgressItems.Any())
        {
            <div class="item-list">
                @foreach (var item in InProgressItems)
                {
                    <div class="work-item">
                        <div class="item-title" title="@item.Title">@item.Title</div>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <div class="item-description" title="@item.Description">@TruncateDescription(item.Description)</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-items">No items in this category</div>
        }
    </div>

    <div class="work-item-column">
        <h3 class="column-header">
            Carried Over
            <span class="item-count">(@CarriedOverItems.Count)</span>
        </h3>
        @if (CarriedOverItems.Any())
        {
            <div class="item-list">
                @foreach (var item in CarriedOverItems)
                {
                    <div class="work-item">
                        <div class="item-title" title="@item.Title">@item.Title</div>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <div class="item-description" title="@item.Description">@TruncateDescription(item.Description)</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-items">No items in this category</div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<WorkItem> WorkItems { get; set; } = new();

    private List<WorkItem> ShippedItems = new();
    private List<WorkItem> InProgressItems = new();
    private List<WorkItem> CarriedOverItems = new();

    protected override void OnInitialized()
    {
        GroupWorkItems();
    }

    private void GroupWorkItems()
    {
        ShippedItems = WorkItems?.Where(w => w.Status == WorkItemStatus.Shipped).ToList() ?? new();
        InProgressItems = WorkItems?.Where(w => w.Status == WorkItemStatus.InProgress).ToList() ?? new();
        CarriedOverItems = WorkItems?.Where(w => w.Status == WorkItemStatus.CarriedOver).ToList() ?? new();
    }

    private string TruncateDescription(string description)
    {
        if (string.IsNullOrEmpty(description))
            return string.Empty;

        return description.Length > 100 ? description[..100] + "…" : description;
    }
}