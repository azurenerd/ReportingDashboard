@using AgentSquad.Runner.Models
@namespace AgentSquad.Runner.Components

@if (WorkItems == null || WorkItems.Count == 0)
{
    <div class="work-items-empty">No work items available</div>
}
else
{
    <div class="work-items-container">
        @foreach (var status in new[] { WorkItemStatus.Shipped, WorkItemStatus.InProgress, WorkItemStatus.CarriedOver })
        {
            var items = WorkItems.Where(w => w.Status == status).ToList();
            <div class="work-items-column">
                <div class="column-header">
                    <h3>@GetStatusLabel(status)</h3>
                    <span class="item-count">@items.Count</span>
                </div>
                <div class="items-list">
                    @foreach (var item in items)
                    {
                        <div class="work-item">
                            <div class="item-title">@item.Title</div>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <div class="item-description">@item.Description</div>
                            }
                            @if (!string.IsNullOrEmpty(item.AssignedTo))
                            {
                                <div class="item-assigned">@item.AssignedTo</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
    .work-items-empty {
        padding: 20px;
        text-align: center;
        color: #999;
        font-style: italic;
    }

    .work-items-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
    }

    .work-items-column {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background: #f9f9f9;
        overflow: hidden;
    }

    .column-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        background: #f0f0f0;
        border-bottom: 1px solid #e0e0e0;
    }

    .column-header h3 {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a1a;
    }

    .item-count {
        background: #1a1a1a;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        min-width: 24px;
        text-align: center;
    }

    .items-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        max-height: 400px;
        overflow-y: auto;
    }

    .work-item {
        padding: 8px;
        background: white;
        border-radius: 4px;
        border-left: 3px solid #2196f3;
    }

    .item-title {
        font-weight: 600;
        color: #1a1a1a;
        font-size: 13px;
        margin-bottom: 4px;
    }

    .item-description {
        font-size: 12px;
        color: #666;
        margin-bottom: 4px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .item-assigned {
        font-size: 11px;
        color: #999;
        font-style: italic;
    }
</style>

@code {
    [Parameter]
    public List<WorkItem>? WorkItems { get; set; }

    private string GetStatusLabel(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "Shipped This Month",
        WorkItemStatus.InProgress => "In Progress",
        WorkItemStatus.CarriedOver => "Carried Over",
        _ => status.ToString()
    };
}