@using AgentSquad.Runner.Models

@if (GroupedWorkItems != null)
{
    <div class="work-item-summary">
        @foreach (var statusGroup in GetStatusGroups())
        {
            <div class="work-item-column">
                <div class="column-header">
                    <span>@GetStatusLabel(statusGroup.Status)</span>
                    <span class="item-count">@statusGroup.Items.Count</span>
                </div>

                @if (statusGroup.Items.Count > 0)
                {
                    <div class="item-list">
                        @foreach (var item in statusGroup.Items)
                        {
                            @if (!string.IsNullOrEmpty(item.Title))
                            {
                                <div class="work-item">
                                    <div class="item-title">@item.Title</div>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <div class="item-description">@TruncateDescription(item.Description)</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="no-items">No items in this category</div>
                }
            </div>
        }
    </div>
}

@code {
    /// <summary>
    /// Collection of work items to display and group by status.
    /// </summary>
    [Parameter]
    public List<WorkItem> WorkItems { get; set; } = new();

    private Dictionary<WorkItemStatus, List<WorkItem>> GroupedWorkItems { get; set; } = new();

    /// <summary>
    /// Groups work items by status on component initialization.
    /// </summary>
    protected override void OnInitialized()
    {
        GroupWorkItems();
    }

    /// <summary>
    /// Groups work items by their status for display.
    /// Validates status enum values and skips invalid items.
    /// </summary>
    private void GroupWorkItems()
    {
        GroupedWorkItems = new Dictionary<WorkItemStatus, List<WorkItem>>
        {
            { WorkItemStatus.Shipped, new List<WorkItem>() },
            { WorkItemStatus.InProgress, new List<WorkItem>() },
            { WorkItemStatus.CarriedOver, new List<WorkItem>() }
        };

        if (WorkItems == null || WorkItems.Count == 0)
            return;

        foreach (var item in WorkItems)
        {
            if (item == null || string.IsNullOrEmpty(item.Title))
                continue;

            if (GroupedWorkItems.ContainsKey(item.Status))
            {
                GroupedWorkItems[item.Status].Add(item);
            }
        }
    }

    /// <summary>
    /// Returns status groups in display order for rendering.
    /// </summary>
    private List<(WorkItemStatus Status, List<WorkItem> Items)> GetStatusGroups()
    {
        return new List<(WorkItemStatus, List<WorkItem>)>
        {
            (WorkItemStatus.Shipped, GroupedWorkItems[WorkItemStatus.Shipped]),
            (WorkItemStatus.InProgress, GroupedWorkItems[WorkItemStatus.InProgress]),
            (WorkItemStatus.CarriedOver, GroupedWorkItems[WorkItemStatus.CarriedOver])
        };
    }

    /// <summary>
    /// Gets user-friendly label for work item status.
    /// </summary>
    private string GetStatusLabel(WorkItemStatus status) => status switch
    {
        WorkItemStatus.Shipped => "Shipped This Month",
        WorkItemStatus.InProgress => "In Progress",
        WorkItemStatus.CarriedOver => "Carried Over",
        _ => "Unknown"
    };

    /// <summary>
    /// Truncates description to 100 characters with ellipsis if needed.
    /// Returns empty string for null/empty input.
    /// </summary>
    private string TruncateDescription(string description)
    {
        if (string.IsNullOrEmpty(description))
            return string.Empty;

        return description.Length > 100
            ? description[..100] + "..."
            : description;
    }
}