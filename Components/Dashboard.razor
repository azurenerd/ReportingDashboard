@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject ProjectDataService ProjectDataService

<div class="dashboard-container">
    <div class="container-fluid dashboard-main">
        @if (isLoading)
        {
            <div class="row mt-5">
                <div class="col-12">
                    <div class="alert alert-info text-center" role="alert">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        Loading dashboard data...
                    </div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="row mt-3">
                <div class="col-12">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Error Loading Dashboard</strong>
                        <p class="mb-0">@errorMessage</p>
                        <button type="button" class="btn-close" @onclick="RetryLoadData"></button>
                    </div>
                </div>
            </div>
        }
        else if (projectData != null)
        {
            <div class="dashboard-header mb-4">
                <h1 class="display-5">@projectData.ProjectName</h1>
                <p class="text-muted">@projectData.ProjectDescription</p>
            </div>

            <div class="row mb-4">
                <div class="col-12">
                    <div class="status-cards-section">
                        <div class="row g-4 card-grid">
                            <div class="col-lg-4 col-md-6 col-12">
                                <StatusCard 
                                    StatusCategory="Shipped" 
                                    TaskCount="shippedTasks.Count" 
                                    Tasks="shippedTasks" 
                                    CardColor="bg-success" />
                            </div>
                            <div class="col-lg-4 col-md-6 col-12">
                                <StatusCard 
                                    StatusCategory="In-Progress" 
                                    TaskCount="inProgressTasks.Count" 
                                    Tasks="inProgressTasks" 
                                    CardColor="bg-primary" />
                            </div>
                            <div class="col-lg-4 col-md-6 col-12">
                                <StatusCard 
                                    StatusCategory="Carried-Over" 
                                    TaskCount="carriedOverTasks.Count" 
                                    Tasks="carriedOverTasks" 
                                    CardColor="bg-warning" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (projectData.Tasks != null && projectData.Tasks.Any())
            {
                <div class="row">
                    <div class="col-12">
                        <div class="dashboard-footer text-muted small mt-4 pt-3 border-top">
                            <p>Total Tasks: <strong>@projectData.Tasks.Count</strong> | Last Updated: <strong>@lastLoadTime.ToString("g")</strong></p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="row mt-5">
                <div class="col-12">
                    <div class="alert alert-warning text-center" role="alert">
                        No project data available. Please check that data.json is configured correctly.
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private ProjectData? projectData;
    private List<TaskItem> shippedTasks = new();
    private List<TaskItem> inProgressTasks = new();
    private List<TaskItem> carriedOverTasks = new();
    
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private DateTime lastLoadTime = DateTime.Now;

    /// <summary>
    /// Lifecycle method to load project data on component initialization
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    /// <summary>
    /// Loads project data from the ProjectDataService and groups tasks by status
    /// </summary>
    private async Task LoadProjectData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            
            projectData = await ProjectDataService.LoadProjectDataAsync();
            
            if (projectData != null && projectData.Tasks != null)
            {
                GroupTasksByStatus();
                lastLoadTime = DateTime.Now;
            }
            else
            {
                errorMessage = "Project data is null or empty.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load project data: {ex.Message}";
            projectData = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Groups tasks by their status category for display in StatusCard components
    /// </summary>
    private void GroupTasksByStatus()
    {
        if (projectData?.Tasks == null)
        {
            shippedTasks.Clear();
            inProgressTasks.Clear();
            carriedOverTasks.Clear();
            return;
        }

        shippedTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.Shipped)
            .ToList();

        inProgressTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.InProgress)
            .ToList();

        carriedOverTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.CarriedOver)
            .ToList();
    }

    /// <summary>
    /// Allows user to retry loading data after an error
    /// </summary>
    private async Task RetryLoadData()
    {
        await LoadProjectData();
    }
}