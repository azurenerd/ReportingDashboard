@page "/dashboard"
@using System.Text.Json
@using AgentSquad.Dashboard.Services
@using AgentSquad.Dashboard.Models
@inject ProjectDataService DataService
@inject ILogger<Dashboard> Logger

<style>
    :root {
        --base-font-size: 12pt;
    }
    
    body, html {
        font-size: 12pt;
    }
</style>

<div class="container-fluid mt-5" style="font-size: 12pt;">
    @if (loading)
    {
        <div class="text-center">
            <p style="font-size: 12pt;">Loading project data...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong style="font-size: 12pt;">Error loading project data:</strong> <span style="font-size: 12pt;">@errorMessage</span>
            <button class="btn btn-sm btn-primary mt-2" @onclick="RetryLoad">Refresh</button>
        </div>
    }
    else if (projectData != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <h1 style="font-size: 24pt;">@projectData.Project.Name</h1>
                <p class="text-muted" style="font-size: 12pt;">@projectData.Project.Description</p>
            </div>
        </div>

        <MilestoneTimeline Milestones="projectData.Milestones" 
                          ProjectStartDate="projectData.Project.StartDate" 
                          ProjectEndDate="projectData.Project.EndDate" />

        <div class="row mt-5">
            @foreach (var card in statusCards)
            {
                <div class="col-md-4 mb-3">
                    <StatusCard StatusCategory="card.Category" 
                               TaskCount="card.Count" 
                               Tasks="card.Tasks" 
                               CardColor="card.Color" />
                </div>
            }
        </div>

        <div class="row mt-5">
            <div class="col-12">
                <ProgressMetrics CompletionPercentage="projectData.Metrics.CompletionPercentage" 
                                TotalTasks="projectData.Metrics.TotalTasks" 
                                CompletedTasks="projectData.Metrics.CompletedTasks" 
                                BurndownRate="projectData.Metrics.EstimatedBurndownRate" />
            </div>
        </div>
    }
</div>

@code {
    private ProjectData? projectData;
    private List<StatusCardModel> statusCards = new();
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        loading = true;
        errorMessage = null;

        try
        {
            projectData = await DataService.LoadProjectDataAsync("wwwroot/data/data.json");
            BuildStatusCards();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Failed to load project data");
        }
        finally
        {
            loading = false;
        }
    }

    private void BuildStatusCards()
    {
        if (projectData?.Tasks == null) return;

        var shippedTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.Shipped)
            .ToList();

        var inProgressTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.InProgress)
            .ToList();

        var carriedOverTasks = projectData.Tasks
            .Where(t => t.Status == TaskStatus.CarriedOver)
            .ToList();

        statusCards = new()
        {
            new StatusCardModel { Category = "Shipped", Count = shippedTasks.Count, Tasks = shippedTasks, Color = "success" },
            new StatusCardModel { Category = "In Progress", Count = inProgressTasks.Count, Tasks = inProgressTasks, Color = "info" },
            new StatusCardModel { Category = "Carried Over", Count = carriedOverTasks.Count, Tasks = carriedOverTasks, Color = "warning" }
        };
    }

    private async Task RetryLoad()
    {
        await LoadProjectData();
    }

    private class StatusCardModel
    {
        public string Category { get; set; } = string.Empty;
        public int Count { get; set; }
        public List<Task>? Tasks { get; set; }
        public string Color { get; set; } = string.Empty;
    }
}