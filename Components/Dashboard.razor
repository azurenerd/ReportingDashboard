@page "/"
@using AgentSquad.Runner.Data
@inject ProjectDataService DataService
@inject ILogger<Dashboard> Logger

<PageTitle>AgentSquad Dashboard</PageTitle>

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="page-title">Executive Dashboard</h1>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="section-header mb-0">Project Timeline</h3>
                </div>
                <div class="card-body">
                    <MilestoneTimeline Milestones="MilestoneList" ProjectStartDate="ProjectStart" ProjectEndDate="ProjectEnd" />
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <StatusCard StatusCategory="Shipped" TaskCount="ShippedCount" Tasks="ShippedTasks" CardColor="status-completed" />
        </div>
        <div class="col-md-4 mb-3">
            <StatusCard StatusCategory="In Progress" TaskCount="InProgressCount" Tasks="InProgressTasks" CardColor="status-inprogress" />
        </div>
        <div class="col-md-4 mb-3">
            <StatusCard StatusCategory="Carried Over" TaskCount="CarriedOverCount" Tasks="CarriedOverTasks" CardColor="status-carried-over" />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="section-header mb-0">Progress Metrics</h3>
                </div>
                <div class="card-body">
                    <ProgressMetrics CompletionPercentage="CompletionPercent" TotalTasks="TotalTaskCount" CompletedTasks="CompletedTaskCount" BurndownRate="BurnRate" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Milestone> MilestoneList = new();
    private List<Task> ShippedTasks = new();
    private List<Task> InProgressTasks = new();
    private List<Task> CarriedOverTasks = new();
    
    private int ShippedCount = 0;
    private int InProgressCount = 0;
    private int CarriedOverCount = 0;
    private int CompletionPercent = 0;
    private int TotalTaskCount = 0;
    private int CompletedTaskCount = 0;
    private double BurnRate = 0.0;
    private DateTime ProjectStart = DateTime.Now;
    private DateTime ProjectEnd = DateTime.Now.AddMonths(3);

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Dashboard component initialized");
        
        try
        {
            var dataPath = Path.Combine(AppContext.BaseDirectory, "wwwroot", "data", "data.json");
            var projectData = await DataService.LoadProjectDataAsync(dataPath);
            
            if (projectData != null)
            {
                MilestoneList = projectData.Milestones ?? new();
                
                var allTasks = projectData.Tasks ?? new();
                ShippedTasks = allTasks.Where(t => t.Status == TaskStatus.Shipped).ToList();
                InProgressTasks = allTasks.Where(t => t.Status == TaskStatus.InProgress).ToList();
                CarriedOverTasks = allTasks.Where(t => t.Status == TaskStatus.CarriedOver).ToList();
                
                ShippedCount = ShippedTasks.Count;
                InProgressCount = InProgressTasks.Count;
                CarriedOverCount = CarriedOverTasks.Count;
                
                if (projectData.Metrics != null)
                {
                    CompletionPercent = projectData.Metrics.CompletionPercentage;
                    TotalTaskCount = projectData.Metrics.TotalTasks;
                    CompletedTaskCount = projectData.Metrics.CompletedTasks;
                    BurnRate = projectData.Metrics.EstimatedBurndownRate;
                    ProjectStart = projectData.Metrics.ProjectStartDate;
                    ProjectEnd = projectData.Metrics.ProjectEndDate;
                }
                
                Logger.LogInformation("Dashboard data loaded successfully");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
        }
    }
}