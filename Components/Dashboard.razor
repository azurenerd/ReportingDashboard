@page "/"
@using AgentSquad.Models
@using AgentSquad.Services
@inject ProjectDataService ProjectDataService

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>@(ProjectData?.ProjectName ?? "Project Dashboard")</h1>
    </div>

    @if (ShowError)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @ErrorMessage
        </div>
    }

    @if (ProjectData != null)
    {
        <MilestoneTimeline 
            Milestones="@ProjectData.Milestones"
            ProjectStartDate="@ProjectData.ProjectStartDate"
            ProjectEndDate="@ProjectData.ProjectEndDate"
            ProjectDurationDays="@((int)(ProjectData.ProjectEndDate - ProjectData.ProjectStartDate).TotalDays)">
        </MilestoneTimeline>

        <div class="status-cards-container">
            @foreach (var statusCategory in GetStatusCategories())
            {
                <StatusCard 
                    StatusCategory="@statusCategory.Key"
                    TaskCount="@statusCategory.Value.Count"
                    Tasks="@statusCategory.Value"
                    CardColor="@GetCardColor(statusCategory.Key)">
                </StatusCard>
            }
        </div>

        @if (ProjectData.CompletionPercentage > 0)
        {
            <ProgressMetrics 
                CompletionPercentage="@ProjectData.CompletionPercentage"
                TotalTasks="@(ProjectData.Tasks?.Count ?? 0)">
            </ProgressMetrics>
        }
    }
    else if (!ShowError)
    {
        <div class="loading">Loading project data...</div>
    }
</div>

@code {
    private ProjectData ProjectData;
    private bool ShowError = false;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ProjectData = await ProjectDataService.LoadProjectDataAsync();
        }
        catch (Exception ex)
        {
            ShowError = true;
            ErrorMessage = $"Failed to load project data: {ex.Message}";
        }
    }

    private Dictionary<string, List<TaskItem>> GetStatusCategories()
    {
        var categories = new Dictionary<string, List<TaskItem>>
        {
            { "Shipped", new List<TaskItem>() },
            { "InProgress", new List<TaskItem>() },
            { "CarriedOver", new List<TaskItem>() }
        };

        if (ProjectData?.Tasks != null)
        {
            foreach (var task in ProjectData.Tasks)
            {
                if (categories.ContainsKey(task.Status))
                {
                    categories[task.Status].Add(task);
                }
            }
        }

        return categories;
    }

    private string GetCardColor(string status)
    {
        return status switch
        {
            "Shipped" => "status-shipped",
            "InProgress" => "status-inprogress",
            "CarriedOver" => "status-carriedover",
            _ => "status-default"
        };
    }
}

<style>
.dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

.dashboard-header {
    margin-bottom: 30px;
}

.dashboard-header h1 {
    font-size: 32px;
    font-weight: bold;
    color: #333;
}

.status-cards-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.loading {
    text-align: center;
    font-size: 16px;
    color: #666;
    padding: 40px;
}

@media (max-width: 1024px) {
    .dashboard-container {
        padding: 15px;
    }

    .dashboard-header h1 {
        font-size: 24px;
    }
}
</style>