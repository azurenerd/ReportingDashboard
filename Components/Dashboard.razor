@page "/"
@using AgentSquad.Services.Models
@using AgentSquad.Services
@inject ProjectDataService ProjectDataService

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Executive Project Dashboard</h1>
        <p class="dashboard-subtitle">Real-time Project Status & Milestones</p>
    </div>

    <div class="dashboard-content">
        @if (projectData != null)
        {
            <MilestoneTimeline 
                Milestones="projectData.Milestones" 
                ProjectDurationDays="(int)(projectData.EndDate - projectData.StartDate).TotalDays"
                ProjectStartDate="projectData.StartDate"
                ProjectEndDate="projectData.EndDate" />
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }
        else
        {
            <div class="loading-message">Loading project data...</div>
        }
    </div>
</div>

@code {
    private ProjectData projectData;
    private string errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectDataAsync();
    }

    private async Task LoadProjectDataAsync()
    {
        try
        {
            var dataPath = Path.Combine("wwwroot", "data", "data.json");
            projectData = await ProjectDataService.LoadProjectDataAsync(dataPath);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading project data: {ex.Message}";
            projectData = null;
        }
    }
}

<style>
    .dashboard-container {
        min-height: 100vh;
        background-color: #ffffff;
        padding: 0;
        margin: 0;
    }

    .dashboard-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        color: #ffffff;
        padding: 40px 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    }

    .dashboard-title {
        font-size: 28pt;
        font-weight: 700;
        margin: 0 0 8px 0;
        letter-spacing: -1px;
    }

    .dashboard-subtitle {
        font-size: 14pt;
        color: #d0d0d0;
        margin: 0;
        font-weight: 400;
    }

    .dashboard-content {
        padding: 32px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .loading-message {
        font-size: 14pt;
        color: #666666;
        padding: 32px;
        text-align: center;
    }

    .error-message {
        font-size: 14pt;
        color: #d32f2f;
        padding: 16px;
        background-color: #ffebee;
        border: 1px solid #ef5350;
        border-radius: 4px;
        margin-bottom: 20px;
    }

    @media (max-width: 1023px) {
        .dashboard-header {
            padding: 32px 16px;
        }

        .dashboard-title {
            font-size: 22pt;
        }

        .dashboard-subtitle {
            font-size: 13pt;
        }

        .dashboard-content {
            padding: 24px 16px;
        }
    }

    @media (max-width: 767px) {
        .dashboard-header {
            padding: 24px 12px;
        }

        .dashboard-title {
            font-size: 18pt;
            margin-bottom: 6px;
        }

        .dashboard-subtitle {
            font-size: 12pt;
        }

        .dashboard-content {
            padding: 16px 12px;
        }
    }

    @media print {
        .dashboard-container {
            background-color: #ffffff;
        }

        .dashboard-header {
            background-color: #1a1a1a;
            page-break-after: avoid;
        }

        .dashboard-content {
            padding: 16px 0;
        }
    }
</style>