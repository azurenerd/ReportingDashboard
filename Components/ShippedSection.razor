@using ReportingDashboard.Models

@if (Items is not null && Items.Count > 0)
{
    <section class="shipped-section">
        <h3 class="section-header">
            <span class="section-icon">✓</span>
            Shipped (@Items.Count)
        </h3>
        <div class="card-list">
            @foreach (var item in Items)
            {
                @if (!string.IsNullOrWhiteSpace(item.Title))
                {
                    <div class="shipped-card">
                        <div class="card-indicator">
                            <span class="checkmark"></span>
                        </div>
                        <div class="card-body">
                            <div class="card-title">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <div class="card-description">@item.Description</div>
                            }
                            <div class="card-badges">
                                @if (!string.IsNullOrWhiteSpace(item.Category))
                                {
                                    <span class="badge badge-category">@item.Category</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Priority))
                                {
                                    <span class="badge badge-priority @GetPriorityClass(item.Priority)">@item.Priority</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public List<WorkItem>? Items { get; set; }

    private static string GetPriorityClass(string? priority) => priority switch
    {
        "P0" => "priority-p0",
        "P1" => "priority-p1",
        "P2" => "priority-p2",
        "P3" => "priority-p3",
        _ => "priority-default"
    };
}