@using ReportingDashboard.Models

@if (Metrics is not null && Metrics.Count > 0)
{
    <div class="metrics-bar">
        @foreach (var item in Metrics)
        {
            <MetricBadge Metric="@item" />
        }
    </div>
}

@code {
    [Parameter]
    public List<KeyMetric>? Metrics { get; set; }
}