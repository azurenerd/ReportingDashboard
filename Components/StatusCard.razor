@using AgentSquad.Runner.Data

<div class="card h-100 status-card @GetBorderClass()">
    <div class="card-header @GetHeaderClass()">
        <h5 class="mb-0">
            <span class="status-badge">@StatusCategory</span>
            <span class="badge bg-light text-dark float-end">@TaskCount</span>
        </h5>
    </div>
    <div class="card-body">
        @if (Tasks == null || Tasks.Count == 0)
        {
            <div class="text-muted text-center py-3">
                <small>No tasks in this status</small>
            </div>
        }
        else
        {
            <div class="btn-group w-100 mb-3" role="group">
                <button type="button" 
                        class="btn btn-sm @(IsExpanded ? "btn-outline-secondary" : "btn-secondary")" 
                        @onclick="() => IsExpanded = !IsExpanded">
                    @if (IsExpanded)
                    {
                        <span>▼ Hide Tasks</span>
                    }
                    else
                    {
                        <span>► Show Tasks</span>
                    }
                </button>
            </div>
            @if (IsExpanded)
            {
                <div class="task-list">
                    @foreach (var task in Tasks)
                    {
                        <div class="task-item mb-2 pb-2 border-bottom">
                            <div class="d-flex align-items-start gap-2">
                                <span class="task-checkbox mt-1">✓</span>
                                <div class="flex-grow-1 min-width-0">
                                    <div class="task-name font-monospace text-break" title="@task.Name">
                                        @task.Name
                                    </div>
                                    <small class="text-muted d-block">
                                        @task.AssignedTo
                                    </small>
                                    <small class="text-muted d-block">
                                        Due: @task.DueDate.ToString("MMM dd")
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<ProjectTask> Tasks { get; set; }

    [Parameter]
    public string CardColor { get; set; } = "secondary";

    private bool IsExpanded = false;

    private string GetHeaderClass()
    {
        return CardColor switch
        {
            "success" => "bg-success text-white",
            "info" => "bg-info text-white",
            "warning" => "bg-warning text-dark",
            _ => "bg-secondary text-white"
        };
    }

    private string GetBorderClass()
    {
        return CardColor switch
        {
            "success" => "border-start border-success border-5",
            "info" => "border-start border-info border-5",
            "warning" => "border-start border-warning border-5",
            _ => "border-start border-secondary border-5"
        };
    }
}

<style>
.status-card {
    transition: box-shadow 0.2s ease-in-out;
}

.status-card:hover {
    box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.1);
}

.status-badge {
    font-weight: 600;
    font-size: 1rem;
}

.task-list {
    max-height: 400px;
    overflow-y: auto;
}

.task-item {
    padding: 0.5rem 0;
}

.task-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
}

.task-checkbox {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background-color: #e9ecef;
    border-radius: 3px;
    color: #198754;
    font-weight: bold;
    font-size: 0.85rem;
}

.task-name {
    font-size: 0.9rem;
    font-weight: 500;
}

.min-width-0 {
    min-width: 0;
}

.card-header {
    padding: 1rem 1.25rem;
}

.card-body {
    padding: 1rem 1.25rem;
}
</style>