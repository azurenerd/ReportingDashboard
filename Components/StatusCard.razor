@using AgentSquad.Dashboard.Models

<div class="card border-0 shadow-sm h-100">
    <div class="card-body">
        <h4 class="card-title mb-3">
            <span class="badge bg-@CardColor me-2">@Tasks.Count</span>
            @StatusCategory
        </h4>
        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted small">No tasks in this category.</p>
        }
        else
        {
            <ul class="list-unstyled small">
                @foreach (var task in Tasks)
                {
                    <li class="mb-2 pb-2 border-bottom">
                        <div class="d-flex justify-content-between">
                            <span class="fw-500" style="font-size: 12pt;">@task.Name</span>
                        </div>
                        <div class="text-muted small">
                            <span style="font-size: 11pt;">@task.Owner</span>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; } = string.Empty;

    [Parameter]
    public List<ProjectTask> Tasks { get; set; } = new();

    [Parameter]
    public string CardColor { get; set; } = "primary";
}