@using AgentSquad.Runner.Data

<div class="status-card">
    <div class="status-card-header @CardColor">
        <p class="status-card-count">@TaskCount</p>
        <p class="status-card-label">@StatusCategory</p>
    </div>
    <div class="status-card-body">
        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted small">No tasks in this category.</p>
        }
        else
        {
            <button class="btn btn-sm btn-outline-secondary w-100 mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@StatusCategory" aria-expanded="false" aria-controls="collapse-@StatusCategory">
                Show Tasks (@Tasks.Count)
            </button>
            <div class="collapse" id="collapse-@StatusCategory">
                <div class="task-list">
                    @foreach (var task in Tasks)
                    {
                        <div class="task-item">
                            <span class="task-checkbox">✓</span>
                            <span>@task.Name</span>
                            @if (!string.IsNullOrEmpty(task.Owner))
                            {
                                <span class="task-owner">@task.Owner</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<ProjectTask>? Tasks { get; set; }

    [Parameter]
    public string? CardColor { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(StatusCategory))
            throw new InvalidOperationException("StatusCategory parameter is required");

        Tasks ??= new();
    }
}