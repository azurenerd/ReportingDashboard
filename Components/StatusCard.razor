@using AgentSquad.Dashboard.Models

<div class="card border-left-@CardColor mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0" style="font-size: 13pt;">@StatusCategory</h5>
            <span class="badge badge-@CardColor" style="font-size: 12pt; padding: 8px 12px;">@TaskCount</span>
        </div>

        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted" style="font-size: 12pt;">No tasks in this category.</p>
        }
        else
        {
            <div class="task-list">
                @foreach (var task in Tasks)
                {
                    <div class="task-item d-flex align-items-start mb-2">
                        <i class="bi bi-check-circle-fill text-@CardColor me-2 mt-1"></i>
                        <div class="flex-grow-1">
                            <p class="mb-1" style="font-size: 12pt;"><strong>@task.Name</strong></p>
                            <small class="text-muted" style="font-size: 11pt;">
                                @if (!string.IsNullOrEmpty(task.AssignedTo))
                                {
                                    <span>Assigned to: @task.AssignedTo</span>
                                }
                                @if (task.DueDate != default)
                                {
                                    <span> | Due: @task.DueDate.ToString("MMM dd, yyyy")</span>
                                }
                            </small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; } = string.Empty;

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task>? Tasks { get; set; }

    [Parameter]
    public string CardColor { get; set; } = "primary";
}