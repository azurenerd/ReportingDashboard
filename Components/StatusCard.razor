@namespace AgentSquad.Components
@using AgentSquad.Models;

<div class="card mb-3 border-start border-5" style="border-color: @GetColorValue(CardColor) !important;">
    <div class="card-header bg-light">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <span class="fw-bold">@StatusCategory</span>
                <span class="badge bg-secondary ms-2">@TaskCount</span>
            </h5>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#tasks-@(StatusCategory.Replace(" ", "-").ToLower())" aria-expanded="false">
                <span class="toggle-icon">▼</span>
            </button>
        </div>
    </div>
    <div class="collapse" id="tasks-@(StatusCategory.Replace(" ", "-").ToLower())">
        <div class="card-body">
            @if (Tasks != null && Tasks.Count > 0)
            {
                <ul class="list-unstyled">
                    @foreach (var task in Tasks)
                    {
                        <li class="mb-2 pb-2 border-bottom">
                            <div class="d-flex align-items-start">
                                <span class="me-2">✓</span>
                                <div class="flex-grow-1">
                                    <p class="mb-1 fw-bold">@task.Name</p>
                                    <small class="text-muted">Assigned to: @(task.AssignedTo ?? "Unassigned")</small>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-0">No tasks</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; }

    [Parameter]
    public int TaskCount { get; set; }

    [Parameter]
    public List<Task> Tasks { get; set; }

    [Parameter]
    public string CardColor { get; set; }

    private string GetColorValue(string color)
    {
        return color switch
        {
            "green" => "#28a745",
            "blue" => "#007bff",
            "orange" => "#fd7e14",
            _ => "#6c757d"
        };
    }
}