@using AgentSquad.Models

<div class="status-card card mb-3 @GetCardClass()">
    <div class="card-header @GetHeaderClass()">
        <h4 class="mb-0">@StatusCategory</h4>
        <span class="badge bg-light text-dark fs-5">@Tasks?.Count ?? 0</span>
    </div>
    <div class="card-body">
        @if (Tasks != null && Tasks.Count > 0)
        {
            <div class="task-list">
                @foreach (var task in Tasks)
                {
                    <div class="task-item mb-2">
                        <div class="d-flex align-items-start">
                            <span class="me-2">✓</span>
                            <div class="flex-grow-1">
                                <p class="mb-1 fw-semibold">@task.Name</p>
                                <small class="text-muted">Assigned to: @task.AssignedTo</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No tasks in this category</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; } = "";

    [Parameter]
    public List<ProjectTask> Tasks { get; set; } = new();

    private string GetCardClass() => StatusCategory switch
    {
        "Shipped" => "border-success",
        "InProgress" => "border-info",
        "CarriedOver" => "border-warning",
        _ => ""
    };

    private string GetHeaderClass() => StatusCategory switch
    {
        "Shipped" => "bg-success text-white",
        "InProgress" => "bg-info text-white",
        "CarriedOver" => "bg-warning text-dark",
        _ => "bg-light"
    };
}