@namespace AgentSquad.Components
@inherits ComponentBase

<div class="card status-card h-100 shadow-sm" style="@GetBorderStyle()">
    <div class="card-header bg-light border-0 p-4">
        <div class="d-flex align-items-center justify-content-between">
            <h4 class="mb-0 fw-bold text-dark">
                @StatusCategory
            </h4>
            <span class="badge @GetBadgeColorClass() fs-6 px-3 py-2">
                @TaskCount
            </span>
        </div>
    </div>
    <div class="card-body p-4">
        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted mb-0">No tasks</p>
        }
        else
        {
            <button class="btn btn-sm btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@StatusCategory.Replace(" ", "-")" aria-expanded="true" aria-controls="collapse-@StatusCategory.Replace(" ", "-")">
                View Tasks
            </button>
            <div class="collapse mt-3 show" id="collapse-@StatusCategory.Replace(" ", "-")">
                <div class="list-group">
                    @foreach (var task in Tasks)
                    {
                        <div class="list-group-item">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@task.Name</p>
                                    @if (!string.IsNullOrEmpty(task.AssignedOwner))
                                    {
                                        <small class="text-muted">@task.AssignedOwner</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    /// <summary>
    /// The status category name to display in the card header.
    /// Examples: "Shipped", "In-Progress", "Carried-Over"
    /// </summary>
    [Parameter]
    public string StatusCategory { get; set; } = string.Empty;

    /// <summary>
    /// The count of tasks in this status category. Displayed in badge next to status name.
    /// </summary>
    [Parameter]
    public int TaskCount { get; set; } = 0;

    /// <summary>
    /// The list of tasks to display in the collapsible task list.
    /// Null or empty lists display a "No tasks" message.
    /// </summary>
    [Parameter]
    public List<Task> Tasks { get; set; } = new();

    /// <summary>
    /// The color code for the left border stripe. Valid values: "green", "blue", "orange".
    /// Colors map to status: green=Shipped, blue=In-Progress, orange=Carried-Over.
    /// </summary>
    [Parameter]
    public string CardColor { get; set; } = "gray";

    private string GetBorderStyle()
    {
        var borderColor = CardColor?.ToLower() switch
        {
            "green" => "#28a745",
            "blue" => "#007bff",
            "orange" => "#fd7e14",
            _ => "#6c757d"
        };

        return $"border-left: 4px solid {borderColor};";
    }

    private string GetBadgeColorClass()
    {
        return CardColor?.ToLower() switch
        {
            "green" => "bg-success",
            "blue" => "bg-primary",
            "orange" => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}