@namespace AgentSquad.Components
@inherits ComponentBase

<div class="status-card border-start h-100" style="@GetBorderColorStyle()">
    <div class="card-header bg-white p-3">
        <h5 class="mb-0 fw-bold">
            @StatusCategory <span class="badge bg-secondary ms-2">@TaskCount</span>
        </h5>
    </div>
    <div class="card-body p-3">
        @if (Tasks == null || Tasks.Count == 0)
        {
            <p class="text-muted mb-0">No tasks</p>
        }
        else
        {
            <button class="btn btn-sm btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@StatusCategory" aria-expanded="true">
                View Tasks
            </button>
            <div class="collapse mt-3 show" id="collapse-@StatusCategory">
                <div class="list-group">
                    @foreach (var task in Tasks)
                    {
                        <div class="list-group-item">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@task.Name</p>
                                    @if (!string.IsNullOrEmpty(task.AssignedOwner))
                                    {
                                        <small class="text-muted">@task.AssignedOwner</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    /// <summary>
    /// The status category name to display in the card header.
    /// Examples: "Shipped", "In-Progress", "Carried-Over"
    /// </summary>
    [Parameter]
    public string StatusCategory { get; set; } = string.Empty;

    /// <summary>
    /// The count of tasks in this status category. Displayed in badge next to status name.
    /// </summary>
    [Parameter]
    public int TaskCount { get; set; } = 0;

    /// <summary>
    /// The list of tasks to display in the collapsible task list.
    /// Null or empty lists display a "No tasks" message.
    /// </summary>
    [Parameter]
    public List<Task> Tasks { get; set; } = new();

    /// <summary>
    /// The color code for the left border stripe. Valid values: "green", "blue", "orange".
    /// Colors map to status: green=Shipped, blue=In-Progress, orange=Carried-Over.
    /// </summary>
    [Parameter]
    public string CardColor { get; set; } = "gray";

    private string GetBorderColorStyle()
    {
        return CardColor?.ToLower() switch
        {
            "green" => "border-start-color: #28a745; border-start-width: 4px;",
            "blue" => "border-start-color: #007bff; border-start-width: 4px;",
            "orange" => "border-start-color: #fd7e14; border-start-width: 4px;",
            _ => "border-start-color: #6c757d; border-start-width: 4px;"
        };
    }
}