@using AgentSquad.Runner.Models

<div class="status-card card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="card-title mb-0">
                @GetStatusDisplay()
            </h3>
            <span class="badge rounded-pill @GetCardColorClass()" style="font-size: 1.25rem; padding: 0.5rem 1rem;">
                @Tasks.Count
            </span>
        </div>

        @if (Tasks != null && Tasks.Count > 0)
        {
            <div class="task-list">
                @foreach (var task in Tasks)
                {
                    <div class="task-item p-2 mb-2 rounded" style="background-color: #f8f9fa;">
                        <div class="d-flex align-items-start">
                            <span class="me-2">✓</span>
                            <div class="flex-grow-1">
                                <p class="mb-1 fw-500">@task.Name</p>
                                <small class="text-muted">@task.Owner</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No tasks in this category</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public string StatusCategory { get; set; }

    [Parameter]
    public List<ProjectTask> Tasks { get; set; } = new();

    private string GetStatusDisplay() => StatusCategory switch
    {
        "Shipped" => "🚀 Shipped",
        "InProgress" => "⚙️ In Progress",
        "CarriedOver" => "📋 Carried Over",
        _ => StatusCategory
    };

    private string GetCardColorClass() => StatusCategory switch
    {
        "Shipped" => "bg-success",
        "InProgress" => "bg-info",
        "CarriedOver" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}