## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/

# NuGet lock file
packages.lock.json

# Entity Framework
Migrations/
*.db
*.db-shm
*.db-wal

# Application data
App_Data/
!App_Data/.gitkeep

# Environment-specific files
.env
.env.local
appsettings.local.json

# macOS
.DS_Store

# Node modules (if any frontend tools added later)
node_modules/
npm-debug.log
yarn-error.log

# Rider
.idea/
.idea_modules/

# Resharper
_ReSharper*/
*.DotSettings.user

# Test Results
TestResults/
*.trx