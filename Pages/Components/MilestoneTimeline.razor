@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inherits ComponentBase
@implements IAsyncDisposable

<div class="milestone-timeline">
    @if (ProcessedMilestones != null && ProcessedMilestones.Count > 0)
    {
        <div class="row g-3">
            @foreach (var milestone in ProcessedMilestones)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card milestone-card h-100 d-flex flex-column">
                        <div class="card-body flex-grow-1">
                            <h5 class="card-title">
                                @milestone.Name
                                <small class="text-muted d-block" style="font-size: 0.875rem;">
                                    @milestone.Date.ToString("MMM dd, yyyy")
                                </small>
                            </h5>
                            
                            <div class="mb-3">
                                <span class="badge @GetBadgeClass(milestone.StatusCssClass)">
                                    @milestone.StatusLabel
                                </span>
                            </div>
                            
                            <p class="card-text text-secondary">
                                @GetDaysRemainingText(milestone.DaysRemaining)
                            </p>

                            @if (isExpanded.ContainsKey(milestone.Id) && isExpanded[milestone.Id])
                            {
                                <div class="milestone-description">
                                    <p class="card-text">
                                        @(string.IsNullOrWhiteSpace(milestone.Description) ? "No description" : milestone.Description)
                                    </p>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(milestone.Description))
                        {
                            <div class="card-footer bg-transparent border-top">
                                <button class="btn btn-sm btn-outline-secondary w-100 milestone-toggle-btn" 
                                        @onclick="() => ToggleDetails(milestone.Id)"
                                        aria-label="@(isExpanded.ContainsKey(milestone.Id) && isExpanded[milestone.Id] ? "Hide details" : "Show details")">
                                    @(isExpanded.ContainsKey(milestone.Id) && isExpanded[milestone.Id] ? "Hide Details" : "Show Details")
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (ProcessedMilestones != null)
    {
        <div class="alert alert-info">No milestones to display.</div>
    }
</div>

<style>
    .milestone-timeline {
        padding: 1rem 0;
    }

    .milestone-card {
        border: 1px solid #ddd;
        border-radius: 0.375rem;
        transition: background-color 0.15s ease-in-out;
    }

    .milestone-card:hover {
        background-color: #f9f9f9;
    }

    .card-title {
        margin-bottom: 0.75rem;
        font-weight: 600;
    }

    .card-title small {
        font-weight: 400;
        margin-top: 0.25rem;
    }

    .badge.status-completed {
        background-color: #28a745;
        color: white;
    }

    .badge.status-inprogress {
        background-color: #ffc107;
        color: #212529;
    }

    .badge.status-atrisk {
        background-color: #dc3545;
        color: white;
    }

    .badge.status-planned {
        background-color: #6c757d;
        color: white;
    }

    .badge.status-unknown {
        background-color: #999;
        color: white;
    }

    .card-text {
        margin-bottom: 0;
        font-size: 0.9375rem;
    }

    .milestone-description {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #e9ecef;
        max-height: 500px;
        overflow: hidden;
        transition: max-height 0.3s ease-in-out;
    }

    .milestone-description p {
        font-size: 0.875rem;
        font-style: italic;
        color: #666;
        margin-bottom: 0;
    }

    .card-footer {
        padding: 0.75rem 1rem;
    }

    .milestone-toggle-btn {
        font-size: 0.875rem;
        padding: 0.375rem 0.75rem;
        text-decoration: none;
    }

    .milestone-toggle-btn:hover {
        background-color: #e9ecef;
    }

    @media (max-width: 1919px) {
        .milestone-timeline {
            overflow-x: auto;
        }
    }

    @media print {
        .milestone-card {
            page-break-inside: avoid;
            border: 1px solid #000;
            margin-bottom: 0.5rem;
            background-color: white !important;
        }

        .milestone-toggle-btn {
            display: none !important;
        }

        .milestone-description {
            display: block !important;
            max-height: none !important;
            border-top: 1px solid #000;
            margin-top: 0.5rem;
            padding-top: 0.5rem;
        }

        .card-title {
            font-size: 12pt;
        }

        .card-text {
            font-size: 11pt;
        }

        .milestone-description p {
            font-size: 10pt;
        }

        .badge {
            font-size: 10pt;
            padding: 0.25rem 0.5rem;
        }

        .card-footer {
            display: none;
        }
    }
</style>

@code {
    [CascadingParameter]
    public IEnumerable<Milestone> Milestones { get; set; }

    [Inject]
    private MilestoneCalculations MilestoneCalcs { get; set; }

    private List<MilestoneViewModel> ProcessedMilestones { get; set; } = new();
    private Dictionary<string, bool> isExpanded { get; set; } = new();

    protected override void OnParametersSet()
    {
        ProcessedMilestones = TransformAndSortMilestones();
        InitializeExpandedState();
    }

    private void InitializeExpandedState()
    {
        isExpanded.Clear();
        foreach (var milestone in ProcessedMilestones)
        {
            if (!isExpanded.ContainsKey(milestone.Id))
            {
                isExpanded[milestone.Id] = false;
            }
        }
    }

    private void ToggleDetails(string milestoneId)
    {
        if (isExpanded.ContainsKey(milestoneId))
        {
            isExpanded[milestoneId] = !isExpanded[milestoneId];
        }
        else
        {
            isExpanded[milestoneId] = true;
        }
    }

    private List<MilestoneViewModel> TransformAndSortMilestones()
    {
        if (Milestones == null || !Milestones.Any())
        {
            return new List<MilestoneViewModel>();
        }

        var viewModels = Milestones.Select(milestone => new MilestoneViewModel
        {
            Id = milestone.Id,
            Name = milestone.Name,
            Date = milestone.Date,
            Status = ResolveStatus(milestone),
            Description = milestone.Description,
            DaysRemaining = CalculateDaysRemaining(milestone.Date),
            IsOverdue = IsOverdueDate(milestone.Date),
            StatusLabel = ResolveStatusLabel(milestone),
            StatusCssClass = ResolveCssClass(milestone)
        }).ToList();

        // Sort chronologically by date (earliest to latest)
        return viewModels.OrderBy(m => m.Date).ToList();
    }

    private int CalculateDaysRemaining(DateTime targetDate)
    {
        return (int)Math.Round((targetDate - DateTime.UtcNow).TotalDays);
    }

    private bool IsOverdueDate(DateTime targetDate)
    {
        return targetDate < DateTime.UtcNow;
    }

    private MilestoneStatus ResolveStatus(Milestone milestone)
    {
        var daysRemaining = CalculateDaysRemaining(milestone.Date);
        
        // If milestone is 3+ days overdue, flag as AtRisk
        if (daysRemaining <= -3)
        {
            return MilestoneStatus.AtRisk;
        }

        return milestone.Status;
    }

    private string ResolveStatusLabel(Milestone milestone)
    {
        var daysRemaining = CalculateDaysRemaining(milestone.Date);
        var resolvedStatus = ResolveStatus(milestone);
        
        return resolvedStatus switch
        {
            MilestoneStatus.Completed => "Completed",
            MilestoneStatus.InProgress => "In Progress",
            MilestoneStatus.Planned => "Planned",
            MilestoneStatus.AtRisk => "At Risk",
            _ => "Unknown"
        };
    }

    private string ResolveCssClass(Milestone milestone)
    {
        var resolvedStatus = ResolveStatus(milestone);
        
        return resolvedStatus switch
        {
            MilestoneStatus.Completed => "status-completed",
            MilestoneStatus.InProgress => "status-inprogress",
            MilestoneStatus.Planned => "status-planned",
            MilestoneStatus.AtRisk => "status-atrisk",
            _ => "status-unknown"
        };
    }

    private string GetBadgeClass(string statusCssClass)
    {
        return $"badge {statusCssClass}";
    }

    private string GetDaysRemainingText(int daysRemaining)
    {
        return daysRemaining switch
        {
            0 => "Due today",
            < 0 => $"{Math.Abs(daysRemaining)} {(Math.Abs(daysRemaining) == 1 ? "day" : "days")} overdue",
            _ => "Unknown"
        };
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }

    private class MilestoneViewModel
    {
        public string Id { get; set; }
        public string Name { get; set; }
        public DateTime Date { get; set; }
        public MilestoneStatus Status { get; set; }
        public string Description { get; set; }
        public int DaysRemaining { get; set; }
        public bool IsOverdue { get; set; }
        public string StatusLabel { get; set; }
        public string StatusCssClass { get; set; }
    }
}