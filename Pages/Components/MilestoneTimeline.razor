@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services

<div class="milestone-timeline-container">
    @if (ProcessedMilestones == null)
    {
        <div class="alert alert-info" role="alert">
            Loading milestones...
        </div>
    }
    else if (!ProcessedMilestones.Any())
    {
        <div class="alert alert-warning" role="alert">
            No milestones available.
        </div>
    }
    else
    {
        <div class="milestone-list">
            @foreach (var milestone in ProcessedMilestones)
            {
                <div class="milestone-card card mb-3 border-start border-4" style="border-color: @GetBorderColor(milestone)">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <h5 class="card-title mb-2">@milestone.Name</h5>
                                <p class="card-text text-muted mb-0">
                                    <small>Target: @milestone.Date.ToString("ddd, MMM d, yyyy")</small>
                                </p>
                            </div>

                            <div class="col-md-3 text-center">
                                <span class="@milestone.CssClasses">@milestone.StatusLabel</span>
                            </div>

                            <div class="col-md-3 text-end">
                                <div class="days-remaining-counter">
                                    @if (milestone.IsOverdue)
                                    {
                                        <span class="badge badge-danger fs-6">
                                            @Math.Abs((int)Math.Floor(milestone.DaysRemaining)) days overdue
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success fs-6">
                                            @Math.Floor(milestone.DaysRemaining) days remaining
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Expandable Details Section -->
                        <div class="mt-3">
                            <button class="btn btn-sm btn-outline-secondary details-toggle" 
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#details-@milestone.Id"
                                    aria-expanded="false"
                                    aria-controls="details-@milestone.Id"
                                    @onclick="@(() => ToggleDetails(milestone.Id))">
                                @if (IsExpanded(milestone.Id))
                                {
                                    <span>▼ Hide Details</span>
                                }
                                else
                                {
                                    <span>▶ View Details</span>
                                }
                            </button>
                        </div>

                        <!-- Collapsible Details Panel -->
                        <div class="collapse mt-3" id="details-@milestone.Id">
                            <div class="card card-body bg-light border-0">
                                @if (!string.IsNullOrWhiteSpace(milestone.Description))
                                {
                                    <div class="mb-3">
                                        <h6 class="fw-bold text-dark">Description</h6>
                                        <p class="card-text">@milestone.Description</p>
                                    </div>
                                }

                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="fw-bold text-dark">Target Date</h6>
                                        <p class="card-text">
                                            <small>
                                                @milestone.Date.ToString("dddd, MMMM d, yyyy")
                                                <br />
                                                <span class="text-muted">@milestone.Date.ToString("h:mm tt z")</span>
                                            </small>
                                        </p>
                                    </div>

                                    <div class="col-md-6">
                                        <h6 class="fw-bold text-dark">Status</h6>
                                        <p class="card-text">
                                            <small>
                                                <strong>Enum Value:</strong> @milestone.Status<br />
                                                <strong>Display Label:</strong> @milestone.StatusLabel
                                            </small>
                                        </p>
                                    </div>
                                </div>

                                @if (milestone.IsOverdue)
                                {
                                    <div class="alert alert-warning mt-3 mb-0" role="alert">
                                        <small>
                                            <strong>⚠ Overdue:</strong> This milestone is @Math.Abs((int)Math.Floor(milestone.DaysRemaining)) days overdue.
                                        </small>
                                    </div>
                                }
                                else if (milestone.DaysRemaining <= 7)
                                {
                                    <div class="alert alert-info mt-3 mb-0" role="alert">
                                        <small>
                                            <strong>ℹ Approaching:</strong> This milestone is coming up in @Math.Floor(milestone.DaysRemaining) days.
                                        </small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .milestone-timeline-container {
        width: 100%;
        overflow-x: hidden;
    }

    .milestone-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .milestone-card {
        background-color: #fff;
        border-radius: 0.375rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        transition: box-shadow 0.2s ease-in-out;
    }

    .milestone-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .milestone-card .card-body {
        padding: 1.25rem;
    }

    .milestone-card .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #212529;
    }

    .days-remaining-counter {
        display: inline-flex;
        white-space: nowrap;
    }

    .days-remaining-counter .badge {
        font-size: 0.875rem;
        padding: 0.5rem 0.75rem;
    }

    .details-toggle {
        font-size: 0.875rem;
        padding: 0.4rem 0.75rem;
        transition: all 0.2s ease-in-out;
    }

    .details-toggle:hover {
        background-color: #6c757d;
        color: white;
        border-color: #6c757d;
    }

    .details-toggle:focus {
        box-shadow: 0 0 0 0.25rem rgba(108, 117, 125, 0.25);
    }

    .milestone-card .collapse {
        animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .milestone-card .bg-light {
        background-color: #f8f9fa !important;
    }

    .milestone-card .fw-bold {
        font-weight: 600 !important;
    }

    .milestone-card .text-dark {
        color: #212529 !important;
    }

    /* Responsive adjustments for smaller screens */
    @media (max-width: 768px) {
        .milestone-card .row {
            flex-direction: column;
            align-items: flex-start !important;
        }

        .milestone-card .col-md-3,
        .milestone-card .col-md-6 {
            width: 100%;
            margin-bottom: 0.75rem;
        }

        .milestone-card .col-md-3.text-end {
            text-align: left !important;
        }

        .milestone-card .card-title {
            margin-bottom: 0.5rem;
        }

        .details-toggle {
            width: 100%;
            text-align: left;
        }
    }

    /* Print styles - hide toggle button and show all details */
    @media print {
        .details-toggle {
            display: none !important;
        }

        .milestone-card .collapse {
            display: block !important;
        }

        .milestone-card {
            page-break-inside: avoid;
            margin-bottom: 1.5rem;
        }

        .milestone-card .card-body {
            padding: 1rem;
        }

        .alert {
            border: 1px solid #ccc;
            page-break-inside: avoid;
        }
    }

    /* Ensure no horizontal scrolling at 1920px */
    @media (min-width: 1920px) {
        .milestone-timeline-container {
            max-width: 100%;
        }

        .milestone-card {
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .milestone-card .card-title {
            word-break: break-word;
        }
    }
</style>

@code {
    /// <summary>
    /// Cascading parameter containing milestone data from parent component.
    /// </summary>
    [CascadingParameter]
    public IEnumerable<Milestone> Milestones { get; set; }

    /// <summary>
    /// Processed milestones with calculated properties, sorted chronologically.
    /// </summary>
    private List<MilestoneViewModel> ProcessedMilestones { get; set; }

    /// <summary>
    /// Tracks expanded/collapsed state per milestone by Id.
    /// </summary>
    private Dictionary<string, bool> ExpandedStates { get; set; } = new();

    /// <summary>
    /// Initializes component: sorts milestones chronologically and transforms to view models.
    /// </summary>
    protected override void OnInitialized()
    {
        if (Milestones != null && Milestones.Any())
        {
            // Transform milestones to view models and sort chronologically (earliest to latest)
            ProcessedMilestones = Milestones
                .Select(m => MilestoneCalculations.CalculateMilestoneViewModel(m))
                .OrderBy(vm => vm.Date)
                .ToList();

            // Initialize expanded state tracking
            foreach (var milestone in ProcessedMilestones)
            {
                ExpandedStates[milestone.Id] = false;
            }
        }
        else
        {
            ProcessedMilestones = new List<MilestoneViewModel>();
        }
    }

    /// <summary>
    /// Determines border color for milestone card based on status.
    /// Green (success) for completed, yellow (warning) for in progress,
    /// red (danger) for at risk, gray (secondary) for planned.
    /// </summary>
    /// <param name="milestone">The milestone view model.</param>
    /// <returns>Hex color code for the border.</returns>
    private string GetBorderColor(MilestoneViewModel milestone)
    {
        return milestone.CssClasses switch
        {
            string css when css.Contains("badge-success") => "#198754",   // Bootstrap success green
            string css when css.Contains("badge-warning") => "#ffc107",   // Bootstrap warning yellow
            string css when css.Contains("badge-danger") => "#dc3545",    // Bootstrap danger red
            _ => "#6c757d"                                                // Bootstrap secondary gray
        };
    }

    /// <summary>
    /// Toggles the expanded state of a milestone details section.
    /// </summary>
    /// <param name="milestoneId">The milestone ID to toggle.</param>
    private void ToggleDetails(string milestoneId)
    {
        if (ExpandedStates.ContainsKey(milestoneId))
        {
            ExpandedStates[milestoneId] = !ExpandedStates[milestoneId];
        }
    }

    /// <summary>
    /// Determines if a milestone's details section is expanded.
    /// </summary>
    /// <param name="milestoneId">The milestone ID to check.</param>
    /// <returns>True if expanded, false otherwise.</returns>
    private bool IsExpanded(string milestoneId)
    {
        return ExpandedStates.TryGetValue(milestoneId, out var expanded) && expanded;
    }
}