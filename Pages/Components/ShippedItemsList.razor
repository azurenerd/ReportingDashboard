@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@using System.Collections.Generic
@using System.Linq

<div class="shipped-items-container">
    <h3>Shipped Items</h3>
    
    @if (ProcessedItems == null || !ProcessedItems.Any())
    {
        <p class="text-muted">No shipped items to display.</p>
    }
    else
    {
        <div class="table-responsive shipped-table-wrapper">
            <table class="table table-hover shipped-table">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%;">Title</th>
                        <th style="width: 30%;">Description</th>
                        <th style="width: 15%;">Milestone</th>
                        <th style="width: 15%;">Owner</th>
                        <th style="width: 15%;">Completion Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ProcessedItems)
                    {
                        <tr class="@item.RowCssClass">
                            <td class="align-middle">@item.Title</td>
                            <td class="align-middle text-truncate" title="@item.Description">@item.Description</td>
                            <td class="align-middle">@item.MilestoneName</td>
                            <td class="align-middle">@item.Owner</td>
                            <td class="align-middle">@(item.CompletionDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .shipped-items-container {
        padding: 1rem;
    }

    .shipped-table-wrapper {
        max-width: 100%;
    }

    .row-even {
        background-color: #ffffff;
    }

    .row-odd {
        background-color: #f8f9fa;
    }

    .shipped-table tbody tr:hover {
        background-color: #e9ecef !important;
        cursor: pointer;
    }

    .text-truncate {
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @media (max-width: 768px) {
        .shipped-items-container {
            padding: 0.5rem;
        }

        .shipped-table {
            font-size: 0.875rem;
        }

        .shipped-table thead th:nth-child(2) {
            display: none;
        }

        .shipped-table tbody td:nth-child(2) {
            display: none;
        }

        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
    }

    @media (min-width: 1920px) {
        .shipped-table-wrapper {
            max-width: 100%;
            overflow-x: hidden;
        }

        .shipped-table {
            table-layout: fixed;
        }

        .shipped-table td {
            word-break: break-word;
        }
    }

    @media print {
        .shipped-items-container {
            padding: 0;
            margin: 0;
        }

        .shipped-table-wrapper {
            max-width: 100%;
            overflow: visible;
        }

        .shipped-table {
            font-size: 11pt !important;
            border-collapse: collapse;
            width: 100%;
        }

        .shipped-table thead {
            display: table-header-group;
        }

        .shipped-table tbody tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        .shipped-table tbody tr td {
            padding: 0.75rem !important;
            border: 1px solid #333;
        }

        .shipped-table tbody tr:hover {
            background-color: transparent !important;
        }

        .row-even,
        .row-odd {
            background-color: transparent !important;
        }

        .text-truncate {
            white-space: normal !important;
            overflow: visible !important;
            text-overflow: clip !important;
        }

        h3 {
            page-break-after: avoid;
            margin-top: 0;
        }
    }
</style>

@code {
    [CascadingParameter]
    public IEnumerable<WorkItem> Items { get; set; }

    [CascadingParameter]
    public IEnumerable<Milestone> Milestones { get; set; }

    private List<WorkItemViewModel> ProcessedItems = new();

    protected override void OnInitialized()
    {
        if (Items == null || Milestones == null)
        {
            ProcessedItems = new List<WorkItemViewModel>();
            return;
        }

        try
        {
            var allViewModels = WorkItemCalculations.MapWorkItemViewModels(Items, Milestones);
            
            ProcessedItems = allViewModels
                .OrderByDescending(x => x.CompletionDate ?? DateTime.MinValue)
                .ToList();
        }
        catch (ArgumentNullException)
        {
            ProcessedItems = new List<WorkItemViewModel>();
        }
    }
}