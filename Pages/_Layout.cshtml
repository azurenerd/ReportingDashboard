@using Microsoft.AspNetCore.Components.Web
@namespace AgentSquad.Runner.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" integrity="sha384-9ndCyUaIbzAi2FUarbnLYV4Ll8l8z3+tfeQvkRLBSoTLlnrfIyIWvvBarY5URe1r" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVJkEZSMUkrQ6usKu8zTlHdWAucqNoU+7i5E56KwswNJ8Z7p4G1scc+9RLwQkgK+5t4+fBg6s0" crossorigin="anonymous">
    <link rel="stylesheet" href="css/dashboard.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <component type="typeof(HeadOutlet)" render-mode="InteractiveServer" />
</head>
<body>
    <component type="typeof(Routes)" render-mode="InteractiveServer" />

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" integrity="sha384-eNQYcFEF6XMVfQxeZQ4DWS2rM0aG3SIAhZZ40+G3JSg/YAdM8UKo+2r60VARhnGM" crossorigin="anonymous"></script>
    <script src="js/chart-interop.js"></script>
</body>
</html>