@page "/"
@using AgentSquad.Runner.Interfaces
@using AgentSquad.Runner.Models
@using Microsoft.Extensions.Logging

@inject IDataLoaderService DataLoaderService
@inject IDataWatcherService DataWatcherService
@inject IDataValidator DataValidator
@inject ILogger<Index> Logger

<div class="dashboard-container">
    @if (isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading dashboard data...</span>
            </div>
        </div>
    }
    else if (validationResult?.IsValid == false && validationResult.Errors?.Count > 0)
    {
        <div class="error-banner">
            <h4>⚠️ Data Validation Error</h4>
            <p>The dashboard could not load due to the following errors:</p>
            <ul>
                @foreach (var error in validationResult.Errors)
                {
                    <li><strong>@error.Field:</strong> @error.Message</li>
                }
            </ul>
            <p style="margin-top: 1rem; font-size: 0.875rem;">
                Please fix the errors in <code>data.json</code> and save the file. The dashboard will refresh automatically.
            </p>
        </div>
    }
    else if (currentReport != null)
    {
        <ProjectMetadata 
            ProjectName="@currentReport.ProjectName" 
            ReportingPeriod="@currentReport.ReportingPeriod" 
            Kpis="@currentReport.Kpis" />

        <div class="timeline-section">
            <h5>Project Timeline</h5>
            <MilestoneTimeline 
                Milestones="@currentReport.Milestones" />
        </div>

        <div class="status-section">
            <h5>Delivery Status</h5>
            <StatusSnapshot 
                CurrentStatus="@currentReport.StatusSnapshot" />
        </div>

        <div class="refresh-indicator">
            @if (!string.IsNullOrEmpty(dataWatcherService?.LastRefreshTimeFormatted))
            {
                <small>Last updated: <span class="refresh-timestamp">@dataWatcherService.LastRefreshTimeFormatted</span></small>
            }
            else
            {
                <small class="text-muted">Data loaded at startup</small>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h4>Dashboard Initializing</h4>
            <p>Please wait while the dashboard loads data...</p>
        </div>
    }
</div>

@code {
    private ProjectReport currentReport;
    private ValidationResult validationResult = new();
    private bool isLoading = true;
    private IDataWatcherService dataWatcherService;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            dataWatcherService = DataWatcherService;

            // TODO: Implement data loading and watcher subscription:
            // 1. Load initial project data from data.json via DataLoaderService.LoadAsync()
            // 2. Validate loaded data via DataValidator.Validate()
            // 3. Subscribe to DataWatcherService.OnDataChanged event
            // 4. Start file monitoring via DataWatcherService.Start()
            // 5. Handle refresh events by reloading and re-validating data
            // 6. Update component state variables (currentReport, validationResult, isLoading)
            // 7. Call StateHasChanged() to trigger re-render
            //
            // For now, this scaffold displays placeholder UI only.
            // Implementation in next phase will:
            // - Catch FileNotFoundException if data.json not found
            // - Catch JsonException if JSON is malformed
            // - Display error banner with user-friendly guidance
            // - Keep last-known-good data in memory during file access errors
            // - Log all operations to browser console at INFO level

            Logger.LogInformation("Index.razor component initialized (scaffold phase)");
            
            // Placeholder: Set isLoading to false to show placeholder UI
            isLoading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError($"Failed to initialize dashboard: {ex.Message}");
            isLoading = false;
            validationResult = new ValidationResult
            {
                IsValid = false,
                Errors = new()
                {
                    new ValidationError
                    {
                        Field = "initialization",
                        Message = $"Failed to load dashboard: {ex.Message}"
                    }
                }
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // TODO: Implement chart initialization on first render
