        // - Call IJSRuntime.InvokeAsync("initMilestoneChart", config)
        // - JavaScript will initialize Chart.js with milestone data
        // - Color-code by status (green/yellow/red/gray)
        // - Ensure responsive layout for 1080p and 1440p
        
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task HandleDataChanged()
    {
        // TODO: Implement file watcher event handler
        // Called when DataWatcherService detects data.json change after debounce period
        // Steps:
        // 1. Set isLoading = true to show spinner
        // 2. Reload JSON via DataLoaderService.LoadAsync()
        // 3. Validate via DataValidator.Validate()
        // 4. Update currentReport and validationResult state
        // 5. Update lastRefreshTime from DataWatcherService.LastRefreshTime
        // 6. Call StateHasChanged() to trigger re-render
        // 7. Set isLoading = false
        
        Logger.LogInformation("Data changed event triggered (placeholder)");
    }

    public async ValueTask DisposeAsync()
    {
        // TODO: Implement cleanup on component destroy
        // - Unsubscribe from DataWatcherService.OnDataChanged event
        // - Call DataWatcherService.Stop() to halt file monitoring
        // - Dispose of FileSystemWatcher resources
        
        try
        {
            if (dataWatcherService != null)
            {
                dataWatcherService.Stop();
                if (dataWatcherService is IAsyncDisposable asyncDisposable)
                {
                    await asyncDisposable.DisposeAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning($"Error during watcher cleanup: {ex.Message}");
        }
    }
}

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .timeline-section,
    .status-section {
        margin-top: 2rem;
        page-break-inside: avoid;
    }

    .timeline-section h5,
    .status-section h5 {
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1.5rem;
    }

    .refresh-indicator {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #dee2e6;
        font-size: 0.875rem;
        color: #6c757d;
    }

    .loading-spinner {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
    }

    .alert {
        padding: 1rem;
        border-radius: 6px;
        margin: 2rem 0;
    }

    .alert-warning {
        background-color: #fff3cd;
        border: 1px solid #ffc107;
        color: #664d03;
    }

    .alert h4 {
        margin: 0 0 0.5rem 0;
        color: #664d03;
    }

    .alert p {
        margin: 0;
    }
</style>