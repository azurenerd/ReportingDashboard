@page "/"
@inject DataService DataService
@implements IAsyncDisposable

<div class="dashboard-container">
    <CascadingValue Value="CurrentData">
        <Header />
        <StatusSummary />
        <div class="dashboard-grid">
            <!-- Placeholder for MilestoneTimeline - implemented in Step 2 -->
            <div class="milestone-timeline-placeholder">Timeline visualization will be added in Step 2</div>
            
            <!-- Placeholder for MetricsContainer - implemented in Step 4 -->
            <div class="metrics-container-placeholder">Metrics cards will be added in Step 4</div>
        </div>
        <!-- Placeholder for DataRefreshIndicator - implemented in Step 2 -->
        <div class="data-refresh-indicator-placeholder no-print">Refresh indicator will be added in Step 2</div>
    </CascadingValue>
</div>

@code {
    private DashboardData CurrentData;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await DataService.InitializeAsync();
            CurrentData = DataService.CurrentData;
            
            DataService.OnDataChanged += HandleDataChanged;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Dashboard initialization error: {ex.Message}");
            CurrentData = new DashboardData 
            { 
                ProjectName = "Dashboard",
                ProjectStatus = "Unknown",
                LastUpdated = DateTime.UtcNow
            };
        }
    }

    private async Task HandleDataChanged()
    {
        try
        {
            CurrentData = await DataService.ReloadDataAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Dashboard data refresh error: {ex.Message}");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (DataService != null)
        {
            DataService.OnDataChanged -= HandleDataChanged;
        }
    }
}