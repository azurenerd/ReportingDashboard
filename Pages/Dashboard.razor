@page "/"
@using AgentSquad.Runner.Models
@using AgentSquad.Runner.Services
@inject ProjectDataService ProjectDataService

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="alert alert-info" role="alert">
            <div class="spinner-border spinner-border-sm me-2" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            Loading project data...
        </div>
    }
    else if (ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error Loading Dashboard</strong>
            <p>@ErrorMessage</p>
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
        </div>
    }
    else if (ProjectData != null)
    {
        <header class="dashboard-header mb-4">
            <h1 class="display-4 fw-bold">@ProjectData.ProjectName</h1>
            <p class="text-muted">Last updated: @DateTime.Now:g</p>
        </header>

        <section class="timeline-section mb-5">
            <MilestoneTimeline Milestones="ProjectData.Milestones" />
        </section>

        <section class="status-cards-section mb-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <StatusCard StatusCategory="Shipped" Tasks="GetTasksByStatus(\"Shipped\")" />
                </div>
                <div class="col-md-4">
                    <StatusCard StatusCategory="InProgress" Tasks="GetTasksByStatus(\"InProgress\")" />
                </div>
                <div class="col-md-4">
                    <StatusCard StatusCategory="CarriedOver" Tasks="GetTasksByStatus(\"CarriedOver\")" />
                </div>
            </div>
        </section>

        <section class="metrics-section">
            <ProgressMetrics ProjectData="ProjectData" />
        </section>
    }
</div>

@code {
    private ProjectData ProjectData;
    private string ErrorMessage;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ProjectData = await ProjectDataService.LoadProjectDataAsync();
            IsLoading = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load dashboard: {ex.Message}";
            IsLoading = false;
        }
    }

    private List<ProjectTask> GetTasksByStatus(string status)
    {
        return ProjectData?.Tasks?.Where(t => t.Status == status).ToList() ?? new();
    }
}