@page "/"
@using System.Collections.Generic

<div class="container-fluid full-width dashboard-container">
    <!-- Page Title Section -->
    <div class="row section-spacing-bottom">
        <div class="col-12">
            <h1 class="fs-1 mb-0">Executive Dashboard</h1>
        </div>
    </div>

    <!-- Milestone Timeline Section - Full Width Responsive -->
    <div class="row section-spacing">
        <div class="col-12">
            <div class="dashboard-section">
                <h2 class="dashboard-section-title fs-2 mb-0">Project Milestones</h2>
                <div class="timeline-container component-gutter">
                    <div class="timeline">
                        <div class="timeline-item">
                            <div class="timeline-marker completed">✓</div>
                            <div class="timeline-label">Phase 1</div>
                            <div class="timeline-date">Jan 15, 2026</div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-marker in-progress">◐</div>
                            <div class="timeline-label">Phase 2</div>
                            <div class="timeline-date">Apr 01, 2026</div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-marker pending">◯</div>
                            <div class="timeline-label">Phase 3</div>
                            <div class="timeline-date">Jun 30, 2026</div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-marker pending">◯</div>
                            <div class="timeline-label">Phase 4</div>
                            <div class="timeline-date">Sep 15, 2026</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Cards Section - Responsive Grid (1 col mobile, 2 col tablet, 3 col desktop) -->
    <div class="row section-spacing">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="status-card shipped">
                <h4 class="status-card-title fs-4 mb-0">Shipped</h4>
                <div class="status-card-count">12</div>
                <ul class="status-card-list component-gutter-y">
                    <li class="status-card-item">Dashboard UI</li>
                    <li class="status-card-item">Data Load Service</li>
                    <li class="status-card-item">Error Handling</li>
                </ul>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="status-card in-progress">
                <h4 class="status-card-title fs-4 mb-0">In Progress</h4>
                <div class="status-card-count">5</div>
                <ul class="status-card-list component-gutter-y">
                    <li class="status-card-item">Timeline Component</li>
                    <li class="status-card-item">Progress Metrics</li>
                    <li class="status-card-item">Responsive Grid</li>
                </ul>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="status-card carried-over">
                <h4 class="status-card-title fs-4 mb-0">Carried Over</h4>
                <div class="status-card-count">2</div>
                <ul class="status-card-list component-gutter-y">
                    <li class="status-card-item">Advanced Analytics</li>
                    <li class="status-card-item">Multi-Project Support</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Progress Metrics Section - Full Width Responsive -->
    <div class="row section-spacing">
        <div class="col-12">
            <div class="dashboard-section">
                <h2 class="dashboard-section-title fs-2 mb-0">Progress Metrics</h2>
                <div class="metrics-row">
                    <div class="metric-card">
                        <div class="metric-label">Overall Completion</div>
                        <div class="metric-value">68%</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Tasks Completed</div>
                        <div class="metric-value">17</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">On-Time Delivery</div>
                        <div class="metric-value">89%</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Resource Utilization</div>
                        <div class="metric-value">92%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Dashboard initialization logic complete
        // Bootstrap 5 responsive grid styling fully integrated
        // Typography scale established with 12pt minimum readability
        // Spacing hierarchy consistently applied
        // Media queries configured for 768px, 1024px, 1440px, 1920px breakpoints
        // Status cards collapse/expand: 1 col (mobile) → 2 col (tablet) → 3 col (desktop)
        // MilestoneTimeline and ProgressMetrics full-width responsive without overflow
        // No CSS animations/transitions for deterministic screenshot rendering
        // Page renders without layout shifts during load
    }
}