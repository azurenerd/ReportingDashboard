@page "/dashboard"
@using AgentSquad.Runner.Data
@using AgentSquad.Runner.Services
@inject ProjectDataService DataService
@inject ILogger<Dashboard> Logger
@rendermode InteractiveServer

<div class="container-fluid py-4">
    @if (IsLoading)
    {
        <div class="row justify-content-center mt-5">
            <div class="col-12 text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Loading project dashboard...</p>
            </div>
        </div>
    }
    @if (ErrorMessage != null)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">Error Loading Dashboard</h4>
                    <p>@ErrorMessage</p>
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ReloadData">
                        <span>🔄 Refresh Data</span>
                    </button>
                    <button type="button" class="btn-close" @onclick="DismissError" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }
    @if (ProjectData != null)
    {
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1 class="display-5 mb-2">@ProjectData.Project.Name</h1>
                        <p class="lead text-muted">@ProjectData.Project.Description</p>
                        <div class="row g-3">
                            <div class="col-auto">
                                <small class="text-muted">
                                    <strong>Sponsor:</strong> @ProjectData.Project.Sponsor
                                </small>
                            </div>
                            <div class="col-auto">
                                <small class="text-muted">
                                    <strong>PM:</strong> @ProjectData.Project.ProjectManager
                                </small>
                            </div>
                            <div class="col-auto">
                                <span class="badge bg-@GetStatusBadgeClass(ProjectData.Project.Status)">
                                    @ProjectData.Project.Status
                                </span>
                            </div>
                            <div class="col-auto">
                                <small class="text-muted d-block">
                                    Last updated: @LastLoadTime.ToString("g")
                                </small>
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadData" title="Refresh data from data.json">
                        <span>🔄 Sync</span>
                    </button>
                </div>
                <hr class="my-4" />
            </div>
        </div>

        <!-- Timeline Section -->
        <div class="row mb-5">
            <div class="col-12">
                <MilestoneTimeline 
                    Milestones="ProjectData.Milestones"
                    ProjectStartDate="ProjectData.Project.StartDate"
                    ProjectEndDate="ProjectData.Project.EndDate" />
            </div>
        </div>

        <!-- Status Cards Section -->
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="mb-4">Task Status</h2>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <StatusCard 
                    StatusCategory="Shipped"
                    TaskCount="ShippedTaskCount"
                    Tasks="GetTasksByStatus(TaskStatus.Shipped)"
                    CardColor="success" />
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <StatusCard 
                    StatusCategory="In-Progress"
                    TaskCount="InProgressTaskCount"
                    Tasks="GetTasksByStatus(TaskStatus.InProgress)"
                    CardColor="info" />
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <StatusCard 
                    StatusCategory="Carried-Over"
                    TaskCount="CarriedOverTaskCount"
                    Tasks="GetTasksByStatus(TaskStatus.CarriedOver)"
                    CardColor="warning" />
            </div>
        </div>

        <!-- Metrics Section -->
        <div class="row">
            <div class="col-12">
                <ProgressMetrics 
                    CompletionPercentage="ProjectData.Metrics.CompletionPercentage"
                    CompletedTasks="ProjectData.Metrics.CompletedTasks"
                    TotalTasks="ProjectData.Metrics.TotalTasks"
                    BurndownRate="ProjectData.Metrics.EstimatedBurndownRate" />
            </div>
        </div>
    }
</div>

@code {
    private ProjectData ProjectData;
    private string ErrorMessage;
    private bool IsLoading = true;
    private DateTime LastLoadTime = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private async Task LoadProjectData()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            ProjectData = await DataService.LoadProjectDataAsync("data/data.json");
            LastLoadTime = DateTime.Now;
            StateHasChanged();
        }
        catch (DataLoadException ex)
        {
            Logger.LogError(ex, "Failed to load project data");
            ErrorMessage = ex.Message;
            ProjectData = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error loading project data");
            ErrorMessage = "An unexpected error occurred while loading the dashboard. Please try again.";
            ProjectData = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ReloadData()
    {
        await LoadProjectData();
    }

    private void DismissError()
    {
        ErrorMessage = null;
    }

    private int ShippedTaskCount => ProjectData?.Metrics.CompletedTasks ?? 0;
    private int InProgressTaskCount => ProjectData?.Metrics.InProgressTasks ?? 0;
    private int CarriedOverTaskCount => ProjectData?.Metrics.CarriedOverTasks ?? 0;

    private List<ProjectTask> GetTasksByStatus(TaskStatus status)
    {
        return ProjectData?.Tasks.Where(t => t.Status == status).ToList() ?? new List<ProjectTask>();
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "OnTrack" => "success",
            "AtRisk" => "warning",
            "Delayed" => "danger",
            _ => "secondary"
        };
    }
}