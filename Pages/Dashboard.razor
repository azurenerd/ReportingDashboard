@page "/"
@using AgentSquad.Models;
@using AgentSquad.Services;
@using System.Linq;
@inject ProjectDataService ProjectDataService

<ErrorBoundary>
    <ChildContent>
        <div class="container-fluid py-4">
            <div class="row mb-4">
                <div class="col-12">
                    <h1 class="display-4 fw-bold">Project Dashboard</h1>
                </div>
            </div>

            @if (ProjectData != null)
            {
                <div class="row mb-4">
                    <div class="col-12">
                        <MilestoneTimeline Milestones="ProjectData.Milestones" 
                                         ProjectDurationDays="CalculateProjectDays()" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <StatusCard StatusCategory="Shipped" 
                                   TaskCount="GetShippedTasks().Count" 
                                   Tasks="GetShippedTasks()" 
                                   CardColor="green" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <StatusCard StatusCategory="In-Progress" 
                                   TaskCount="GetInProgressTasks().Count" 
                                   Tasks="GetInProgressTasks()" 
                                   CardColor="blue" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <StatusCard StatusCategory="Carried-Over" 
                                   TaskCount="GetCarriedOverTasks().Count" 
                                   Tasks="GetCarriedOverTasks()" 
                                   CardColor="orange" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <ProgressMetrics ProjectData="ProjectData" />
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">Loading project data...</div>
            }
        </div>
    </ChildContent>
    <ErrorContent>
        <div class="container-fluid py-4">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">An error occurred</h4>
                <p>The dashboard encountered an error while rendering. Please refresh the page and try again.</p>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private ProjectData ProjectData;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ProjectData = await ProjectDataService.LoadProjectDataAsync();
        }
        catch (Exception ex)
        {
            throw;
        }
    }

    private int CalculateProjectDays()
    {
        if (ProjectData?.ProjectEndDate != null && ProjectData?.ProjectStartDate != null)
        {
            return (int)(ProjectData.ProjectEndDate - ProjectData.ProjectStartDate).TotalDays;
        }
        return 0;
    }

    private List<Task> GetShippedTasks()
    {
        return ProjectData?.Tasks?.Where(t => t.Status == "Shipped").ToList() ?? new List<Task>();
    }

    private List<Task> GetInProgressTasks()
    {
        return ProjectData?.Tasks?.Where(t => t.Status == "InProgress").ToList() ?? new List<Task>();
    }

    private List<Task> GetCarriedOverTasks()
    {
        return ProjectData?.Tasks?.Where(t => t.Status == "CarriedOver").ToList() ?? new List<Task>();
    }
}