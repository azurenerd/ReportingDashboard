@page "/dashboard"
@using AgentSquad.Dashboard.Models
@using AgentSquad.Dashboard.Services
@implements IAsyncDisposable

<ErrorBoundary>
    <ChildContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <strong>Error Loading Dashboard:</strong> @errorMessage
            </div>
        }
        else if (projectData == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <!-- Dashboard sections will be rendered here in subsequent steps -->
            <div class="container-fluid">
                <p>Dashboard content loading...</p>
            </div>
        }
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger" role="alert">
            <strong>Unexpected Error:</strong> @ex.Message
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private ProjectData projectData;
    private string errorMessage;

    [Inject]
    private ProjectDataService ProjectDataService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projectData = await ProjectDataService.LoadProjectDataAsync();
            errorMessage = null;
        }
        catch (JsonException jex)
        {
            errorMessage = $"Invalid project data format: {jex.Message}";
            projectData = null;
        }
        catch (FileNotFoundException fnex)
        {
            errorMessage = $"Project data file not found: {fnex.Message}";
            projectData = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load project data: {ex.Message}";
            projectData = null;
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }
}