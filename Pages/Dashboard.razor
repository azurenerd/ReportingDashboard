@page "/dashboard"
@using AgentSquad.Dashboard.Models
@using AgentSquad.Dashboard.Services
@using System.Text.Json
@implements IAsyncDisposable

<ErrorBoundary>
    <ChildContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <strong>Error Loading Dashboard:</strong> @errorMessage
            </div>
        }
        else if (projectData == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="container-fluid" style="padding: 30px;">
                <!-- Page Header Section -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div style="padding: 20px; background-color: #f8f9fa; border-left: 5px solid #0066cc; font-size: 16px;">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h1 style="margin: 0; font-size: 32px; font-weight: bold; color: #333;">@projectData.ProjectName</h1>
                                    <div style="margin-top: 12px; color: #666;">
                                        <p style="margin: 4px 0; font-size: 13px;"><strong>Sponsor:</strong> @projectData.Sponsor</p>
                                        <p style="margin: 4px 0; font-size: 13px;"><strong>Project Manager:</strong> @projectData.ProjectManager</p>
                                    </div>
                                </div>
                                <div class="col-md-4 text-end">
                                    <span class="badge" style="background-color: @GetStatusColor(projectData.Status); font-size: 14px; padding: 8px 16px;">
                                        @projectData.Status
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Row 1: MilestoneTimeline (Full Width) -->
                <div class="row mb-5">
                    <div class="col-12">
                        <div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px;">
                            <h2 style="margin: 0 0 20px 0; font-size: 20px; font-weight: bold; color: #333;">Milestone Timeline</h2>
                            <!-- MilestoneTimeline component will be rendered here -->
                        </div>
                    </div>
                </div>

                <!-- Row 2: StatusCard Grid (Responsive 3-Column) -->
                <div class="row mb-5">
                    <div class="col-12 col-md-4 mb-3">
                        <div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px; border-top: 4px solid #28a745;">
                            <h3 style="margin: 0 0 12px 0; font-size: 16px; font-weight: bold; color: #333;">Shipped</h3>
                            <!-- StatusCard component for Shipped -->
                        </div>
                    </div>
                    <div class="col-12 col-md-4 mb-3">
                        <div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px; border-top: 4px solid #0066cc;">
                            <h3 style="margin: 0 0 12px 0; font-size: 16px; font-weight: bold; color: #333;">In-Progress</h3>
                            <!-- StatusCard component for In-Progress -->
                        </div>
                    </div>
                    <div class="col-12 col-md-4 mb-3">
                        <div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px; border-top: 4px solid #ff9800;">
                            <h3 style="margin: 0 0 12px 0; font-size: 16px; font-weight: bold; color: #333;">Carried-Over</h3>
                            <!-- StatusCard component for Carried-Over -->
                        </div>
                    </div>
                </div>

                <!-- Row 3: ProgressMetrics (Full Width) -->
                <div class="row">
                    <div class="col-12">
                        <div style="padding: 20px; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 4px;">
                            <h2 style="margin: 0 0 20px 0; font-size: 20px; font-weight: bold; color: #333;">Progress Metrics</h2>
                            <!-- ProgressMetrics component will be rendered here -->
                        </div>
                    </div>
                </div>
            </div>
        }
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger" role="alert">
            <strong>Unexpected Error:</strong> @ex.Message
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private ProjectData projectData;
    private string errorMessage;

    [Inject]
    private ProjectDataService ProjectDataService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projectData = await ProjectDataService.LoadProjectDataAsync();
            errorMessage = null;
            StateHasChanged();
        }
        catch (JsonException jex)
        {
            errorMessage = $"Invalid project data format: {jex.Message}. Please check the data.json file for syntax errors.";
            projectData = null;
            StateHasChanged();
        }
        catch (FileNotFoundException fnex)
        {
            errorMessage = $"Project data file not found: {fnex.Message}. Ensure data.json exists in the configured location.";
            projectData = null;
            StateHasChanged();
        }
        catch (ArgumentException aex)
        {
            errorMessage = $"Invalid project data: {aex.Message}. Please verify the data structure matches the expected schema.";
            projectData = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load project data: {ex.GetType().Name} - {ex.Message}";
            projectData = null;
            StateHasChanged();
        }
    }

    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "on-track" => "#28a745",
            "at-risk" => "#ffc107",
            "off-track" => "#dc3545",
            _ => "#6c757d"
        };
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }
}